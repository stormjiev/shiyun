[["〔应钟羽二奏〕旨酒嘉肴，于登于豆。","是享是宜，乐既合奏。","衎我懿德，执事温恭。","灵兮允格，有翼其从。"],["列爵陈俎，芬芳和羹。","𪭢金击石，洋洋和声。","礼行伊始，我德惟明。","既盥而往，于昭斯诚。"],["笙箫纷如，陟彼庙庭。","锵锵佩玉，怀兹先灵。","神保聿止，音容杳冥。","繁禧是介，万年惟宁。"],["雝雝玉佩，清酤惟良。","粢盛具列，有𫗣其香。","怀其徽范，德洽无疆。","于兹燕止，降福穰穰。"],["嫔于潜邸，爰正坤仪。","关雎化被，思齐名垂。","柔德益茂，家邦以熙。","皇心追崇，永羞牲粢。"],["翩然干戚，扬庭陈阶。","文以经纬，武以威怀。","其张其弛，节与音谐。","迄兹献享，妥灵绥来。"],["珩璜之贵，袆褕之尊。","天作之合，内治慈温。","元良钟庆，祉福乾坤。","以享以祀，事亡如存。"],["锵洋纯绎，于论鼓钟。","周旋陟降，齐庄肃容。","维罍既旨，维笾伊丰。","歌彻以雍，介福来崇。"],["黍稷维馨，虡业充庭。","既钦既戒，灵心是承。","顾予烝尝，言从之迈。","申锡无疆，是用大介。"],["威仪皇止，庶尹在庭。","爰举徽章，遹观厥成。","勒崇扬休，写之琼瑛。","迄于万祀，发闻惟馨。"],["有犹有言，顺承天则。","聿崇号名，再扬典册。","朱英宝函，左右翼翼。","千秋万岁，保兹无极。"],["〔黄钟宫〕笾豆大房，牺尊将将。","馨香既登，明灵迪尝。","其乐伊何，吹笙鼓簧。","灵来燕娭，降福无疆。"],["〔大吕角二奏〕吉蠲惟时，礼仪既备。","奉璋峨峨，群公在位。","神之格思，永锡尔类。","展彼令德，于焉来暨。"],["〔太簇征二奏〕雍雍在宫，翼翼在庭。","显相休嘉，肃雍和鸣。","神嗜饮食，明德惟馨。","绥我思成，式燕以宁。"],["〔应钟羽二奏〕牺牲既成，笾豆有楚。","𪭢金击石，式歌且舞。","追怀懿德，令闻令仪。","灵兮来格，是享是宜。"],["嘉肴旨酒，洁粢丰盛。","既盥而往，以我齐明。","有孚颙若，黍稷非馨。","神之格思，享于克诚。"],["佩玉锵锵，其来雝雝。","陟降孔时，步武有容。","恪兹祀事，神罔时恫。","绥我邦家，福禄来崇。"],["旨酒嘉栗，有𫗣其香。","衎我淑灵，歆此令芳。","德贻彤管，号正椒房。","神具醉止，降福穰穰。"],["籥翟既陈，干戚斯扬。","进旅退旅，一弛一张。","其仪不忒，容服有光。","以宴以娭，德音不忘。"],["望高六宫，位应四星。","辅佐君子，警戒相成。","袆衣褒崇，琛册追荣。","于以奠之，有椒其馨。"],["濯濯其英，殖殖其庭。","有来群工，赉我思成。","嘉肴既将，旨酒既清。","雍彻不迟，福禄来宁。"],["礼仪既备，神保聿归。","洋洋在上，不可度思。","神之来兮，肸蚃之随。","神之去兮，休嘉是贻。"],["上帝锡羡，寔生婉淑。","辅佐神皇，宠膺天禄。","诞育泰陵，劬劳顾复。","于昭徽音，久而弥郁。"],["于显惟德，徽柔懿明。","嫔于初载，有闻惟馨。","肆我鼓钟，万舞在庭。","神保是格，来止来宁。"],["有炜柔仪，率履不越。","惠于初终，既明且达。","我将我享，相盥乃登。","胡臭亶时，攸介攸宁。"],["苾苾其芳，殽核维旅。","陟降孔时，有秩斯所。","雍容内化，维神之明。","明则不渝，绥我思成。"],["天维显思，有相于内。","右贤去邪，夙夜儆戒。","猗欤追册，重翟袆衣。","既右享之，百世是仪。"],["酌彼玉瓒，有椒其馨。","鬷假无言，雍容在庭。","生莫与崇，于赫厥声。","祀事孔明，神格是听。"],["恭俭宜家，柔顺承天。","德昭彤管，忧在进贤。","宝册袆翟，追荣寿原。","四时祼享，何千万年。"],["清宫有严，广乐在庭。","钟鼓筦磬，九变既成。","缩茅以献，洁秬惟馨。","灵游可想，来燕来宁。"],["秉翟竣事，万舞𪭢金。","总干挥戚，节以鼓音。","礼容有炜，肸蚃来歆。","淑灵是听，雅奏愔愔。"],["登献罔愆，俎豆斯彻。","神具醉止，礼终乐阕。","御事既退，珊珊佩玦。","介我繁祉，歆此蠲洁。"],["备成熙事，虚徐翠楹。","神保聿归，云车夙征。","鉴我休德，神交惚恍。","留祉降祥，千秋是享。"],["新庙肃肃，蒇事以时。","陟降阶墄，雍容有仪。","鞠躬周旋，罔敢不祗。","祝史正辞，灵其格思。"],["肇严庙祀，爰图遗芳。","物必称德，或陈或将。","有缛其仪，有苾其香。","灵兮来下，割烹是尝。"],["曾沙表庆，正位椒庭。","徽音杳邈，宫壶仪刑。","虔修祀事，清酌惟馨。","缩以包茅，昭格明灵。"],["霄汉月堕，郊原露晞。","徽音如在，延伫来归。","有酒既清，累觞载祗。","神具醉止，燕衎怡怡。"],["仙驭弗返，眇邈清都。","荐此嘉殽，既丰既腴。","奠享有成，鼓乐愉愉。","彻我豆笾，率礼无逾。"],["涓选休辰，于秋之杪。","既齐既戒，爰假祖庙。","有侐仪坤，旧章是傚。","享祀奚为，天子纯孝。"],["宗祀九筵，先荐閟宫。","陟自东阶，煌煌衮龙。","於穆圣善，监兹礼容。","是享是宜，介福无穷。"],["丕显文母，厚德维坤。","仙驭虽邈，徽音固存。","瑟彼玉瓒，酌此鬰尊。","简简穰穰，裕我后昆。"],["祥发伣天，符彰梦日。","有怀慈容，孝享庙室。","泰尊是酌，旨酒嘉栗。","灵其格思，祚以元吉。"],["美咏河洲，德嫔妫汭。","徽音如存，肇修祀事。","缩以包茅，酌以醴齐。","灵来顾歆，降福攸备。"],["恭惟圣母，跻祔孔时。","陈羞宗祏，徼福坤仪。","钟鼓惟序，牲玉载祗。","于皇来格，永介丕基。"],["天合重华，内治昭融。","承承继继，保佑恩隆。","归从阜陵，登祔太宫。","燕我后人，福禄来崇。"],["巍巍真宇，奕奕殊庭。","规模太紫，炳焕丹青。","元命祗答，大猷是经。","多仪有践，丕应无形。","肆设金石，声闻杳冥。","伫回飚驭，永祐基扃。"],["芳气上浃，飚驭下临。","绍承丕绪，永励精明。","氤氲成雾，葱鬰垂阴。","虔恭对越，介祉攸钦。"],["发祥有自，介福无疆。","纷纶丕应，保佑下方。","嘉荐斯备，雅奏具扬。","寅威洞达，监眄昭章。"],["无体之体，强名之名。","监观万宇，统治九清。","真期保祐，瑞命昭明。","干干翼翼，祗答财成。"],["于昭灵贶，诞启鸿源。","功济庶汇，庆流后昆。","兰肴登俎，桂酒盈尊。","俯回飚驾，永庇云孙。"],["赫赫艺祖，受命高穹。","威加海外，化浃区中。","发祥宗祏，锡祐眇冲。","钦承积德，励翼精衷。"],["明明文考，储精上苍。","礼乐明备，溥率宾王。","功德累洽，历数会昌。","孝思罔极，丕祐无疆。"],["太初非有体，至道本无声。","降迹临下土，成功陟上清。","至仁敦动植，丕绪启宗祊。","紫禁承来格，鸿基保永宁。","发祥垂诞告，致孝荐崇名。","广乐伸钦奉，储休固太平。"],["明明始祖，诞启庆基。","翼翼后嗣，虔奉孝思。","精洁斯达，祉福咸宜。","于以报贶，于以受厘。"],["雕俎在御，飚驾闻声。","真游斯降，旨酒斯盈。","大乐云阕，大礼云成。","彻彼常荐，罄此明诚。"],["精心既达，真游允臻。","礼容斯举，福应惟醇。","将整僊驭，言还上旻。","永存嘉贶，用泰烝民。"],["玉虚上帝，金像睟容。","宅真云构，练日龟从。","维皇对越，率礼寅恭。","灵心丕应，福禄来崇。"],["总化在天，保昌厥绪。","降格皇闱，琼轮载御。","藻仗星陈，睟容金铸。","佑我庆基，宅兹灵宇。"],["烝哉大君，聿怀帝祖。","镕范真仪，奉尊灵宇。","至感祥开，洪辉物臯。","瞻谒尽恭，飞英率土。"],["于显神宗，德洽区中。","祥金烁冶，范兹睟容。","殊庭胥宇，备物致恭。","明威有赫，降福来同。"],["登隆妙号，钦翼渊宗。","茂宣德礼，有恪其容。","奉璋升荐，垂佩弥恭。","扬休咏美，以间笙镛。"],["皇灵垂祐，洪福弥隆。","祗率绵宇，洁祀真容。","严恭奉册，对越清躬。","睟容肃穆，懿号尊崇。","礼成乐举，福禄来同。"],["赫赫列圣，盛德巍然。","彤彤灵宇，睟仪在焉。","奉以龙衮，被之象天。","重庆宗稷，亿万斯年。"],["上旻降监，介祉实繁。","邦家修报，妙道归尊。","增名霄极，奉册灵轩。","茂宣圣典，永祐黎元。"],["图书昭锡，典礼绍成。","烝民何幸，教父储灵。","钦承景贶，祗奉崇名。","致虔宝册，垂祐基扃。"],["犹龙之圣，降生厉乡。","教流清浄，道符混茫。","大君肃谒，盛仪允臧。","森罗羽卫，躬荐萧芗。","簪绂济济，钟石洋洋。","高真至止，介福诞祥。"],["琳宫奕奕，黼坐煌煌。","玉帛成礼，飚驭延祥。","鸿仪有则，景福无疆。","嘉应昭协，丕犹诞扬。"],["金奏以谐，飚游斯格。","灵监章明，皇心励翼。","肃奉雕俎，来升彩席。","享德有孚，凝禧无斁。"],["钦崇至道，肃谒殊庭。","顺风而拜，明德惟馨。","飚驭来格，尊酒斯盈。","是酌是献，心通杳冥。"],["彼涡之壤，指李之区。","千乘万骑，来朝密都。","躬陈芳荐，款接仙舆。","饮酒受福，永耀鸿图。"],["邈矣道祖，冥几惚恍。","常德不离，至真无象。","引位清穹，降祥神壤。","酌醴荐诚，控飚来享。"],["醴醆在户，金奏在庭。","笾豆有践，黍稷非馨。","义尽蠲洁，诚通杳冥。","言旋风驷，祚我修龄。"],["荐号穹冥，登名祖祢。","陟配阳郊，协宣典礼。","感电灵区，诞圣鸿懿。","册宝斯陈，福禄来暨。"],["穆穆真宗，锡羡蕃昌。","飚轮临贶，谆诲洞彰。","虔崇懿号，祗答景祥。","至诚致享，降福无疆。"],["真馆奉币，洁齐致馨。","灵因斯格，社稷庆宁。"],["椒浆尊享，珍馔精祈。","睟容杳邈，瑶辂霞飞。"],["威灵洋洋，靡有常向。","于惟钦承，来假来飨。","博硕芬香，是烝是享。","奉器有虔，载德无爽。"],["尔牲既充，是烹是肆。","尔肴既具，是羞是馈。","非物之重，惟德之备。","神之格思，歆我精意。"],["维皇齐居，承神其初。","颙颙昂昂，龙步云趋。","景钟铿如，肃觐清都。","肸蚃之交，神人用孚。"],["帝既临飨，罄兹精意。","对越在天，爰升紫陛。","孔容翼翼，保承丕绪。","孝奉天仪，永锡尔类。"],["惟德馨香，升闻八方。","粤神临之，来从帝乡。","万灵景卫，有烨其光。","监我精纯，降福穰穰。"],["斋居皇皇，琼琚锵锵。","承祭之初，其如在旁。","挹彼注兹，储禧迎祥。","神之听之，欣欣乐康。"],["涓选休辰，有事嘉荐。","琅琅琼珮，陟降岩殿。","其陟伊何，币玉斯奠。","周旋中礼，千亿储羡。"],["上灵始祖，云景元尊。","严祀夙展，六乐朱轩。","明玉之洁，丰帛之温。","畅乃继序，承德不愆。"],["我后临飨，奠币攸毕。","式旋其趋，矩度有式。","礼容斋庄，孝思纯实。","天休滋至，时万时亿。"],["百职骏奔，来相于庭。","奉盛以告，登兹芳馨。","际天蟠地，默运三灵。","神兮来歆，祚我休平。"],["有严大礼，对时休明。","情文则粲，蠲洁必清。","再临观盥，以专以精。","真游来格，永观厥成。"],["于赫炎宋，十叶华耀。","属兹郊报，陟降在庙。","其降伊何，椒浆桂酒。","再拜斟酌，永御九有。"],["瑶源诞启，玉牒肇荣。","复育群有，监观圆清。","酒醴既洽，登荐惟诚。","无有后艰，骏惠云仍。"],["奠鬯告成，式旋厥位。","天步雍容，神人燕喜。","九庙观德，百灵荐祉。","子孙其昌，垂千万祀。"],["于皇乐舞，进旅退旅。","一弛一张，笙磬具举。","岂惟玩声，象德是似。","神鉴孔昭，福禄来予。"],["五音饬奏，神既亿康。","澹其容与，荐此嘉觞。","有来显相，𫓶玉锵锵。","奉承若宥，罔不斋庄。"],["嘉荐既终，神贶斯复。","赉我思成，灵光下烛。","孝孙承之，载祗载肃。","敷锡庶民，函蒙祉福。"],["帝临閟庭，逆厘上灵。","神羯安坐，肃若有承。","嘉觞既申，德闻惟馨。","灵光留俞，祚我亿龄。"],["普淖既荐，苾芬孔时。","神嗜而顾，有来燕娭。","飨矣将彻，载钦载祗。","展诗以侑，益臻厥熙。"],["雍歌既彻，熙事备成。","神夕奄虞，忽乘青冥。","灵心回睠，监我精禋。","诞降嘉祉，休德昭清。"],["我秩元祀，上推灵源。","展事有侐，祲威肃然。","丹墄既降，秉心益虔。","荷天之休，于千万年。"],["奕奕灵宫，有严毖祀。","燔燎具扬，礼仪既备。","帝心肃祗，天步旋止。","对越在天，永膺蕃祉。"],["帝将于郊，昭事上祀。","爰兹毕觞，复即于此。","飚游载旋，容旌沓骑。","维皇嘉承，锡祚昌炽。"],["德惟馨香，升闻八方。","粤神之从，灿然有光。","骖飞乘苍，啾啾跄跄。","消摇从容，顾予不忘。"],["帝既临享，龙驭华耀。","孝孙承之，陟降在庙。","诚意上交，庆阴下冒。","天休骈至，千亿克绍。"],["玉气如虹，丰缯充笥。","既奉既将，亦奠在位。","有永群后，实相祀事。","何以临下，心意不贰。"],["琼琚锵锵，玄衣绣裳。","荐嘉升香，粢盛芬芳。","礼仪莫愆，鼓钟喤喤。","曾孙之常，绥福无疆。"],["裴回若留，灵其有喜。","荐我馨香，挹兹酒醴。","我祖在天，执道之纪。","申佑无疆，奏神称礼。"],["进旅退旅，载执干戚。","不愆于仪，容服有赫。","式妥式侑，神保是格。","灵鉴孔昭，孝思维则。"],["于赫大神，总司元化。","监我纯精，威光来下。","延昌之贶，千亿冯藉。","曾孙保之，丕平是迓。"],["洋洋降临，肃肃布列。","熙事既成，嘉笾告彻。","九天储庆，垂佑无缺。","寖明寖昌，绵绵瓜瓞。"],["高飞安翔，持御阴阳。","幽赞圆穹，监观四方。","元精回复，奄虞孔良。","毕觞降嘏，偃蹇于骧。"],["奕奕原祠，有严毖祀。","礼仪孔宣，燔燎斯暨。","帝心肃祗，天步旋止。","熙事既成，永膺蕃祉。"],["合宫之飨，报本奉先。","钦惟道祖，濬发璇源。","驾言谒款，其盥惟虔。","尚监精衷，锡祚绵绵。"],["骏命有开，庆基无穷。","祗率百辟，仰瞻睟容。","鼓钟斯和，黍稷斯丰。","灵其居歆，福禄来崇。"],["嘉玉既设，量币既陈。","仿佛灵游，来顾来宁。","对越伊何，厥惟一纯。","佑我熙事，以迄于成。"],["发祥仙源，流泽万世。","曷其报之，亲飨三岁。","相维列卿，洁粢是馈。","匪物之尚，诚之为至。"],["华灯荧煌，瑞烟氤氲。","威神如在，蠲洁必亲。","再盥于罍，再帨于巾。","皇心肃祗，其敢惮勤。"],["岁逢有年，月旅无射。","我将我飨，如几如式。","肃尔臣工，谐尔金石。","本原休功，垂裕罔极。"],["旨酒思柔，神具醉止。","工祝既告，孝孙旋位。","何以酢之，纯嘏来备。","燕及云来，蕃衍无已。"],["象德之成，有奕其舞。","一弛一张，进旅退旅。","嘒以管箫，和以镛鼓。","神其乐康，永锡多祜。"],["閟幄邃深，云景杳冥。","天清日晬，展容玉庭。","缔基发祥，希夷降灵。","神其来燕，是飨是听。"],["帝居瑶图，璇题玉京。","日月经振，列宿上荧。","桂簋𫗣芬，瑚器华晶。","夤承禋祀，用戒昭明。"],["〔圜钟为宫〕四灵晨耀，五纬夕明。","风云晏和，天地粹清。","灵兮来迎，灵兮来宁。","启我子孙，飨于纯精。"],["〔黄钟为角〕芬枝扬烈，𤈶珠叶陶。","闿珍阐符，展诗舞箾。","神哉来下，神哉来翱。","肃若有承，灵心招摇。"],["〔太簇为征〕龙车既奏，凤驭载翔。","帝幄伫灵，天衢腾芳。","神来留俞，神来蹇骧。","礼鬯乐明，奏假孔将。"],["〔姑洗为羽〕虹旌蜺旄，鸾旗翠盖。","星枢扶轮，月御叶卫。","灵至阴阴，灵般裔裔。","来格来飨，福流万世。"],["礼文有俶，祀事孔明。","将以洁告，允惟齐精。","自盥而往，聿观厥成。","灵监下临，天德其清。"],["维宋肖德，钦天顾右。","于皇道祖，丕厘灵祐。","葛藟殖繁，瓜瓞孕茂。","克昌厥后，世世孝奏。"],["桂宫耽耽，藻仪穆穆。","天回衮彩，风韶璜玉。","咸英皦亮，容典炳煜。","假我上灵，景命有仆。"],["我簋斯盈，我簠斯实。","或剥或烹，或燔或炙。","有殽既将，为俎孔硕。","礼仪卒度，永锡尔极。"],["觞澹初勺，礼戒重盥。","假庙以萃，取象于观。","清明外畅，精肃中贯。","我仪图之，三灵攸赞。"]]