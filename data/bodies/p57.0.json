[["苹蘩礼著，黍稷诚微。","音盈凤管，彩驻龙旗。","洪歆式就，介福攸归。","送乐有阕，灵驭遄飞。"],["大阴凝至化，真耀蕴轩仪。","德迈娥台敞，仁高姒幄披。","扪天遂启极，梦日乃升曦。"],["瞻紫极，望玄穹。","翘至恳，罄深衷。","听虽远，诚必通。","垂厚泽，降云宫。"],["干仪混成冲邃，天道下济高明。","闿阳晨披紫阙，太一晓降黄庭。","圆坛敢[申]昭报，方璧冀展虔情。","丹禁式敷衷恳，玄鉴庶察微诚。"],["巍巍睿业广，赫赫圣基隆。","菲德承先顾，祯符萃眇躬。","铭开武岩侧，图荐洛川中。","微诚讵幽感，景命忽昭融。","有怀慙紫极，无以谢玄穹。"],["朝坛雾卷，曙岭烟沈。","爰设筐币，式表诚心。","筵辉丽璧，乐畅和音。","仰惟灵鉴，俯察翘襟。"],["昭昭上帝，穆穆下临。","礼崇备物，乐奏锵金。","兰羞委荐，桂醑盈斟。","敢希[明]德，聿罄庄心。"],["樽浮九酝，礼备三周。","陈诚菲奠，契福神猷。"],["奠璧郊坛昭大礼，锵金拊石表虔诚。","始奏承云娱帝赏，复歌调露畅韶英。"],["荷恩承顾托，执契恭临抚。","庙畧静边荒，天兵耀神武。","有截资先化，无为遵旧矩。","祯符降昊穹，大业光寰宇。"],["肃肃祀典，邕邕礼秩。","三献已周，九成斯毕。","爰撤其俎，载迁其实。","或升或降，唯诚唯质。"],["礼终肆类，乐阕九成。","仰惟明德，敢荐非馨。","顾慙菲奠，久驻云𫐌。","瞻荷灵泽，悚恋兼盈。"],["式干路，辟天扉。","回日驭，动云衣。","登金阙，入紫微。","望仙驾，仰恩徽。"],["天之历数归睿唐，顾惟菲德钦昊苍。","撰吉日兮表殷荐，冀神鉴兮降闿阳。"],["恭临宝位，肃奉瑶图。","恒思解网，每轸泣辜。","德慙巢燧，化劣唐虞。","期我良弼，式赞嘉谟。"],["得一流玄泽，通三御紫宸。","远叶千龄运，遐销九域尘。","绝瑞骈阗集，殊祥络绎臻。","登年庆栖亩，稔岁贺盈囷。"],["悠哉广覆，大矣曲成。","九玄著象，七曜贞明。","珪璧是奠，酝酎斯盈。","作乐崇德，爰畅咸英。"],["郊坛展敬，严配因心。","孤竹箫管，空桑瑟琴。","肃穆大礼，铿锵八音。","恭惟上帝，希降灵歆。"],["九成爰奏，三献式陈。","钦承景福，恭托明禋。"],["坤元光至德，柔训阐皇风。","芣苡芳声远，螽斯美化隆。","睿范超千载，嘉猷备六宫。","肃恭陪盛典，钦若荐禋宗。"],["三灵降飨，三后配神。","虔敷藻奠，敬展郊禋。"],["已陈粢盛敷严祀，更奏笙镛协雅声。","璇图宝历欣宁谧，晏俗淳风乐太平。"],["堂堂圣祖兴，赫赫昌基泰。","戎车盟津偃，玉帛涂山会。","舜日启祥晖，尧云卷征斾。","风猷被有截，声教覃无外。"],["至矣丕搆，烝哉太平。","授牺膺箓，复禹继明。","草木仁化，凫鹥颂声。","祀宗陈德，无媿斯诚。"],["郊坛斋帝，礼乐祀天。","丹青寰宇，宫征山川。","神祇毕降，行止重旋。","融融穆穆，纳祉洪延。"],["止奏潜聆，登仪宿啭。","太玉躬奉，参钟首奠。","簠簋聿升，牺牲遰荐。","昭事颙若，存存以伣。"],["烂云普洽，律风无外。","千品其凝，九宾斯会。","禋尊晋烛，纯牺涤汰。","玄覆攸广，鸿休汪濊。"],["六变爰阕，八阶载虔。","祐我皇祚，于万斯年。"],["于赫圣祖，龙飞晋阳。","底定万国，奄有四方。","功格上下，道冠农黄。","郊天配享，德合无疆。"],["崇崇泰畤，肃肃严禋。","粢盛既洁，金石毕陈。","上帝来享，介福爰臻。","受厘合祉，宝祚维新。"],["祝史正辞，人神叶庆。","福以德招，享以诚应。","六变云备，百礼斯浃。","祀事孔明，祚流万叶。"],["馨香惟后德，明命光天保。","肃和崇圣灵，陈信表皇道。","玉𬭭初蹈厉，金匏既静好。"],["大号成命，思文配天。","神光肸蚃，龙驾言旋。","眇眇阊阖，昭昭上玄。","俾昌而大，于斯万年。"],["六成既阕，三荐云终。","神心具醉，圣敬愈崇。","受厘皇邸，回跸帷宫。","穰穰之福，永永无穷。"],["履艮斯绳，居中体正。","龙运垂祉，昭符启圣。","式事严禋，聿怀嘉庆。","惟帝永锡，时皇休命。"],["殷荐乘春，太坛临曙。","八簋盈和，六瑚登御。","嘉稷匪歆，德馨斯饫。","祝嘏无易，灵心有豫。"],["玉帛牺牲申敬享，金丝𬭭羽盛音容。","庶俾亿龄禔景福，长欣万宇洽时邕。"],["鸟纬迁序，龙星见辰。","纯阳在律，明德崇禋。","五方降帝，万宇安人。","恭以致享，肃以迎神。"],["祀遵经设，享缘诚举。","献毕于樽，彻临于俎。","舞止干戚，乐停柷敔。","歌以送神，神还其所。"],["朱明季序，黄郊王辰。","厚以载物，甘以养人。","毓金为体，禀火成身。","宫音式奏，奏以迎神。"],["春末冬暮，徂夏杪秋。","土王四月，时季一周。","黍稷已享，笾豆宜收。","送神有乐，神其赐休。"],["缇幕移候，青郊启蛰。","淑景迟迟，和风习习。","璧玉宵备，旌旄曙立。","张乐以迎，帝神其入。"],["文物流彩，声明动色。","人竭其恭，灵昭其饬。","歆荐不已，垂祯无极。","送礼有章，惟神还轼。"],["青阳节谢，朱明候改。","靡草雕华，含桃流彩。","虡列钟磬，筵陈脯醢。","乐以迎神，神其如在。"],["炎精式降，苍生攸仰。","羞列豆笾，酒陈牺象。","昭祀有应，冥期不爽。","送乐张音，惟灵之往。"],["序移玉律，节应金商。","天严杀气，吹警秋方。","槱燎既积，稷奠并芳。","乐以迎奏，庶降神光。"],["祀遵五礼，时属三秋。","人怀肃敬，灵降祯休。","奠歆旨酒，荐享珍羞。","载张送乐，神其上游。"],["玄英戒序，黑郊临候。","掌礼陈彝，司筵执豆。","寒氛敛色，沍泉凝漏。","乐以迎神，八音斯奏。"],["北郊时冽，南陆辉处。","奠本虔诚，献弥恭虑。","上延祉福，下承欢豫。","广乐送神，神其整驭。"],["惟圣格天，惟明飨日。","帝郊肆类，王宫戒吉。","珪奠春舒，钟歌晓溢。","礼云克备，斯文有秩。"],["晨仪式荐，明祀惟光。","神物爰止，灵晖载扬。","玄端肃事，紫幄兴祥。","福履攸假，于昭允王。"],["崇牙树羽延调露，旋宫扣律掩承云。","诞敷懿德昭神武，载集丰功表睿文。"],["太阳朝序，王宫有仪。","蟠桃彩驾，细柳光驰。","轩祥表合，汉历彰奇。","礼和乐备，神其降斯。"],["五齐兼酌，百羞具陈。","乐终广奏，礼毕崇禋。","明鉴万宇，照临兆人。","永流洪庆，式动曦轮。"],["测妙为神，通微曰圣。","坎祀贻则，郊禋展敬。","璧荐登光，金歌动映。","以载嘉德，以流曾庆。"],["朏晨争举，天宗礼辟。","夜典凉秋，阴明湛夕。","有𨠨斯旨，有牲斯硕。","穆穆其晖，穰穰是积。"],["合吹八风金奏动，分容万舞玉鞘惊。","词昭茂典光前列，夕曜乘功表盛明。"],["于昭上穹，临下有光。","羽翼五佐，周流八荒。","谁其飨之，时文对敭。","虞经夏典，兹礼未遑。"],["黑帝旋驭，青躔导日。","金箓上玄，玉堂初吉。","钩陈夕次，銮和先跸。","蔼蔼群灵，昭昭咸秩。"],["帝临中坛，受厘元神。","皇灵萃止，羽旄肃陈。","摄提运衡，招摇移轮。","光光宇宙，电耀雷震。"],["夜如何其，明星煌煌。","天清容卫，露结坛场。","树羽幢幢，佩玉锵锵。","凝精驻目，瞻望神光。"],["九位既肃，万灵毕会。","天门启扄，日驭飞盖。","焕兮棽离，傧兮暗霭。","如山之福，惟圣时对。"],["崇崇泰坛，灵具临兮。","铿锽大乐，振动心兮。","神之降矣，卿云郁兮。","神之至止，清风肃兮。"],["帝在灵坛，大明登光。","天回云粹，穆穆皇皇。","金奏九夏，圭陈八芗。","旷哉动植，如熙春阳。"],["歌工既奏，神位既秩。","天符众星，运行太一。","声和十管，气应中律。","肃肃明廷，介兹元吉。"],["俎豆有践，黄流在尊。","九宫之祀，三代莫存。","乐变六宫，坛开八门。","圣皇昭对，祐我黎元。"],["时文哲后，肃事严禋。","馨我明德，享于贵神。","大庖载盈，旨酒斯醇。","精意所属，期于利人。"],["祀既云毕，明灵告旋。","礼洽和应，神歆福延。","动植咸若，阴阳不愆。","锡兹纯嘏，天子万年。"],["羽籥既阕干戚陈，八音克谐六变新。","愉贵神兮般以乐，保皇祚兮万斯春。"],["盛德陈万舞，威棱畅九垓。","风云交律候，日月丽昭回。","行庆休祥发，乘和春气来。","百神肃临享，荡荡天门开。"],["精意严恭，明祠丰洁。","献酬既备，俎豆斯撤。","日丽天仪，风和乐节。","事光祀典，福覃有截。"],["享申百礼，庆洽百灵。","上排阊阖，洞入杳冥。","奠玉高坛，燔柴广庭。","神之降福，万国咸宁。"],["九玄眷命，三圣基隆。","奉承先旨，明台毕功。","宗祀展敬，冀表深衷。","永昌帝业，式播淳风。"],["神功不测兮运阴阳，包藏万宇兮孕八荒。","天符既出兮帝业昌，愿临明祀兮降祯祥。"],["坎泽祠容备举，坤坛祭典爰申。","灵睠遥行秘躅，嘉贶荐委殊珍。","肃礼恭禋载展，翘襟邈志逾殷。","方期交际悬应。"],["祗荷坤德，钦若干灵。","慙惕罔寘，兴居匪宁。","恭崇礼则，肃奉仪形。","惟凭展敬，敢荐非馨。"],["菲躬承睿顾，薄德忝坤仪。","干干遵后命，翼翼奉先规。","抚俗勤虽切，还淳化尚亏。","未能弘至道，何以契明祇。"],["顾德有慙虚菲，明祇屡降祯符。","汜水初呈秘象，温洛荐表昌图。","玄泽流恩载洽，丹襟荷渥增愉。"],["舒阴致养，合大资生。","德以恒固，功由永贞。","升歌荐序，垂币翘诚。","虹开玉照，凤引金声。"],["兰俎既升，苹羞可荐。","金石载设，咸英已变。","林泽斯总，山川是遍。","敢用敷诚，实惟忘倦。"],["沈潜演贶分三极，广大凝祯总万方。","既荐羽旌文化启，还呈干𬭭武威扬。"],["夕惕司龙契，晨兢当凤扆。","崇儒习旧规，偃伯循先旨。","绝壤飞冠盖，遐区丽山水。","幸承三圣余，忻属千年始。"],["百礼崇容，千官肃事。","灵降无兆，神凝有粹。","奠享咸周，威仪毕备。","奏夏登列，歌雍彻肆。"],["皇皇灵睠，穆穆神心。","暂动凝质，还归积阴。","功玄枢纽，理寂高深。","衔恩佩德，耸志翘襟。"],["言旋云洞兮蹑烟途，永宁中宇兮安下都。","包涵动植兮顺荣枯，长贻宝贶兮赞璇图。"],["调云阕兮神座兴，骖云驾兮俨将升。","腾绛霄兮垂景祐，翘丹恳兮荷休征。"],["坤厚载物，德柔垂祉。","九域咸雍，四溟为纪。","敬因良节，虔修阴祀。","广乐式张，灵其降止。"],["坤元至德，品物资生。","神凝博厚，道协高明。","列镇五岳，环流四瀛。","于何不载，万宝斯成。"],["乐备金石，礼光尊俎。","大享爰终，洪休是举。","雨零感节，云飞应序。","缨绂载辞，皇灵具举。"],["黄舆厚载，赤寰归德。","含育九区，保安万国。","诚敬无怠，禋祀有则。","乐以迎神，其仪不忒。"],["神州阴祀，洪恩广济。","草树沾和，飞沈沐惠。","礼修鼎俎，奠歆瑶币。","送乐有章，灵轩其逝。"],["烈山有子，后土有臣。","播种百谷，济育兆人。","春官缉礼，宗伯司禋。","戊为吉日，迎享兹辰。"],["吉祥式就，酬功载毕。","亲地尊天，礼文经术。","贶征令序，福流初日。","神驭爰归，祠官其出。"],["序迫岁阴，日躔星纪。","爰稽茂典，聿崇清祀。","绮币霞舒，瑞珪虹起。","百禩垂裕，万灵荐祉。"],["缇籥劲序，玄英晚候。","姬蜡开仪，豳歌入奏。","蕙馥雕俎，兰芬玉酎。","大享明祇，永绥多祐。"],["经纬两仪文化洽，削平方域武功成。","瑶弦自乐乾坤泰，玉𬭭长欢区宇宁。"],["八蜡开祭，万物合祀。","上极天维，下穷坤纪。","鼎俎流芬，罇彝荐美。","有灵有祇，咸希来止。"],["十旬欢洽，一日祠终。","澄彝拂俎，报德酬功。","虑虔容肃，礼缛仪丰。","神其降祉，整驭随风。"],["三推礼就，万庾祈凝。","夤宾志远，藨衮惟兴。","降歆肃荐，垂祐祗膺。","送神有乐，神其上升。"],["芳春开令序，韶苑畅和风。","惟灵申广祐，利物表神功。","绮会周天宇，黼黻藻寰中。","庶几承庆节，歆奠下帷宫。"],["明灵光至德，深功掩百神。","祥源应节启，福绪逐年新。","万宇承恩覆，七庙伫恭禋。","于兹申至恳，方期远庆臻。"],["霞庄列宝卫，云集动和声。","金卮荐绮席，玉币委芳庭。","因心罄丹款，先己励苍生。","所冀延明福，于兹享至诚。"],["桂筵开玉俎，兰圃荐琼芳。","八音调凤历，三献奉鸾觞。","絜粢申大享，庭宇冀降祥。","神其覃有庆，契福永无疆。"],["仙坛礼既毕，神驾俨将升。","伫属深祥起，方期庶绩凝。","虔诚资宇内，务本勖黎蒸。","灵心昭备享，率土洽休征。"],["圣道日用，神几不测。","金石以陈，弦歌载陟。","爰释其菜，匪馨于稷。","来顾来享，是宗是极。"],["万国以贞光上嗣，三善茂德表重轮。","视膳寝门尊要道，高辟崇贤引正人。"],["粤惟上圣，有纵自天。","傍周万物，俯应千年。","旧章允著，嘉贽孔虔。","王化兹首，儒风是宣。"],["堂献瑶篚，庭敷璆县。","礼备其容，乐和其变。","肃肃亲享，雍雍执奠。","明德惟馨，苹蘩可荐。"],["隼集龟开昭圣烈，龙蹲凤跱肃神仪。","尊儒敬业宏图阐，纬武经文盛德施。"],["通吴表圣，问老探真。","三千弟子，五百贤人。","亿龄规法，万载嗣禋。","洁诚以祭，奏乐迎神。"],["醴溢牺象，羞陈俎豆。","鲁壁类闻，泗川入觏。","里校覃福，胄筵承祐。","雅乐清音，送神具奏。"],["五运改卜，千龄启圣。","彤云晓聚，黄星夜映。","叶阐珠囊，基开玉镜。","下临万宇，上齐七政。","雾开三象，尘清九服。","海溓星晖，远安迩肃。","天地交泰，华夷辑睦。","翔泳归仁，中外禔福。","绩逾黜夏，勋高翦商。","武陈七德，刑设三章。","祥禽巢阁，仁兽游梁。","卜年惟永，景福无疆。"],["承天抚箓，纂圣登皇。","遐清万宇，仰协三光。","功成日用，道济时康。","璇图载永，宝历斯昌。","日月扬晖，烟云烂色。","河岳修贡，神祇効职。","舜风攸偃，尧曦先就。","睿感通寰，孝思浃宙。","奉扬先德，虔遵曩狩。","展义天扄，飞英云岫。","化逸王表，神凝帝先。","乘云厌俗，驭日登玄。"],["广乐既备，嘉荐既新。","述先惟德，孝飨惟亲。","七献具举，五齐毕陈。","锡兹祚福，于万斯春。"],["惟睿作圣，惟圣登皇。","精感耀魄，时膺会昌。","舜慙大孝，尧推让王。","能事斯极，振古谁方。","文明履运，车书同轨。","巍巍赫赫，尽善尽美。","衢室凝旒，大庭端扆。","释负之寄，事光复子。","脱屣高天，登遐上玄。","龙湖超忽，象野芊绵。","游衣复道，荐果初年。","新庙奕奕，明德配天。"],["大业龙祉，徽音骏尊。","潜居皇德，赫嗣天昆。","展仪宗祖，重诚孝孙。","春秋无极，享奏存存。"],["七庙观德，百灵攸仰。","俗荷财成，物资含养。","道光执契，化笼提象。","肃肃雍雍，神其来飨。"],["肃肃清庙，巍巍盛唐。","配天立极，累圣重光。","乐和管磬，礼备烝尝。","永惟来格，降福无疆。"],["五声备奏，三献终祠。","车移凤辇，斾转虹旗。","礼周笾豆，诚效虔祗。","皇灵徙跸，簪绅拜辞。"],["建清庙，赞玄功。","择吉日，展禋宗。","乐已变，礼方崇。","望神驾，降仙宫。"],["隆周创业，宝命惟新。","敬宗茂典，爰表虔禋。","声明已备，文物斯陈。","肃容如在，恳志方申。"],["肃敷大礼，上谒尊灵。","敬[陈]筐币，载表丹诚。"],["敬奠苹藻，式罄虔襟。","洁诚斯展，伫降灵歆。"],["爰陈玉醴，式奠琼浆。","灵心有穆，介福无疆。"],["帝图草创，皇业初开。","功高佐命，业赞云雷。"],["赫赫玄功被穹壤，皇皇至德洽生灵。","开基拨乱妖氛廓，佐命宣威海内清。"],["荷恩承顾托，执契恭临抚。","庙畧静边荒，天兵耀神武。"],["登歌已阕，献礼方周。","钦承景福，肃奉鸿休。"]]