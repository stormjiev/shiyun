[["于赫明堂，肇称禋祀。","祖宗来游，亦侑于帝。","九州骏奔，百辟咸事。","敛时纯休，锡我万世。"],["噫神何亲，惟德是辅。","玉牲具陈，诚则来顾。","我开明堂，遵国之故。","尚蒙居歆，以笃宗祜。"],["肇开九筵，维古之倣。","皇皇大神，来顾来享。","庶仪交修，百辟显相。","微诚自中，交际天壤。"],["皇皇后帝，周览四方。","眷我前烈，燕娭此堂。","金支秀发，黼帐高张。","世歆明祀，曰宋是常。"],["至哉坤元，持载万物。","继天神圣，观世治忽。","颂祇之堂，荐以圭黻。","孰为邦休，四海无拂。"],["推尊太元，重屋为盛。","谁其配之，我祖齐圣。","开基握符，正位凝命。","于万斯年，孝孙有庆。"],["帝神来格，靡祀不从。","侑坐而食，独升祖宗。","在庭祗肃，展采错重。","三献之礼，百年之容。"],["於穆帝临，至矣元造。","克配其仪，惟我文考。","仁恩广覃，奕叶永保。","宗祀惟初，以扬孝道。"],["耳听𫓶玉，目瞻𤈶珠。","乐备周奏，仪参汉图。","神人并况，天地同符。","亦既见帝，王心则愉。"],["展牲登俎，箫韶在庭。","羞陈五室，意彻三灵。","匪物斯享，惟诚则馨。","永作祭主，神其亿宁。"],["日在东陆，维时上辛。","肇开阳馆，恭礼尊神。","苍玉辉夜，紫烟炀晨。","祖宗并配，天地同禋。"],["地禩泰折，歌同我将。","黝牲纯洁，丝竹发扬。","博厚而久，含洪以光。","扶持宗社，曰笃不忘。"],["一德开基，百年垂统。","中天禘郊，薄海朝贡。","宝龟相承，器鼎加重。","泽深庆绵，帝复命宋。"],["绍天承业，继世立功。","帷幄屡胜，车书始同。","武扫氛雾，文垂日虹。","遗泽所及，孰知其终。"],["钦惟合宫，承神至尊。","祗戒专精，俨然若存。","奠兹嘉觞，茝兰其芬。","发祉𬯎祥，以子以孙。"],["匏尊既举，鞂席未移。","有德斯顾，靡神不娭。","物情肃穆，天宇清夷。","宅中受命，永复邦基。"],["神之歘至，庆阴杳冥。","风马云车，恍若有承。","备形声容，于昭文明。","庶几嘉虞，来享来宁。"],["四阿有严，神既戾止。","备物虽仪，洁诚惟己。","有来振振，相我熙事。","载酌陶匏，以成毖祀。"],["诚一为专，礼三而称。","孰陪邦祠，惟我同姓。","金丝屡调，圭玉交映。","是谓熙成，福来神听。"],["孰谓天远，至诚则通。","孰谓地厚，与天则同。","惠我纯嘏，克成大功。","握图而治，如日之中。"],["工祝告休，笙镛云阕。","酒茅既除，牲俎斯彻。","幽明罔恫，中外咸悦。","礼成伊何，天地同节。"],["奕奕宗祀，煌煌礼文。","高灵下堕，精意升闻。","熙事既毕，忽乘青云。","敢拜明贶，永清世氛。"],["载酌载献，以纯以精。","歌传夜诵，物备秋成。","报本斯极，听卑则明。","愿储景贶，福我群生。"],["礼协丰融，诚交仿佛。","辟公受膰，宗祀临瘗。","贻我来牟，以兴嗣岁。","山川出云，天地同气。"],["应天以实，已事而竣。","毡案朝帝，竹宫拜神。","灵光下烛，协气斯陈。","福禄时万，基图日新。"],["〔圜钟为宫〕上直房心，时惟明堂。","配天享亲，宗祀有常。","盛德在金，日吉辰良。","享我克诚，来格来康。"],["〔黄钟为角〕合宫盛礼，金商令时。","备成熙事，搜扬上仪。","骏奔在庭，精意肃祗。","来享嘉荐，神灵燕娭。"],["〔太簇为征〕休德孔昭，灵承上帝。","孝极尊亲，严配于位。","嘉荐芬芳，礼无不备。","神其格思，享兹诚至。"],["〔姑洗为羽〕霜露既降，孝思奉先。","陟降上帝，礼隆九筵。","有馨黍稷，有肥牲牷。","神来燕娭，想像肃然。"],["礼经之重，祭典为宗。","上公摄事，进退弥恭。","庶品丰洁，令仪肃雍。","百祥萃止，惟吉之从。"],["皇祖配帝，岁祀明堂。","冕服陟降，玉佩玱玱。","疾徐有节，进止克庄。","维时右享，日靖四方。"],["大享季秋，百执扬厉。","明明太宗，赫赫上帝。","祗荐忱诚，式严圭币。","祚我明德，锡兹来裔。"],["穆穆皇祖，丕昭圣功。","声律身度，乐备礼隆。","祗荐量币，祀于合宫。","玉帛万国，驩心载同。"],["备物昭陈，工祝告具。","维羊维牛，孔硕孔庶。","有嘉维馨，加食宜饫。","敛时五福，永膺丰胙。"],["烨彼房心，明明有融。","维圣享帝，礼行合宫。","祀事时止，粢盛洁丰。","昭受申命，万福攸同。"],["受命溥将，勋高百王。","寰宇大定，圣治平康。","有严陟配，宗祀明堂。","神保是格，申锡无疆。"],["温厚严凝，于皇上帝。","文德武功，列圣并配。","舞缀象成，肃雍进退。","秉翟踆踆，总干蹈厉。"],["总章灵承，维国之常。","礼乐宣鬯，降升齐庄。","竭诚尽志，荐兹累觞。","于昭在上，申锡无疆。"],["于皇上帝，肃然来临。","恭荐芳俎，以达高明。","烹饪既事，享于克诚。","以介景福，惟德之馨。"],["帝在合宫，鉴观盛礼。","黍稷惟馨，神心则喜。","礼备乐成，亦既归止。","亿万斯年，以贶多祉。"],["赫赫高庙，于尧有光。","覆被万祀，冠冕百王。","有量斯币，蠲洁是将。","在帝左右，维时降康。"],["炎运中兴，苍生载宁。","九秩燕豫，三纪丰凝。","精祀上帝，陟配威灵。","锡羡胙祉，万世承承。"],["至哉厚德，陟配天长。","沈潜刚克，广大无疆。","资生万物，神化含章。","同和八变，神灵效祥。"],["于昭祀典，致享坤仪。","备物咸秩，柔祇格思。","功宣敏树，日益鸿禧。","持载品汇，率土攸宜。"],["妙用无方，倏来忽逝。","蠲洁寅恭，式终禋瘗。"],["赫矣淳耀，俶载帝基。","一戎以定，万国来仪。","寅恭洁祀，博厚皇祇。","威灵攸在，福禄如茨。"],["丕命惟皇，万物咸臯。","卜年迈周，崇功冠禹。","有烨炎精，大昌圣祚。","酌鬯祈年，永锡繁祜。"],["昭灵积厚，混混坤舆。","配天作极，阴惨阳舒。","齐明荐享，百福其储。","庶几来止，风马云车。"],["有来穆穆，临此方丘。","其行风动，其止霆收。","躬事匪懈，丰盛洁羞。","百昌咸殖，允矣神休。"],["纯诚昭融，芳美嘉荐。","肃将二精，以享以奠。","休光四充，灵祇来燕。","其祥伊何，永世锡羡。"],["于皇烈祖，维帝所兴。","光辉宗祀，如日之升。","告灵作配，孝享烝烝。","锡兹祉福，百世其承。"],["我修祀事，于何致诚。","罔敢怠佚，视兹硕牲。","纳烹荐俎，侑以和声。","格哉休应，世济皇明。"],["猗嗟富媪，博厚含弘。","发荣敷秀，动植兹丰。","爰酌兹酒，肸蚃交通。","众祥萃止，垂祜无穷。"],["光大含弘，坤元之力。","海宇咸宁，烈祖之德。","作配方坛，不僭不忒。","子孙其承，毋替厥则。"],["载登坛阼，载酌尊彝。","牲酒嘉旨，福禄纯熙。","其福维何，万物咸宜。","其禄维何，永承神禧。"],["雍雍肃肃，建我采旄。","舞以玉戚，不吴不敖。","其将其肆，脾臄嘉肴。","何以侑乐，钟鼓管箫。"],["折俎在笾，胾羹在豆。","何以酌之，酒醴是侑。","何以锡之，贻尔眉寿。","何以格之，永尔康阜。"],["曳我黼黻，履舄接武。","锵我珩璜，降升圉圉。","其将肆兮，既曰不侮。","其终彻兮，恭钦惟主。"],["神兮来下，享此苾芬。","酌献雍雍，执事孔勤。","神之还矣，忽乘飞云。","遗我祺祥，物象忻忻。"],["坤元之德，光大无疆。","一气交感，百物阜昌。","吉蠲致享，精明是将。","介兹景福，鼎祚灵长。"],["礼经之重，祭典为宗。","上公摄事，登降弥恭。","庶品丰洁，令仪肃雍。","百祥萃止，维吉之从。"],["礼崇禋祀，神鉴孔明。","牲牷博腯，以炰以烹。","馨香蠲洁，品物惟精。","锡以纯嘏，享兹至诚。"],["进旅退旅，载扬干扬。","不愆于仪，容服有章。","式绥式侑，神保是听。","鼓之舞之，神永安宁。"],["物备百嘉，乐周八变。","克诚是享，明德斯荐。","神鉴孔昭，蕃禧锡羡。","回驭飘然，邈不可见。"],["〔函钟为宫〕至哉厚德，物生是资。","直方维则，翕辟攸宜。","于昭祀典，致享坤仪。","礼罔不答，神之格思。"],["〔太簇为角〕蒇事方丘，旧典时式。","至诚感神，馨非黍稷。","肸蚃来临，鉴兹明德。","永锡坤珍，时万时亿。"],["〔姑洗为征〕至哉坤元，乃顺承天。","厚德载物，含洪八埏。","日北多暑，祀仪吉蠲。","式昭毋事，敢告恭虔。"],["〔南吕为羽〕蒇事方丘，情文孔时。","名山大泽，侑祭无遗。","牲陈黝犊，乐备咸池。","柔祇皆出，介我繁禧。"],["於穆盛礼，肃肃在宫。","蒇事有初，直于东荣。","涤濯是谨，惟寅惟清。","祗荐柔嘉，享兹克诚。"],["景风应时，聿严毖祀。","用事方丘，锵锵济济。","登降有节，三献成礼。","神其格思，锡我繁祉。"],["坤元博厚，对越天明。","展事方泽，亶惟顾歆。","嘉玉量币，祗荐纯精。","锡我繁祉，燕及函生。"],["毖祀泰折，柔祇是承。","于赫艺祖，道格三灵。","式严配侑，厚德惟宁。","爰昭荐币，享于克诚。"],["丕答灵贶，蒇事方丘。","豆登在列，鼎俎斯俦。","牲牷告具，寅畏弥周。","柔祇昭格，飚至云流。"],["祗事坤元，饬躬敢惮。","爰洁粢盛，载严圭瓒。","清明内融，嘉旨外粲。","介我繁厘，时亿时万。"],["皇矣艺祖，九围是式。","至哉柔祇，万汇允殖。","保兹嘉邦，介我黍稷。","酌鬯告虔，作配无极。"],["於穆媪神，媲德彼天。","我修毖祀，以莫不虔。","肆陈时夏，干羽相宣。","灵其来游，降福绵绵。"],["礼有祈报，国惟典常。","笾豆丰洁，降升齐庄。","备物致志，式荐累觞。","昭格来享，自天降康。"],["承天效法，其道贵诚。","牲羞黄犊，荐德之馨。","芳俎告毕，礼备乐盈。","既静既安，庶物沾生。"],["至厚至深，其动也刚。","精诚默通，或出其藏。","神之言归，化斯有光。","相我炎图，万世无疆。"],["膴膴郊原，茫茫宇县。","画野分疆，禹功疏奠。","灵祇是臻，豆笾祗荐。","幽赞皇图，视之不见。"],["肸蚃储灵，肃恭用币。","锵洋导和，洪休允契。","嘉气云蒸，浃于华裔。","式荐坤珍，聿符明世。"],["献奠云毕，纯嘏祁祁。","威灵藏用，邈矣何之。"],["削平伪邦，嗣兴鸿业。","礼乐交修，仁德该洽。","柔祇荐享，量币攸摄。","侑坐延灵，神休允答。"],["有炜弥文，克隆宏构。","贻此燕谋，具膺多祐。","嶰律吹莩，彝尊奠酒。","佐乃沈潜，永祈丰楙。"],["膴膴浚邦，皇天是宅。","必有幽赞，聪明正直。","布列笾豆，考击金石。","中外谧宁，繄神之力。"],["都邑浩穰，民物富盛。","主以灵祇，昭乃丕应。","玉帛牲牷，鼓钟筦磬。","祗荐攸歆，归于至静。"],["〔函钟为宫〕芒芒下土，恢恢方仪。","富媪统摄，潜运八维。","爰称元祀，告备吉时。","揭兹虔恭，僾其格思。"],["〔太簇为角〕洪惟坤元，道著品物。","上配紫旻，厚载其德。","良月肇蒇，祭器布列。","必先皇祇，以迓景福。"],["〔姑洗为征〕坱圠无垠，磅礴罔测。","山盈川冲，自生自殖。","其报惟何，率礼靡忒。","亿万斯年，功被无极。"],["〔南吕为羽〕翕辟以时，协气陶蒸。","播之金石，锵厥和声。","冥冥眑眑，孔享纯诚。","是听是娭，邦基永宁。"],["晨炀致烟，浡然四施。","飘飘风马，仿佛来斯。","祀事维清，沃之盥之。","载涓载肃，罔有愧辞。"],["崇崇其坛，屹矣层级。","佩约步趋，降登中节。","左瞻右睨，祥风蔼集。","斿旆羽纷，昭鉴翊翊。"],["璇玑谐序，籍敛荐嘉。","昭答柔祇，迭奏雅歌。","币琮以侑，仪腆气和。","灵其溥临，容与燕嘉。"],["穆穆令闻，溥博有容。","泽被万宇，靡不率从。","恭陈量币，明荐其衷。","礼亦宜之，享德攸同。"],["肃肃嘉承，唯德其物。","工祝以告，繄民之力。","神哉广生，孔蕃且硕。","奠于嘉坛，吐之则弗。"],["恭承明祀，嘉荐令芳。","亦有桂酒，诚悫是将。","瑟瓒以酌，效懽厥觞。","庶乎燕享，永怀不忘。"],["宗德含洪，方祇可儗。","辟土开疆，八埏同轨。","是用作配，有永无纪。","祼献以享，茂格蕃祉。"],["奕奕缀兆，咸池孔彰。","丕阐文德，靡忘发扬。","进退有节，乃容之常。","乐备尔奏，烨烨荣光。"],["缩酌以祼，既旨且多。","三献有序，情文愈加。","黄祇临享，锡以休嘉。","广兹灵祲，覃及迩遐。"],["展牲告全，迺登于俎。","竣事而彻，侑以乐语。","奉厘宣室，祚我神主。","敛敷庶民，并受其祜。"],["云驭洋洋，既歆既顾。","悠然聿归，曷求厥路。","钦想颂堂，跛立以慕。","赉我肸蚃，莫不怿豫。"],["神罔怨恫，燕其有喜。","蒇事告成，爰修瘗礼。","乐阕仪备，休气四起。","尚谨不愆，念终如始。"],["阳德之母，羲御寅宾。","得天久照，首兹三辰。","正辞备物，肃肃振振。","沦精降监，克享明禋。"],["醴齐良洁，有牲斯纯。","大采玄冕，乃昭其文。","王宫定位，粢盛苾芬。","民事以叙，盛德升闻。"],["县象著明，照临下土。","降福穰穰，德施周普。"],["凝阴禀粹，照临八埏。","丽天垂象，继日代明。","一气资始，四时运行。","灵祇昭格，备物荐诚。"],["夕耀乘秋，功存宇县。","金奏在县，以时致荐。","祀事孔寅，明灵降眷。","洁粢丰盛，仓箱流衍。"],["夙陈笾豆，洁诚致祈。","垂休保佑，景祚巍巍。"],["至阴之精，亏而复盈。","轮高僊桂，阶应祥蓂。","玉兔影孤，金茎露溢。","其驾星车，顾于兹夕。"],["玉钩初弯，冰盘乍圆。","扇掩秋后，乌飞枝边。","精凝蟾蜍，辉光婵娟。","歆于明祀，弭芳节焉。"],["名稽汉仪，歌参唐宗。","往于卿少，乘秋气中。","周天而行，如姊之崇。","可飞霞佩，下瑠璃宫。"],["四扉大开，五云车立。","霓裾娣从，风翿童执。","摇曳胥来，锵洋爰集。","歆我严禋，西面以揖。"],["〔圜钟为宫〕玄鸟既至，序属春分。","朝于太阳，厥典备存。","载严大采，示民有尊。","扬光下烛，煜爚东门。"],["〔黄钟为角〕升晖丽天，阳德之母。","率无颇偏，兼烛下土。","恭事崇坛，礼乐具举。","顿御六龙，裴回容与。"],["〔太簇为征〕周祀及暗，汉制中营。","肸蚃是届，礼神以兄。","我洁斯璧，我肥斯牲。","神兮燕享，鉴观孔明。"],["〔姑洗为羽〕屹尔王宫，泛临翊翊。","惠此万方，岂惟五色。","以修阳政，以习地德。","云景杳冥，施祥无极。"],["天宇四霁，嘉坛聿崇。","肃祗严祀，登降有容。","仰瞻曜灵，位居其中。","既安既妥，沛哉丰融。"],["物之备矣，以交于神。","时惟炎精，不忘顾歆。","经纬之文，璆琳之质。","灿然相辉，其仪秩秩。"],["扶桑朝暾，和气肸饬。","奉此牲牢，为俎孔硕。","芬馨进闻，介我黍稷。","所将以诚，兹用享德。"],["匏爵斯陈，百味旨酒。","勺以献之，再拜稽首。","钟鼓在列，灵方安留。","眷然加荐，惟时之休。"],["礼罄沃盥，诚意肃将。","包茅是缩，冀毕重觞。","焕矣情文，既具醉止。","熙事备成，灵其有喜。"],["羲和驾兮，其容杲杲。","将安之兮，言归黄道。","光赫万物，无古无今。","人君之表，咸仰照临。"],["〔圜钟为宫〕金行告遒，玉律分秋。","礼蒇西郊，毖祀聿修。","精意潜达，永孚于休。","神之听之，爰格飚斿。"],["〔黄钟为角〕时维秋仲，夜寂天清。","实严姊事，用答阴灵。","坛壝斯设，黍稷惟馨。","云车来下，庶歆厥诚。"],["〔太簇为征〕溯日著明，丽天作配。","洁诚以祠，礼行肃拜。","光凝冕服，气肃环珮。","庶几昭格，祗而不懈。"],["〔姑洗为羽〕穆穆流辉，太阴之精。","盈亏靡忒，寒暑以均。","克禋克祀，揆日涓辰。","牲硕酒旨，来燕来宁。"],["猗欤崇基，右平左墄。","祗率典常，届兹秋夕。","陟降惟寅，威仪抑抑。","神其鉴观，穰简是集。"],["少采陈仪，实曰坎祭。","礼备乐举，严恭将事。","于以奠之，嘉玉量币。","神兮昭受，阴骘万汇。"]]