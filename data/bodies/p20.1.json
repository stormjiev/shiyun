[["西颢腾晶，天地始肃。","盛德在金，百嘉茂育。","彍弩射牲，筑场登谷。","明灵格思，旌罕纷属。"],["博硕肥腯，以炰以烹。","嘉栗旨酒，有弥斯盈。","肴核惟旅，肃肃烝烝。","吉蠲备物，享于克诚。"],["飚轮戾止，景烛灵坛。","金奏绎如，白露漙漙。"],["隆冬戒序，岁历顺成。","一人有庆，万物由庚。","有旨斯酒，有硕斯牲。","报功崇德，正直聪明。"],["大仪斡运，星纪环周。","三时不害，黍稷盈畴。","克诚致享，品物咸羞。","礼成乐变，锡祚贻休。"],["管磬咸和，礼献斯毕。","灵驭言旋，神降之吉。"],["〔圜钟宫三奏〕于神何司，而德于木。","肃然顾歆，则我斯福。","我祀孔时，我心载祗。","匪我之私，神来不来。"],["〔黄钟为角一奏〕神兮焉居，神在震方。","仁以为宅，秉天之阳。","神之来矣，道修以阻。","望神未来，使我心苦。"],["〔太簇为征一奏〕神在途矣，习习以风。","百灵后先，敢一不恭。","奔走疠疫，祓除菑凶。","顾瞻下方，逍遥从容。"],["〔姑洗羽一奏〕温然仁矣，熙然春矣。","龙驾帝服，穆将临矣。","我酒清矣，我肴烝矣。","我乐备矣，我神顾矣。"],["在国之东，有坛崇成。","节以和乐，式降式登。","洁我珮服，璆琳锵鸣。","匪坛斯高，曷妥厥灵。"],["物之熙熙，胡为其然。","蒙神之休，迺敢报旃。","有邸斯珪，有量斯币。","于以奠之，格此精意。"],["卜岁之初，我迎春祗。","孰克侑飨，曰古宓戏。","于皇宓戏，万世之德。","再拜稽首，敢爱斯璧。"],["灵兮安留，烟燎既升。","有硕其牲，有俎斯承。","匪牲则硕，我德惟馨。","缓节安歌，庶几是听。"],["百末布兰，我酒伊旨。","酌以匏爵，洽我百礼。","帝居青阳，顾予嘉觞。","右我天子，宜君宜王。"],["五德之王，谁实始之。","功括造化，与天无期。","酌我清酤，盥献载饬。","神鉴孔飨，天子之德。"],["贰觞具举，承神嘉虞。","神具醉止，眷焉此都。","我岁方新，我亩伊殖。","时旸时雨，繄神之力。"],["忽而来兮，格神鸿休。","忽而往兮，神不予留。","神在天兮，福我寿我。","千万春兮，高灵下堕。"],["〔圜钟为宫〕离明御正，德协于火。","有感其生，维帝是何。","帝图炎炎，贻福锡我。","鉴于妥虔，高灵下堕。"],["〔黄钟为角〕赤精之君，位于朱明。","茂育万物，假然长嬴。","我洁我盛，我蠲我诚。","神其下来，云车是承。"],["〔太簇为征〕八卦相荡，一气散施。","隆炽恢台，职神尸之。","肃肃飚御，神戾于天。","于昭神休，天子万年。"],["〔姑洗为羽〕烨烨其光，炳炳其灵。","窅其如容，歘其如声。","扇以景风，导以朱斿。","我德匪类，神其安留。"],["除地国南，有基崇崇。","载陟载降，式虔式恭。","燎烟既燔，黻冕斯容。","神如在焉，肆予幽通。"],["太微呈祥，炎德克彰。","佑我基命，格于明昌。","一纯二精，有严典祀。","于以奠之，以介繁祉。"],["练以𫄸黄，有篚将之。","肸蚃斯答，有神昭之。","维神于民，实始货食。","归德报功，敢怠王国。"],["有牲在涤，从以骍牡。","或肆或将，有洁其俎。","神嗜饮食，𫗣𫗣芬芬。","莫腆于诚，神其顾歆。"],["四月维夏，兆于重离。","帝执其衡，物无疠疵。","于皇帝功，思乐旨酒。","奠爵既成，垂福则有。"],["猗欤先农，肇兹黍稷。","既殖既播，有此粒食。","秬鬯洁清，彝罇疏幂。","竭我瑶斝，莫报嘉绩。"],["盥爵奠斝，载虔载恭。","笾豆静嘉，于乐鼓钟。","礼备三献，神具醉止。","孰显神德，扬光纷委。"],["神来何从，馺然灵风。","神去何之，杳然幽踪。","伊神去来，雾散云烝。","独遗休祥，山崇川增。"],["〔圜钟为宫〕维帝奠位，乃咸于时。","孰主张是，而枢纽之。","谷我腹我，比予于儿。","告我冠服，迨其委蛇。"],["〔黄钟角〕荪无不在，日与我居。","孰不可来，肸蚃斯须。","象服龙驾，渊渊鼓桴。","荪不汝多，多汝意孚。"],["〔太簇征〕乐哉帝居，逝留无常。","尔信我宅，尔中我乡。","乃眷兹土，于赫君王。","翩然下来，去未遽央。"],["〔姑洗羽〕澹兮抚琴，啾兮吹笙。","神之未来，肃穆以听。","缤纷羽旄，姣服在中。","神既来止，亦无惰容。"],["民生地中，动作食息。","与我周旋，莫匪尔极。","捕鲽东海，搴茅南山。","彼劳如何，矧升降间。"],["万椟之宝，一絇之丝。","孕之育之，谁为此施。","归之后神，神曰何为。","不宰之功，荡然四垂。"],["维有熊氏，以土胜王。","其后皆沿，兹德用壮。","黼黻幅舄，裳衣是创。","币之玄𫄸，对此昭亮。"],["王曰钦哉，无爱斯牲。","登我元祀，亦有皇灵。","以将以享，或剥或烹。","大夫之俎，天子之诚。"],["黍以为翁，鬰以为妇。","以侑元功，以酌大斗。","伊谁歆之，皇皇帝后。","伊谁嘏之，天子万寿。"],["昔在绵邈，有人公孙。","登政抚辰，节用良勤。","所蓄既大，所行宜远。","载其华罇，从以箫管。"],["羽觞更陈，厥味清凉。","饮之不烦，又有蔗浆。","夜未艾止，明星浮浮。","愿言妥灵，灵兮淹留。"],["灵不肯留，沛兮将归。","玉节猋逝，翠旗并驰。","顾瞻伫立，怅然佳期。","蹇千万年，无斁人斯。"],["〔圜钟为宫〕白藏启序，庶汇向成。","有严禋祀，用答幽灵。","风马云车，来燕来宁。","洋洋在上，休福是承。"],["〔黄钟角〕素精肇节，金行固藏。","气冲炎伏，明河翻霜。","功收有年，礼荐有章。","祇越眇冥，鸿基永昌。"],["〔太簇征〕昊天之气，揫敛万汇。","涓日洁齐，有严厥祀。","有牲维肥，有酒维旨。","神之燕娭，锡兹福祉。"],["〔姑洗羽〕执矩斯兑，实惟素灵。","受职储休，万宝以成。","飨于西郊，奠玉陈牲。","侑以雅乐，来歆克诚。"],["素猋谐律，西颢堕灵。","肇复元祀，晨炀肃清。","下土层陔，嘉荐芳馨。","以御蕃祉，介我西成。"],["惟时素秋，肇举元祀。","礼备乐作，降登有数。","洋洋在上，神既来止。","神之格思，锡我繁祉。"],["西颢肃清，群生茂遂。","有严报典，孔明祀事。","珪币告虔，神灵燕喜。","赉我丰年，以锡民祉。"],["洽礼既陈，谐音具举。","有涤斯牲，孔硕为俎。","维帝居歆，介我稷黍。","乐哉有秋，繄神之祜。"],["徂商肇祀，灵盖孔飨。","恭承嘉禧，湛澹秬鬯。","监此馨香，灵其安留。","畴惠下民，匪灵之休。"],["沆砀西颢，功载万世。","乘金宅兑，侑我明祀。","嘉觞布兰，牲玉洁精。","神之燕虞，肃用有成。"],["肃成万物，泬寥其秋。","惟兹祀事，戾止灵斿。","酌献具举，典礼是求。","冀福斯民，黍稷盈畴。"],["沆砀白藏，顺成万宝。","有来德馨，于昭神妥。","露华晨晞，飚驭聿还。","介我嗣岁，泽均幅员。"],["〔圜钟为宫〕吉日壬癸，律中应钟。","国有故常，北郊迎冬。","乃蒇祀事，必祗必恭。","明默虽异，感而遂通。"],["〔黄钟为角〕良月盈数，四气推迁。","帝于是时，典司其权。","高灵下堕，降祉幅员。","神之听之，祀事罔愆。"],["〔太簇为征〕北方之神，执权司冬。","三时务农，于焉告功。","礼备乐作，归功于神。","风马来游，永锡斯民。"],["〔姑洗为羽〕天地闭塞，盛德在水。","黑精之君，降福羡祉。","洋洋在上，若或见之。","齐庄承祀，其敢斁思。"],["昧爽昭事，煌煌露光。","涤溉蠲洁，容仪肃庄。","牲肥酒旨，荐此芬芳。","降陟有序，礼无越常。"],["晨曦未升，天宇肃穆。","祗若元祀，将以币玉。","神之格思，三献茅缩。","明灵怿豫，下土是福。"],["飚驭云盖，神之顾歆。","丕昭礼容，发扬乐音。","祀事既举，仰当神心。","申以嘉币，式荐诚谌。"],["辰牡孔硕，奉牲以告。","秘祝非祈，丰年宜报。","至意昭彻，交乎神明。","降福穰穰，用燕群生。"],["赫赫神游，周流八极。","德馨上闻，于焉来格。","不腆酒醴，用伸悃愊。","神其歆之，民用向德。"],["十月纳禾，民务藏盖。","不有神休，民罔攸頼。","孟冬之吉，礼行不昧。","神降百祥，昭著蓍蔡。"],["万汇揫敛，时惟冬序。","蠢尔黎氓，入此室处。","酌献告神，礼以时举。","頼此阴骘，民有所怙。"],["神之戾止，天门夜开。","礼备告成，云{车井}亟回。","旗纛晻霭，万灵喧豗。","独遗祉福，用泽九垓。"],["和均玉管，政协璇衡。","四序资始，万物含生。","皇猷允洽，至德惟明。","为民祈福，克致精诚。"],["衣冠俨若，步武有容。","公卿济济，率礼惟恭。"],["昊天降康，云何以报。","斯谋斯惟，雍雍灌鬯。","身之洁兮，神斯来止。","神之享兮，民斯福矣。"],["笾豆有践，玉帛斯陈。","神无常享，享于精纯。"],["俎实具列，明德惟馨。","肃容祗荐，神其降灵。"],["乐调凤律，酒浥牺尊。","至灵斯御，盛德弥敦。"],["三阳戒律，万汇腾精。","既苏昆虫，毕达勾萌。","具陈牺象，式荐诚明。","锡以蕃祉，永保咸平。"],["大君有命，祀典咸修。","荐献式叙，淑慎优柔。"],["奉承明祀，惟羊惟牛。","卬盛于豆，备陈庶羞。","钟鼓喤喤，神具醉止。","其彻嘉笾，永绥福祉。"],["既临下土，复归于天。","神之报贶，受福无边。"],["濬发长源，粤惟始祖。","五运协图，万灵来护。"],["龙德而隠，源流则长。","宜乎亿祀，侑享弥昌。"],["二仪交泰，七政顺行。","四序资始，万物含生。","皇朝创业，盛德致平。","为民祈福，洁此精诚。"],["冕旒俨若，步武有容。","公卿济济，韶頀邕邕。"],["乐和凤律，酒奠牺尊。","神明斯享，礼盛难论。"],["大君有命，阙典咸修。","帝歆明祀，佑圣千秋。"],["俯临下土，回复上天。","触类而长，荷福无边。"],["〔圜钟为宫〕炎精之神，飞{车井}碧落。","驾以浮云，丹书赤雀。","礼备豆笾，乐谐箫勺。","神具醉止，佑我景铄。"],["〔黄钟为角〕宋德惟火，神实司之。","上仪申蒇，迎方重离。","瑶币告洁，秀华金支。","啾啾神龙，来介繁禧。"],["〔太簇为征〕于物司火，于方峙南。","璇霄来下，羽卫毵毵。","祠官祝厘，联珮合簪。","本支有衍，则百斯男。"],["〔姑洗为羽〕惟神之安，方解羽銮。","赤旗霞曳，从以炎官。","居歆嘉荐，肸蚃灵坛。","神之格矣，民讫多盘。"],["冲牙锵鸣，肃容专精。","交神之义，罔敢弗诚。","设洗于阼，罍水惟清。","盥以致洁，感通神明。"],["三阳交泰，日新惟良。","大建厥祀，兹报兴王。","礼严陟降，德荐馨香。","聿怀嘉庆，降福穰穰。"],["肃肃严祀，神幽必闻。","骋驾临飨，将歆𫗣芬。","嘉玉陈币，钦恭无文。","永绥多祜，国祚何垠。"],["於穆文献，景炎发祥。","启兹皇运，垂庆无疆。","篚币有陈，式昭肃庄。","神之格思，如在洋洋。"],["笾豆大房，秩秩在列。","奉牲以告，既全既洁。","乐均无爽，牲醴攸设。","神兮燕娭，霓旌孑孑。"],["盛德在火，相我炎祚。","典祀有常，牲玉维具。","风马云车，翩翩来顾。","式蕃帝祉，后昆有裕。"],["皇矣文献，开国有先。","德配感生，对越在天。","练日得辛，来止灵坛。","神其锡羡，瑞应猗兰。"],["苾苾芬芬，神具醉止。","笙磬铿锵，干旄旖旎。","鬷假无言，神灵惟喜。","申锡蕃厘，暨我孙子。"],["伟炎厥初，缘感而系。","庆衍式崇，昭融有契。","乐功既谐，觞献斯继。","歆类不违，克昌百世。"],["洁陈斯备，昭格惟禋。","神歆以饫，宰彻其馂。","清歌振晓，叶气流春。","永锡祚嗣，以渥烝民。"],["丰祀孔饰，肃来自天。","兰尊既彻，飚驭载遄。","骑云缥缈，聆乐流连。","惟迈惟顾，降福绵绵。"],["礼文既洽，熏燎聿升。","嘉气四塞，丹诚上腾。","惟类之应，惟福之兴。","永炽天统，亿载灵承。"],["思文圣考，对越在天。","侑神作主，奉币申虔。"],["偃革兴文，封峦考瑞。","威烈巍巍，允膺宗祀。"],["维圣享帝，维孝严亲。","肇图世室，躬展精禋。","镛鼓既设，笾豆既陈。","至诚攸感，保格上神。"],["干亨坤庆育函生，路寝明堂致洁诚。","玉帛非馨期感格，降康亿载保登平。"],["肃肃路寝，相维明堂。","二仪鉴止，三圣侑旁。","灵期䜣合，祠节齐庄。","至诚并贶，降福无疆。"],["祖功宗德启隆熙，严配交修太室祠。","圭币荐诚知顾享，本支锡羡固邦基。"],["艺祖造邦，二宗绍德。","肃雍孝享，登配圜极。","先训有开，菲躬何力。","歆馨锡羡，保民丽亿。"],["我将我享，辟公显助。","献终豆彻，礼成乐具。","饰驾上游，升烟高骛。","神保聿归，介兹景祚。"],["烨烨房心，下照重屋。","我严帝亲，匪配之渎。","西颢沆砀，夕景已肃。","灵其来娭，嘉荐芳鬰。"],["明明合宫，莫尊享帝。","礼乐熙成，精与神契。","桂尊初阑，羽驾倏逝。","遗我嘉祥，于显万世。"],["于皇圣考，克配上帝。","永言孝思，昭荐嘉币。"],["英声迈古，德施在民。","允秩宗祀，宾延上神。"],["严父配天，孝乎明堂。","与奠升阶，降音以将。","天步有节，帝容必庄。","辟公宪之，礼无不臧。"],["圣能享帝，孝克事亲。","于皇宗祀，盛节此陈。","何以荐虔，二精有炜。","何以致祥，上天鉴止。"],["合宫礼备，时维哲王。","堂筵四敞，明德馨香。","圣考来格，降福穰穰。","承承继继，万祀其昌。"],["奕奕明堂，天子即事。","奠我圣考，配于上帝。","凡百有职，畴敢不祗。","俎洁牲肥，其登有仪。"],["惟礼不渎，所以严亲。","惟孝不匮，所以教民。","陟配文考，享于大神。","重禧累福，祚裔无垠。"],["隆功骏德，两有烈光。","陟配宗祀，惠我无疆。"],["舞以象功，乐惟崇德。","文经万邦，武靖四国。","一张一弛，其仪不忒。","神鉴孔昭，孝思维则。"],["于昭盛礼，严父配天。","尽物尽诚，莫匪吉蠲。","重觞既荐，九奏相宣。","神介景福，亿万斯年。"],["莫尊乎天，莫亲乎父。","既享既侑，诚申礼举。","戛击堂上，八音始具。","天子亿龄，饮神之胙。"],["穆穆在堂，肃肃在庭。","于显辟公，来相思成。","神既歆止，有闻无声。","锡我休嘉，燕及群生。"],["有奕明堂，万方时会。","宗子圣考，作帝之配。","乐酌虞典，礼从周志。","厘事既成，于皇来暨。"],["交于神明，内心为贵。","外致其文，亦效精意。","嘉玉既陈，将以量币。","肃肃雝雝，惟帝之对。"],["有邦事神，享帝为尊。","内心致德，外示弥文。","嘉玉效珍，荐以量币。","恭钦伊何，惟以宗祀。"],["肇祀明堂，告成大报。","颙颙祗祗，率见昭考。","涓选休辰，齐明朝夕。","于惟皇王，孝思罔极。"],["若昔大猷，孝思维则。","永言孝思，丕承其德。","于昭明威，侑于上帝。","赉我思成，永绥福祉。"],["于昭皇考，大明体神。","宪章文思，宜民宜人。","严父之道，陟配于天。","躬行孝告，有孚于先。"],["惟我有宋，昊天子之。","三年卜祀，百世承基。","施及冲眇，奉牲以祠。","敢忘斋栗，偏举上仪。"]]