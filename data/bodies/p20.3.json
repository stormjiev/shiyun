[["谷旦其差，有牲在涤。","工祝致告，为俎孔硕。","肸蚃是期，祚我明德。","备兹孝钦，式和民则。"],["白藏在序，享惟其时。","躬即明坛，礼惟载祗。","斟以瑶爵，神灵燕娭。","歆馨顾德，锡我蕃厘。"],["肃雍严祀，圣治昭彰。","清酒既载，或肆或将。","礼匝三献，终然允臧。","神具醉止，其乐且康。"],["歌奏云阕，式礼莫愆。","以我齐明，罄其吉蠲。","神保聿归，降康自天。","萝图永固，亿万斯年。"],["容台讲礼，禖宫立祠。","司分届后，带韣陈仪。","嘉祥萃止，灵驭来思。","皇支蕃衍，永固邦基。"],["郊禖之应，肇自生商。","诞膺宝命，濬发其祥。","天材蕃衍，德称君王。","本支万世，与天无疆。"],["昔帝高辛，先禖肇祀。","爰揆仲阳，式祈嘉祉。","陈之牺牲，授以弓矢。","敷祐皇宗，施于孙子。"],["昭荐精衷，灵承端命。","青帝顾怀，神禖储庆。","祚以蕃昌，协于熙盛。","螽斯众多，流于雅咏。"],["赫赫高禖，万世所祀。","其德不回，锡兹福祉。","蕃衍椒聊，和平芣苢。","传类降康，世济其美。"],["礼奠蠲衷，祭仪竣事。","丕拥灵休，蕃衍皇嗣。"],["〔圜钟为宫〕聿分春气，施生在时。","禖宫肇启，精意以祠。","礼仪告备，神其格思。","厥灵有赫，锡我繁厘。"],["〔黄钟为角〕眷此尊祀，实惟仲春。","青圭束帛，克祀克禋。","庶蒙嘉惠，嗣续诜诜。","神之降鉴，云车来臻。"],["〔太簇为征〕猗欤禖宫，祀典所贵。","粤自艰难，礼或弗备。","以迄于今，始建坛壝。","愿戒云车，歆此诚意。"],["〔姑洗为羽〕春气肇分，万类滋荣。","惟此祀事，皆象发生。","求神以类，式昭至诚。","庶几来格，子孙绳绳。"],["有奕禖宫，在国之南。","坛壝既设，威仪孔严。","登祀济济，神兮顾瞻。","佑我皇祚，宜百斯男。"],["青律载阳，有鳦颉颃。","祈我繁祉，立子生商。","三牲既荐，玉帛是将。","克禋克祀，有嘉其祥。"],["祗祓禖坛，洁蠲羊豕。","博硕肥腯，爰具牲醴。","执事骏奔，肃将俎几。","神其顾歆，永锡多子。"],["瑞鳦至止，祀事孔时。","酌以清酒，祼献载祗。","神具醉止，介我蕃禧。","乃占吉梦，维熊维罴。"],["中春涓吉，蒇事禖祠。","礼备乐作，笾豆孔时。","贰觞毕举，荐献无违。","庶几神惠，祥启熊罴。"],["嘉荐令芳，有严禋祀。","神来燕娭，亦既醉止。","风驭言还，栗然歘起。","以祓以除，锡我蕃祉。"],["倬彼垂象，照临下土。","躔次运行，功德周普。","九宫既位，惟德是辅。","神之至上，皇皇斯臯。"],["灵禋既肃，明神既秩。","在国之东，协日之吉。","升歌有仪，六变中律。","怀和万灵，降兹阴骘。"],["祗荐有常，惟神无方。","回飚整驭，垂休降祥。"],["上天贵神，九宫设位。","功德及物，乃秩明祀。","望拜紫坛，赫然灵气。","奠玉荐币，歆之无愧。"],["天之贵神，推移九宫。","厥位靡常，降康则同。","来集于坛，顾歆恪恭。","歌以送之，飚静旋穹。"],["〔圜钟为宫〕紫阙幽宏，惟神灵尊。","辅成泰元，赞役乃坤。","曰雨曰旸，缊豫调纷。","享荐陨光，蒙祉如屯。"],["〔黄钟为角〕载阳衍德，农祥孔昭。","赉兹元嘏，穰穰黍苗。","象舆眇冥，金奏远姚。","无阏厥灵，丹衷匪恌。"],["〔太簇为征〕于赫九宫，天神之贵。","煌煌彪列，下土是莅。","幽赞高穹，阴骘万类。","肃若旧典，有严祗事。"],["〔姑洗为羽〕练时吉良，聿崇明祀。","粢盛洁丰，牲硕酒旨。","肃唱和声，来燕来止。","嘉承天休，赉及含齿。"],["于昭毖祀，周旋有容。","历阶将事，趋进鞠躬。","改步如初，没阶弥恭。","左墄右平，陟降雍雍。"],["煌煌九宫，照临下土。","阴骘庶类，功施周普。","恪修祀典，礼备乐举。","嘉玉量币，馨非稷黍。"],["灵鉴匪远，诚心肃祗。","是烝是享，俎实孔时。","礼行乐奏，肸蚃是期。","云车风马，神其燕娭。"],["惟天丕冒，彪列九神。","财成元化，阴骘下民。","有酒斯旨，登荐苾芬。","昭哉降鉴，茀禄来臻。"],["均调大化，阴骘下民。","骏功有赫，诞举明禋。","嘉觞中贰，执事惟寅。","清明鬯矣，福禄攸臻。"],["荐献有序，降登无违。","礼乐备举，昭格燕娭。","云车缥缈，神曰还归。","报以景贶，翊我昌期。"],["肃肃清庙，奉祠来诣。","格思之灵，如在之祭。","克谨威仪，载严容卫。","降福孔皆，以克永世。"],["工祝升阶，宾尸在位。","祗达孝思，允修毖祀。","显相有仪，克恭乃事。","俨恪其容，通此精意。"],["木符启瑞，著象成文。","于昭大号，协应明君。","灵命有属，鸿禧洞分。","歌以升荐，休嘉洽闻。"],["嘉彼驯象，来归帝乡。","南州毓质，中区效祥。","仁格巨兽，德柔遐荒。","有感斯应，神化无方。"],["素乌爰止，淳精允臧。","名符瑞牒，色应金方。","洁白容与，翘英奋扬。","孝思攸感，皇德逾张。"],["维牺维牲，以炰以烹。","植其鞉鼓，洁彼铏羹。","孔硕兹俎，於穆厥声。","肃雍显相，福禄来成。"],["汤汤洪河，经启长源。","鬰鬰嘉木，挺生本根。","大哉崇基，出乎庆门。","发祥垂裕，永世贻孙。"],["元钟九千，生于仲吕。","崇台九层，起于累土。","赫日之升，明夷为主。","孝孙作帝，式由祖武。"],["明明我祖，积德攸宜。","肇继瓜瓞，将隆本支。","爰资庆绪，式昭帝基。","於穆清庙，永洽重熙。"],["艰难积行，绵长钟庆。","同人之时，得主乃定。","既叙宗祧，乃修舞咏。","经武开先，永昭丕命。"],["猗欤太祖，受命于天。","化行区宇，功溢简编。","武威震耀，文德昭宣。","开基垂统，亿万斯年。"],["赫赫皇运，明明太宗。","四隩咸暨，一变时雍。","睿文炳焕，圣德温恭。","千龄万祀，永播笙镛。"],["嘉粟旨酒，博腯牲牷。","神鉴孔昭，享兹吉蠲。","夙夜毖祀，孝以奉先。","永锡纯嘏，功格于天。"],["已象文治，乃观武成。","进退可度，威仪克明。"],["常武徂征，诗人所称。","总干山立，厥象伊凝。"],["肥腯之牲，既析既荐。","鬰鬯之酒，已酌已献。","祝辞亦陈，和奏斯徧。","享礼具举，彻其有践。"],["肃肃清庙，昭事祖祢。","粢盛苾芬，四海来祭。","皇灵格思，令容有睟。","降福孔皆，以克永世。"],["祼鬯溥将，宾尸在位。","帝德升闻，孝思光被。","公卿庶正，傅御师氏。","至诚感神，福禄来暨。"],["淳清育物，瑞木成文。","元气陶冶，非烟鬰氛。","玄贶昭格，至和所熏。","登歌祼献，肸蚃如闻。"],["丽碑割牲，以炰以烹。","博硕肥腯，荐羞神明。","祖考来格，享于克诚。","如闻謦欬，式燕以宁。"],["肃肃艺祖，肇基鸿源。","权舆光大，燕翼贻孙。","载祀惟永，庆流后昆。","威灵在天，顾我思存。"],["思文圣祖，长发其祥。","锡羡蕃衍，德厚流光。","眷命自天，卜世聿昌。","祗肃孝享，降福无疆。"],["明明我祖，积德累仁。","居晦匿曜，迈种惟勤。","帝图天锡，辉光日新。","寝庙绎绎，昭事同寅。"],["洸洸我祖，时惟鹰扬。","潜德弗耀，发源灵长。","肆类配天，永思不忘。","来顾来享，百福是将。"],["赫赫太祖，受命于天。","赤符启运，威加八埏。","神武戡难，功无间然。","翼翼丕承，亿万斯年。"],["穆穆太宗，与天合德。","昧旦丕显，干干翼翼。","敷佑下民，时帝之力。","永怀圣神，孝思罔极。"],["煌煌真宗，善继善承。","经武耀德，臻于治平。","对祀礼乐，丕昭鸿名。","陟配文庙，皇图永宁。"],["鼎俎既陈，豆笾既设。","金石在庭，工师就列。","备物有严，著诚致洁。","孝惟时思，礼以雍彻。"],["神之来兮风肃然，神之去兮升九天。","排凌兢兮还恍惚，羽旄纷兮萧燔烟。"],["鸿源濬发，睿图诞彰。","高明锡羡，累洽延祥。","巍巍艺祖，溥率宾王。","煌煌文考，区宇大康。","珍符昭显，宝历绵长。","物性茂遂，民俗阜昌。","甫田多稼，禾黍穰穰。","含生嘉育，鸟兽跄跄。","八纮统域，九服要荒。","沐浴惠泽，祗畏典常。","隔谷分壤，望斗辨方。","并袭冠带，来奉圭璋。","峨峨双阙，济济明堂。","诸侯执帛，天后当阳。","何以辨等，衮衣绣裳。","何以褒德，辂车乘黄。","声明焕赫，雅颂汪洋。","启兹丕绪，祐我无疆。","大统斯集，大乐斯扬。","俯隆宗祏，仰继穹苍。"],["五代衰替，六合携离。","封疆窃据，兵甲竞驰。","天顾黎献，涂炭可悲。","帝启灵命，濬哲应期。","皇祖丕变，金钺俄麾。","率土执贽，犷俗来仪。","瞻彼大卤，窃此余基。","独迷文告，莫畏天威。","神宗继统，璇图有辉。","尚安蠢尔，罔怀格思。","六飞夙驾，万旅奉辞。","徯来发咏，不阵行师。","云旗先路，壶浆塞岐。","天临日照，宸虑通微。","前歌后舞，人心悦随。","要领自得，智力何施。","风移僭冒，政治淳熙。","书文混一，盛德咸宜。","干戈倒载，振振言归。","诞昭七德，永定九围。"],["宝命自天，鸿禧锡祚。","昭晰绿文，氤氲黄素。","玄感荐彰，灵休诞布。","寅奉珍符，聿怀永慕。"],["报贶陟封，聿昭典礼。","让德穹厚，归功祖祢。","丕显尊称，尽善尽美。","寅威孝思，以介蕃祉。"],["奕奕清庙，锡羡诒谋。","升中神岳，显允皇猷。","归格艺祖，昭报灵休。","奉先追远，盛德益修。"],["于昭列圣，休德清明。","威灵如在，享于克诚。","报功厚载，馨荐惟精。","归格饮至，礼备乐成。"],["于赫圣祖，景灵在天。","神游来暨，睟容穆然。","诲言昭示，帝胄开先。","齐明钦若，延鸿亿年。"],["钦崇太霄，肃奉徽册。","大礼克诚，鸿猷有赫。","令芳爰荐，明灵斯格。","照谢垂祥，永怀何极。"],["追养奉先，纳孝练主。","金奏凤鸣，关雎乐舞。","奠鬯恭神，肥腯展俎。","积庆聪明，降景寰宇。"],["於穆真皇，宅心道粹。","和戎偃革，焕乎文治。","操瑞拜图，封天祀地。","盛德为宗，烝尝万世。"],["濡露降霜，永怀孝思。","祫食谛叙，再闰之期。","歌德咏功，八音播之。","歆神惟始，灵其格兹。"],["昭穆亲祖，自室徂堂。","礼备乐成，肃然祼将。","瑟瓒黄流，条鬯芬芳。","气达渊泉，神孚来享。"],["四祖基庆，三后在天。","荐侑备成，灵娭其旋。","孝孙应嘏，受福永年。","送之怀之，明发恻然。"],["躬兹孝享，礼备乐成。","神登于俎，祝导于祊。","展牲肥腯，奏格和平。","灵其昭格，肃僾凝情。"],["灵神归止，光景肃然。","福祥裕世，明威在天。","孝孙有庆，骏烈推先。","佑兹基绪，弥万斯年。"],["在宋五世，天子嗣昌。","躬发英断，若干之刚。","声容沄沄，被于八荒。","垂千万年，永烈有光。"],["钟鼓惟旅，笾豆孔时。","衎我祖宗，既右享之。","神亟来止，孝孙之喜。","神保聿归，孝孙之思。"],["进退有容，服章有仪。","匪亟匪迟，降登孔时。"],["於穆仁庙，圣泽滂流。","华夷用乂，动植蒙休。","徽名冠古，奕世垂谋。","帝躬祼献，盛典昭修。"],["赫赫英皇，总提邦纪。","濬发神功，恢张圣理。","仙驭虽遥，鸿徽不弭。","永言孝思，竭诚躬祀。"],["奕奕清庙，昭穆定位。","霜露增感，粢盛洁祭。","神灵来格，福祉攸暨。","追孝奉先，本支百世。"],["有秩时祀，匪怠匪渎。","有来宗工，载祗载肃。","厥作祼将，流黄瓒玉。","是享是宜，永绥多福。"],["皇祖皇考，配帝配天。","骏奔显相，神保言旋。","祝以孝告，嘏以慈宣。","去来永慕，宗事惟虔。"],["〔黄钟为宫〕奉先严祀，率礼大经。","时思致享，肃荐芳馨。","竭诚备物，乐奏和声。","真驭来止，熙事克成。"],["〔大吕为角〕圣灵在天，九关崇深。","风马云车，纷其顾临。","拥祥储休，昭答孝心。","孝孙受祉，万福是膺。"],["〔太簇为征〕嘉承和平，秩祀为先。","乃练休辰，祝史告虔。","内心齐明，祀具吉蠲。","交际恍惚，如在后前。"],["〔应钟为羽〕道信于神，神灵燕娭。","酒有嘉德，物惟其时。","缓节安歌，乐奏具宜。","欣欣乐康，福禄绥之。"],["王假有庙，子孙保光。","奉牲以告，玉俎膏香。","专精厉意，神其迪尝。","休承灵意，申锡无疆。"],["恪恭祀典，涓选休成。","设洗致洁，直于东荣。","嘉觞祗荐，明德惟馨。","祖考来格，享兹孝诚。"],["冠佩雍容，时惟上公。","享于清庙，陟降弥恭。","笾豆静嘉，粢盛洁丰。","孝孙有庆，万福来同。"],["於穆文献，自天发祥。","肇基明命，锡羡无疆。","子孙千亿，宗社灵长。","神之格思，如在洋洋。"],["天启炎历，集我大命。","长发其祥，笃生上圣。","夷乱芟荒，乾坤以定。","时祀聿修，孝孙有庆。"],["赫赫艺祖，受天明命。","威加八纮，德垂累圣。","祀事孔明，有严笙磬。","对越在天，延休锡庆。"],["明明在上，时维太宗。","允武允文，丕基绍隆。","于肃清庙，昭报是丰。","皇灵格思，福禄来同。"],["於穆真皇，维烈有光。","丕承二后，奄奠万方。","威加戎狄，道格穹苍。","歆时禋祀，降福无疆。"],["至哉帝德，乃圣乃神。","恭己南面，天下归仁。","历年长久，垂裕后人。","祀修旧典，宝命维新。"],["炎基克巩，赫赫英宗。","绍休前烈，仁化弥隆。","笃生圣子，尧汤比踪。","烝尝万世，福禄来崇。"],["于昭神祖，运抚明昌。","肇新百度，克配三王。","遐荒底绩，圣武维扬。","永言执竞，上帝是皇。"],["于皇濬哲，遹骏有声。","率时昭考，丕显仪刑。","功光大业，道协三灵。","永绥厥后，来燕来宁。"],["天锡神圣，徽柔懿恭。","垂衣拱手，遵制扬功。","配天立极，体道居中。","佑我烈考，万福攸同。"],["于皇钦宗，道备德宏。","允恭允俭，克类克明。","孝遵前烈，仁翊函生。","歆兹肆祀，永燕宗祊。"],["于皇时宋，自天保定。","高宗受之，再仆景命。","绍开中兴，翼善传圣。","何千万年，永绥厥庆。"],["圣人之德，无加于孝。","思皇孝宗，履行立教。","始终纯诚，非曰笑貌。","于万斯年，是则是傚。"],["维宋洽熙，帝继于理。","万姓厚生，三辰顺轨。","对时天休，以燕翼子。","肃唱和声，神其有喜。"],["肃肃清庙，于显维德。","我祀孔时，我奏有翼。","秉翟载骏，有来干戚。","神之燕娭，休祥允格。"],["观德宗祏，奕世烈光。","有严祀典，粤循旧章。","乐谐九变，献举重觞。","燕娭如在，戬谷穰穰。"],["礼备乐成，物称诚竭。","相维辟公，神人以说。","歌雍一章，诸宰斯彻。","天子万年，无竞维烈。"],["霜露既降，时思展禋。","在天之御，睠然顾歆。","乐成礼备，言归靡停。","既安既乐，福禄来成。"],["〔黄钟宫〕时维孟冬，霜露既零。","合食盛礼，以时以行。","孝心翼翼，惟神来宁。","肃倡斯举，神具是听。"],["〔大吕角〕於穆孝思，嘉荐维时。","诚通兹格，咸来燕娭。","神之听之，申锡蕃厘。","于万斯年，永保丕基。"],["〔太簇征〕于昭孝治，通乎神明。","寒暑不忒，熙事备成。","牲牷孔硕，黍稷惟馨。","以享以祀，来燕来宁。"],["〔应钟羽〕苾芬孝祀，荐灌肃雍。","致力于神，明信咸通。","灵之妥留，惠我庞鸿。","广被万宇，福禄攸同。"],["于赫皇祖，濬发其祥。","德盛流远，奕世弥昌。","孝孙有庆，嘉荐令芳。","神保是享，锡羡无疆。"],["上天眷命，佑我丕基。","翼翼皇祖，不耀其辉。","积厚流长，福禄攸宜。","祀事孔时，曾孙笃之。"],["于皇光宗，握符御极。","昭哉嗣服，惟仁与德。","勤施于民，靡有暇逸。","万年之思，永奠宗祏。"],["合祭大事，因时发天。","翼翼孝思，三献礼虔。","神兮乐康，飚驭言旋。","永福后人，于千万年。"],["於穆仁祖，宠绥万方。","执竞英考，迄用成康。","图徽宝册，有烈其光。","庶几亿载，与天无疆。"],["在宋五世，天子神明。","群公奉册，迺扬鸿名。","金书煌煌，遹昭厥成。","思皇多祜，与天同声。"],["于惟祢庙，乃圣乃神。","秉文之士，作起惟新。","建宫稽古，一视同仁。","庶几备号，以享天人。"],["于铄徽考，如天莫名。","迨兹丕扬，拟纯粹精。","温玉镂文，来至于祊。","有严奕奕，礼备乐成。"],["金字煌煌，瑶光灿灿。","群工奉之，登此宝殿。","对越祖宗，式遵成宪。","威灵在天，来止来燕。"],["惟精惟一，乃圣乃神。","鸿名克扬，茂实斯宾。","如禹之功，如尧之仁。","孝思永慕，用诏无垠。"],["於穆高皇，功德兼隆。","称天以诔，初谥未崇。","载稽礼典，扬徽垂鸿。","涓日之良，登进庙宫。"],["有瑑斯宝，有编斯册。","导以麾仗，奏以金石。","祲威盛容，煌煌赫赫。","巨工奉之，高灵来格。"]]