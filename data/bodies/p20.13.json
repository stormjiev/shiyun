[["生而知之，有教无私。","成均之祀，威仪孔时。","维兹初丁，洁我盛粢。","永适其道，万世之师。"],["大哉宣圣，道德尊崇。","维持王化，斯民是宗。","典祀有常，精纯并隆。","神其来格，于昭盛容。"],["今月季秋，谷日辛亥。","路寝合宫，亲修严配。","北方之神，五室来会。","馨烈是，庬褫攸介。"],["天之贵神，推移九宫。","厥位靡常，降康则同。","来集于坛，顾歆恪恭。","歌以送之，飙静旋穹。"],["大君有命，阙典咸脩。","帝歆明祀，佑圣千秋。"],["火在六气，独处其两。","感生维君，繄辰克相。","何以验之，占兹垂象。","腾驾苍虬，歘其来飨。"],["乐音上达，粤惟出虚。","火性炎上，亦生于无。","我镛我磬，我笙我竽。","气同声应，昭哉合符。"],["烨烨我宋，火德所畀。","用火纪时，允惟象类。","神以类歆，诚繇类至。","有感斯通，孚我阳燧。"],["云兮飘飘，风兮棱棱。","飙驭返空，杲日来升。","归旆扬扬，众乐锵锵。","我神式欢，惠我嘉祥。"],["天日清晏，朝野靖安。","三灵答祉，万国腾欢。","帝命不违，王业艰难。","天子万年，永迪监观。"],["天心仁佑，坤德世昭。","灼有慈范，著于累朝。","俭以赞虞，勤以承尧。","是用则效，共励夙宵。"],["象服之文，鹊巢之风。","化以妇道，觐于内宫。","采蘋涧滨，采藻涧中。","夙夜在公，赞彼累功。"],["上帝有赫，百灵效祥。","储祉垂恩，锡年降康。","皇仪睟温，帝躬肃庄。","三宫齐欢，地久天长。"],["大安耽耽，兴庆崇崇。","维皇之尊，与天比隆。","非心閒燕，文命延鸿。","欲报之恩，礼缛仪丰。"],["晨趋慈幄，佳气郁葱。","受帝之祉，配天其崇。","璧华金精，礼敷乐充。","天子是若，欢声融融。"],["盛服承祀，出自公桑。","衣不羽皮，利及万方。","百味旨酒，有飶其香。","神其歆止，洋洋在傍。"],["明明我后，重祭钦祠。","有司肃事，式荐晨仪。","礼惟其称，物惟其时。","神之听之，福禄来为。"],["季秋之月，律中无射。","农事备收，火功告毕。","克禋克祀，有严有翼。","风马云车，尚其来格。"],["火星之躔，有烨其光。","表于辰位，伏于戌方。","时和岁稔，仁显用藏。","告尔万民，出纳有常。"],["赫赫皇图，炎炎火德。","侈神之赐，奄有方国。","粢盛既丰，俎豆有飶。","于万斯年，报祀无斁。"],["青社分封，前星启燄。","繁弱绥章，厥光莫掩。","容称其德，蓄学之验。","芳誉敷华，大圭无玷。"],["善颂善祷，三加弥尊。","爵弁峨峨，介圭温温。","阳德方长，成德允存。","燕及君亲，厥祉孔蕃。"],["维牺维牲，以炰以烹。","植其鼗鼓，洁彼铏羹。","孔硕兹俎，于穆厥声。","肃雍显相，福禄来成。"],["明明我祖，积德攸宜。","肇继瓜瓞，将隆本支。","爰资庆绪，式昭帝基。","于穆清庙，永洽重熙。"],["汤汤洪河，经启长源。","郁郁嘉木，挺生本根。","大哉崇基，出乎庆门。","发祥垂裕，永世贻孙。"],["肥腯之牲，既析既荐。","郁鬯之酒，已酌已献。","祝辞亦陈，和奏斯遍。","享礼具举，彻其有践。"],["礼均孝慈，乐合韶武。","至德光矣，鸿恩亦溥。","上下和济，华夷乐湑。","盏斝三行，盛仪斯举。"],["献终豆彻，礼备乐成。","祠容肃肃，风驭冥冥。","三时务本，一垡躬耕。","人祇胥悦，祉福是膺。"],["晬仪临拱，丕命明扬。","鸾回宝势，鸿贯瑶光。","礼成乐备，德裕名芳。","肇基王化，永懋天祥。"],["烨烨其光，炳炳其灵。","窅其如容，歘其如声。","扇以景风，导以朱斿。","我德匪类，神其安留。"],["八卦相荡，一气散施。","隆炽恢台，职神尸之。","肃肃飙御，神戾于天。","于昭神休，天子万年。"],["赤精之君，位于朱明。","茂育万物，假然长嬴。","我洁我盛，我蠲我诚。","神其下来，云车是承。"],["离明御正，德协于火。","有感其生，维帝是何。","帝图炎炎，贻福锡我。","鉴于妥虔，高灵下堕。"],["天地闭塞，盛德在水。","黑精之君，降福羡祉。","洋洋在上，若或见之。","齐庄承祀，其敢斁思。"],["北方之神，执权司冬。","三时务农，于焉告功。","礼备乐作，归功于神。","风马来游，永锡斯民。"],["良月盈数，四气推迁。","帝于是时，典司其权。","高灵下堕，降祉幅员。","神之听之，祀事罔愆。"],["吉日壬癸，律中应钟。","国有故常，北郊迎冬。","乃蒇祀事，必祗必恭。","明默虽异，感而遂通。"],["执矩斯兑，实惟素灵。","受职储休，万宝以成。","飨于西郊，奠玉陈牲。","侑以雅乐，来歆克诚。"],["昊天之气，揫敛万汇。","涓日洁齐，有严厥祀。","有牲维肥，有酒维旨。","神之燕娭，锡兹福祉。"],["素精肇节，金行固藏。","气冲炎伏，明河翻霜。","功收有年，礼荐有章。","祇越眇冥，鸿基永昌。"],["白藏启序，庶汇向成。","有严禋祀，用答幽灵。","风马云车，来燕来宁。","洋洋在上，休福是承。"],["澹兮抚琴，啾兮吹笙。","神之未来，肃穆以听。","缤纷羽旄，姣服在中。","神既来止，亦无惰容。"],["乐哉帝居，逝留无常。","尔信我宅，尔中我乡。","乃眷兹土，于赫君王。","翩然下来，去未遽央。"],["荪无不在，日与我居。","孰不可来，肸蚃斯须。","象服龙驾，渊渊鼓桴。","荪不汝多，多汝意孚。"],["维帝奠位，乃咸于时。","孰主张是，而枢纽之。","谷我腹我，比予于儿。","告我冠服，迨其委蛇。"],["温然仁矣，熙然春矣。","龙驾帝服，穆将临矣。","我酒清矣，我肴烝矣。","我乐备矣，我神顾矣。"],["神在途矣，习习以风。","百灵后先，敢一不恭。","奔走疠疫，祓除菑凶。","顾瞻下方，逍遥从容。"],["神兮焉居，神在震方。","仁以为宅，秉天之阳。","神之来矣，道修以阻。","望神未来，使我心苦。"],["于神何司，而德于木。","肃然顾歆，则我斯福。","我祀孔时，我心载祗。","匪我之私，神来不来。"],["惟神之安，方解羽銮。","赤旂霞曳，从以炎官。","居歆嘉荐，肸蚃灵坛。","神之格矣，民讫多盘。"],["于物司火，于方峙南。","璇霄来下，羽卫毵毵。","祠官祝釐，联佩合簪。","本支有衍，则百斯男。"],["炎精之神，飞碧落。","驾以浮云，丹书赤雀。","礼备豆笾，乐谐箫勺。","神具醉止，佑我景铄。"],["丰年穰穰，美芳职职。","笾豆方圆，其仪孔硕。","风马在御，云车载饬。","来顾来飨，维俟休德。"],["神罔小大，奠方兹土。","祭列坊庸，礼迨猫虎。","有功斯民，祀乃其所。","非稷馨香，厥福周溥。"],["魄生自西，照望太阳。","下暨诸神，贶施万方。","节适风雨，富我囷箱。","共承嘉祀，惟以迪尝。"],["玄冬肇祀，始于伊耆。","岁事聿成，庸答蕃釐。","眷言西顾，匪神司之。","归功尔神，翩其下来。"],["日昱乎昼，容光必照。","肸蚃之交，惟人所召。","有监在下，视兹升燎。","肃若其承，云骈星曜。"],["三时不害，四方顺成。","酬功报始，以我齐明。","豳颂土鼓，乐此嘉平。","降祥幅员，惠于函生。"],["惟大明尊，实首三辰。","功赫庶物，光被广轮。","岁方索飨，咸秩群神。","灵斿来下，尸此明禋。"],["玄冥凌厉，岁聿其周。","天地闭藏，农且息休。","古大蜡礼，伊耆肇修。","爰荐飶馨，以迓飙游。"],["练时吉良，聿崇明祀。","粢盛洁丰，牲硕酒旨。","肃唱和声，来燕来止。","嘉承天休，赉及含齿。"],["于赫九宫，天神之贵。","煌煌彪列，下土是莅。","幽赞高穹，阴骘万类。","肃若旧典，有严祗事。"],["载阳衍德，农祥孔昭。","赉兹元嘏，穰穰黍苗。","象舆眇冥，金奏远姚。","无阏厥灵，丹衷匪恌。"],["紫阙幽宏，惟神灵尊。","辅成泰元，赞役乃坤。","曰雨曰旸，缊豫调纷。","享荐陨光，蒙祉如屯。"],["于赫我宋，以火德王。","永永丕图，繄神之相。","神之来矣，维其时矣。","礼备乐奏，神其知矣。"],["小大率礼，不愆于仪。","展采错事，秩祀孔时。","维今之故，阅我数度。","修厥典常，神其来顾。"],["有出有藏，伏见靡常。","相我国家，鉴观四方。","视罔不正，终然允臧。","神其来格，明德馨香。"],["国主社稷，时祀有常。","肃若旧典，报本不忘。","粢盛丰洁，歌吟青黄。","尊神倏来，百物宾将。"],["谷资土养，民赖谷生。","功利之博，莫之与京。","式严祠坛，因物荐诚。","礼具乐奏，惟神顾歆。"],["是尊是奉，兹率旧章。","乐音纯绎，荐溢圆方。","情文备矣，神其迪尝。","永观锡羡，多穑穰穰。"],["功烈在民，诞受露雨。","良耜既歌，乃扬帗舞。","是奉是尊，厚礼斯举。","相其丰年，多稌多黍。"],["五祀之本，社稷有严。","芟柞伊始，夫敢不虔。","吉日惟戊，式荐豆笾。","神其来格，用介有年。"],["青阳开动，土膏脉起。","日练吉亥，为农祈祉。","典秩增峻，仪物具美。","幄光熉黄，庶几戾止。"],["灵既醉饱，礼斯彻兮。","灵亦乐康，乐斯阕兮。","云征飙举，不可尼兮。","荐福锡祉，曷有极兮。"],["俎豆纷披，金石繁会。","侑以贰尊，匪渎匪怠。","我仪既周，我心孔戒。","憺兮容与，彷佛如在。"],["八裔皆水，此一会同。","沄沄天墟，洞荡洪濛。","至哉维坎，不有斯功。","所秩伊何，黄流在中。"],["瞻彼芒芒，曰北之常。","既高既厚，乃纪乃纲。","荐鬯伊始，灵示孔将。","玄服铁驾，览此下方。"],["相予阴威，厥功浩浩。","一岁之功，何以为报。","府有圭币，我其敢私。","肃肃孔怀，于以将之。"],["寿宫煇煌，聿修时祀。","缤其临矣，吉蠲以俟。","居乎昂昂，行乎遂遂。","敬尔攸司，展采错事。"],["乃羞既彻，乃奏及阕。","无馂斯俎，式听致谒。","不蹇不蹶，不沸不决。","厉魃其祛，永庇有截。"],["自彼昆虚，于以潜流。","念兹诞润，岂侯不犹。","在昔中府，暨海聿脩。","迄既望止，神保先卣。"],["维吴崇崇，于汧之西。","瞻彼有陇，赫赫不迷。","克裨于岳，我酌俶齐。","于凡有旅，视公维跻。"],["彼林有庪，彼泽有沈。","猗与西望，弗菲弗淫。","乃追斯邸，乃㡛斯寻。","卬礼既卒，是用是歆。"],["有岌斯安，有涵斯洽。","聿相厥成，允祀是答。","爰饬乃奏，乃奏既协。","于昭降止，是遵是接。"],["天作高山，屹然中峙。","经营厥宇，万亿咸遂。","火熙土王，爰举时祀。","绳绳宣延，彷佛来止。"],["荐彻豆笾，熙事备成。","灵兮将归，羽旄纷纭。","飘其逝矣，浮空籋云。","怅然顾瞻，有抚怀心。"],["维水善下，利物曰功。","逶迤百川，谁欤朝宗。","荡荡大受，于焉会同。","膋萧列陈，以答鸿濛。"],["爰熙嘉坛，揭虔毖祀。","郁人沃盥，赞我祼事。","于降于登，以作以止。","莫不肃雍，告灵飨矣。"],["蹇兮纷纷，神实戾止。","以饮以食，以享以祀。","兮冥冥，神亦归止。","以醉以饱，以锡尔祉。"],["我祀伊何，于彼长淮。","导源桐柏，委注蓬莱。","捍齐护楚，宣威示怀。","豆笾列陈，亦孔之偕。"],["澒洞鸿濛，天与无极。","导纳江汉，节宣南北。","顺助其功，善下惟德。","我祀孔时，以介景福。"],["岩岩天齐，自古在昔。","肤寸之云，四方其泽。","惟时东作，祀事乃饬。","惠我无疆，恩沾动植。"],["司历告时，惟孟之春。","爰举时祀，旅于有神。","鼓钟既设，圭帛具陈。","阜蕃庶物，以福我民。"],["帝奠九㙻，孰匪我疆。","繄我东土，山川相望。","祀事孔时，肃雍不忘。","嶪峨濛鸿，郁哉洋洋。"],["蒇事方丘，情文孔时。","名山大泽，侑祭无遗。","牲陈黝犊，乐备咸池。","柔祇皆出，介我繁禧。"],["至哉坤元，乃顺承天。","厚德载物，含洪八埏。","日北多暑，祀仪吉蠲。","式昭毋事，敢告恭虔。"],["蒇事方丘，旧典时式。","至诚感神，馨非黍稷。","肸蚃来临，鉴兹明德。","永锡坤珍，时万时亿。"],["至哉厚德，物生是资。","直方维则，翕辟攸宜。","于昭祀典，致享坤仪。","礼罔不答，神之格思。"],["灵宇，神安且翔。","三哲鼎峙，中荐嘉觞。","凛若义气，千载弥光。","猗其祐之，锡羡无疆。"],["立孤固难，死亦匪易。","义轻一身，开先赵嗣。","肃穆庙貌，烈有馀气。","式旋嘉荐，昭哉祀事。"],["翕辟以时，协气陶蒸。","播之金石，锵厥和声。","冥冥眑眑，孔享纯诚。","是听是娭，邦基永宁。"],["坱圠无垠，磅礴罔测。","山盈川冲，自生自殖。","其报惟何，率礼靡忒。","亿万斯年，功被无极。"],["洪惟坤元，道著品物。","上配紫旻，厚载其德。","良月肇蒇，祭器布列。","必先皇祇，以迓景福。"],["芒芒下土，恢恢方仪。","富媪统摄，潜运八维。","爰称元祀，告备吉时。","揭兹虔恭，僾其格思。"],["春气肇分，万类滋荣。","惟此祀事，皆象发生。","求神以类，式昭至诚。","庶几来格，子孙绳绳。"],["猗欤禖宫，祀典所贵。","粤自艰难，礼或弗备。","以迄于今，始建坛壝。","愿戒云车，歆此诚意。"],["眷此尊祀，实惟仲春。","青圭束帛，克祀克禋。","庶蒙嘉惠，嗣续诜诜。","神之降鉴，云车来臻。"],["聿分春气，施生在时。","禖宫肇启，精意以祠。","礼仪告备，神其格思。","厥灵有赫，锡我繁釐。"],["莫重于祭，非礼不成。","笾豆有践，尔殽既馨。","神具醉止，荐以齐明。","赞彻孔时，釐事斯成。"],["蠲涤盏斝，巾帨而升。","挹彼注兹，酒醴维清。","洋洋在上，享于克诚。","神其孚佑，以厚民生。"],["于穆思文，克配上帝。","涓选休成，遵扬严卫。","祗荐明诚，肃陈量币。","享兹吉蠲，申锡来裔。"],["于穆帝临，至矣元造。","克配其仪，惟我文考。","仁恩广覃，奕叶永保。","宗祀惟初，以扬孝道。"],["钦惟合宫，承神至尊。","祗戒专精，俨然若存。","奠兹嘉觞，茝兰其芬。","发祉隤祥，以子以孙。"],["肇开九筵，维古之仿。","皇皇大神，来顾来享。","庶仪交修，百辟显相。","微诚自中，交际天壤。"],["礼协丰融，诚交彷佛。","辟公受膰，宗祀临瘗。","贻我来牟，以兴嗣岁。","山川出云，天地同气。"],["地祀泰折，歌同我将。","黝牲纯洁，丝竹发扬。","博厚而久，含洪以光。","扶持宗社，曰笃不忘。"],["耳听鋗玉，目瞻熉珠。","乐备周奏，仪参汉图。","神人并况，天地同符。","亦既见帝，王心则愉。"],["霜露既降，孝思奉先。","陟降上帝，礼隆九筵。","有馨黍稷，有肥牲牷。","神来燕娭，想像肃然。"],["休德孔昭，灵承上帝。","孝极尊亲，严配于位。","嘉荐芬芳，礼无不备。","神其格思，享兹诚至。"],["合宫盛礼，金商令时。","备成熙事，蒐扬上仪。","骏奔在庭，精意肃祗。","来享嘉荐，神灵燕娭。"],["上直房心，时惟明堂。","配天享亲，宗祀有常。","盛德在金，日吉辰良。","享我克诚，来格来康。"],["荃其止乎，禗禗其容。","奄横四海，蹇莫之穷。","时不骤得，礼焉有终。","荃其行乎，余心。"],["神哉沛矣，厥灵载扬。","扬灵如何，剡剡皇皇。","我其承之，绳绳齐庄。","往从郁人，爰侠斯芳。"],["夫物絪缊，神气挠之。","谁欤其司，维南之箕。","俶哉明庶，我祀维时。","我心孔劳，神其下来。"],["屹尔王宫，泛临翊翊。","惠此万方，岂惟五色。","以修阳政，以习地德。","云景杳冥，施祥无极。"],["拜况于郊，皇哉唐哉。","熙事休成，六騑鼎来。","天阃以决，地垠以开。","隤祉发祥，如登春台。"],["肃肃庙中，有严阶墄。","匪棘匪徐，进退可则。","冕服是仪，环佩有节。","神之鉴观，率履不越。"],["乾健为君，坤柔曰臣。","惟其臣子，克奉君亲。","永御皇极，以绥兆民。","称觞献寿，山岳嶙峋。"]]