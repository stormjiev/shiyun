[["肆眚云毕，淳熙溥将。","雷雨丽泽，云物效祥。","礼容济济，天威皇皇。","大赉四海，富寿无疆。"],["农皇既祀，礼毕躬耕。","商辂旋轸，周颂腾声。","观魏将陟，服御爰更。","舆人瞻仰，如日之明。"],["应门斯御，雉扇爰开。","人瞻日月，泽动云雷。","同风三代，均禧九垓。","欢心允洽，时咏康哉。"],["夹钟纪月，初吉在辰。","眚灾流庆，布德推仁。","采章震耀，典礼具陈。","茂昭丕贶，永庇斯民。"],["皇衢赫敞，黼坐穹崇。","华缨在列，严令发中。","王制巨丽，宝瑞丰融。","均禧绵宇，万寿无穷。"],["拜况于郊，皇哉唐哉。","熙事休成，六𬴂鼎来。","天阃以决，地垠以开。","𬯎祉发祥，如登春台。"],["鸿霈普洽，言归端门。","荡荡巍巍，旋乾转坤。","穆然宣室，储思垂恩。","于万斯年，敷锡群元。"],["帝飨于郊，荷天之休。","五福敷锡，皇明烛幽。","云行雨施，仁翔德游。","圣人多男，歌颂九州。"],["天日清晏，朝野靖安。","三灵答祉，万国腾懽。","帝命不违，王业艰难。","天子万年，永迪监观。"],["於穆元后，天临紫宸。","飞緌星拱，建羽林芬。","徽册是奉，鸿名愈新。","荷兹介祉，永永无垠。"],["圣母有子，重光类禋。","圣皇事母，感极天人。","百辟在庭，九仪具陈。","礼容之盛，万国咸宾。"],["帝率四海，承颜尽恭。","端闱肃设，群后来同。","玉佩锵鸣，衣冠有容。","英韶节步，磬管雍雍。"],["天子之德，形于四方。","尊亲立爱，化洽风扬。","圣母袆衣，明君黼裳。","因时献寿，克盛朝章。"],["盛礼煌煌，六衣有光。","千官在位，百福称觞。","坤德慈仁，邦斯淑祥。","如山之寿，佑圣无疆。"],["烨烨灵芝，生于殿闱。","照映华拱，纷敷玉蕤。","感召元和，光符圣期。","祥篇协吉，百福咸宜。"],["现彼南极，昭然瑞文。","腾光丙位，荐寿中宸。","太史骈奏，升歌有闻。","轩宫就养，亿万斯春。"],["王化无外，坤珍效灵。","旁枝内附，直干来并。","群分非一，祺祥绍登。","至诚攸感，海县斯宁。"],["肃肃临下，有威有容。","循循事上，惟信惟忠。","盛礼兴乐，示慈训恭。","君臣协吉，惟道之从。"],["湛湛零露，晞于载阳。","我有旨酒，群臣乐康。","既饮以德，亦图尔良。","永言修辅，用协天常。"],["礼均孝慈，乐合韶武。","至德光矣，鸿恩亦溥。","上下和济，华夷乐湑。","醆斝三行，盛仪斯举。"],["尧母之圣，放勋为子。","同心协谋，柔远能迩。","以德康俗，以文兴治。","斯焉象功，罔不昭济。"],["至矣坤元，道符惟圣。","就养宸极，助隆善政。","翟籥纷举，笙镛协应。","翱翔有容，表德之盛。"],["七德之舞，四朝用康。","有如姬姒，助集周邦。","威克厥爱，居安不忘。","风旋山立，济济皇皇。"],["左秉朱干，右挥玉戚。","以象武缀，以明皇德。","天子荣养，群臣述职。","四夷宾附，罔不承式。"],["长乐居尊，盛容有炜。","文王事亲，万国归美。","朝会之则，邦家之纪。","受福于天，克昭隆礼。"],["王化之始，治繇内孚。","时庸作命，玉简金书。","磬筦在庭，其纵绎如。","天临法扆，礼与诚俱。"],["晬仪临拱，丕命明敭。","鸾回宝势，鸿贯瑶光。","礼成乐备，德裕名芳。","肇基王化，永懋天祥。"],["衮衣绣裳，严威肃庄。","八音具张，簨虡龙骧。","玉简瑶章，金书煌煌。","寿千万年，与天比长。"],["煌煌凤字，玉气宛延。","天门崛岉，飞骖后先。","龙簨四合，奏鼓渊渊。","母仪天下，何千万年。"],["峨峨绣扆，旋佩以登。","如彼杲日，凌天而升。","玉色下照，亹亹绳绳。","猗欤大孝，四海其承。"],["皇帝降席，流云四开。","尧趋舜步，下蹑天阶。","恭授宝册，翠旄裴回。","明明纯孝，鸿厘大来。"],["大矣孝熙，帅民以躬。","奉承宝册，钦明两宫。","万乐具举，一人肃雍。","化繇上始，四海来同。"],["皇帝仁孝，总临万方。","褒显其亲，日严以庄。","龙衮翼翼，玉书煌煌。","传之亿世，休有烈光。"],["总裁庶政，拥佑嗣皇。","金书玉简，烂其文章。","众歌警作，筦磬将将。","保安四极，降福无疆。"],["涂山之德，渭涘之祥。","图徽宝册，玉色金相。","管弦烨煜，钟鼓喤喤。","天之所启，既寿而昌。"],["玉车临御，凤盖棽丽。","奉承宝册，弥文盛仪。","抗声极律，助我孝熙。","天之所佑，万寿无期。"],["景祚有开，符天媲昊。","诞毓圣神，是崇位号。","星拱天随，祗严册宝。","还御慈宁，增光舜道。"],["声乐备陈，礼容罔忒。","相维辟公，虔奉玉册。","皇则受之，慕形于色。","既寿且康，与天无极。"],["祖启瑶光，诞生明圣。","尊极母仪，帝庸作命。","宝章煌煌，导以笙磬。","还燕慈宁，邦家徯庆。"],["肃肃东朝，帝隆孝治。","猗欤丕称，宝册斯备。","皇扉四辟，导迎庆瑞。","德迈太任，有周卜世。"],["静顺坤仪，圣神是育。","懿铄昭陈，镂文华玉。","乐奏既备，礼仪不渎。","导迎善祥，翟车归毣。"],["孝奉天仪，信维休德。","发越徽音，礼文靡忒。","永保嘉祥，时万时亿。","归于东朝，含饴燕息。"],["肃雍长乐，克笃其庆。","河洲茂德，沙麓启圣。","是生睿哲，蚤隆丕运。","钦称鸿宝，永膺天命。"],["礼行东朝，乐奏大吕。","羽卫森陈，簪绅式序。","云幄邃严，宏典是举。","天子万年，母仪寰宇。"],["元祀介福，孰绥孰将。","归于尊亲，孝哉君王。","载镂斯牒，载琢斯章。","得名得寿，如虞如唐。"],["宗郊斯成，交举典册。","汝辅汝弼，威仪是力。","陈于广庭，迨此上日。","巍巍煌煌，乌臯在昔。"],["仪物陈矣，礼乐明矣。","天子戾止，诒尔臣矣。","陟降维则，恭且勤矣。","茫茫四海，德教形矣。"],["天门九重，荡荡开彻。","金支秀华，垂绅佩玦。","或导或陪，率履不越。","注民耳目，四表胥悦。"],["礼神颂祇，福禄来下。","不有荣名，孰缉伊嘏。","千乘万骑，鱼鱼雅雅。","皇扉洞开，鞠躬如也。"],["穆穆圣颜，安安天步。","有缛者仪，以莫不举。","天人和同，恩泽洋普。","亿载万年，为众父父。"],["大哉尧乎，南向垂裳。","君哉舜也，拜而奉觞。","缫藉光华，鼓钟铿锵。","三事稽首，宋德无疆。"],["乾元资始，坤元资生。","允也圣德，同实异名。","春王三朝，典册并行。","咨尔上公，相仪以登。"],["维册伊何，镂玉垂鸿。","维宝伊何，范金钮龙。","翊以𣊓御，间以笙镛。","谁敢不恭，天子寔从。"],["帝膺永福，功靡专有。","既尊圣父，亦燕寿母。","怡怡在宫，大典时受。","彤管纪之，天长地久。"],["敛福于郊，逢时之泰。","揭名日月，侔德复载。","自我作古，域中有大。","永言保之，眉寿无害。"],["高明者干，博厚者坤。","以清以宁，资始资生。","寿胡可度，德胡可评。","愿言从欲，诞受强名。"],["受命既长，福禄既康。","如日之升，如月之常。","追琢其章，金玉其相。","君子万年，保其家邦。"],["翠华之旗，灵鼍之鼓。","陈于广宇，相我盛举。","来汝公傅，肃乃仪矩。","毋愆于素，以笃多祜。"],["蚴蟉青龙，婉嬗象舆。","其载伊何，煌煌金书。","乃由端门，乃行康衢。","于以荣亲，振古所无。"],["惟天为大，其德曰诚。","惟尧则之，其性曰仁。","迺文迺武，得寿得名。","于万斯年，以莫不增。"],["天行惟健，天步惟安。","圣子中立，臣工四环。","民无能名，威不违颜。","宋德宜颂，汉仪可删。"],["天畀遐福，允彰父慈。","维昔旷典，我能举之。","徐尔陟降，敬尔威仪。","申锡无疆，永言保之。"],["干健坤从，阳刚阴相。","迨兹受祉，允也并况。","虡业在下，仪物在上。","咨时三公，执事无旷。"],["丕显文王，之德之纯。","亦有太姒，式扬徽音。","维册维宝，迺玉迺金。","伊谁从之，一人事亲。"],["重翟出房，袆衣被躬。","委委佗佗，河润山容。","圣皇临轩，圣母在宫。","并受鸿名，与天无穷。"],["珉玉玢豳，褭蹄精良。","既刻厥文，亦铸之章。","象德维何，至静而方。","辅我光尧，万寿无疆。"],["维天盖高，维地克承。","父尊母亲，天地难名。","疆名广大，建号安荣。","衍登寿嘏，阐绎皇明。"],["二仪同尊，两耀齐光。","巍巍煌煌，不显亦彰。","实茂号荣，玉振金相。","于万斯年，既寿且昌。"],["我尊我亲，承天之祉。","寿名兼美，家国咸喜。","公傅秉礼，宝册有炜。","惟千万祀，令闻不已。"],["羽卫有严，宝书有辉。","昭衍尊名，铺张上仪。","出其端闱，由于康逵。","比屋延瞻，歌之舞之。"],["南山之巩，皇寿无穷。","太极之尊，皇名是崇。","奉兹宝册，于皇之宫。","皇则受之，于昭盛容。"],["圣明太上，天子有尊。","玉坐高拱，慈颜睟温。","震禁嘉承，朝弁昈分。","盛礼缛典，邃古未闻。"],["天锡伊嘏，地效其珍。","诞作宝典，奉于尊亲。","尔公尔相，尔恭尔寅。","协举令仪，遹臻厥成。"],["坤载有元，干行是顺。","施生万汇，厥德弥盛。","翼翼母道，赞我皇训。","相维群公，奉典斯敬。"],["大矣母慈，德备且纯。","思古齐敬，佐我皇文。","明章茂典，金玉其音。","帝亲奉之，以翼以钦。"],["天相慈皇，庆臻壶闱。","徽柔内修，寿与天齐。","既承皇欢，载觌母仪。","懿典鸿名，永绥多祺。"],["有美英瑶，于昭祥金。","为策为章，并著徽音。","德圣而尊，备举弥文。","亿载万年，永辅尧勋。"],["帝受内禅，纪元绍熙。","钦崇慈亲，孝心肃祗。","迺建显号，迺蒇丕仪。","发册广庭，声歌侑之。"],["钟鼓交作，文物咸备。","彤庭玉阶，天子是莅。","咨尔辅臣，展采错事。","辅臣稽首，敢不率礼。"],["巍巍天宫，洞开阊阖。","旗常葳蕤，剑佩杂沓。","宝册启行，法驾继发。","铄哉盛典，快臯胥悦。"],["仰止皇居，九门载辟。","丽日重光，非烟五色。","雷动万乘，云从百辟。","咫尺重霄，鞠躬屏息。"],["玉玺瑶编，礼容毕具。","穆穆至尊，华殿是御。","德配有虞，绍唐授禹。","于万斯年，受天之祜。"],["慈皇天临，睟表怡怡。","钦哉圣子，亲奉玉巵。","鼇抃嵩呼，欢浃华夷。","迩臣捧册，是恪是祗。"],["瑟彼华玉，篆鱼钮龙。","与册并登，咨尔上公。","咏以歌诗，协之鼓钟。","是陟是降，靡有弗恭。"],["天祐皇家，庆集重闱。","宝兮扬名，册兮流徽。","金支秀华，盛容祲威。","诏我近弼，相礼不违。"],["大哉乾元，既极形容。","坤元德至，实与比隆。","宝册并登，勒崇垂鸿。","相我缛仪，肃肃雍雍。"],["涓辰协吉，时维春元。","上册三殿，旷古无前。","思齐重闱，积庆有源。","是尊是崇，帝心载虔。"],["丕赫有宋，三圣授受。","谁其助之，繄我太母。","东朝受册，饮此春酒。","圣子神孙，密侍左右。"],["坤德益崇，天寿平格。","庆流万世，子孙千亿。","刻玉范金，铺张赫奕。","惟昔姜任，则莫我匹。"],["鞠育保护，母道备矣。","密赞亲传，德其至矣。","彩服来朝，慈容有喜。","既受鸿名，又多受祉。"],["仰瞻慈闱，登进宝册。","惟时𣊓御，祗率厥职。","曰寿曰名，母兮兼得。","俪我尊父，亿载无极。"],["德厚重闱，冲澹粹穆。","何以名之，惟慈惟福。","宝镂精镠，册镌华玉。","物盛礼崇，丕昭群目。"],["于皇帝室，休运贻孙。","重熙叠庆，祗进号荣。","爰授兹册，必躬必亲。","天子圣孝，万邦仪刑。"],["煌煌册宝，天子受之。","言徐其行，肃展迺仪。","其仪维何，剑佩黄麾。","鸾驾清跸，耸瞻九逵。"],["熙辰礼备，济济雍雍。","言奉斯册，重亲之宫。","宫帷既敞，协气感通。","皇仪亲展，寿祉无穷。"],["既肃琨庭，载升金戺。","迺导迺陪，威仪济济。","天步继临，孝诚备矣。","声容孔昭，中外悦喜。"],["雕舆彩仗，祗诣慈宫。","宝册前奉，龙挟云从。","言备兹礼，于宫之中。","惟天子孝，于昭祲容。"],["懿典大册，陈仪邃深。","怡怡愉愉，宝坐是临。","重彩俨侍，罙展肃心。","三宫协庆，永播徽音。"],["宝册既奉，祗诵迺言。","仁深庆衍，益显益尊。","和声协气，充溢乾坤。","并受伊嘏，圣子神孙。"],["天拥帝家，泽流子孙。","三宫燕胥，四海崇尊。","声谐韶濩，辉烛瑶琨。","维皇缉熙，耀德乾坤。"],["祖后重寿，亲闱并崇。","骈庆联休，申景铺鸿。","叠璧交辉，多仪焕丛。","亿万斯年，福禄攸同。"],["太任媚姜，涂山翼禹。","慈祥曼衍，鸿仪迭举。","宝章奕奕，祲宫俣俣。","帝用将之，于彼宫所。"],["东朝层邃，端闱靖深。","列仗节銮，镂玉绳金。","来奉来崇，载祗载钦。","曾孙之庆，世世徽音。"],["纯佑我宋，母仪四朝。","拥翼孙谋，如虞承尧。","仁覃函夏，喜浮庆霄。","福禄万年，金玉孔昭。"],["神人和怿，天日淑清。","王母来燕，必寿而名。","琨庭璈音，五云佩声。","勉勉我皇，遹昭厥成。"],["曾孙致养，五福骈臻。","太极所运，两仪三辰。","辉光日新，启佑后人。","永翼瑶图，亿万尧春。"],["徽光宣华，仁声流文。","旷仪合沓，泰和𬘡缊。","慈颜有喜，祚我圣君。","珠宫含饴，坐阅来云。"],["缛仪既登，宝册既膺。","喜洽祥流，云烝川增。","天子万年，鸣玉慈庭。","惠我无疆，诜诜绳绳。"],["新庭靖安，祖后燕怡。","有开圣谋，累崇天基。","典章文明，声容葳蕤。","御于邦家，曰寿曰慈。"],["三礼崇容，八銮警卫。","有来辰仪，阐徽妫汭。","璇宫肃雍，藻景澄霁。","文子文孙，本支百世。"],["尧门叠瑞，姒幄齐辉。","重坤靖夷，丽册华徽。","天子仁圣，礼文弗违。","福寿康宁，同燕层闱。"],["文母曼寿，载锡之光。","总集瑞命，宜君宜王。","惠以仁显，慈以德彰。","保佑子孙，受福无疆。"],["华鸾编玉，文螭液金。","颂德摛英，扬徽嗣音。","紫幄天开，翠华日临。","岁岁年年，如周太任。"],["宋有明德，天保佑之。","以寿继寿，以慈广慈。","声文宣昭，福祉茂绥。","神孙之休，燕及华夷。"],["大安耽耽，兴庆崇崇。","维皇之尊，与天比隆。","非心闲燕，文命延鸿。","欲报之恩，礼缛仪丰。"],["上帝有赫，百灵效祥。","储祉垂恩，锡年降康。","皇仪睟温，帝躬肃庄。","三宫齐懽，地久天长。"],["夏典稽瑞，禹玉含淳。","追琢有章，温润孔纯。","圣底于安，寿绵于仁。","太上立德，自天其申。"],["父尊母亲，天涵地育。","燕我翼子，景命有仆。","得名得寿，如金如玉。","子孙千亿，成其厚福。"],["天地清宁，日月华光。","归尊慈极，嵩呼未央。","庆函百嘉，寿跻八荒。","上皇万岁，俾炽俾昌。"],["晨趋慈幄，佳气鬰葱。","受帝之祉，配天其崇。","璧华金精，礼敷乐充。","天子是若，懽声融融。"],["文物流彩，銮辂靖陈。","龟瑞荐祉，坤仪效珍。","比皇之寿，翼帝以仁。","和气致祥，与物为春。"],["黼黻其文，金玉其相。","永寿于万，合德无疆。","福绪祥源，厥后克昌。","天维格斯，祚我圣皇。"],["荣怀之庆，莫盛于斯。","三宫四册，五叶一时。","德阜而丰，福大而滋。","子子孙孙，于时保之。"],["思齐太任，嫔于周京。","至哉坤元，万物资生。","不可仪测，矧可强名。","镂玉绳金，昭哉号荣。"],["鼓钟喤喤，仪物载陈。","仪物陈矣，烂其瑶琨。","咨尔上公，相予文孙。","勿亟勿徐，奉我重亲。"],["荡荡天门，金铺玉户。","采旄翠旌，流苏葆羽。","千官影从，迺导迺辅。","都人纵观，填道呼舞。"],["煌煌宝书，玉篆金缕。","曷为来哉，自天子所。","自天子所，以燕文母。","婉嬗祥云，日正当午。"],["文物备矣，三事其承。","崇牙高张，乐充宫庭。","耽耽广殿，左墄右平。","敬尔威仪，摄齐以登。"]]