[["肇基骏命，巩右鸿业。","鼎玉龟符，垂固万叶。","灵贶具臻，神光烨烨。","晖祚无疆，规重矩叠。"],["皇帝瑞庆，长发其祥。","纂系悠远，溯源灵长。","德之克明，休烈有光。","配天作极，孝飨是将。"],["持翟成象，秉朱就列。","旄乘整溢，凤仪谐节。","挥舒皇文，歌蹈先烈。","合好效懽，福流有截。"],["光𤈶紫幄，神流玉房。","秉文侑仪，嘉虞贰觞。","震澹醉喜，仿佛迪尝。","璇源之休，地久天长。"],["灵舆蹇骧，毕觞泰筵。","贰飨允穆，祼将克竣。","垂恩储祉，锡羡永年。","将以庆成，燕及皇天。"],["若木露英，清云流霞。","蔓蔓芝秀，冯冯桂华。","绵瑞无疆，产嘏孔奢。","皇则受之，巩我帝家。"],["旨酒惟兰，勺浆惟椒。","福流瓒斝，光烛琨瑶。","拜贶清宫，凝辉庆霄。","神其如在，徘徊招摇。"],["烝哉我皇，继天毓圣。","逆厘玄都，对越灵庆。","如天斯久，如日斯盛。","瑶图濬邈，永隆骏命。"],["房铏陈列，室簋登奉。","告飨具歆，展彻惟拱。","祥光奕奕，嘉气蒙蒙。","受嘏不諐，燕天之宠。"],["云车风马，灵其来游。","天门轶荡，神其莫留。","遗庆阴阴，祉发祥流。","康我有宋，与天匹休。"],["璇庭烂景，紫殿流光。","礼洽干回，福应日昌。","圣系厖鸿，景命溥将。","德茂功成，率祀无疆。"],["厥初生民，渊濬唯祖。","芳荐既辍，明燎具举。","德馨升闻，灵贶蕃诩。","怀濡上灵，佑周之祜。"],["帝假于宫，彝承清祀。","天晖临幄，宸卫森峙。","行繇大室，旋趋紫畤。","率礼不违，式旉灵祉。"],["我享我将，罄兹精意。","陟降左右，维天与契。","斋明乃心，祗肃在位。","于万斯年，百福来备。"],["庆云鬰鬰，鸣璆琅琅。","澹其容与，申荐贰觞。","奉承若宥，神其乐康。","锡以多祉，源深流长。"],["岩岩泰山，配德于天。","奉符展采，翼翼干干。","涤濯静嘉，罔有弗蠲。","上帝顾𬤊，冷风肃然。"],["皇天上帝，阴骘下民。","道崇广覆，化洽鸿钧。","灵文诞锡，宝命惟新。","增高钦事，式奉严禋。"],["於穆圣祖，肇开鸿业。","我武惟扬，皇威有晔。","四隩混同，百灵震叠。","陟配高穹，明灵是接。"],["祗若封祀，神宗配天。","礼乐明备，奠献精虔。","景灵来格，休祥蔼然。","于昭垂庆，亿万斯年。"],["因高定位，礼修物备。","荐鬯卜牲，虔恭寅畏。","八音克谐，天神咸暨。","降福穰穰，永锡尔类。"],["浩浩元精，无臭无声。","临下有赫，得一以清。","备物致享，荐兹至诚。","泰尊奠献，夙夜齐明。"],["至哉坤元，资生伊始。","博厚称德，沈潜柔止。","降禅方位，聿修明祀。","寅恭吉蠲，永锡蕃祉。"],["坤德直方，博厚无疆。","秉阴得一，静而有常。","宝藏以发，乃育百昌。","肃祗禅祭，锡祉穰穰。"],["皇矣圣祖，丕赫神武。","秉运宅中，威加九土。","德厚功崇，颂声载路。","陟配方祗，对天之祜。"],["毖祀柔祇，报功厚载。","思文太宗，侑神严配。","钟石斯和，笾豆咸在。","永锡坤珍，资生为大。"],["茫茫坤载，粤惟太宁。","资生光大，品物流形。","瞻言汾曲，允宅神灵。","圣皇躬享，明德惟馨。"],["至诚旁达，柔祇格思。","奉以琮币，致诚在兹。"],["博硕者牲，载纯其色。","体荐登俎，聿崇坤德。"],["秉阴成德，敏树宣功。","应变审谛，神力无穷。","沈潜刚克，流谦示中。","洁兹奠献，妙物玄通。"],["坤元茂育，植物成形。","於穆圣祖，功齐三灵。","严恭配侑，厚德攸宁。","永怀锡羡，歆此惟馨。"],["报功厚载，祀事惟明。","思文烈考，道济群生。","侑神定位，协德安平。","馨洁并荐，享于克诚。"],["寅威宝命，明祀惟虔。","协神备物，罔不吉蠲。","后祇格思，灵飚肃然。","诞受景福，遐哉亿年。"],["至哉柔祇，滋生蕃锡。","涤濯静嘉，寅恭夕惕。","金奏纯如，万舞有奕。","立我烝民，莫匪尔极。"],["博厚流形，秉阴成德。","柔顺利正，直方维则。","明祇格思，素汾之侧。","祗载吉蠲，宸心翼翼。"],["至哉物祖，设象隆脽。","动静之德，翕辟攸宜。","嘉栗以荐，精祷洪厘。","茂宣阴贶，五谷蕃滋。"],["妙道非常，神变无方。","惟天辅德，灵贶诞章。","玄文昭锡，宝历弥昌。","礼崇明祀，式荐馨香。"],["运格熙盛，将封介丘。","礼神之域，瑞命殊尤。","灵文荐降，丕显皇猷。","圣心肃奉，永洽鸿休。"],["玄穹眷怀，宝符申锡。","垂露腾文，粲然灵迹。","发祥吉图，纯熙写奕。","登荐钦崇，式昭天历。"],["谓天盖高，惟皇合德。","倬彼灵章，图书是锡。","眷命谆谆，被以遐历。","膺箓告成，虔恭钦翼。"],["地届兴王，祥开图箓。","典礼昭成，祺祥交属。","大辂逶迤，卿云纷鬰。","祐我含灵，锡兹介福。"],["旻穹无声，惟德是辅。","降监锡符，垂文篆素。","孝瑞纪封，英声载路。","既寿而昌，笃天之祜。"],["日号丙丁，方号中央。","德惟其时，蠲吉是将。","夫何饮之，黄流玉瓒。","夫何食之，有陈伊馔。"],["粢盛既丰，牲牢既充。","展兹熙事，温温其恭。","惟明欣欣，燔炙芬芬。","保乎天子，繁祉荐臻。"],["工祝致辞，黄流协鬯。","爰登清歌，载期神享。","噫予诚心，精禋是虔。","嘉予陈祀，丰盈豆笾。"],["法干刚兮，铸鼎奠方。","涓嘉旦兮，齐明迎祥。","胡为持币，维箱及筥。","胡为和羹，有锜维釜。"],["我方东南，我日朱明。","爰因其时，鼎以冈名。","粢盛既馨，牲牷既盈。","佑我皇家，巽令风行。"],["黄流在中，惟馨香祀。","于荐于神，爰祗厥事。","礼从多仪，以进为文。","尊斝三献，昭示孔勤。"],["牺尊将将，徂基自堂。","牲牷肥腯，鼓钟喤喤。","肆予醴齐，椒馨𫗣香。","聿来歆顾，天祚永昌。"],["明德崇享，磬筦锵锵。","铿兮佩举，峨冠齐庄。","肆陈有序，承箱是将。","其牲伊何，笾豆大房。"],["神宫巍巍，庭燎有辉。","声谐备乐，物陈丰仪。","清酤既载，酌言献之。","惟神醉止，聿来蕃厘。"],["时运而冬，乃神玄冥。","阴阳相推，丰年以成。","越陈嘉肃，牲牢粢盛。","来享来依，监于明诚。"],["罍之初登，其仪昭陈。","罍之既祼，其香升闻。","神心嘉止，于焉欣欣。","贻我有年，穰穰其仁。"],["秉心齐明，奉牲博硕。","匏丝铿陈，冠佩俨饰。","其肆其将，明神来格。","执奠维何，猗欤币帛。"],["钟石既作，俎豆在前。","云旗飞扬，神光肃然。","当驾飚欻，来乎青圆。","言备缛礼，享兹吉蠲。"],["节彼乔岳，神明之府。","秩秩威仪，肃肃灵宇。","懿号克崇，庶物咸臯。","帝籍升名，式绥九土。"],["节彼岱宗，有严庙貌。","惟辟奉天，依神设教。","帝典焜煌，嘉荐普淖。","至灵格思，殊祥是效。"],["作镇炎夏，畜兹灵光。","敷与万物，既阜既昌。","爰刻温玉，式荐徽章。","昭嘏神意，福熙穰穰。"],["瞻言太华，奠方作镇。","典册是膺，等威以峻。","上公奉仪，祀宗荐信。","介祉万邦，永配坤顺。"],["仰止灵岳，镇于朔方。","增崇懿号，度越彝章。","祗荐嘉乐，式陈令芳。","永资纯佑，国祚蕃昌。"],["岩岩神岳，作镇中央。","肃奉徽册，尊名孔章。","聿降飚驾，载献兰觞。","熙事允洽，宝祚弥昌。"],["祗荐鸿名，寅威明祀。","有楚之仪，如在之祭。","奠献既终，礼容克备。","神鉴孔昭，福禧来暨。"],["名岳奠方，帝仪克举。","吉日惟良，九宾咸旅。","温玉镂文，𫄸裳正宁。","礼备乐成，笃神之祜。"],["盛德惟木，勾芒御神。","沂岱淮海，厥功在民。","爰熙坛坎，裒对庶神。","于以歆格，灵贻具臻。"],["绅𫖒襜兮，玉珮橤兮。","于我将事，神燕喜兮。","帝命望祀，敢有不共。","往返于位，肃肃雍雍。"],["祀以崇德，币则有仪。","肃我将事，登降孔时。","精明纯洁，罔有弗祗。","史辞无愧，神用来娭。"],["肇兹东土，含润无疆。","维时发春，嘉荐令芳。","祭用薶沈，顺性含藏。","不涸不童，诞降祺祥。"],["神之至止，熙坛为春。","神之将归，旗服振振。","欻兮回飚，窅兮旋云。","祐于东方，永施厥仁。"],["嵩嵇衡霍，暨厥海江。","时维长养，惠我南邦。","肆严牲币，神式来降。","以侑以妥，百福是庞。"],["景风应律，朱鸟开辰。","肃肃明祀，嘉笾列陈。","牲用牷物，乐奏蕤宾。","克绥永福，祐此下民。"],["鼓钟云云，龡管伊伊。","神既醉饱，曰送言归。","山有厚藏，水有灵德。","物其永依，往奠炎宅。"],["维土作德，维帝御行。","含养载育，万物以成。","有严祀典，荐我德馨。","神其歆止，永用亿宁。"],["高广融结，实维中央。","宣气报功，利彼一方。","坎坛以祀，六乐锵锵。","灵其有喜，酌以大璋。"],["言旋其处，以奠中域。","无替厥灵，四方是则。","神永不息，祀永不愆。","以享以报，于万斯年。"],["品物顺说，时司金行。","于郊迎气，以望庶灵。","雅歌维乐，圭荐惟牲。","作民之祉，永相厥成。"],["西颢沆砀，执矩司秋。","诹言协灵，时祀孔修。","礼有荐献，爰视公侯。","秩而祭之，百福是遒。"],["我乐我神，簋俎腥饔。","曰神之还，西土是宫。","于蕃禽鱼，于衍草木。","富我薮隰，滋我高陆。"],["帝德乘坎，时御闭藏。","爰洁牲醴，兆兹北方。","海山攸宅，神施无疆。","具享蠲吉，降福孔穰。"],["凄寒凝阴，陨箨涤场。","百物顺成，黍稷馨香。","款于北郊，爰因其方。","何以侑神，荐此嘉觞。"],["维山及川，奠宅幽方。","我度其灵，降止靡常。","肃肃坎坛，既迎既将。","促乐彻俎，是送是望。"],["帝奠九廛，孰匪我疆。","繄我东土，山川相望。","祀事孔时，肃雍不忘。","嶪峨蒙鸿，郁哉洋洋。"],["青阳肇开，祀事孔饬。","鬰人赞溉，其馨苾苾。","敬尔威仪，亦孔之则。","神之格思，无我有斁。"],["司历告时，惟孟之春。","爰举时祀，旅于有神。","鼓钟既设，珪帛具陈。","阜蕃庶物，以福我民。"],["岩岩天齐，自古在昔。","肤寸之云，四方其泽。","惟时东作，祀事迺饬。","惠我无疆，恩沾动植。"],["惟山有镇，雄于其方。","东孰为雄，于沂之疆。","祀事有时，爰举旧章。","我望匪遥，庶几燕飨。"],["澒洞鸿蒙，天与无极。","导纳江汉，节宣南北。","顺助其功，善下惟德。","我祀孔时，以介景福。"],["我祀伊何，于彼长淮。","导源桐柏，委注蓬莱。","扞齐护楚，宣威示怀。","豆笾列陈，亦孔之偕。"],["我祀孔肃，神其安留。","容与裴回，若止若浮。","洽此重觞，申以百羞。","无我斁遗，万邦之休。"],["蹇兮纷纷，神实戾止。","以饮以食，以享以祀。","𣅺兮冥冥，神亦归止。","以醉以饱，以锡尔祉。"],["朱明盛长，我祀用饬。","厥祀伊何，山川咸秩。","如将见之，绳绳齐栗。","神哉沛兮，消摇来格。"],["爰熙嘉坛，揭虔毖祀。","鬰人沃盥，赞我祼事。","于降于登，以作以止。","莫不肃雍，告灵飨矣。"],["我祀我享，仪物孔周。","一纯斯举，二精聿修。","璞兮其温，丝兮其紑。","是荐洁蠲，神兮安留。"],["神曰司天，居南之衡。","位焉则帝，于以奠方。","南讹秩事，望礼有常。","庶几嘉虞，介福无疆。"],["维南有山，于彼会稽。","作镇在昔，神则司之。","厥有旧典，以祀以时。","百味维旨，灵其燕娭。"],["维水善下，利物曰功。","逶迤百川，谁欤朝宗。","荡荡大受，于焉会同。","膋萧列陈，以答鸿蒙。"],["四渎之利，经营中国。","南曰大江，险兮天设。","维尔有神，隃其庙食。","望秩孔时，我心翼翼。"],["神之游兮，洋洋对越。","澹乎容与，肸蚃斯答。","乃奏既备，八音攸节。","重觞申陈，百礼以洽。"],["荐彻豆笾，熙事备成。","灵兮将归，羽旄纷纭。","飘其逝矣，浮空𥬞云。","怅然顾瞻，有抚怀心。"],["天作高山，屹然中峙。","经营厥宇，万亿咸遂。","火熙土王，爰举时祀。","绳绳宣延，仿佛来止。"],["思来感格，肃雍不忘。","礼仪既备，济济跄跄。","洁蠲致敬，往荐其芳。","交若有承，神兮孔飨。"],["练日有望，高灵来下。","何以告诚，心惟物假。","有篚斯实，有宝斯籍。","于以奠之，神光烛夜。"],["与天齐极，伊嵩之高。","显灵效异，神休孔昭。","饬我祀事，实俎鸾膋。","以侑旨酒，其馨有椒。"],["禹画九州，河内曰冀。","霍山崇崇，作镇积势。","我祀如何，百末旨味。","承神燕娭，诸神毕至。"],["礼乐既成，肃容有常。","奄留消摇，申毕重觞。","仰胪所求，降福滂洋。","师象山则，以况皇章。"],["虞至旦兮，灵亦有喜。","蹇欲骧兮，象舆已轙。","粥音送兮，灵聿归矣。","长无极兮，锡我以祉。"],["有岌斯安，有涵斯洽。","聿相厥成，允祀是答。","爰饬迺奏，迺奏既协。","于昭降止，是遵是接。"],["靡实不新，靡陈不濯。","人之弗蠲，矧敢将酌。","载晞之帨，载濡之勺。","洗仪告备，陟降时若。"],["彼林有庪，彼泽有沈。","猗与西望，弗菲弗淫。","迺追斯邸，迺㡛斯寻。","卬礼既卒，是用是歆。"],["屹削厥方，风云斯所。","阴邑有宫，侐侐俣俣。","清酤在尊，灵眷在下。","于俎献兮，则莫我吐。"],["维吴崇崇，于汧之西。","瞻彼有陇，赫赫不迷。","克裨于岳，我酌俶齐。","于凡有旅，眡公维跻。"],["奄浸坤轴，滋殖其濊。","而典斯稽，有陛有壝。","弗替时举，元斝斯酹。","胡先于河，实委之会。"],["自彼昆虚，于以潜流。","念兹诞润，岂侯不犹。","在昔中府，暨海聿修。","迄既望止，神保先卣。"],["肃肃其乂，既旨既溢。","迨其毕酌，偏兹博硕。","祀事既遂，不敢谇射。","神或醉止，我心斯怿。"],["迺羞既彻，迺奏及阕。","无馂斯俎，式听致谒。","不蹇不蹶，不沸不决。","厉魃其祛，永庇有截。"],["我土绵绵，孰匪疆理。","惟时幽都，匪曰隃只。","涤哉艮月，朔风其同。","曷阻曷深，其亦来降。"],["寿宫𪸩煌，聿修时祀。","缤其临矣，吉蠲以竢。","居乎昂昂，行乎遂遂。","敬尔攸司，展采错事。"],["相予阴威，厥功浩浩。","一岁之功，何以为报。","府有珪币，我其敢私。","肃肃孔怀，于以将之。"],["瞻彼芒芒，曰北之常。","既高既厚，迺纪迺纲。","荐鬯伊始，灵示孔将。","玄服铁驾，览此下方。"],["赫赫作镇，幽朔之垂。","兼福我民，食哉具宜。","克配彼岳，有严等衰。","蠲我灌礼，其敢不祗。"],["八裔皆水，此一会同。","沄沄天墟，洞荡洪蒙。","至哉维坎，不有斯功。","所秩伊何，黄流在中。"],["水星之精，播液发灵。","不胁于河，既介以清。","翼翼盥荐，椒糈芬馨。","载止载留，爰弭翠旌。"],["俎豆纷披，金石繁会。","侑以贰尊，匪渎匪怠。","我仪既周，我心孔戒。","憺兮容与，仿佛如在。"],["灵既醉饱，礼斯彻兮。","灵亦乐康，乐斯阕兮。","云征飚举，不可尼兮。","荐福锡祉，曷有极兮。"],["〔宫一曲〕堪舆之间，最巨惟瀛。","包干括坤，吐日滔星。","祀典载新，礼乐孔明。","鉴吾嘉頼，来燕来宁。"],["〔角一曲〕四溟广矣，八纮是纪。","我宅东南，回复万里。","洪涛飘风，安危所倚。","祀事特隆，神其戾止。"],["〔征一曲〕若稽有唐，克致崇极。","祝号既升，爰增祭式。","从享于郊，神斯受职。","我祀肇新，式祈阴骘。"],["〔羽一曲〕猗与祀礼，四海会同。","灵之来沛，鞭霆驭风。","肸蚃仿佛，在位肃雍。","佑我烝民，式徼神功。"],["灵之来至，垂庆阴阴。","灵之已坐，饬兹五音。","坛殿聿严，陟降孔钦。","灵宜安留，鉴我德心。"],["百川所归，天地之左。","澒洞鸿蒙，功高善下。","行都攸依，百禄是荷。","制币嘉玉，以侑以妥。"]]