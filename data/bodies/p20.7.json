[["祝融之位，贵乎三神。","吞纳江汉，广大无垠。","长为委输，祐我黎民。","敬陈明享，允鉴恭勤。"],["蒲昌之泽，派引天潢。","羲娥出入，浩渺微茫。","盖高斯覆，犹隔封疆。","我思六合，肇正吉昌。"],["瀚海重润，地纪亦归。","吞受百渎，限制北陲。","一视同仁，我心则怡。","嘉荐玉币，神其格思。"],["昭格灵贶，祀典肇升。","牲牷告充，雕俎是承。","荐虔效物，省德惟馨。","灵其有喜，万宇肃澄。"],["沧溟之德，东南具依。","熬波出素，国计攸资。","石臼却敌，济我王师。","神其享锡，益畀燕绥。"],["南溟浮天，旁通百蛮。","风樯迅疾，琛舶来还。","民商永頼，坐消寇奸。","荐兹嘉觞，弭矣惊澜。"],["积流疏派，被于流沙。","布润施泽，功均迩遐。","我秩祀典，四海一家。","祗荐令芳，灵其享嘉。"],["儵忽会同，裴回安留。","牲肥酒香，晨事聿修。","惟德之凉，曷奄九州。","帝命是祗，多福自求。"],["笾豆有楚，贰觞斯旅。","神其醉饱，式燕以序。","百灵秘怪，蜿蜒飞舞。","锡我祺祥，有永终古。"],["告灵飨矣，锡我嘉祚。","干端坤倪，开豁呈露。","玄云聿收，群龙咸骛。","灭除凶灾，六幕清豫。"],["〔圜钟为宫〕五纬相天，各率其职。","司礼与视，则维荧惑。","至阳之精，届我长嬴。","于以求之，祀事孔明。"],["〔黄钟为角〕有出有藏，伏见靡常。","相我国家，鉴观四方。","视罔不正，终然允臧。","神其来格，明德馨香。"],["〔太簇为征〕小大率礼，不愆于仪。","展采错事，秩祀孔时。","维今之故，阅我数度。","修厥典常，神其来顾。"],["〔姑洗为羽〕于赫我宋，以火德王。","永永丕图，繄神之相。","神之来矣，维其时矣。","礼备乐奏，神其知矣。"],["有俨其容，有洁其衷。","屹屹崇坛，伊神与通。","神肯降格，嘉神之休。","虔恭降登，神乎安留。"],["馨香接神，肸蚃恍惚。","求神以诚，荐诚以物。","有藉斯玉，有篚斯币。","是用荐陈，昭兹精意。"],["荧惑在天，惟火与合。","繄神主火，纯一不杂。","作配荧惑，祀功则然。","不腆之币，于以告虔。"],["火遵其令，无物不长。","视此牲牢，务得其养。","豢以祀神，有腯其肥。","非神之宜，其将曷归。"],["皇念有神，介我戬谷。","登时休明，有此美禄。","酌言献之，有𫗣其香。","神兮燕娭，醉此嘉觞。"],["谁其祀神，知神嗜好。","阏伯祀火，为神所劳。","睠言配食，既与火俱。","于乐旨酒，承神嘉虞。"],["神既贶施，嗜我饮食。","申以累献，以承灵亿。","神方常羊，咸毕我觞。","于再于三，于诚之将。"],["登降上下，奠璧献斝。","音送粥粥，礼无违者。","已虞至旦，神其将归。","顾我国家，遗以繁厘。"],["〔圜钟为宫〕烨烨我宋，火德所畀。","用火纪时，允惟象类。","神以类歆，诚繇类至。","有感斯通，孚我阳燧。"],["〔黄钟为角〕乐音上达，粤惟出虚。","火性炎上，亦生于无。","我镛我磬，我笙我竽。","气同声应，昭哉合符。"],["〔太簇为征〕火在六气，独处其两。","感生维君，繄辰克相。","何以验之，占兹垂象。","腾驾苍虬，歘其来飨。"],["〔姑洗为羽〕星入于戌，与火俱诎。","火出于辰，与星俱伸。","一伸一诎，孰操纵之。","利用出入，民咸用之。"],["屹彼嘉坛，赤伏始届。","掞光耀明，洋乎如在。","俛仰重离，默与精会。","随我降升，肃听环珮。"],["维莫之春，五阳发舒。","日之夕矣，三星在隅。","莫量匪币，莫嘉匪玉。","明荐孔时，神光下瞩。"],["二七储神，与天地并。","孰俪厥德，聿惟南正。","功楙陶唐，泽流亿姓。","作配严禋，贽列惟称。"],["有严在涤，陈彼牲牢。","孔硕其俎，荐此血毛。","厥初生民，饮茹则然。","以燔以炙，伊谁云先。"],["孰为大辰，维北有斗。","曾是彗星，斯名孔有。","幽荣报功，洁齐敢后。","容与嘉觞，式歆旨酒。"],["周设司爟，虽列夏官。","仍袭孔易，闿端实难。","相彼商丘，永怀初造。","不腆桂椒，匪以为报。"],["潜之伏矣，柞槱既休。","有俶其来，榆柳是求。","灵驾纷羽，尚其安留。","饮我三爵，言言油油。"],["五运惟火，寔宗众阳。","宿壮用明，千载愈光。","神保聿归，安处火房。","鬰攸不作，炎图永昌。"],["〔圜钟为宫〕赫赫皇图，炎炎火德。","侈神之赐，奄有方国。","粢盛既丰，俎豆有𫗣。","于万斯年，报祀无斁。"],["〔黄钟为角〕火星之躔，有烨其光。","表于辰位，伏于戌方。","时和岁稔，仁显用藏。","告尔万民，出纳有常。"],["〔太簇为征〕季秋之月，律中无射。","农事备收，火功告毕。","克禋克祀，有严有翼。","风马云车，尚其来格。"],["〔姑洗为羽〕明明我后，重祭钦祠。","有司肃事，式荐晨仪。","礼惟其称，物惟其时。","神之听之，福禄来为。"],["猗与明坛，右平左墄。","冕服斯皇，玉珮有节。","陟降惟寅，匪徐匪疾。","式崇大祀，礼文咸秩。"],["金行序晚，玉露晨清。","齐戒丰洁，肃恭神明。","嘉币惟量，嘉玉惟精。","于以奠之，庶几来听。"],["恭惟火正，自陶唐氏。","邑于商丘，配食辰祀。","有功在民，有德在位。","敢替典常，惟恭奉币。"],["万汇攸成，四方宁谧。","工祝致告，普存民力。","迺荐斯牲，为俎孔硕。","介以繁祉，式和民则。"],["庶功备矣，休德昭明。","天地酿和，鬰鬯斯清。","玉瓒以酌，瑶觞载盈。","周流常羊，来燕来宁。"],["广大建祀，式崇其配。","馨香在兹，清酒既载。","穆穆有晖，洋洋如在。","聿怀嘉庆，繄神之赉。"],["币玉肃陈，笙簧具举。","桂醑浮觞，琼羞溢俎。","礼有三献，式和且序。","神具醉止，庆流寰宇。"],["神灵降鉴，天地回旋。","惟馨荐矣，既醉歆焉。","诸宰斯彻，式礼莫愆。","𬯎祉降祥，天子万年。"],["百谷蕃滋，丽乎下土。","聿崇明祀，垂之千古。","育物惟茂，粒民斯普。","报本攸宜，国章咸臯。"],["於穆大祀，功利相宣。","灵坛美报，历代昭然。","介以蕃祉，祚以丰年。","土爰稼穑，允协民天。"],["制币牺齐，正辞无愧。","乐以送之，毕其精意。"],["五祀之本，百货何极。","道著开辟，惠周动植。","国崇美谷，民资力穑。","奠献惟寅，神灵来格。"],["神之来兮，降兹下土。","神之去兮，杳无处所。","坛壝肃然，瘗币彻俎。","乃粒之功，冠于万古。"],["礼崇明禋，维馨斯酒。","洁粢丰盛，杀时犉牡。","齐庄严祗，升燎于槱。","其报伊何，如山如阜。"],["〔黄钟二奏〕惟土之尊，民食资焉。","阴祀昭格，牲牢腥膻。","有功于民，告其吉蠲。","神之来享，云车翩翩。"],["〔太簇角二奏〕惟谷之神，函育无穷。","百嘉蕃殖，民依厥功。","严饬坛壝，威仪肃雍。","神之来享，祈于登丰。"],["〔姑洗征二奏〕猗欤那欤，生养斯民。","家给人足，时底熙纯。","祗严明禋，于荐苾芬。","粢盛丰洁，神乃有闻。"],["〔南吕羽二奏〕笾豆斯陈，三牲告幽。","报本之礼，答神之休。","来歆芬香，丰登于秋。","仓箱千万，治符成周。"],["崇崇广坛，严恭祀事。","威仪孔时，周旋进止。","锵若环佩，诚通于幽。","相于农植，邦其咸休。"],["于嘻阴祀，封土惟崇。","于时之吉，歆予鼓钟。","柔静化光，人頼其功。","陈兹量币，百货是隆。"],["坤元生物，功利相宣。","蠲兹祀事，美报致虔。","清酤芬如，灵坛岿然。","酌尊奠觞，神其格焉。"],["荐嘉亶时，洋洋来格。","载登兹坛，齐明维敕。","神用居歆，顺成农穑。","其崇若墉，其比如栉。"],["尊罍芬香，威仪肃雍。","灵心嘉止，洋洋交通。","神归降禧，年斯屡丰。","仓箱千万，慰予三农。"],["〔函钟为宫〕五祀之本，社稷有严。","芟柞伊始，夫敢不虔。","吉日惟戊，式荐豆笾。","神其来格，用介有年。"],["〔函钟为宫〕功烈在民，诞受露雨。","良耜既歌，乃扬帗舞。","是奉是尊，厚礼斯举。","相其丰年，多稌多黍。"],["〔太簇为角〕是尊是奉，兹率旧章。","乐音纯绎，荐溢圆方。","情文备矣，神其迪尝。","永观锡羡，多穑穰穰。"],["〔姑洗为征〕谷资土养，民頼谷生。","功利之博，莫之与京。","式严祠坛，因物荐诚。","礼具乐奏，惟神顾歆。"],["〔南吕为羽〕国主社稷，时祀有常。","肃若旧典，报本不忘。","粢盛丰洁，歌吟青黄。","尊神倏来，百物宾将。"],["祭重齐肃，神格专精。","沃洗于阼，涓洁著诚。","清明鬯矣，熙事备成。","以似以续，如坻如京。"],["神地之道，粒食有先。","岁谨祈报，礼严豆笾。","降登祼荐，罔或不虔。","以似以续，宜屡丰年。"],["土发而祭，农祥是祈。","笾豆加篚，典礼有彝。","惟兹珪币，用告肃祗。","神灵降鉴，锡我繁厘。"],["赫赫媪神，稼穑是司。","方是藉敛，报本攸宜。","嘉坛建祀，玉帛陈仪。","明灵昭格，以介蕃厘。"],["国主太祀，地道聿神。","稷司百谷，利毓惟均。","练日新吉，粢盛𫗣芬。","神燕娭矣，福此下民。"],["嘉承天和，黍稷翼翼。","默相农功，繄神之德。","俎实牺牲，旧章是式。","嗣有丰年，我庾维亿。"],["封土崇祀，有烈在民。","千载不昧，福此人群。","洗爵奠斝，有酒其芬。","神具醉止，恺乐欣欣。"],["叶气嘉生，年谷顺成。","万亿及秭，如坻如京。","奉时犉牡，告于神明。","歌此良耜，于昭德馨。"],["风雨时若，自天降康。","稼穑滋殖，自神发祥。","谷我妇子，丰年穰穰。","报本严祀，齐明允臧。"],["报本之礼，载于甲令。","灵坛昭告，神既来听。","彻彼豆笾，精诚斯罄。","实惟丰年，农夫之庆。"],["乃粒烝民，功昭万古。","国有常祀，荐献式叙。","肃肃雍雍，旧章咸举。","神保聿归，介我稷黍。"],["地载万物，民资迺功。","报本称祀，太稷攸同。","礼乐既备，讫埋愈恭。","神其降嘏，时和岁丰。"],["飘飖而来，淅沥而下。","爰张其旗，爰整其驾。","有豆有登，有兆有坛。","弭旌柅辀，降止且安。"],["盥帨于下，有盘有匜。","馈酌于上，有登有彝。","服容柔止，进退优止。","即事寅恭，神其休止。"],["育我嘉生，神惠是仰。","载致斯币，庶几用享。","鼓之舞之，式繄尔神。","锡福无疆，佑此下民。"],["栗栗坛坫，载是豆觞。","醇烈氤氲，普荐芬芳。","酌之维宜，献之维时。","民有报侑，灵用安之。"],["奠献纷纷，灵心欣欣。","超然而返，众御如云。","其施伊何，多黍多稌。","其祥伊何，不愆厥叙。"],["羽旗云车，飘飖自天。","猗欤南箕，歆嘉升烟。","牲饩粢盛，俎簋铏笾。","维神戾止，从空泠然。"],["明昭惟馨，威仪孔时。","锵锵鸣佩，钦荐牲牺。","惟恭惟祗，无愆无违。","周旋中礼，肃恭委蛇。"],["吹嘘于喁，披拂氤氲。","众窍咸作，潜运化钧。","恩大功丰，酬神维恭。","嘉赠盈箱，于物有容。"],["牺尊斯陈，清酤盈中。","芬芬苾苾，馨香交通。","明灵来思，歆我精衷。","维千万祀，品物芃芃。"],["清酤洋洋，虔恭注兹。","条鬯敷宣，神用歆之。","尊罍静嘉，金奏谐熙。","于皇肆祀，休我群黎。"],["窈冥无穷，肸蚃斯融。","来终嘉荐，归返遥空。","惟神之归，欣安导和。","惟神之泽，于彼滂沱。"],["神之无象，亦可思索。","维云阴阴，维风莫莫。","降止坛宇，来顾芳馨。","侑以鼓歌，荐此明诚。"],["佩玉璆如，黼黻襜如。","承神不懈，讫获嘉虞。","圣皇命祀，臣敢弗恭。","凡尔在位，翼翼雍雍。"],["崇崇坛阶，灵既降止。","有严执奠，承祀兹始。","明灵在天，式顾庶察。","泽润以时，永拂荒札。"],["寅恭我神，惟上之使。","俾成康年，民徯休祉。","折俎既登，𣂏酒既盈。","匪荐是专，配以明诚。"],["牲俎告彻，嘉乐休成。","卒事有严，燕虞高灵。","蕃我民人，育我稷黍。","万有千祀，承神之祜。"],["夫物𬘡缊，神气挠之。","谁欤其司，维南之箕。","俶哉明庶，我祀维时。","我心孔劳，神其下来。"],["神哉沛矣，厥灵载扬。","扬灵如何，剡剡皇皇。","我其承之，绳绳齐庄。","往从鬰人，爰侠斯芳。"],["物之流形，甚畏瘥疠。","八风平矣，嘉生以遂。","丝缕之积，有量斯币。","惟本之报，匪物之贵。"],["我求于神，无臭无声。","神之燕飨，惟时专精。","大磬在列，槱燎在庭。","侑我桂酒，娭其以听。"],["礼有三祀，仪物视帝。","神临消摇，畴敢跛倚。","重觞载申，百味孔旨。","神兮乐康，答我以祉。"],["荃其止乎，禗禗其容。","奄横四海，蹇莫之穷。","时不骤得，礼焉有终。","荃其行乎，余心𢥞𢥞。"],["众万之托，动之润之。","昭格孔时，维神之依。","泠然后先，肆我肯顾。","是耶非耶，纷其来下。"],["言言祠宫，爰考我礼。","维西有罍，维东有洗。","爰洁爰涤，载荐其醴。","神在何斯，匪远具迩。"],["霈兮隠兮，蹶其阴威。","相我有终，胡宁不知。","我币有陈，我邸斯珪。","岂维有陈，于以奠之。"],["山川出云，裔裔而缕。","载霪载蒙，其德迺溥。","自古有年，胡然莫祖。","无简我觞，无怠我俎。"],["瞻彼南山，有虺其出。","维蛰之奋，维疠之息。","眷焉顾飨，在夏之日。","觞豆匪报，皇忍忘德。"],["作解之德，形声一兮。","爰展献侑，酌则三兮。","我兴有假，云胡有私。","下土是冒，庶其远而。"],["阴旄载旋，鼓车其鞭。","问神安归，冥然而天。","皇有正命，祀事孔蠲。","其临其归，亿万斯年。"],["先农播种，九谷务滋。","灵坛致享，良耜陈仪。","吉日惟亥，运属纯熙。","乐之作矣，神其格思。"],["亲耕展祀，明灵来格。","九有骏奔，百司庇职。","献奠肃肃，登降翼翼。","祈彼丰穰，福流万国。"],["肃陈韶舞，祗荐牺牲。","乃逆黄俎，以率躬耕。"],["祀惟古典，食乃民天。","歆兹洁祀，以应祈年。"],["式陈芳荐，爰致虔诚。","神其降鉴，永福黎甿。"],["明禋绀坛，灵风肃然。","登歌已阕，神驭将旋。","道光帝籍，礼备公田。","鉴兹躬稼，永赐丰年。"],["稼政之本，民食惟天。","甫田兆岁，后稷其先。","灵坛既祀，黛耜攸虔。","乃圣能享，亿万斯年。"],["冕服在御，坛壝有仪。","陟降左右，天惟显思。"],["将躬黛耜，先陟灵坛。","嘉玉量币，乐举礼殚。","神既至止，福亦和安。","千斯积咏，万国多欢。"],["将迎景福，乃荐嘉牲。","籍于千亩，用此精诚。"],["云罍已实，玉爵有舟。","荐于灵籍，伫乃神休。"],["神既至飨，福亦来酬。","申锡纯嘏，旨酒惟柔。","思文后稷，贻我来牟。","子孙千亿，丕荷天休。"],["羽葆有奕，文武交相。","周旋合度，福禄无疆。"],["豆笾虽荐，黍稷非馨。","惠我丰岁，歆兹至诚。"],["歆我嘉荐，锡我蕃禧。","多黍多稌，如京如坻。"],["献终豆彻，礼备乐成。","祠容肃肃，风驭冥冥。","三时务本，一墢躬耕。","人祇胥悦，祉福是膺。"],["在昔神农，首兹播殖。","无有污莱，尽为稼穑。","乃粒斯民，实惟帝力。","嘉荐令芳，伫瞻来格。"],["居德之厚，厥祀攸陈。","土膏初脉，农事先春。","铿然金奏，俨若华绅。","陟降于阼，福禄惟神。"],["农为政本，食乃民天。","苾芬明祀，蔗蔉良田。","陈兹量币，望彼丰年。","茂介福祉，来钦吉蠲。"],["农祥晨正，平秩东作。","倬彼大田，庤乃钱镈。","酒醴盈尊，金璆合乐。","期兹万年，充于六幕。"],["务啬之本，恤祀惟馨。","神斯至止，降福攸宁。","崇兹稼政，合于礼经。","俎彻乐阕，邈仰回灵。"]]