[["中兴之烈，高掩商宗。","揖逊之美，放勋比隆。","字十有六，拟诸形容。","威灵在天，裕后无穷。"],["巍巍孝庙，圣德天通。","同符艺祖，克绍高宗。","有仪有册，载推载崇。","镂玉绳金，登奉祏宫。"],["文金晶荧，册玉辉润。","统绍乎尧，德全于舜。","勤崇推高，子孝孙顺。","冠德百王，万年垂训。"],["金石充庭，珩璜在列。","绘画乾坤，形容日月。","巍巍功德，显显谟烈。","垂亿万年，鸿徽昭揭。"],["于皇我后，祗戒专精。","假于有庙，祖考是承。","趋进惟肃，僾思惟诚。","神之听之，来燕来宁。"],["皇皇大宫，丕显於穆。","休德昭清，元气回复。","芝叶蔓茂，桂华冯翼。","孝孙假斯，受兹介福。"],["维皇齐精，鬷假于庙。","观盥之初，惟以洁告。","衎承祖宗，恤祀昭孝。","诚心有孚，介福斯报。"],["秬鬯既将，黄钟具奏。","肃我祖考，祗栗以俟。","于皇列圣，在帝左右。","监观于兹，云车来下。"],["有硕其牲，登于大房。","肃展以享，庶几迪尝。","匪腯是告，我民其康。","保艾尔后，垂休无疆。"],["盥至于再，洁诚愈孚。","帝用祗荐，灵咸嘉虞。","腾歌胪欢，会于轩朱。","观厥颙若，受福之符。"],["思文僖祖，基德之元。","皇武大之，受命于天。","积厚流光，不已其传。","曾孙笃之，于万斯年。"],["天命有开，维仁是依。","迺睠冀邦，于以顾之。","其顾伊何，发祥肇基。","施于孙子，虔奉孝思。"],["昭哉皇祖，源深流长。","雕戈圭瓒，休有烈光。","天祐潜德，继世其昌。","永怀积累，嘉荐令芳。"],["为民请命，皇祖赫临。","天地并贶，亿万同心。","造邦以德，介福宜深。","挹彼惟旨，真游居歆。"],["皇矣太宗，嗣服平成。","益奋神旅，再征不庭。","文武秉德，仁孝克明。","以圣传圣，对越紫清。"],["思文真宗，体道之崇。","憺威赫灵，遵制扬功。","真符鼎来，告成登封。","盛德百世，于昭无穷。"],["仁德如天，徧覆无偏。","功济九有，恩涵八埏。","齐民受康，朝野晏然。","击壤歌谣，四十二年。"],["穆穆英宗，持盈守成。","世德作求，是缵是承。","齐家睦族，偃武恢文。","于荐清酤，酌之欣欣。"],["烝哉维后，继明体神。","稽古行道，文物一新。","润色鸿业，垂裕后人。","灵斿沛然，来燕来宁。"],["明哲煌煌，照临无疆。","绍述先志，寔宣重光。","诒谋燕翼，率由旧章。","苾芬孝祀，降福穰穰。"],["于皇烈考，道化圣神。","尧聪舜孝，文恬武忻。","命子出震，遗骏上宾。","罔极之哀，有古莫伦。"],["明德惟馨，进止回复。","裼袭安恭，严若惟谷。","诚意昭融，群工袂属。","成此祲容，生乎齐肃。"],["于皇我后，祗戒专精。","躬制声诗，文思聪明。","雍容戾止，玉立端诚。","神听如在，福禄来宁。"],["八音谐律，缀兆充庭。","进旅退旅，肃恭和平。","盛荐祖宗，灵监昭升。","象功崇德，遹观厥成。"],["威神在天，享于克诚。","申以贰觞，式昭德馨。","笾豆孔嘉，乐舞具陈。","庶几是听，福禄来成。"],["疏幂三举，诚意一纯。","孰陪予祀，公族振振。","神具醉止，燕娭窈冥。","于万斯年，绥我思成。"],["夙戒告备，礼节俯成。","妥侑惟干，氛氲夜澄。","有严有翼，列圣灵承。","於穆清閟，肃肃无声。"],["维皇亲享，至再至三。","礼备乐奏，层陛森严。","粢盛芳洁，酒醴旨甘。","云车风马，从卫观瞻。"],["赫赫明明，维祖维宗。","鉴于文孙，维德之同。","日靖四方，亦同其功。","亿万斯年，以承家邦。"],["帝既临享，步武鸣鸾。","陟降规矩，颙昂周旋。","登歌一再，典礼莫愆。","神之听之，祉福绵绵。"],["熙事既成，嘉笾告彻。","洋洋来临，蔼蔼布列。","配帝其功，在天对越。","允集丛厘，万邦和悦。"],["神之来游，风马云车。","淹留仿佛，顾瞻欷歔。","神之还归，钧天帝居。","监观于下，何福不除。"],["于皇上天，钦哉成命。","集于冲人，丕承列圣。","爰熙紫坛，于庙告庆。","肸蚃潜通，休祥荐应。"],["盛德丰功，一祖六宗。","钦翼燕诒，禋享是崇。","厉意齐精，假庙惟恭。","率礼周旋，福禄来同。"],["王假有庙，四极骏奔。","鼎俎宵严，簴簨云屯。","积厚流广，德隆庆蕃。","是则是绳，保我子孙。"],["於穆清宫，奕奕孔硕。","芝茎蔓秀，桂华冯翼。","八簋登列，六瑚贲室。","皇代拥庆，启佑千亿。"],["天一以清，地一以宁。","维皇精专，承神明灵。","娥御堕津，渎祇扬溟。","盥事允严，先祖是听。"],["丹楹云深，芳勺宵奠。","乐华淳鬯，礼文炳绚。","有容有仪，载肃载见。","维时缉熙，世世以燕。"],["旅楹有闲，人神允叶。","福以德昭，飨以诚接。","六乐宣扬，百礼炜烨。","对越在天，流祚万叶。"],["〔黄钟为宫〕咸英备乐，簋席列斝。","诗歌安世，声叶皇雅。","翠旗羽盖，云车风马。","神其来兮，以燕以下。"],["〔大吕为角〕勾陈旦辟，阊阖夜分。","轸风挟月，车驷凌云。","瑞景晻霭，神光耀煴。","神其来兮，以留以忻。"],["〔太簇为征〕穆穆紫幄，璜璜清宫。","旱麓流咏，凫鹥叶工。","道闳诒燕，业绵垂鸿。","神其来兮，以康以崇。"],["〔应钟为羽〕文以谟显，武以烈承。","圣训之保，祖武之绳。","有肃孝假，式严衎烝。","神其来兮，以宜以宁。"],["簋豆荐牲，铏笾实馈。","其俎孔庶，吉蠲为饎。","惟德达馨，以忱以贵。","神既佑享，祉贶来暨。"],["精粹象天，明清鉴月。","再御兹盥，益致其洁。","齐容颙若，诚意洞彻。","百礼允洽，率礼不越。"],["天地熙泰，跻时升平。","阐符建坛，声容文明。","君臣赓载，夷夏肃清。","本支百世，持盈守成。"],["在宋四世，天子圣神。","用贤致治，约己裕民。","海内富庶，裔夷肃宾。","四十二年，尧舜之仁。"],["明明英后，仁孝俭恭。","丕显丕承，增光祖宗。","继志述事，遵制扬功。","万邦作孚，盛德形容。"],["厉精基治，大哉干刚。","信赏必罚，内修外攘。","礼乐法理，号令文章。","作新之功，度越百王。"],["于皇我宋，世有哲明。","元祐用人，遹骏有声。","绍述先志，思监于成。","受天之祜，王配于京。"],["帝抚熙运，晏粲协期。","礼明乐备，文恬武嬉。","道光授受，谋深燕诒。","骏命不易，子孙保之。"],["显显令主，辉光日新。","奉亲以孝，绥下以仁。","兢兢业业，诞保庶民。","於穆不已，之德之纯。"],["昊天有命，中兴复古。","治定功成，修文偃武。","德隆商宗，业闳汉祖。","付托得人，系尧之绪。"],["艺祖有孙，聪睿神武。","绍兴受禅，归尊于父。","行道袭爵，百度修举。","圣德曰孝，光于千古。"],["维宋洽熙，帝继于理。","万姓厚生，三辰顺轨。","对时天休，以燕翼子。","肃唱和声，神其有喜。"],["在周之庭，设业设簴。","酒醴惟醹，尔殽伊脯。","帝觞毕勺，天步旋举。","丕显丕承，念兹皇祖。"],["黼幄蝉蜎，飚斿宁燕。","尊彝献祼，瑚簋陈荐。","眎仪天旋，淳音韶变。","遹求厥宁，福禄流羡。"],["皇容肃祗，天步舒迟。","对越惟恭，敬事不遗。","陟降莅止，永言孝思。","上帝临女，日监于兹。"],["明庭承神，鞉磬柷敔。","玉梢饰歌，佾缀维旅。","既肖厥文，复象乃武。","祖德宗功，惟帝时举。"],["尊斝星陈，罍幂云舒。","来贰鸾觞，玉佩琼琚。","相予严祀，秉德有初。","对扬王休，何福不除。"],["秉德翼翼，显相肃雝。","疏幂三举，诚意益恭。","光烛黼绣，和流笙镛。","子孙众多，福禄来从。"],["庙楹邃严，夜景藻清。","文物炳彪，礼仪熙成。","帷宫载敞，珮珩有声。","帝复对越，将受厥明。"],["明明维后，诒厥孙谋。","系隆我汉，陈锡哉周。","以孝以飨，世德作求。","介以繁祉，万邦咸休。"],["玉瓒黄流，有𫗣其香。","来假来享，降福穰穰。","我应受之，汤孙之将。","有百斯男，福禄无疆。"],["圣图广大，宗祊光辉。","假于有庙，帝命不违。","僾若有慕，夙夜畏威。","嘉乐君子，福禄祁祁。"],["升馔有章，卒食攸序。","庭锵金奏，凯收铏筥。","其献惟成，其馂维旅。","礼洽庆流，皇祖之祜。"],["珠幄𤈶黄，神既燕娭。","监观于下，福禄来宜。","云车风马，神保聿归。","启佑我后，福禄来为。"],["圣有谟训，诒谋燕翼。","奉天酌祖，万世维则。","维皇孝熙，干干夕惕。","礼既式旋，惟福之锡。"],["王假有庙，对越在天。","帷宫旋御，率礼不愆。","泰畤展祠，云阳奉瑄。","齐居精明，益用告虔。"],["于皇祖宗，清庙奕奕。","威灵在天，不显惟德。","垂裕鸿延，诒谋燕翼。","孝孙格斯，受祉罔极。"],["秬鬯既将，黄钟具奏。","瞻望真游，僾若有慕。","于皇列圣，在帝左右。","云车具来，以妥以侑。"],["帝德之休，恭俭渊懿。","三十一年，谨终如始。","升祔在宫，祖功并美。","民怀有仁，何千万世。"],["于皇我后，祗戒专精。","齐肃有容，祖考是承。","造次匪懈，孝思纯诚。","神听有格，福禄来宁。"],["肃哉清宫，𤈶珠照幄。","神之来思，八音振作。","赤舄龙章，奉玉惟恪。","匪今斯今，先民时若。"],["于皇维后，观盥之初。","精意昭著，既顺既愉。","圭鬯承祀，卿士咸趋。","目视心化，四方其孚。"],["涓选休成，祖考是享。","夙夜专精，求诸惚恍。","洋洋在上，惟神之仰。","鬯矣清明，应之如响。"],["来相于庭，鸣𫓶锵锵。","奉牲而告，登彼雕房。","非牲之备，民庶是康。","神依民听，上帝斯皇。"],["何庆之长，实兆于商。","由商太戊，子孙其昌。","皇基成命，宋道用光。","诒厥孙谋，膺受四方。"],["上帝监观，维仁是依。","继世修德，皇心顾之。","其顾伊何，在彼冀方。","施于子孙，降福穰穰。"],["昭哉皇祖，骏发其祥。","雕戈圭瓒，盛烈载扬。","天锡宝符，俾炽而昌。","神圣应期，赫然垂光。"],["猗欤皇祖，下民攸归。","膺帝之命，龙翔太微。","戎车雷动，天地清夷。","峨峨奉璋，万世无违。"],["煌煌神武，再御戎轩。","时惠南土，旋定太原。","车书混同，声教布宣。","维天佑之，亿万斯年。"],["于皇真宗，体道之崇。","游心物外，应迹寰中。","四方既同，化民以躬。","清浄无为，盛德之容。"],["噫我大君，嗣世修文。","维文维武，𬤊继虞勋。","天锡丕祚，施于后昆。","于荐清酤，酌之欣欣。"],["烝哉维后，继明体神。","宪章文武，宜民宜人。","经世之道，功格于天。","子孙严祀，无穷之传。"],["明哲煌煌，照临无疆。","丕承先志，嘉靖多方。","朝廷尊荣，民庶乐康。","珍符来应，锡兹重光。"],["圣考巍巍，光绍丕基。","礼隆乐备，时维纯熙。","天仁兼覆，皇化无为。","功成弗处，心潜希夷。"],["作乐合祖，笋簴在庭。","众奏具举，肃雝和鸣。","神灵来格，庶几是听。","皦绎以终，永观厥成。"],["威神在天，来格于诚。","既载清酤，有闻无声。","相予熙事，时頼宗英。","肃肃雝雝，允协思成。"],["疏幂三举，诚意一纯。","孰陪予祀，公族振振。","明灵来娭，乐舞具陈。","奉神所佑，昭孝息民。"],["赫赫明明，德与天通。","施于孙子，福禄攸同。","日靖四方，民和年丰。","有秩斯祜，申锡无穷。"],["歆我齐明，威德如存。","牲牷是享，圭玉其温。","群公执事，亦既骏奔。","礼成告彻，咸福黎元。"],["神明既交，恍若有承。","钦翼齐庄，福禄具膺。","王业是兴，祖武是绳。","佑我亿年，以莫不增。"],["明明徽祖，抚世升平。","制礼作乐，发政施仁。","圣灵在天，德泽在民。","亿万斯年，保佑后人。"],["于皇时宋，自天保定。","高宗受之，再仆景命。","绍开中兴，翼善传圣。","何千万年，永绥厥庆。"],["礼既行矣，乐既成矣。","维祖维妣，安且宁矣。","皇举玉趾，佩锵鸣矣。","拜贶总章，于厥明矣。"],["皇矣昭考，圣灵在天。","称秩宗祀，有严恭先。","奉币以荐，见之僾然。","仁深泽厚，厥光以延。"],["假哉皇考，必世后仁。","嘉靖我邦，与物皆春。","之纯之德，克配穹旻。","余庆渊如，佑我后人。"],["閟宫翼翼，雅乐洋洋。","牲器肃设，几筵用张。","饰以明备，秩其令芳。","神兮来格，风动云翔。"],["服章观象，山龙是则。","容止跄跄，威仪翼翼。"],["恪恭奉祀，祗荐牺牲。","九成爰奏，有俎斯盈。"],["祀事孔明，庙室惟肃。","铏登笾豆，金石丝竹。","既灌既荐，允恭允穆。","奉神如在，以介景福。"],["初阳作配，内助惟贤。","柔顺中积，英徽外宣。","神宫有侐，明祀惟虔。","歆诚降祐，于万斯年。"],["猗那淑圣，象应资生。","配天作合，与日齐明。","椒宫垂范，彤史扬名。","聿修毖祀，永奉粢盛。"],["王门禀庆，帝族惟贤。","功存内治，德协静专。","流芳图史，垂范纮𫄧。","新庙有侐，祀礼昭然。"],["明明英媛，德备椒庭。","笾豆有践，黍稷匪馨。","静嘉致荐，容与昭灵。","精意以达，顾享来宁。"],["曾孙袭庆，柔祇育德。","正位居体，其仪不忒。","教被宫壶，化行邦国。","祝史正辞，垂裕无极。"],["淑德昭著，至乐和平。","登豆在列，膋香荐诚。","六变合礼，八音谐声。","穰穰景福，佑我休明。"],["为太宗后，为天下母。","诞圣继明，膺干作主。","玉振金相，兰芬桂芳。","于万斯年，永奉烝尝。"],["彝尊鬯酒，庆佑遂行。","介以纯嘏，允答明诚。"],["宗臣率礼，步玉锵锵。","吉蠲斯献，百禄是将。"],["荐献有终，礼容斯穆。","以奉嘉觞，以膺多福。"],["明禋告毕，灵辂难留。","升云杳邈，整驭优游。","诚深嘉栗，礼罄钦修。","丰融垂佑，以永洪休。"],["肃肃閟宫，顺时荐事。","鬰鬯馨香，如见于位。"],["祥标曾麓，德合方仪。","万邦展养，九御蒙慈。","孝恭祊祏，美播声诗。","淑灵顾享，申锡维祺。"],["青金玉瓒，祼将于京。","永怀罔极，夙夜齐明。"],["翊佐先朝，章明壶教。","淑顺谦勤，徽音在劭。","树风不止，劬劳匪报。","黍稷令芳，嘏兹乃告。"],["祼圭既陈，酌鬯斯醇。","音容仿佛，奠献惟寅。"],["内辅先猷，夙昭壶则。","保祐之劳，慈惠其德。","荣养有终，芳风无极。","享献閟宫，载怀凄恻。"],["閟宫奕奕，韶乐洋洋。","牲币虔布，几筵肃张。","醴泉淳美，嘉肴洁香。","俟神来格，降彼帝乡。"],["乐铿金石，俎奉牺牲。","九成斯奏，五教爰行。"],["鸾骖复整，鹤驾难留。","白云缥缈，紫府深幽。","庙虽载止，神无不游。","垂佑皇宋，以永鸿休。"],["显矣皇妣，德侔柔祇。","升祔太室，协礼之宜。","耀彼宝册，列之尊彝。","惟诚是厚，永佑庆基。"],["伣天生德，作配元符。","仪刑壶则，辅佐帝图。","登崇庙祏，勒号璠玙。","烝尝亿载，皇极之扶。"],["曰嫔于京，天作之配。","进贤审官，克勤其志。","於穆清庙，本仁祖义。","亿万斯年，神灵攸暨。"],["〔黄钟宫二奏〕閟宫有侐，堂筵屹崇。","灵徽匪遐，精诚感通。","苾芬维时，登兹明祀。","泠然云车，有来其驭。"],["〔大吕角二奏〕羽旌风翔，翠蕤飘举。","俨其音徽，登兹位处。","笙镛始奏，合止柷敔。","是享是宜，永求伊祜。"],["〔太簇征二奏〕枚枚閟宫，鼎俎肆陈。","烝畀明灵，登其嘉新。","鼓钟既戒，旨酒既醇。","攸介攸止，纯禧荐臻。"]]