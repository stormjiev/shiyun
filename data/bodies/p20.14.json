[["仰瞻慈闱，登进宝册。","惟时御，祗率厥职。","曰寿曰名，母兮兼得。","俪我尊父，亿载无极。"],["鞠育保护，母道备矣。","密赞亲传，德其至矣。","綵服来朝，慈容有喜。","既受鸿名，又多受祉。"],["寅恭我神，惟上之使。","俾成康年，民徯休祉。","折俎既登，酒既盈。","匪荐是专，配以明诚。"],["山川出云，裔裔而缕。","载霪载濛，其德乃溥。","自古有年，胡然莫祖。","无简我觞，无怠我俎。"],["霈兮隐兮，蹶其阴威。","相我有终，胡宁不知。","我币有陈，我邸斯圭。","岂维有陈，于以奠之。"],["教民稼穑，不令而行。","进退有度，琚瑀锵鸣。","言还熉幄，礼则告成。","帝命率育，明德惟馨。"],["畟畟良耜，我田既臧。","土膏其动，春日载阳。","执事有恪，于此中邦。","农夫之庆，栖亩馀粮。"],["方坛屹立，陛级而登。","玉色下照，临观耦耕。","万目咸睹，如日之升。","成规成矩，百禄是膺。"],["元辰既择，礼备乐成。","洪縻在手，祗饰专精。","三推一垡，端冕朱纮。","靡辞染屦，以示黎氓。"],["蒐讲上仪，式修毖祀。","日吉辰良，礼成乐备。","风驭云旗，聿来歆止。","嘉我馨德，介兹繁祉。"],["惟天为大，物始攸资。","恭承禋祀，以报以祈。","神不可度，日监在兹。","有馨明德，庶其格思。"],["我将我享，涓选休成。","执事有恪，惟寅惟清。","乐既六变，肃雍和鸣。","高高在上，庶几是听。"],["皇衢赫敞，黼坐穹崇。","华缨在列，严令发中。","王制钜丽，宝瑞丰融。","均禧绵宇，万寿无穷。"],["敛福于郊，逢时之泰。","揭名日月，侔德覆载。","自我作古，域中有大。","永言保之，眉寿无害。"],["维册伊何，镂玉垂鸿。","维宝伊何，范金钮龙。","翊以御，间以笙镛。","谁敢不恭，天子寔从。"],["宗郊斯成，交举典册。","汝辅汝弼，威仪是力。","陈于广庭，迨此上日。","巍巍煌煌，乌睹在昔。"],["大君有命，祀典咸脩。","荐献式叙，淑慎优柔。"],["和均玉管，政协璿衡。","四序资始，万物含生。","皇猷允洽，至德惟明。","为民祈福，克致精诚。"],["猗与祀礼，四海会同。","灵之来沛，鞭霆驭风。","肸蚃彷佛，在位肃雍。","佑我烝民，式徼神功。"],["若稽有唐，克致崇极。","祝号既升，爰增祭式。","从享于郊，神斯受职。","我祀肇新，式祈阴骘。"],["四溟广矣，八纮是纪。","我宅东南，回复万里。","洪涛飘风，安危所倚。","祀事特隆，神其戾止。"],["堪舆之间，最钜惟瀛。","包乾括坤，吐日滔星。","祀典载新，礼乐孔明。","鉴吾嘉赖，来燕来宁。"],["珉玉玢豳，袅蹄精良。","既刻厥文，亦铸之章。","象德维何，至静而方。","辅我光尧，万寿无疆。"],["丕显文王，之德之纯。","亦有太姒，式扬徽音。","维册维宝，乃玉乃金。","伊谁从之，一人事亲。"],["乾健坤从，阳刚阴相。","迨兹受祉，允也并况。","虡业在下，仪物在上。","咨时三公，执事无旷。"],["惟天为大，其德曰诚。","惟尧则之，其性曰仁。","乃文乃武，得寿得名。","于万斯年，以莫不增。"],["高明者乾，博厚者坤。","以清以宁，资始资生。","寿胡可度，德胡可评。","愿言从欲，诞受强名。"],["坤载有元，乾行是顺。","施生万汇，厥德弥盛。","翼翼母道，赞我皇训。","相维群公，奉典斯敬。"],["铺昭典礼，诞合神灵。","飨通纯孝，治感至馨。","郁香既祼，圣酒来宁。","膺兹福禄，万寿益龄。"],["于穆神宗，惟皇永命。","荐醴六尊，声歌千咏。"],["龙德而隐，源流则长。","宜乎亿祀，侑享弥昌。"],["浚发长源，粤惟始祖。","五运协图，万灵来护。"],["丕命惟皇，万物咸睹。","卜年迈周，崇功冠禹。","有烨炎精，大昌圣祚。","酌鬯祈年，永锡繁祜。"],["上公摄事，衮服斯皇。","礼容济济，佩响锵锵。","灵斿惚恍，嘉荐令芳。","神具醉止，降福穰穰。"],["维师尚父，四履分封。","灵神峻密，祀事寅恭。","萧芗祗荐，飙驭排空。","如几如式，福禄来崇。"],["农为政本，食乃民天。","苾芬明祀，蔗蓘良田。","陈兹量币，望彼丰年。","茂介福祉，来钦吉蠲。"],["祗荐有常，惟神无方。","回飙整驭，垂休降祥。"],["倬彼垂象，照临下土。","躔次运行，功德周普。","九宫既位，惟德是辅。","神之至上，皇皇斯睹。"],["于穆大祀，功利相宣。","灵坛美报，历代昭然。","介以蕃祉，祚以丰年。","土爰稼穑，允协民天。"],["百谷蕃滋，丽乎下土。","聿崇明祀，垂之千古。","育物惟茂，粒民斯普。","报本攸宜，国章咸睹。"],["式陈芳荐，爰致虔诚。","神其降鉴，永福黎氓。"],["烨烨房心，下照重屋。","我严帝亲，匪配之渎。","西颢沆砀，夕景已肃。","灵其来娭，嘉荐芳郁。"],["皇帝降席，流云四开。","尧趋舜步，下蹑天阶。","恭授宝册，翠旄裴回。","明明纯孝，鸿釐大来。"],["鼓钟云云，吹管伊伊。","神既醉饱，曰送言归。","山有厚藏，水有灵德。","物其永依，往奠炎宅。"],["神之至止，熙坛为春。","神之将归，旂服振振。","欻兮回飙，窅兮旋云。","祐于东方，永施厥仁。"],["绅韠襜兮，玉佩橤兮。","于我将事，神燕喜兮。","帝命望祀，敢有不共。","往返于位，肃肃雍雍。"],["飘飖而来，淅沥而下。","爰张其旂，爰整其驾。","有豆有登，有兆有坛。","弭旌柅辀，降止且安。"],["于穆明祀，莫如报功。","灵之利泽，惠我无穷。","斋以涤志，币以达衷。","抚宁四极，永锡登丰。"],["于穆文祖，妙道九德。","默契灵心，肇基王迹。","启佑后人，垂裕罔极。","合食昭荐，孝思维则。"],["皇基缔构，帝系灵长。","躬荐郁鬯，子孙保昌。"],["有奕明堂，万方时会。","宗子圣考，作帝之配。","乐酌虞典，礼从周志。","釐事既成，于皇来暨。"],["倬彼星象，于昭于天。","维南有极，离丙之躔。","既明且大，应圣乘乾。","诞受景福，亿万斯年。"],["帝将于郊，昭事上祀。","爰兹毕觞，复即于此。","飙游载旋，容旌沓骑。","维皇嘉承，锡祚昌炽。"],["帝临閟庭，逆釐上灵。","神羯安坐，肃若有承。","嘉觞既申，德闻惟馨。","灵光留俞，祚我亿龄。"],["地载万物，阴翕而成。","山岳河渎，皆坤之灵。","克肖其象，与阴俱凝。","视瘗于坎，思求厥成。"],["莫神乎天，阳嘘而生。","日月星辰，皆乾之精。","肆求厥类，与阳俱升。","视燎于坛，展也大成。"],["璇图天深，鼎文日辉。","庆流皇家，象炳紫微。","乾回冕旒，云焕衮衣。","何千万年，式于九围。"],["天锡多祉，皇受五福。","言瞻瑶坛，迄奉瑄玉。","昭星炳耀，元气回复。","帝仪载旋，有嘉穆穆。"],["听惟飨德，监惟棐忱。","顾諟思明，灵承思钦。","永言端莅，肃对下临。","上帝是皇，毋贰尔心。"],["崇台穹窿，高灵下堕。","庆阴彷佛，从坐嶪峨。","宵升于丘，时通权火。","维天之命，百禄是荷。"],["金石宣昭，羽旄纷纶。","洁火夕照，明水夜陈。","娭哉惟灵，娭哉惟神。","风马招摇，惟德之亲。"],["泰尊媪釐，祖功宗德。","辰躔陪营，岳渎受职。","神哉来下，神哉来格。","飨德惟馨，留虞嘉席。"],["华盖既动，紫微洞开。","星枢周旋，日车徘徊。","灵兮顾佑，灵兮沛来。","载燕载娭，式时坛垓。"],["天门荡荡，云车阴阴。","百神咸秩，三灵顾歆。","神哉来娭，神哉溥临。","飨时宋德，翼翼小心。"],["帝出于震，孝奏上仪。","燔燎膻芗，神徕燕娭。","肃若旧典，罔或不祗。","既右飨之，翕受蕃釐。"],["帝出于震，巽惟洁齐。","神明其德，乃称禋柴。","惟兹吉蠲，昭事聿怀。","重盥而祀，敷锡孔皆。"],["爰熙紫坛，天地并贶。","来燕来宁，毕陈郁鬯。","承神至尊，精意所乡。","告灵飨矣，祉福其畅。"],["牺牲既成，笾豆有楚。","摐金击石，式歌且舞。","追怀懿德，令闻令仪。","灵兮来格，是享是宜。"],["雍雍在宫，翼翼在庭。","显相休嘉，肃雍和鸣。","神嗜饮食，明德惟馨。","绥我思成，式燕以宁。"],["吉蠲惟时，礼仪既备。","奉璋峨峨，群公在位。","神之格思，永锡尔类。","展彼令德，于焉来暨。"],["笾豆大房，牺尊将将。","馨香既登，明灵迪尝。","其乐伊何，吹笙鼓簧。","灵来燕娭，降福无疆。"],["秉翟竣事，万舞摐金。","总干挥戚，节以鼓音。","礼容有炜，肸蚃来歆。","淑灵是听，雅奏愔愔。"],["于穆圣祖，肇开鸿业。","我武惟扬，皇威有晔。","四隩混同，百灵震叠。","陟配高穹，明灵是接。"],["岩岩泰山，配德于天。","奉符展采，翼翼乾乾。","涤濯静嘉，罔有弗蠲。","上帝顾諟，冷风肃然。"],["龙车既奏，凤驭载翔。","帝幄伫灵，天衢腾芳。","神来留俞，神来蹇骧。","礼鬯乐明，奏假孔将。"],["维宋肖德，钦天顾右。","于皇道祖，丕釐灵祐。","葛藟殖繁，瓜瓞孕茂。","克昌厥后，世世孝奏。"],["虹旌蜺旄，鸾旗翠盖。","星枢扶轮，月御叶卫。","灵至阴阴，灵般裔裔。","来格来飨，福流万世。"],["厥初生民，渊浚唯祖。","芳荐既辍，明燎具举。","德馨升闻，灵贶蕃诩。","怀濡上灵，佑周之祜。"],["芬枝扬烈，熉珠叶陶。","闿珍阐符，展诗舞箾。","神哉来下，神哉来翱。","肃若有承，灵心招摇。"],["帝居瑶图，璇题玉京。","日月经振，列宿上荧。","桂簋飶芬，瑚器华晶。","夤承禋祀，用戒昭明。"],["烝哉我皇，继天毓圣。","逆釐玄都，对越灵庆。","如天斯久，如日斯盛。","瑶图浚邈，永隆骏命。"],["璇庭烂景，紫殿流光。","礼洽乾回，福应日昌。","圣系厖鸿，景命溥将。","德茂功成，率祀无疆。"],["四灵晨耀，五纬夕明。","风云晏和，天地粹清。","灵兮来迎，灵兮来宁。","启我子孙，飨于纯精。"],["圣有谟训，诒谋燕翼。","奉天酌祖，万世维则。","维皇孝熙，乾乾夕惕。","礼既式旋，惟福之锡。"],["玉瓒黄流，有飶其香。","来假来享，降福穰穰。","我应受之，汤孙之将。","有百斯男，福禄无疆。"],["庙楹邃严，夜景藻清。","文物炳彪，礼仪熙成。","帷宫载敞，佩珩有声。","帝复对越，将受厥明。"],["文以谟显，武以烈承。","圣训之保，祖武之绳。","有肃孝假，式严衎烝。","神其来兮，以宜以宁。"],["穆穆紫幄，璜璜清宫。","旱麓流咏，凫鹥叶工。","道闳诒燕，业绵垂鸿。","神其来兮，以康以崇。"],["勾陈旦辟，阊阖夜分。","轸风挟月，车驷凌云。","瑞景晻霭，神光耀煴。","神其来兮，以留以忻。"],["咸英备乐，簋席列斝。","诗歌安世，声叶皇雅。","翠旗羽盖，云车风马。","神其来兮，以燕以下。"],["于穆清宫，奕奕孔硕。","芝茎蔓秀，桂华冯翼。","八簋登列，六瑚贲室。","皇代拥庆，启佑千亿。"],["嘉玉既设，量币既陈。","彷佛灵游，来顾来宁。","对越伊何，厥惟一纯。","佑我熙事，以迄于成。"],["至哉物祖，设象隆脽。","动静之德，翕辟攸宜。","嘉栗以荐，精祷洪釐。","茂宣阴贶，五谷蕃滋。"],["寅威宝命，明祀惟虔。","协神备物，罔不吉蠲。","后祇格思，灵飙肃然。","诞受景福，遐哉亿年。"],["坤元茂育，植物成形。","于穆圣祖，功齐三灵。","严恭配侑，厚德攸宁。","永怀锡羡，歆此惟馨。"],["烝哉大君，聿怀帝祖。","镕范真仪，奉尊灵宇。","至感祥开，洪辉物睹。","瞻谒尽恭，飞英率土。"],["道信于神，神灵燕娭。","酒有嘉德，物惟其时。","缓节安歌，乐奏具宜。","欣欣乐康，福禄绥之。"],["嘉承和平，秩祀为先。","乃练休辰，祝史告虔。","内心齐明，祀具吉蠲。","交际恍惚，如在后前。"],["奉先严祀，率礼大经。","时思致享，肃荐芳馨。","竭诚备物，乐奏和声。","真驭来止，熙事克成。"],["仙驭弗返，眇邈清都。","荐此嘉殽，既丰既腴。","奠享有成，鼓乐愉愉。","彻我豆笾，率礼无踰。"],["为太宗后，为天下母。","诞圣继明，膺乾作主。","玉振金相，兰芬桂芳。","于万斯年，永奉烝尝。"],["王门禀庆，帝族惟贤。","功存内治，德协静专。","流芳图史，垂范纮綖。","新庙有侐，祀礼昭然。"],["精心既达，真游允臻。","礼容斯举，福应惟醇。","将整仙驭，言还上旻。","永存嘉贶，用泰烝民。"],["雕俎在御，飙驾闻声。","真游斯降，旨酒斯盈。","大乐云阕，大礼云成。","彻彼常荐，罄此明诚。"],["明明始祖，诞启庆基。","翼翼后嗣，虔奉孝思。","精洁斯达，祉福咸宜。","于以报贶，于以受釐。"],["于昭灵贶，诞启鸿源。","功济庶汇，庆流后昆。","兰肴登俎，桂酒盈尊。","俯回飙驾，永庇云孙。"],["无体之体，强名之名。","监观万宇，统治九清。","真期保祐，瑞命昭明。","乾乾翼翼，祗答财成。"],["芳气上浃，飙驭下临。","绍承丕绪，永励精明。","氤氲成雾，葱郁垂阴。","虔恭对越，介祉攸钦。"],["巍巍真宇，奕奕殊庭。","规模太紫，炳焕丹青。","元命祗答，大猷是经。","多仪有践，丕应无形。","肆设金石，声闻杳冥。","伫回飙驭，永祐基扃。"],["五代衰替，六合携离。","封疆窃据，兵甲竞驰。","天顾黎献，涂炭可悲。","帝启灵命，浚哲应期。","皇祖丕变，金钺俄麾。","率土执贽，犷俗来仪。","瞻彼大卤，窃此馀基。","独迷文告，莫畏天威。","神宗继统，璿图有辉。","尚安蠢尔，罔怀格思。","六飞夙驾，万旅奉辞。","徯来发咏，不阵行师。","云旗先路，壶浆塞岐。","天临日照，宸虑通微。","前歌后舞，人心悦随。","要领自得，智力何施。","风移僭冒，政治淳熙。","书文混一，盛德咸宜。","干戈倒载，振振言归。","诞昭七德，永定九围。"],["鸿源浚发，睿图诞彰。","高明锡羡，累洽延祥。","巍巍艺祖，溥率宾王。","煌煌文考，区宇大康。","珍符昭显，宝历绵长。","物性茂遂，民俗阜昌。","甫田多稼，禾黍穰穰。","含生嘉育，鸟兽跄跄。","八纮统域，九服要荒。","沐浴惠泽，祗畏典常。","隔谷分壤，望斗辨方。","并袭冠带，来奉圭璋。","峨峨双阙，济济明堂。","诸侯执帛，天后当阳。","何以辨等，衮衣绣裳。","何以褒德，辂车乘黄。","声明焕赫，雅颂汪洋。","启兹丕绪，祐我无疆。","大统斯集，大乐斯扬。","俯隆宗祏，仰继穹苍。"],["威神在天，来格于诚。","既载清酤，有闻无声。","相予熙事，时赖宗英。","肃肃雍雍，允协思成。"],["作乐合祖，笋簴在庭。","众奏具举，肃雍和鸣。","神灵来格，庶几是听。","皦绎以终，永观厥成。"],["噫我大君，嗣世修文。","维文维武，諟继虞勋。","天锡丕祚，施于后昆。","于荐清酤，酌之欣欣。"],["于皇真宗，体道之崇。","游心物外，应迹寰中。","四方既同，化民以躬。","清净无为，盛德之容。"],["来相于庭，鸣鋗锵锵。","奉牲而告，登彼雕房。","非牲之备，民庶是康。","神依民听，上帝斯皇。"],["肃哉清宫，熉珠照幄。","神之来思，八音振作。","赤舄龙章，奉玉惟恪。","匪今斯今，先民时若。"],["神之来游，风马云车。","淹留彷佛，顾瞻欷歔。","神之还归，钧天帝居。","监观于下，何福不除。"],["熙事既成，嘉笾告彻。","洋洋来临，蔼蔼布列。","配帝其功，在天对越。","允集丛釐，万邦和悦。"],["夙戒告备，礼节俯成。","妥侑惟乾，氛氲夜澄。","有严有翼，列圣灵承。","于穆清閟，肃肃无声。"],["仁德如天，遍覆无偏。","功济九有，恩涵八埏。","齐民受康，朝野晏然。","击壤歌谣，四十二年。"],["天命有开，维仁是依。","乃眷冀邦，于以顾之。","其顾伊何，发祥肇基。","施于孙子，虔奉孝思。"],["皇皇大宫，丕显于穆。","休德昭清，元气回复。","芝叶蔓茂，桂华冯翼。","孝孙假斯，受兹介福。"],["雍歌既彻，熙事备成。","神夕奄虞，忽乘青冥。","灵心回眷，监我精禋。","诞降嘉祉，休德昭清。"],["五音饬奏，神既亿康。","澹其容与，荐此嘉觞。","有来显相，鋗玉锵锵。","奉承若宥，罔不斋庄。"],["瑶源诞启，玉牒肇荣。","覆育群有，监观圆清。","酒醴既洽，登荐惟诚。","无有后艰，骏惠云仍。"],["涓选休辰，有事嘉荐。","琅琅琼佩，陟降岩殿。","其陟伊何，币玉斯奠。","周旋中礼，千亿储羡。"],["丕显文母，厚德维坤。","仙驭虽邈，徽音固存。","瑟彼玉瓒，酌此郁尊。","简简穰穰，裕我后昆。"]]