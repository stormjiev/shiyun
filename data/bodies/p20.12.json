[["我有宫沼，龟龙扰之。","君子有礼，嘉宾式贵表之。"],["我有宫薮，麟凤来思。","君子有乐，嘉宾式慰勤思。"],["相彼嘉鱼，爰纵之壑。","我有旨酒，嘉宾式燕以乐。"],["相彼嘉鱼，在汉之梁。","我有旨酒，嘉宾式燕以康。"],["森森乔木，美蔓萦之。","我有旨酒，嘉宾式燕宜之。"],["喈喈黄鸟，载飞载止。","我有旨酒，嘉宾式燕且喜。"],["崇丘峨峨，动植斯属。","高既自遂，大亦自足。","和风斯扇，膏雨斯沐。","我仁如天，以亭以育。"],["崇丘巍巍，动植其依。","高大之性，各极尔宜。","王道坦坦，皇猷熙熙。","仁寿之域，烝民允跻。"],["关雎于飞，洲渚之湄。","自家刑国，乐且有仪。"],["郁郁芳兰，幽人撷之。","温温恭人，哲后求之。"],["求之无斁，寤寐所属。","罄尔一心，受天百禄。"],["郁郁芳兰，雨露滋之。","温温恭人，圭组縻之。"],["郁郁芳兰，佩服珍之。","温温恭人，福履绥之。"],["关雎跄跄，集水之央。","好求贤辅，同扬德光。"],["苹蘩芳滋，同谁掇之。","愿言贤德，靡日不思。"],["偶其贤德，辅成己职。","永配玉音，服之无斁。"],["洁其粢盛，中心匪宁。","荐于宗庙，助君德馨。"],["贤淑来思，人之表仪。","风化天下，何乐如之。"],["彼鹊成巢，尔类攸处。","之子有归，琼瑶是祖。"],["彼鹊成巢，尔类攸匹。","之子有行，锦绣是饰。"],["彼鹊成巢，尔类攸共。","之子有从，兰荪是奉。"],["伊鹊成巢，珍禽戾止。","婉彼佳人，配于君子。"],["伊鹊营巢，珍禽攸处。","内助贤侯，弼于明主。"],["伊鹊营巢，珍禽辑睦。","均养嘉雏，致于蕃育。"],["多士济济，于彼西雍。","钦肃威仪，亦有斯容。","烝然来思，自西自东。","天畀尔禄，惟王其崇。"],["明明天子，率由旧章。","思乐泮水，光于四方。","薄采其芹，用宾于王。","我有好爵，寘彼周行。"],["乐只君子，式燕又思。","服其命服，摄以威仪。","钟鼓既设，一朝醻之。","德音是茂，邦家之基。"],["圣谟洋洋，纲纪四方。","烝我髦士，观国之光。","遐不作人，而邦其昌。","以燕天子，万寿无疆。"],["我求懿德，烝然来思。","笾豆静嘉，式燕绥之。","温温其恭，莫不令仪。","追琢其章，髦士攸宜。"],["思皇多士，扬于王庭。","钟鼓乐之，肃雝和鸣。","威仪抑抑，既安且宁。","天子万寿，永观厥成。"],["思乐泮水，承流辟雍。","思皇多士，贲然来从。","雝雝济济，四方攸同。","登于天府，维王是崇。"],["钟鼓皇皇，磬筦锵锵。","登降维时，利用宾王。","髦士攸宜，邦家之光。","媚于天子，事举言扬。"],["鸣鹿呦呦，载弁俅俅。","烝然来思，旨酒思柔。","之子言迈，泮涣尔游。","于彼西雍，对扬王休。"],["首善京师，灼于四方。","烝我髦士，金玉其相。","饮酒乐曲，吹笙鼓簧。","勉戒徒御，观国之光。"],["遐不作人，天下喜乐。","何以况之，鸢飞鱼跃。","既劝之驾，献酬交错。","利用宾王，縻以好爵。"],["至哉坤仪，万汇资生。","称物平施，流谦变盈。","礼修泰折，祭极精诚。","皇皇灵睠，永奠寰瀛。"],["礼有五经，无先祭礼。","即时伸虔，惟时盥洗。","品物吉蠲，威仪济济。","锡之纯嘏，来歆恺悌。"],["无疆之德，至哉坤元。","沉潜刚克，资生实蕃。","方丘之仪，惟敬无文。","神其来思，时歆荐殷。"],["礼行方泽，文物备举。","惟皇地祇，昭格来下。","奠瘗玉帛，纯诚内著。","神保是享，陟降斯祐。"],["四阶秩仪，坛于方泽。","昭事皇祇，即阴以墌。","洁肆于祊，孔嘉且硕。","神其福之，如几如式。"],["荡荡坤德，物无不载。","柔顺利贞，含弘光大。","笾豆既陈，金石斯在。","四海永宁，福禄攸介。"],["卓彼嘉坛，奠玉方泽。","百辟祗肃，八音纯绎。","祀事承明，柔祗感格。"],["修理方丘，吉蠲是宜。","笾豆静嘉，登于有司。","芬芬馨香，来享来仪。","郊仪将终，声歌彻之。"],["因地方丘，济济多仪。","乐成八变，灵祇格思。","荐余彻豆，神贶昭垂。","亿万斯年，永祐丕基。"],["帝宅震方，在德惟木。","宣仁赋和，大生□育。","祀法有虔，皇情允肃。","神之格思，报以介福。"],["太微灵德，若首五精。","本仁与益，降气施生。","纯牲有硕，旨酒斯清。","锡兹寿嘏，既寿洽平。"],["惟帝乘离，恢台其德。","平秩南讹，百嘉允殖。","感精启运，祖我炎历。","璋币迎郊，□□翼翼。"],["惟帝乘离，司厥生殖。","感所自兴，据我炎德。","既度斯筵，乃馨斯稷。","对越居歆，介祉无极。"],["圣考能飨，宗祀熙成。","骏烈惟帝，于皇执衡。","茂育元运，降祚丕平。","载清斯酌，庸罄精诚。"],["四序均气，五色奠方。","元标枢纽，位正中央。","至诚馨洁，率土年康。","神兮降止，鼎祚绵长。"],["盛德居厚，含章有融。","惟思惟信，曰黄曰中。","礼诚荐达，福祐嘉通。","永延永阜，九谷咸丰。"],["帝乘中央，沉载函蒙。","经纬四方，物性滋丰。","金石之荐，象德以宫。","神锡嘉虞，介祉无穷。"],["玉琯均和，金风候气。","神其格思，丰粢洁币。","九谷顺成，群物茂遂。","降福无疆，德泽光被。"],["白炜方肃，合宫孔硕。","琥以象象，神惟飨德。","升配有序，虔恭无斁。","降福穰穰，永安邦国。"],["于赫路寝，肆筵有序。","粤若西颢，其神执矩。","以荐币玉，式陈簠簋。","神其格思，受天之祐。"],["水官修职，星昴居方。","执权含宝，万物伏藏。","大明昌祚，临下皇皇。","曰寒时若，神降之康。"],["今月季秋，谷日辛亥。","路寝合宫，亲修严配。","北方之神，五室来会。","馨烈是{目寽}，庬褫攸介。"],["太宇清明，宣以方色。","沛哉灵游，昭示幽则。","崇配尊亲，惟兹孝德。","神熙蕃丕，涵育四极。"],["礼经之重，祀典惟明。","命官摄事，陟降以诚。","既升庶品，亦奉二精。","锡兹福祉，迄用丕平。"],["大享合宫，于礼莫盛。","入太室祼，徧于列圣。","陟降有仪，一主乎敬。","祀事孔明，邦家之庆。"],["猗我僖祖，德潜而充。","庆之所基，日茂以崇。","施及后嗣，天命有融。","庙歌载之，播于无穷。"],["皇矣烈祖，次于僖宫。","燕贻凭厚，德远而隆。","尊昭缀穆，合食惟丰。","孝孙奠爵，福嘏来同。"],["清庙有严，观德惟祖。","裕典时修，亲尊并序。","以祼以献，礼交乐举。","灵其醉止，笃我纯祐。"],["洪绪载德，盛际讲仪。","精崇祫事，恭展孝思。","肸蚃锡羡，齐庄受厘。","猗欤馨烈，垂贶本支。"],["景炎启旦，宝系开基。","登俎如在，缩鬯有仪。","明灵昭格，孝飨肃祗。","福茨绵瓞，罄宇均禧。"],["明明圣宗，大定区宇。","永怀奉先，阙礼兹举。","惟德是馨，冀格我祖。","万嗣其昌，繄神之祐。"],["皇皇在宥，品物由庚。","文教纯被，武功告成。","流颂乐府，拥休宗祊。","帝奉祼瓒，钦哉孝诚。"],["赫赫閟宫，肇亲合食。","玉步徊翔，大姿严翼。","洗奠交举，堂除并饬。","礼宾无违，神其昭格。"],["瑟彼良玉，荐于明灵。","宸襟蠲洁，鬰鬯芬馨。","牲牢在俎，金石在庭。","莫重者祼，慈嘏来宁。"],["嘉牲在俎，广乐在庭。","其所将者，曰躬曰诚。","神兮来歆，以安以宁。","以锡寿嘏，惟皇是膺。"],["铺昭典礼，诞合神灵。","飨通纯孝，治感至馨。","鬰香既祼，圣酒来宁。","膺兹福禄，万寿益龄。"],["礼备乐成，祖考来格。","有严有翼，天子孝德。","臣工在庭，罔不祗饬。","玉爵之华，执如弗克。"],["乐统大安，舞昭盛德。","合奏允谐，孔容有翼。","秉翟言竣，总干是力。","箫勺之仁，参和万国。"],["灵其顾思，降福来萃。","天子受之，馂尔在位。","神既享矣，福既均矣。","豆斯彻矣，礼之成矣。"],["帝还于次，佩玉其徐。","帝色不渝，罔解如初。","凡百府司，各祗乃位。","敢不肃恭，以讫尔事。"],["於穆宋庙，肇允基扃。","文母来献，国祚咸宁。","永言昭格，式荐惟馨。","亦既降止，聿柄神灵。"],["九奏允谐，皇灵来暨。","备物芬馨，昭违精意。","升降有仪，群臣序位。","享于克诚，万福攸至。"],["懿彼灵龟，在宫之池。","芳莲是托，千岁奇姿。","祼将清庙，播于声诗。","神降之吉，永保寿祺。"],["洁尔牺牲，既角且骍。","玉俎奉将，式表纯精。","祖宗斯享，毖祀以成。","福禄来降，邦祚隆平。"],["太宫尔肃，烈祖巍巍。","上炳淳耀，下流德晖。","诒谋燕翼，奄宅邦畿。","子孙千亿，历数同归。"],["乃祖齐圣，绵瓞其昌。","源流濬邈，统祚悠长。","如闻肃僾，有𫗣馨香。","监观垂祐，万叶储祥。"],["奕奕清庙，巍巍帝基。","诒谋积德，累洽熏熙。","粢盛丰洁，礼容肃祗。","俯歆明荐，永锡蕃禧。"],["赤符启祚，长发其祥。","灵源自远，帝运重光。","载洁笾豆，恭荐令芳。","致成翼翼，降福穰穰。"],["英英艺祖，出震承干。","握图抚运，卜祚延年。","衣冠在庙，威灵在天。","永锡无疆，子孙保焉。"],["赫赫皇祖，万邦之君。","功崇偃革，德盛兴文。","圣谟宏达，至教氤氲。","子孙百世，祗荐苾芬。"],["巍巍新庙，穆穆真皇。","德符二圣，仁洽万方。","坠典咸秩，鸿仪用彰。","威灵如在，时思不忘。"],["苾芬既荐，溥硕咸陈。","礼备乐举，先后有伦。","以奉七室，齐洁惟寅。","皇灵斯享，福祥荐臻。"],["籥翟既备，干戚是陈。","德业昭著，用和神人。"],["牲牷腯肥，粢盛丰洁。","三献用行，万舞复列。","礼仪克成，乐奏将阕。","神保聿归，玉豆斯彻。"],["九奏合兮僾然来，百礼成兮欻尔回。","想霜驭兮望天阙，八音阕兮心悠哉。"],["湛湛露斯，其甘如饴。","清宁鉴德，和气应之。","神云播液，冰玉凝姿。","是为仁瑞，万寿维祺。"],["爰有嘉禾，含章自天。","宛城洛画，粲若奎躔。","珍符显著，灵意昭宣。","永告洪业，时万万斯年。"],["地效珍物，时维兹禾。","秀标四颖，祥掩并柯。","嘉生绝拟，善应为多。","光溢图谍，宣用登歌。"],["五辂鸣鸾，八神警跸。","天官景从，莫不祗栗。","祲威盛容，昭哉祖述。","祚我无疆，叶气充溢。"],["青坛帝籍，在国之东。","荐笾执耜，率礼和容。","鸣鸾回跸，瑞气凝空。","万方瞻仰，百顺来同。"],["重城春满，双阙云浮。","将披雉扇，载俨珠旒。","叶风应律，文德怀柔。","溥天率土，惠泽咸周。"],["恩覃春煦，令布风驰。","声名昭晰，文物葳蕤。","重森宝扇，将降端闱。","永光国典，翕受天祺。"],["飨于宗祧，维圣之孝。","骖腾素虬，还归自庙。","端闱百常，耸环七校。","万邦倾瞻，天若覆焘。"],["端闱壮丽，羽卫骁腾。","天仪毕晔，如日之升。","千官景从，万宇仰承。","辉光四充，介福其膺。"],["涣号爰发，皇敷至仁。","幽隠尽达，洪德日新。","国容肃穆，天宇晏温。","惠浃四远，富寿无垠。"],["华滋凝气，灵粹发祥。","紫盖轮囷，金跗炜煌。","阳蓼三秀，甘泉九房。","瑞图休证，君王寿昌。"],["太平之符，昭发众瑞。","爰有嘉禾，异垅合穗。","大田如云，既获既刈。","野人愉愉，不亦有岁。"],["毓粹乾坤，储休阴阳。","氤氲馥郁，纷炜煌煌。","融为和气，发为祥光。","瑞牒昭纪，万寿无疆。"],["惕厉日乾乾，潜蟠或跃渊。","伐谋参上策，受钺总中坚。","田讼归周日，民谣戴舜年。","风云自冥感，嘉会翼飞天。"],["神化妙无方，巍巍迈百王。","鹤书搜隐逸，龙陛策贤良。","拱揖朝群后，宾筵辟四方。","洪图基亿载，淳曜德弥光。"],["接圣宅神都，方来五达区。","国贤熙帝载，灵命握乾符。","至化当纯被，斯文益诞敷。","车书今混一，圣治奉三无。"],["宣榭始观兵，桓桓称鼓行。","一戎期大定，载缵议徂征。","善政从师律，神功冀武成。","勖哉勤誓众，王业自经营。"],["革辂征汾晋，隳城比燎毛。","桓桓勖军旅，将将御英豪。","神武诚无敌，天威讵可逃。","王师宣利泽，霈若沃春膏。"],["冠古耀鸿徽，深仁及隐微。","二南江汉咏，九奏凤凰飞。","设虡罗钟律，盈庭列舞衣。","文明资厚德，怡怿兆民归。"],["升晖丽天，阳德之母。","率无颇偏，兼烛下土。","恭事崇坛，礼乐具举。","顿御六龙，裴回容与。"],["簪绂若云屯，晨趋阊阖门。","侁侁罗禹会，济济奉尧樽。","周礼观明备，天仪仰睟温。","高卑陈表著，同拱帝王尊。"],["穆穆流辉，太阴之精。","盈亏靡忒，寒暑以均。","克禋克祀，揆日涓辰。","牲硕酒旨，来燕来宁。"],["溯日著明，丽天作配。","洁诚以祠，礼行肃拜。","光凝冕服，气肃环佩。","庶几昭格，祗而不懈。"],["时维秋仲，夜寂天清。","实严姊事，用答阴灵。","坛壝斯设，黍稷惟馨。","云车来下，庶歆厥诚。"],["金行告遒，玉律分秋。","礼蒇西郊，毖祀聿修。","精意潜达，永孚于休。","神之听之，爰格飙斿。"],["岩岩神岳，作镇中央。","肃奉徽册，尊名孔章。","聿降飙驾，载献兰觞。","熙事允洽，宝祚弥昌。"],["节彼乔岳，神明之府。","秩秩威仪，肃肃灵宇。","懿号克崇，庶物咸睹。","帝籍升名，式绥九土。"],["钟石既作，俎豆在前。","云旗飞扬，神光肃然。","当驾飙欻，来乎青圆。","言备缛礼，享兹吉蠲。"],["道德渊源，斯文之宗。","功名糠秕，素王之风。","硕兮斯牲，芬兮斯酒。","绥我无疆，与天为久。"],["笾豆斯陈，三牲告幽。","报本之礼，答神之休。","来歆芬香，丰登于秋。","仓箱千万，治符成周。"],["猗欤那欤，生养斯民。","家给人足，时底熙纯。","祗严明禋，于荐苾芬。","粢盛丰洁，神乃有闻。"],["惟谷之神，函育无穷。","百嘉蕃殖，民依厥功。","严饬坛壝，威仪肃雍。","神之来享，祈于登丰。"],["惟土之尊，民食资焉。","阴祀昭格，牲牢腥膻。","有功于民，告其吉蠲。","神之来享，云车翩翩。"],["交于神明，内心为贵。","外致其文，亦效精意。","嘉玉既陈，将以量币。","肃肃雍雍，惟帝之对。"],["名稽汉仪，歌参唐宗。","往于卿少，乘秋气中。","周天而行，如姊之崇。","可飞霞佩，下琉璃宫。"],["至阴之精，亏而复盈。","轮高仙桂，阶应祥蓂。","玉兔影孤，金茎露溢。","其驾星车，顾于兹夕。"],["圣王生知，阐乃儒规。","诗书文教，万世昭垂。","良日惟丁，灵承不爽。","揭此精虔，神其来飨。"],["巍巍堂堂，其道如天。","清明之象，应物而然。","时维上丁，备物荐诚。","维新礼典，乐谐中声。"]]