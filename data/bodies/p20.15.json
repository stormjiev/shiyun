[["宗祀九筵，先荐閟宫。","陟自东阶，煌煌衮龙。","于穆圣善，监兹礼容。","是享是宜，介福无穷。"],["涓选休辰，于秋之杪。","既齐既戒，爰假祖庙。","有侐仪坤，旧章是效。","享祀奚为，天子纯孝。"],["閟宫有侐，堂筵屹崇。","灵徽匪遐，精诚感通。","苾芬维时，登兹明祀。","泠然云车，有来其驭。","羽旌风翔，翠蕤飘举。","俨其音徽，登兹位处。","笙镛始奏，合止柷敔。","是享是宜，永求伊祜。","枚枚閟宫，鼎俎肆陈。","烝畀明灵，登其嘉新。","鼓钟既戒，旨酒既醇。","攸介攸止，纯禧荐臻。","旨酒嘉肴，于登于豆。","是享是宜，乐既合奏。","衎我懿德，执事温恭。","灵兮允格，有翼其从。"],["于穆高皇，功德兼隆。","称天以诔，初谥未崇。","载稽礼典，扬徽垂鸿。","涓日之良，登进庙宫。"],["假哉皇考，必世后仁。","嘉靖我邦，与物皆春。","之纯之德，克配穹旻。","馀庆渊如，佑我后人。"],["庆云郁郁，鸣璆琅琅。","澹其容与，申荐贰觞。","奉承若宥，神其乐康。","锡以多祉，源深流长。"],["神宫巍巍，庭燎有辉。","声谐备乐，物陈丰仪。","清酤既载，酌言献之。","惟神醉止，聿来蕃釐。"],["牺尊将将，徂基自堂。","牲牷肥腯，鼓钟喤喤。","肆予醴齐，椒馨飶香。","聿来歆顾，天祚永昌。"],["法乾刚兮，铸鼎奠方。","涓嘉旦兮，齐明迎祥。","胡为持币，维箱及筥。","胡为和羹，有锜维釜。"],["苾芬孝祀，荐灌肃雍。","致力于神，明信咸通。","灵之妥留，惠我庞鸿。","广被万宇，福禄攸同。"],["于昭孝治，通乎神明。","寒暑不忒，熙事备成。","牲牷孔硕，黍稷惟馨。","以享以祀，来燕来宁。"],["于穆孝思，嘉荐维时。","诚通兹格，咸来燕娭。","神之听之，申锡蕃釐。","于万斯年，永保丕基。"],["时维孟冬，霜露既零。","合食盛礼，以时以行。","孝心翼翼，惟神来宁。","肃倡斯举，神具是听。"],["内辅先猷，夙昭壶则。","保祐之劳，慈惠其德。","荣养有终，芳风无极。","享献閟宫，载怀悽恻。"],["醴盏在户，金奏在庭。","笾豆有践，黍稷非馨。","义尽蠲洁，诚通杳冥。","言旋风驷，祚我修龄。"],["邈矣道祖，冥几惚恍。","常德不离，至真无象。","引位清穹，降祥神壤。","酌醴荐诚，控飙来享。"],["钦崇至道，肃谒殊庭。","顺风而拜，明德惟馨。","飙驭来格，尊酒斯盈。","是酌是献，心通杳冥。"],["金奏以谐，飙游斯格。","灵监章明，皇心励翼。","肃奉雕俎，来升綵席。","享德有孚，凝禧无斁。"],["犹龙之圣，降生厉乡。","教流清净，道符混茫。","大君肃谒，盛仪允臧。","森罗羽卫，躬荐萧芗。","簪绂济济，钟石洋洋。","高真至止，介福诞祥。"],["赫赫英皇，总提邦纪。","浚发神功，恢张圣理。","仙驭虽遥，鸿徽不弭。","永言孝思，竭诚躬祀。"],["于穆仁庙，圣泽滂流。","华夷用乂，动植蒙休。","徽名冠古，奕世垂谋。","帝躬祼献，盛典昭修。"],["在宋五世，天子嗣昌。","躬发英断，若乾之刚。","声容沄沄，被于八荒。","垂千万年，永烈有光。"],["礼备乐成，乾健天行。","帝容有穆，佩玉锵鸣。"],["祀帝圜丘，九州献力。","礼行于郊，百神受职。","灵祗格思，享我明德。","天鉴孔章，玄祉昭锡。"],["匏尊既举，秸席未移。","有德斯顾，靡神不娭。","物情肃穆，天宇清夷。","宅中受命，永复邦基。"],["礼崇禋祀，备物荐诚。","昭格穹昊，明德惟馨。","风马云车，肸蚃居歆。","申锡无疆，赉我思成。"],["宋德惟火，神实司之。","上仪申蒇，迎方重离。","瑶币告洁，秀华金支。","啾啾神龙，来介繁禧。"],["乾亨坤庆育函生，路寝明堂致洁诚。","玉帛非馨期感格，降康亿载保登平。"],["肃肃路寝，相维明堂。","二仪鉴止，三圣侑旁。","灵期欣合，祠节齐庄。","至诚并贶，降福无疆。"],["玄鸟既至，序属春分。","朝于太阳，厥典备存。","载严大采，示民有尊。","扬光下烛，煜爚东门。"],["周祀及闇，汉制中营。","肸蚃是届，礼神以兄。","我洁斯璧，我肥斯牲。","神兮燕享，鉴观孔明。"],["郊禖之应，肇自生商。","诞膺宝命，浚发其祥。","天材蕃衍，德称君王。","本支万世，与天无疆。"],["于穆真皇，宅心道粹。","和戎偃革，焕乎文治。","操瑞拜图，封天祀地。","盛德为宗，烝尝万世。"],["圣灵在天，九关崇深。","风马云车，纷其顾临。","拥祥储休，昭答孝心。","孝孙受祉，万福是膺。"],["肃肃閟宫，顺时荐事。","郁鬯馨香，如见于位。"],["祼圭既陈，酌鬯斯醇。","音容彷佛，奠献惟寅。"],["琳宫奕奕，黼坐煌煌。","玉帛成礼，飙驭延祥。","鸿仪有则，景福无疆。","嘉应昭协，丕犹诞扬。"],["合宫之飨，报本奉先。","钦惟道祖，浚发璿源。","驾言谒款，其盥惟虔。","尚监精衷，锡祚绵绵。"],["帝假于宫，彝承清祀。","天晖临幄，宸卫森峙。","行繇大室，旋趋紫畤。","率礼不违，式敷灵祉。"],["地届兴王，祥开图箓。","典礼昭成，祺祥交属。","大辂逶迤，卿云纷郁。","祐我含灵，锡兹介福。"],["青阳肇开，祀事孔饬。","郁人赞溉，其馨苾苾。","敬尔威仪，亦孔之则。","神之格思，无我有斁。"],["五纬相天，各率其职。","司礼与视，则维荧惑。","至阳之精，届我长嬴。","于以求之，祀事孔明。"],["星入于戌，与火俱诎。","火出于辰，与星俱伸。","一伸一诎，孰操纵之。","利用出入，民咸用之。"],["夐哉圣神，成功微妙。","乃兖乃裳，以供郊庙。","百末旨酒，嘉觞自炤。","灵徕宴飨，不嚬以笑。"],["于穆我王，继序不忘。","明昭上帝，上帝是皇。","长发其祥，惠我无疆。","受命于天，既寿永昌。"],["户牖严丹扆，鹓鸾簉紫庭。","恳祈南岳寿，势拱北辰星。","得士于兹盛，基邦固以宁。","诚明一何至，金石与丹青。","簪绂若云屯，晨趋阊阖门。","侁侁罗禹会，济济奉尧樽。","周礼观明备，天仪仰睟温。","高卑陈表著，同拱帝王尊。","待漏造王庭，威仪盛莫京。","纷纶簪组列，清越佩环声。","礼饮终三爵，韶音毕九成。","永同凫藻乐，千载奉升平。"],["治定资神武，功成显睿文。","贡输庭实旅，朝会羽仪分。","偃革千年运，垂衣万乘君。","孰知尧舜力，明德自升闻。","约法皇纲正，崇文宝历昌。","遒人振木铎，农器铸干将。","瑞日含王宇，卿云蔼帝乡。","万邦成一统，鸿祚与天长。"],["宸扆威容盛，声明礼乐宣。","九州臻禹会，万国戴尧天。","贡职输琛赆，皇猷焕简编。","含和均畅茂，鸿庆结非烟。","朝会俨威仪，司常建九旗。","舞容分缀兆，文物辨威蕤。","运格桃林牧，祥开洛水龟。","帝功潜日用，化俗自登熙。","螭阶聊载笔，纪瑞轶唐虞。","丹凤仪金奏，黄龙负宝图。","群材薪棫朴，仁政煦蒲卢。","荡荡巍巍德，豚鱼信自孚。","接圣宅神都，方来五达区。","国贤熙帝载，灵命握乾符。","至化当纯被，斯文益诞敷。","车书今混一，圣治奉三无。","圣皇临大宝，八表凑才贤。","经纬文天赋，刚柔德日宣。","建邦隆柱石，造物运陶甄。","共致升平业，绵长保亿年。","神化妙无方，巍巍迈百王。","鹤书搜隐逸，龙陛策贤良。","拱揖朝群后，宾筵辟四方。","洪图基亿载，淳曜德弥光。"],["皇猷敷八表，武谊肃三边。","兰锜韬兵日，灵台偃伯年。","奉珍皆述职，削衽尽朝天。","功德超前古，音徽播管弦。","伐叛天威震，恢疆帝业多。","削平侔肃杀，涵煦极阳和。","蹈厉观周舞，风云入汉歌。","功成推大定，归马偃雕戈。"],["轩昊方同德，成康粗比肩。","素风惟普畅，皇道本无偏。","阴魄重轮满，阳精五色圆。","要荒咸率服，卓越圣功全。","圣德比陶唐，千年祚运昌。","茂功虽不宰，鸿业自无疆。","极塞成清谧，齐民益阜康。","文明同日月，遐迩仰辉光。"],["荡荡无私世，巍巍至圣君。","山河分国宝，日月耀人文。","厌浥凝甘露，轮囷吐庆云。","正声兼大雅，洋溢应南薰。","鸿范合彝伦，调元四序均。","岁功天吏正，御苑物华新。","底贡陈方物，来宾列远人。","奉常呈九奏，嘉贶动穹旻。","大君隆至化，兴运契千龄。","觐礼俄班瑞，夷賨尽实庭。","成文调露乐，奉圣拱辰星。","舞佾方更进，朝阳上楚萍。","礼乐昭王业，寰区致太平。","革车停北狩，云稼屡西成。","国有详延诏，乡闻讲诵声。","日华融五色，遐迩仰文明。","亭障戢干戈，人心浃太和。","务农登宝谷，猎俊设云罗。","仪凤书良史，祥麟载雅歌。","嘉辰资宴喜，星拱弁峨峨。","冠古耀鸿徽，深仁及隐微。","二南江汉咏，九奏凤凰飞。","设虡罗钟律，盈庭列舞衣。","文明资厚德，怡怿兆民归。"],["革辂征汾晋，隳城比燎毛。","桓桓勖军旅，将将御英豪。","神武诚无敌，天威讵可逃。","王师宣利泽，霈若沃春膏。","振万方明德，疾徐咸可观。","铿锵动金奏，蹈厉总朱干。","夹进昭威武，申严警宴安。","守方推猛士，当用鹖为冠。"],["于穆宋庙，肇允基扃。","文母来献，国祚咸宁。","永言昭格，式荐惟馨。","亦既降止，聿柄神灵。","九奏允谐，皇灵来暨。","备物芬馨，昭违精意。","升降有仪，群臣序位。","享于克诚，万福攸至。","懿彼灵龟，在宫之池。","芳莲是托，千岁奇姿。","祼将清庙，播于声诗。","神降之吉，永保寿祺。","洁尔牺牲，既角且骍。","玉俎奉将，式表纯精。","祖宗斯享，毖祀以成。","福禄来降，邦祚隆平。","太宫尔肃，烈祖巍巍。","上炳淳耀，下流德晖。","诒谋燕翼，奄宅邦畿。","子孙千亿，历数同归。","乃祖齐圣，绵瓞其昌。","源流浚邈，统祚悠长。","如闻肃僾，有飶馨香。","监观垂祐，万叶储祥。","奕奕清庙，巍巍帝基。","诒谋积德，累洽熏熙。","粢盛丰洁，礼容肃祗。","俯歆明荐，永锡蕃禧。","赤符启祚，长发其祥。","灵源自远，帝运重光。","载洁笾豆，恭荐令芳。","致成翼翼，降福穰穰。","英英艺祖，出震承乾。","握图抚运，卜祚延年。","衣冠在庙，威灵在天。","永锡无疆，子孙保焉。","赫赫皇祖，万邦之君。","功崇偃革，德盛兴文。","圣谟宏达，至教氤氲。","子孙百世，祗荐苾芬。","巍巍新庙，穆穆真皇。","德符二圣，仁洽万方。","坠典咸秩，鸿仪用彰。","威灵如在，时思不忘。","苾芬既荐，溥硕咸陈。","礼备乐举，先后有伦。","以奉七室，齐洁惟寅。","皇灵斯享，福祥荐臻。","籥翟既备，干戚是陈。","德业昭著，用和神人。","牲牷腯肥，粢盛丰洁。","三献用行，万舞复列。","礼仪克成，乐奏将阕。","神保聿归，玉豆斯彻。"],["高烟升太一，明祀达乾坤。","天仗回峣阙，皇舆入应门。","簪裳如雾集，车骑若云屯。","兆庶皆翘首，巍巍万乘尊。","禋祀毕圆丘，嘉辰庆泽流。","天仪临观魏，盛礼蔼风猷。","洋溢欢声动，氛氲瑞气浮。","上穹垂眷佑，邦国拥鸿休。"],["于穆文祖，妙道九德。","默契灵心，肇基王迹。","启佑后人，垂裕罔极。","合食昭荐，孝思维则。","于皇顺祖，积德累祥。","发源深厚，不耀其光。","基天明命，厥后克昌。","是孝是享，申锡无疆。"],["蒐讲上仪，式修毖祀。","日吉辰良，礼成乐备。","风驭云旗，聿来歆止。","嘉我馨德，介兹繁祉。","我将我享，涓选休成。","执事有恪，惟寅惟清。","乐既六变，肃雍和鸣。","高高在上，庶几是听。","礼崇禋祀，备物荐诚。","昭格穹昊，明德惟馨。","风马云车，肸蚃居歆。","申锡无疆，赉我思成。","惟天为大，物始攸资。","恭承禋祀，以报以祈。","神不可度，日监在兹。","有馨明德，庶其格思。"],["天门荡荡，云车阴阴。","百神咸秩，三灵顾歆。","神哉来娭，神哉溥临。","飨时宋德，翼翼小心。","华盖既动，紫微洞开。","星枢周旋，日车徘徊。","灵兮顾佑，灵兮沛来。","载燕载娭，式时坛垓。","泰尊媪釐，祖功宗德。","辰躔陪营，岳渎受职。","神哉来下，神哉来格。","飨德惟馨，留虞嘉席。","金石宣昭，羽旄纷纶。","洁火夕照，明水夜陈。","娭哉惟灵，娭哉惟神。","风马招摇，惟德之亲。"],["于神何司，而德于木。","肃然顾歆，则我斯福。","我祀孔时，我心载祗。","匪我之私，神来不来。","神兮焉居，神在震方。","仁以为宅，秉天之阳。","神之来矣，道修以阻。","望神未来，使我心苦。","神在途矣，习习以风。","百灵后先，敢一不恭。","奔走疠疫，祓除菑凶。","顾瞻下方，逍遥从容。","温然仁矣，熙然春矣。","龙驾帝服，穆将临矣。","我酒清矣，我肴烝矣。","我乐备矣，我神顾矣。"],["离明御正，德协于火。","有感其生，维帝是何。","帝图炎炎，贻福锡我。","鉴于妥虔，高灵下堕。","赤精之君，位于朱明。","茂育万物，假然长嬴。","我洁我盛，我蠲我诚。","神其下来，云车是承。","八卦相荡，一气散施。","隆炽恢台，职神尸之。","肃肃飙御，神戾于天。","于昭神休，天子万年。","烨烨其光，炳炳其灵。","窅其如容，歘其如声。","扇以景风，导以朱斿。","我德匪类，神其安留。"],["维帝奠位，乃咸于时。","孰主张是，而枢纽之。","谷我腹我，比予于儿。","告我冠服，迨其委蛇。","荪无不在，日与我居。","孰不可来，肸蚃斯须。","象服龙驾，渊渊鼓桴。","荪不汝多，多汝意孚。","乐哉帝居，逝留无常。","尔信我宅，尔中我乡。","乃眷兹土，于赫君王。","翩然下来，去未遽央。","澹兮抚琴，啾兮吹笙。","神之未来，肃穆以听。","缤纷羽旄，姣服在中。","神既来止，亦无惰容。"],["白藏启序，庶汇向成。","有严禋祀，用答幽灵。","风马云车，来燕来宁。","洋洋在上，休福是承。","素精肇节，金行固藏。","气冲炎伏，明河翻霜。","功收有年，礼荐有章。","祇越眇冥，鸿基永昌。","昊天之气，揫敛万汇。","涓日洁齐，有严厥祀。","有牲维肥，有酒维旨。","神之燕娭，锡兹福祉。","执矩斯兑，实惟素灵。","受职储休，万宝以成。","飨于西郊，奠玉陈牲。","侑以雅乐，来歆克诚。"],["吉日壬癸，律中应钟。","国有故常，北郊迎冬。","乃蒇祀事，必祗必恭。","明默虽异，感而遂通。","良月盈数，四气推迁。","帝于是时，典司其权。","高灵下堕，降祉幅员。","神之听之，祀事罔愆。","北方之神，执权司冬。","三时务农，于焉告功。","礼备乐作，归功于神。","风马来游，永锡斯民。","天地闭塞，盛德在水。","黑精之君，降福羡祉。","洋洋在上，若或见之。","齐庄承祀，其敢斁思。"],["炎精之神，飞碧落。","驾以浮云，丹书赤雀。","礼备豆笾，乐谐箫勺。","神具醉止，佑我景铄。","宋德惟火，神实司之。","上仪申蒇，迎方重离。","瑶币告洁，秀华金支。","啾啾神龙，来介繁禧。","于物司火，于方峙南。","璇霄来下，羽卫毵毵。","祠官祝釐，联佩合簪。","本支有衍，则百斯男。","惟神之安，方解羽銮。","赤旂霞曳，从以炎官。","居歆嘉荐，肸蚃灵坛。","神之格矣，民讫多盘。"],["交于神明，内心为贵。","外致其文，亦效精意。","嘉玉既陈，将以量币。","肃肃雍雍，惟帝之对。","有邦事神，享帝为尊。","内心致德，外示弥文。","嘉玉效珍，荐以量币。","恭钦伊何，惟以宗祀。"],["上直房心，时惟明堂。","配天享亲，宗祀有常。","盛德在金，日吉辰良。","享我克诚，来格来康。","合宫盛礼，金商令时。","备成熙事，蒐扬上仪。","骏奔在庭，精意肃祗。","来享嘉荐，神灵燕娭。","休德孔昭，灵承上帝。","孝极尊亲，严配于位。","嘉荐芬芳，礼无不备。","神其格思，享兹诚至。","霜露既降，孝思奉先。","陟降上帝，礼隆九筵。","有馨黍稷，有肥牲牷。","神来燕娭，想像肃然。"],["至哉厚德，物生是资。","直方维则，翕辟攸宜。","于昭祀典，致享坤仪。","礼罔不答，神之格思。","蒇事方丘，旧典时式。","至诚感神，馨非黍稷。","肸蚃来临，鉴兹明德。","永锡坤珍，时万时亿。","至哉坤元，乃顺承天。","厚德载物，含洪八埏。","日北多暑，祀仪吉蠲。","式昭毋事，敢告恭虔。","蒇事方丘，情文孔时。","名山大泽，侑祭无遗。","牲陈黝犊，乐备咸池。","柔祇皆出，介我繁禧。"],["芒芒下土，恢恢方仪。","富媪统摄，潜运八维。","爰称元祀，告备吉时。","揭兹虔恭，僾其格思。","洪惟坤元，道著品物。","上配紫旻，厚载其德。","良月肇蒇，祭器布列。","必先皇祇，以迓景福。","坱圠无垠，磅礴罔测。","山盈川冲，自生自殖。","其报惟何，率礼靡忒。","亿万斯年，功被无极。","翕辟以时，协气陶蒸。","播之金石，锵厥和声。","冥冥眑眑，孔享纯诚。","是听是娭，邦基永宁。"],["玄鸟既至，序属春分。","朝于太阳，厥典备存。","载严大采，示民有尊。","扬光下烛，煜爚东门。","升晖丽天，阳德之母。","率无颇偏，兼烛下土。","恭事崇坛，礼乐具举。","顿御六龙，裴回容与。","周祀及闇，汉制中营。","肸蚃是届，礼神以兄。","我洁斯璧，我肥斯牲。","神兮燕享，鉴观孔明。","屹尔王宫，泛临翊翊。","惠此万方，岂惟五色。","以修阳政，以习地德。","云景杳冥，施祥无极。"],["金行告遒，玉律分秋。","礼蒇西郊，毖祀聿修。","精意潜达，永孚于休。","神之听之，爰格飙斿。","时维秋仲，夜寂天清。","实严姊事，用答阴灵。","坛壝斯设，黍稷惟馨。","云车来下，庶歆厥诚。","溯日著明，丽天作配。","洁诚以祠，礼行肃拜。","光凝冕服，气肃环佩。","庶几昭格，祗而不懈。","穆穆流辉，太阴之精。","盈亏靡忒，寒暑以均。","克禋克祀，揆日涓辰。","牲硕酒旨，来燕来宁。"],["聿分春气，施生在时。","禖宫肇启，精意以祠。","礼仪告备，神其格思。","厥灵有赫，锡我繁釐。","眷此尊祀，实惟仲春。","青圭束帛，克祀克禋。","庶蒙嘉惠，嗣续诜诜。","神之降鉴，云车来臻。","猗欤禖宫，祀典所贵。","粤自艰难，礼或弗备。","以迄于今，始建坛壝。","愿戒云车，歆此诚意。","春气肇分，万类滋荣。","惟此祀事，皆象发生。","求神以类，式昭至诚。","庶几来格，子孙绳绳。"],["紫阙幽宏，惟神灵尊。","辅成泰元，赞役乃坤。","曰雨曰旸，缊豫调纷。","享荐陨光，蒙祉如屯。","载阳衍德，农祥孔昭。","赉兹元嘏，穰穰黍苗。","象舆眇冥，金奏远姚。","无阏厥灵，丹衷匪恌。","于赫九宫，天神之贵。","煌煌彪列，下土是莅。","幽赞高穹，阴骘万类。","肃若旧典，有严祗事。","练时吉良，聿崇明祀。","粢盛洁丰，牲硕酒旨。","肃唱和声，来燕来止。","嘉承天休，赉及含齿。"],["祼鬯溥将，宾尸在位。","帝德升闻，孝思光被。","公卿庶正，傅御师氏。","至诚感神，福禄来暨。","煌煌真宗，善继善承。","经武耀德，臻于治平。","对祀礼乐，丕昭鸿名。","陟配文庙，皇图永宁。","鼎俎既陈，豆笾既设。","金石在庭，工师就列。","备物有严，著诚致洁。","孝惟时思，礼以雍彻。"],["奉先严祀，率礼大经。","时思致享，肃荐芳馨。","竭诚备物，乐奏和声。","真驭来止，熙事克成。","圣灵在天，九关崇深。","风马云车，纷其顾临。","拥祥储休，昭答孝心。","孝孙受祉，万福是膺。","嘉承和平，秩祀为先。","乃练休辰，祝史告虔。","内心齐明，祀具吉蠲。","交际恍惚，如在后前。","道信于神，神灵燕娭。","酒有嘉德，物惟其时。","缓节安歌，乐奏具宜。","欣欣乐康，福禄绥之。"],["时维孟冬，霜露既零。","合食盛礼，以时以行。","孝心翼翼，惟神来宁。","肃倡斯举，神具是听。","于穆孝思，嘉荐维时。","诚通兹格，咸来燕娭。","神之听之，申锡蕃釐。","于万斯年，永保丕基。","于昭孝治，通乎神明。","寒暑不忒，熙事备成。","牲牷孔硕，黍稷惟馨。","以享以祀，来燕来宁。","苾芬孝祀，荐灌肃雍。","致力于神，明信咸通。","灵之妥留，惠我庞鸿。","广被万宇，福禄攸同。"],["于皇我后，祗戒专精。","假于有庙，祖考是承。","趋进惟肃，僾思惟诚。","神之听之，来燕来宁。","皇皇大宫，丕显于穆。","休德昭清，元气回复。","芝叶蔓茂，桂华冯翼。","孝孙假斯，受兹介福。","维皇齐精，鬷假于庙。","观盥之初，惟以洁告。","衎承祖宗，恤祀昭孝。","诚心有孚，介福斯报。","秬鬯既将，黄钟具奏。","肃我祖考，祗栗以俟。","于皇列圣，在帝左右。","监观于兹，云车来下。","有硕其牲，登于大房。","肃展以享，庶几迪尝。","匪腯是告，我民其康。","保艾尔后，垂休无疆。","盥至于再，洁诚愈孚。","帝用祗荐，灵咸嘉虞。","腾歌胪欢，会于轩朱。","观厥颙若，受福之符。","思文僖祖，基德之元。","皇武大之，受命于天。","积厚流光，不已其传。","曾孙笃之，于万斯年。","天命有开，维仁是依。","乃眷冀邦，于以顾之。","其顾伊何，发祥肇基。","施于孙子，虔奉孝思。","昭哉皇祖，源深流长。","雕戈圭瓒，休有烈光。","天祐潜德，继世其昌。","永怀积累，嘉荐令芳。","为民请命，皇祖赫临。","天地并贶，亿万同心。","造邦以德，介福宜深。","挹彼惟旨，真游居歆。","皇矣太宗，嗣服平成。","益奋神旅，再征不庭。","文武秉德，仁孝克明。","以圣传圣，对越紫清。","思文真宗，体道之崇。","憺威赫灵，遵制扬功。","真符鼎来，告成登封。","盛德百世，于昭无穷。","仁德如天，遍覆无偏。","功济九有，恩涵八埏。","齐民受康，朝野晏然。","击壤歌谣，四十二年。","穆穆英宗，持盈守成。","世德作求，是缵是承。","齐家睦族，偃武恢文。","于荐清酤，酌之欣欣。","烝哉维后，继明体神。","稽古行道，文物一新。","润色鸿业，垂裕后人。","灵斿沛然，来燕来宁。","明哲煌煌，照临无疆。","绍述先志，寔宣重光。","诒谋燕翼，率由旧章。","苾芬孝祀，降福穰穰。","于皇烈考，道化圣神。","尧聪舜孝，文恬武忻。","命子出震，遗骏上宾。","罔极之哀，有古莫伦。","明德惟馨，进止回复。","裼袭安恭，严若惟谷。","诚意昭融，群工袂属。","成此祲容，生乎齐肃。","于皇我后，祗戒专精。","躬制声诗，文思聪明。","雍容戾止，玉立端诚。","神听如在，福禄来宁。","八音谐律，缀兆充庭。","进旅退旅，肃恭和平。","盛荐祖宗，灵监昭升。","象功崇德，遹观厥成。","威神在天，享于克诚。","申以贰觞，式昭德馨。","笾豆孔嘉，乐舞具陈。","庶几是听，福禄来成。","疏幂三举，诚意一纯。","孰陪予祀，公族振振。","神具醉止，燕娭窈冥。","于万斯年，绥我思成。","夙戒告备，礼节俯成。","妥侑惟乾，氛氲夜澄。","有严有翼，列圣灵承。","于穆清閟，肃肃无声。","维皇亲享，至再至三。","礼备乐奏，层陛森严。","粢盛芳洁，酒醴旨甘。","云车风马，从卫观瞻。","赫赫明明，维祖维宗。","鉴于文孙，维德之同。","日靖四方，亦同其功。","亿万斯年，以承家邦。","帝既临享，步武鸣鸾。","陟降规矩，颙昂周旋。","登歌一再，典礼莫愆。","神之听之，祉福绵绵。","熙事既成，嘉笾告彻。","洋洋来临，蔼蔼布列。","配帝其功，在天对越。","允集丛釐，万邦和悦。","神之来游，风马云车。","淹留彷佛，顾瞻欷歔。","神之还归，钧天帝居。","监观于下，何福不除。","于皇上天，钦哉成命。","集于冲人，丕承列圣。","爰熙紫坛，于庙告庆。","肸蚃潜通，休祥荐应。","盛德丰功，一祖六宗。","钦翼燕诒，禋享是崇。","厉意齐精，假庙惟恭。","率礼周旋，福禄来同。"],["咸英备乐，簋席列斝。","诗歌安世，声叶皇雅。","翠旗羽盖，云车风马。","神其来兮，以燕以下。","勾陈旦辟，阊阖夜分。","轸风挟月，车驷凌云。","瑞景晻霭，神光耀煴。","神其来兮，以留以忻。","穆穆紫幄，璜璜清宫。","旱麓流咏，凫鹥叶工。","道闳诒燕，业绵垂鸿。","神其来兮，以康以崇。","文以谟显，武以烈承。","圣训之保，祖武之绳。","有肃孝假，式严衎烝。","神其来兮，以宜以宁。"],["于皇祖宗，清庙奕奕。","威灵在天，不显惟德。","垂裕鸿延，诒谋燕翼。","孝孙格斯，受祉罔极。","秬鬯既将，黄钟具奏。","瞻望真游，僾若有慕。","于皇列圣，在帝左右。","云车具来，以妥以侑。","帝德之休，恭俭渊懿。","三十一年，谨终如始。","升祔在宫，祖功并美。","民怀有仁，何千万世。"],["于皇我后，祗戒专精。","齐肃有容，祖考是承。","造次匪懈，孝思纯诚。","神听有格，福禄来宁。","肃哉清宫，熉珠照幄。","神之来思，八音振作。","赤舄龙章，奉玉惟恪。","匪今斯今，先民时若。","于皇维后，观盥之初。","精意昭著，既顺既愉。","圭鬯承祀，卿士咸趋。","目视心化，四方其孚。","涓选休成，祖考是享。","夙夜专精，求诸惚恍。","洋洋在上，惟神之仰。","鬯矣清明，应之如响。","来相于庭，鸣鋗锵锵。","奉牲而告，登彼雕房。","非牲之备，民庶是康。","神依民听，上帝斯皇。","何庆之长，实兆于商。","由商太戊，子孙其昌。","皇基成命，宋道用光。","诒厥孙谋，膺受四方。","上帝监观，维仁是依。","继世修德，皇心顾之。","其顾伊何，在彼冀方。","施于子孙，降福穰穰。","昭哉皇祖，骏发其祥。","雕戈圭瓒，盛烈载扬。","天锡宝符，俾炽而昌。","神圣应期，赫然垂光。","猗欤皇祖，下民攸归。","膺帝之命，龙翔太微。","戎车雷动，天地清夷。","峨峨奉璋，万世无违。","煌煌神武，再御戎轩。","时惠南土，旋定太原。","车书混同，声教布宣。","维天佑之，亿万斯年。","于皇真宗，体道之崇。","游心物外，应迹寰中。","四方既同，化民以躬。","清净无为，盛德之容。","噫我大君，嗣世修文。","维文维武，諟继虞勋。","天锡丕祚，施于后昆。","于荐清酤，酌之欣欣。","烝哉维后，继明体神。","宪章文武，宜民宜人。","经世之道，功格于天。","子孙严祀，无穷之传。","明哲煌煌，照临无疆。","丕承先志，嘉靖多方。","朝廷尊荣，民庶乐康。","珍符来应，锡兹重光。","圣考巍巍，光绍丕基。","礼隆乐备，时维纯熙。","天仁兼覆，皇化无为。","功成弗处，心潜希夷。","作乐合祖，笋簴在庭。","众奏具举，肃雍和鸣。","神灵来格，庶几是听。","皦绎以终，永观厥成。","威神在天，来格于诚。","既载清酤，有闻无声。","相予熙事，时赖宗英。","肃肃雍雍，允协思成。","疏幂三举，诚意一纯。","孰陪予祀，公族振振。","明灵来娭，乐舞具陈。","奉神所佑，昭孝息民。","赫赫明明，德与天通。","施于孙子，福禄攸同。","日靖四方，民和年丰。","有秩斯祜，申锡无穷。","歆我齐明，威德如存。","牲牷是享，圭玉其温。","群公执事，亦既骏奔。","礼成告彻，咸福黎元。","神明既交，恍若有承。","钦翼齐庄，福禄具膺。","王业是兴，祖武是绳。","佑我亿年，以莫不增。"],["笾豆大房，牺尊将将。","馨香既登，明灵迪尝。","其乐伊何，吹笙鼓簧。","灵来燕娭，降福无疆。","吉蠲惟时，礼仪既备。","奉璋峨峨，群公在位。","神之格思，永锡尔类。","展彼令德，于焉来暨。","雍雍在宫，翼翼在庭。","显相休嘉，肃雍和鸣。","神嗜饮食，明德惟馨。","绥我思成，式燕以宁。","牺牲既成，笾豆有楚。","摐金击石，式歌且舞。","追怀懿德，令闻令仪。","灵兮来格，是享是宜。"],["涓选休辰，于秋之杪。","既齐既戒，爰假祖庙。","有侐仪坤，旧章是效。","享祀奚为，天子纯孝。","宗祀九筵，先荐閟宫。","陟自东阶，煌煌衮龙。","于穆圣善，监兹礼容。","是享是宜，介福无穷。","丕显文母，厚德维坤。","仙驭虽邈，徽音固存。","瑟彼玉瓒，酌此郁尊。","简简穰穰，裕我后昆。"],["威灵洋洋，靡有常向。","于惟钦承，来假来飨。","博硕芬香，是烝是享。","奉器有虔，载德无爽。","尔牲既充，是烹是肆。","尔肴既具，是羞是馈。","非物之重，惟德之备。","神之格思，歆我精意。"],["维皇齐居，承神其初。","颙颙昂昂，龙步云趋。","景钟铿如，肃觐清都。","肸蚃之交，神人用孚。","帝既临飨，罄兹精意。","对越在天，爰升紫陛。","孔容翼翼，保承丕绪。","孝奉天仪，永锡尔类。","惟德馨香，升闻八方。","粤神临之，来从帝乡。","万灵景卫，有烨其光。","监我精纯，降福穰穰。","斋居皇皇，琼琚锵锵。","承祭之初，其如在旁。","挹彼注兹，储禧迎祥。","神之听之，欣欣乐康。","涓选休辰，有事嘉荐。","琅琅琼佩，陟降岩殿。","其陟伊何，币玉斯奠。","周旋中礼，千亿储羡。","上灵始祖，云景元尊。","严祀夙展，六乐朱轩。","明玉之洁，丰帛之温。","畅乃继序，承德不愆。","我后临飨，奠币攸毕。","式旋其趋，矩度有式。","礼容斋庄，孝思纯实。","天休滋至，时万时亿。","百职骏奔，来相于庭。","奉盛以告，登兹芳馨。","际天蟠地，默运三灵。","神兮来歆，祚我休平。","有严大礼，对时休明。","情文则粲，蠲洁必清。","再临观盥，以专以精。","真游来格，永观厥成。","于赫炎宋，十叶华耀。","属兹郊报，陟降在庙。","其降伊何，椒浆桂酒。","再拜斟酌，永御九有。","瑶源诞启，玉牒肇荣。","覆育群有，监观圆清。","酒醴既洽，登荐惟诚。","无有后艰，骏惠云仍。","奠鬯告成，式旋厥位。","天步雍容，神人燕喜。","九庙观德，百灵荐祉。","子孙其昌，垂千万祀。","于皇乐舞，进旅退旅。","一弛一张，笙磬具举。","岂惟玩声，象德是似。","神鉴孔昭，福禄来予。","五音饬奏，神既亿康。","澹其容与，荐此嘉觞。","有来显相，鋗玉锵锵。","奉承若宥，罔不斋庄。","嘉荐既终，神贶斯复。","赉我思成，灵光下烛。","孝孙承之，载祗载肃。","敷锡庶民，函蒙祉福。","帝临閟庭，逆釐上灵。","神羯安坐，肃若有承。","嘉觞既申，德闻惟馨。","灵光留俞，祚我亿龄。","普淖既荐，苾芬孔时。","神嗜而顾，有来燕娭。","飨矣将彻，载钦载祗。","展诗以侑，益臻厥熙。","雍歌既彻，熙事备成。","神夕奄虞，忽乘青冥。","灵心回眷，监我精禋。","诞降嘉祉，休德昭清。","我秩元祀，上推灵源。","展事有侐，祲威肃然。","丹墄既降，秉心益虔。","荷天之休，于千万年。","奕奕灵宫，有严毖祀。","燔燎具扬，礼仪既备。","帝心肃祗，天步旋止。","对越在天，永膺蕃祉。","帝将于郊，昭事上祀。","爰兹毕觞，复即于此。","飙游载旋，容旌沓骑。","维皇嘉承，锡祚昌炽。"],["合宫之飨，报本奉先。","钦惟道祖，浚发璿源。","驾言谒款，其盥惟虔。","尚监精衷，锡祚绵绵。","骏命有开，庆基无穷。","祗率百辟，仰瞻睟容。","鼓钟斯和，黍稷斯丰。","灵其居歆，福禄来崇。","嘉玉既设，量币既陈。","彷佛灵游，来顾来宁。","对越伊何，厥惟一纯。","佑我熙事，以迄于成。","发祥仙源，流泽万世。","曷其报之，亲飨三岁。","相维列卿，洁粢是馈。","匪物之尚，诚之为至。","华灯荧煌，瑞烟氤氲。","威神如在，蠲洁必亲。","再盥于罍，再帨于巾。","皇心肃祗，其敢惮勤。","岁逢有年，月旅无射。","我将我飨，如几如式。","肃尔臣工，谐尔金石。","本原休功，垂裕罔极。","旨酒思柔，神具醉止。","工祝既告，孝孙旋位。","何以酢之，纯嘏来备。","燕及云来，蕃衍无已。","象德之成，有奕其舞。","一弛一张，进旅退旅。","嘒以管箫，和以镛鼓。","神其乐康，永锡多祜。"],["四灵晨耀，五纬夕明。","风云晏和，天地粹清。","灵兮来迎，灵兮来宁。","启我子孙，飨于纯精。","芬枝扬烈，熉珠叶陶。","闿珍阐符，展诗舞箾。","神哉来下，神哉来翱。","肃若有承，灵心招摇。","龙车既奏，凤驭载翔。","帝幄伫灵，天衢腾芳。","神来留俞，神来蹇骧。","礼鬯乐明，奏假孔将。","虹旌蜺旄，鸾旗翠盖。","星枢扶轮，月御叶卫。","灵至阴阴，灵般裔裔。","来格来飨，福流万世。"],["我享我将，罄兹精意。","陟降左右，维天与契。","斋明乃心，祗肃在位。","于万斯年，百福来备。","庆云郁郁，鸣璆琅琅。","澹其容与，申荐贰觞。","奉承若宥，神其乐康。","锡以多祉，源深流长。"],["谓天盖高，惟皇合德。","倬彼灵章，图书是锡。","眷命谆谆，被以遐历。","膺箓告成，虔恭钦翼。","地届兴王，祥开图箓。","典礼昭成，祺祥交属。","大辂逶迤，卿云纷郁。","祐我含灵，锡兹介福。"],["堪舆之间，最钜惟瀛。","包乾括坤，吐日滔星。","祀典载新，礼乐孔明。","鉴吾嘉赖，来燕来宁。","四溟广矣，八纮是纪。","我宅东南，回复万里。","洪涛飘风，安危所倚。","祀事特隆，神其戾止。","若稽有唐，克致崇极。","祝号既升，爰增祭式。","从享于郊，神斯受职。","我祀肇新，式祈阴骘。","猗与祀礼，四海会同。","灵之来沛，鞭霆驭风。","肸蚃彷佛，在位肃雍。","佑我烝民，式徼神功。"],["五纬相天，各率其职。","司礼与视，则维荧惑。","至阳之精，届我长嬴。","于以求之，祀事孔明。","有出有藏，伏见靡常。","相我国家，鉴观四方。","视罔不正，终然允臧。","神其来格，明德馨香。","小大率礼，不愆于仪。","展采错事，秩祀孔时。","维今之故，阅我数度。","修厥典常，神其来顾。","于赫我宋，以火德王。","永永丕图，繄神之相。","神之来矣，维其时矣。","礼备乐奏，神其知矣。"],["烨烨我宋，火德所畀。","用火纪时，允惟象类。","神以类歆，诚繇类至。","有感斯通，孚我阳燧。","乐音上达，粤惟出虚。","火性炎上，亦生于无。","我镛我磬，我笙我竽。","气同声应，昭哉合符。","火在六气，独处其两。","感生维君，繄辰克相。","何以验之，占兹垂象。","腾驾苍虬，歘其来飨。","星入于戌，与火俱诎。","火出于辰，与星俱伸。","一伸一诎，孰操纵之。","利用出入，民咸用之。"],["赫赫皇图，炎炎火德。","侈神之赐，奄有方国。","粢盛既丰，俎豆有飶。","于万斯年，报祀无斁。","火星之躔，有烨其光。","表于辰位，伏于戌方。","时和岁稔，仁显用藏。","告尔万民，出纳有常。","季秋之月，律中无射。","农事备收，火功告毕。","克禋克祀，有严有翼。","风马云车，尚其来格。","明明我后，重祭钦祠。","有司肃事，式荐晨仪。","礼惟其称，物惟其时。","神之听之，福禄来为。"],["惟土之尊，民食资焉。","阴祀昭格，牲牢腥膻。","有功于民，告其吉蠲。","神之来享，云车翩翩。","惟谷之神，函育无穷。","百嘉蕃殖，民依厥功。","严饬坛壝，威仪肃雍。","神之来享，祈于登丰。","猗欤那欤，生养斯民。","家给人足，时底熙纯。","祗严明禋，于荐苾芬。","粢盛丰洁，神乃有闻。","笾豆斯陈，三牲告幽。","报本之礼，答神之休。","来歆芬香，丰登于秋。","仓箱千万，治符成周。"],["五祀之本，社稷有严。","芟柞伊始，夫敢不虔。","吉日惟戊，式荐豆笾。","神其来格，用介有年。","功烈在民，诞受露雨。","良耜既歌，乃扬帗舞。","是奉是尊，厚礼斯举。","相其丰年，多稌多黍。","是尊是奉，兹率旧章。","乐音纯绎，荐溢圆方。","情文备矣，神其迪尝。","永观锡羡，多穑穰穰。","谷资土养，民赖谷生。","功利之博，莫之与京。","式严祠坛，因物荐诚。","礼具乐奏，惟神顾歆。","国主社稷，时祀有常。","肃若旧典，报本不忘。","粢盛丰洁，歌吟青黄。","尊神倏来，百物宾将。"],["先农播种，九谷务滋。","灵坛致享，良耜陈仪。","吉日惟亥，运属纯熙。","乐之作矣，神其格思。","亲耕展祀，明灵来格。","九有骏奔，百司庇职。","献奠肃肃，登降翼翼。","祈彼丰穰，福流万国。","肃陈韶舞，祗荐牺牲。","乃逆黄俎，以率躬耕。","祀惟古典，食乃民天。","歆兹洁祀，以应祈年。","式陈芳荐，爰致虔诚。","神其降鉴，永福黎氓。","明禋绀坛，灵风肃然。","登歌已阕，神驭将旋。","道光帝籍，礼备公田。","鉴兹躬稼，永赐丰年。"],["勤劳稼穑，必躬必亲。","为藉千亩，以教导民。","帝出乎震，时惟上春。","天颜咫尺，望之如云。","元辰既择，礼备乐成。","洪縻在手，祗饰专精。","三推一垡，端冕朱纮。","靡辞染屦，以示黎氓。","方坛屹立，陛级而登。","玉色下照，临观耦耕。","万目咸睹，如日之升。","成规成矩，百禄是膺。","群公显相，奉事斋庄。","率时农夫，举耜载扬。","播厥百谷，以佑我皇。","多黍多稌，丕应农祥。","畟畟良耜，我田既臧。","土膏其动，春日载阳。","执事有恪，于此中邦。","农夫之庆，栖亩馀粮。","肇新帝藉，率我农人。","三推终亩，祗事咸均。","陟降孔时，粲然有文。","受天之祜，多稼如云。","教民稼穑，不令而行。","进退有度，琚瑀锵鸣。","言还熉幄，礼则告成。","帝命率育，明德惟馨。"],["玄冥凌厉，岁聿其周。","天地闭藏，农且息休。","古大蜡礼，伊耆肇修。","爰荐飶馨，以迓飙游。","惟大明尊，实首三辰。","功赫庶物，光被广轮。","岁方索飨，咸秩群神。","灵斿来下，尸此明禋。","三时不害，四方顺成。","酬功报始，以我齐明。","豳颂土鼓，乐此嘉平。","降祥幅员，惠于函生。","日昱乎昼，容光必照。","肸蚃之交，惟人所召。","有监在下，视兹升燎。","肃若其承，云骈星曜。"],["玄冬肇祀，始于伊耆。","岁事聿成，庸答蕃釐。","眷言西顾，匪神司之。","归功尔神，翩其下来。","魄生自西，照望太阳。","下暨诸神，贶施万方。","节适风雨，富我囷箱。","共承嘉祀，惟以迪尝。","神罔小大，奠方兹土。","祭列坊庸，礼迨猫虎。","有功斯民，祀乃其所。","非稷馨香，厥福周溥。","丰年穰穰，美芳职职。","笾豆方圆，其仪孔硕。","风马在御，云车载饬。","来顾来飨，维俟休德。"],["大哉宣圣，道德尊崇。","维持王化，斯民是宗。","典祀有常，精纯并隆。","神其来格，于昭盛容。","生而知之，有教无私。","成均之祀，威仪孔时。","维兹初丁，洁我盛粢。","永适其道，万世之师。","巍巍堂堂，其道如天。","清明之象，应物而然。","时维上丁，备物荐诚。","维新礼典，乐谐中声。","圣王生知，阐乃儒规。","诗书文教，万世昭垂。","良日惟丁，灵承不爽。","揭此精虔，神其来飨。"],["乾健为君，坤柔曰臣。","惟其臣子，克奉君亲。","永御皇极，以绥兆民。","称觞献寿，山岳嶙峋。","舜韶更奏，尧酒浮觞。","皇情载怿，洪算无疆。","基隆郏鄏，德茂陶唐。","山巍日焕，地久天长。"],["四序伊始，三阳肇开。","条风入律，玉琯飞灰。","望云肃谒，鸣佩斯来。","称觞献寿，瞻拱星回。","一阳应候，万国同文。","天正纪节，太史书云。","凝旒在御，列叙爰分。","寿觞斯荐，祝庆明君。"],["群公卿士，咸造在庭。","式燕以衎，思均露零。","穆穆明明，于斯为盛。","归美报上，一人有庆。","明明天子，万福来同。","嘉宾式燕，曷不肃雍。","燕以示慈，式礼莫愆。","乐胥君子，容止可观。"],["帝德诞敷，销烁群慝。","近悦远来，惟圣时克。","玉振金声，治功兴起。","韶箾象之，尽善尽美。","文物以纪，藻色以明。","礼备乐举，遹观厥成。","睿知有临，诞敷文德。","教雨化风，洽此四国。"],["用戒不虞，谁能去兵。","师出以律，动必有名。","折彼遐冲，布昭圣武。","和众安民，时惟多助。","止戈曰武，惟圣为能。","御得其道，无敢不庭。","整我六师，稽诸七德。","不吴不扬，有严有翼。"],["夹钟纪月，初吉在辰。","眚灾流庆，布德推仁。","采章震耀，典礼具陈。","茂昭丕贶，永庇斯民。","皇衢赫敞，黼坐穹崇。","华缨在列，严令发中。","王制钜丽，宝瑞丰融。","均禧绵宇，万寿无穷。"],["拜况于郊，皇哉唐哉。","熙事休成，六騑鼎来。","天阃以决，地垠以开。","隤祉发祥，如登春台。","鸿霈普洽，言归端门。","荡荡巍巍，旋乾转坤。","穆然宣室，储思垂恩。","于万斯年，敷锡群元。"],["帝飨于郊，荷天之休。","五福敷锡，皇明烛幽。","云行雨施，仁翔德游。","圣人多男，歌颂九州。","天日清晏，朝野靖安。","三灵答祉，万国腾欢。","帝命不违，王业艰难。","天子万年，永迪监观。"],["肃肃临下，有威有容。","循循事上，惟信惟忠。","盛礼兴乐，示慈训恭。","君臣协吉，惟道之从。","湛湛零露，晞于载阳。","我有旨酒，群臣乐康。","既饮以德，亦图尔良。","永言修辅，用协天常。","礼均孝慈，乐合韶武。","至德光矣，鸿恩亦溥。","上下和济，华夷乐湑。","盏斝三行，盛仪斯举。"],["尧母之圣，放勋为子。","同心协谋，柔远能迩。","以德康俗，以文兴治。","斯焉象功，罔不昭济。","至矣坤元，道符惟圣。","就养宸极，助隆善政。","翟籥纷举，笙镛协应。","翱翔有容，表德之盛。"],["七德之舞，四朝用康。","有如姬姒，助集周邦。","威克厥爱，居安不忘。","风旋山立，济济皇皇。","左秉朱干，右挥玉戚。","以象武缀，以明皇德。","天子荣养，群臣述职。","四夷宾附，罔不承式。"],["王化之始，治繇内孚。","时庸作命，玉简金书。","磬筦在庭，其纵绎如。","天临法扆，礼与诚俱。","晬仪临拱，丕命明扬。","鸾回宝势，鸿贯瑶光。","礼成乐备，德裕名芳。","肇基王化，永懋天祥。","衮衣绣裳，严威肃庄。","八音具张，簨虡龙骧。","玉简瑶章，金书煌煌。","寿千万年，与天比长。"],["大矣孝熙，帅民以躬。","奉承宝册，钦明两宫。","万乐具举，一人肃雍。","化繇上始，四海来同。","皇帝仁孝，总临万方。","褒显其亲，日严以庄。","龙衮翼翼，玉书煌煌。","传之亿世，休有烈光。","总裁庶政，拥佑嗣皇。","金书玉简，烂其文章。","众歌警作，筦磬将将。","保安四极，降福无疆。","涂山之德，渭涘之祥。","图徽宝册，玉色金相。","管弦烨煜，钟鼓喤喤。","天之所启，既寿而昌。","玉车临御，凤盖棽丽。","奉承宝册，弥文盛仪。","抗声极律，助我孝熙。","天之所佑，万寿无期。"],["帝受内禅，纪元绍熙。","钦崇慈亲，孝心肃祗。","乃建显号，乃蒇丕仪。","发册广庭，声歌侑之。","钟鼓交作，文物咸备。","彤庭玉阶，天子是莅。","咨尔辅臣，展采错事。","辅臣稽首，敢不率礼。","巍巍天宫，洞开阊阖。","旗常葳蕤，剑佩杂沓。","宝册启行，法驾继发。","铄哉盛典，快睹胥悦。","仰止皇居，九门载辟。","丽日重光，非烟五色。","雷动万乘，云从百辟。","咫尺重霄，鞠躬屏息。","玉玺瑶编，礼容毕具。","穆穆至尊，华殿是御。","德配有虞，绍唐授禹。","于万斯年，受天之祜。","慈皇天临，睟表怡怡。","钦哉圣子，亲奉玉卮。","鳌抃嵩呼，欢浃华夷。","迩臣捧册，是恪是祗。","瑟彼华玉，篆鱼钮龙。","与册并登，咨尔上公。","咏以歌诗，协之鼓钟。","是陟是降，靡有弗恭。","天祐皇家，庆集重闱。","宝兮扬名，册兮流徽。","金支秀华，盛容祲威。","诏我近弼，相礼不违。","大哉乾元，既极形容。","坤元德至，实与比隆。","宝册并登，勒崇垂鸿。","相我缛仪，肃肃雍雍。","涓辰协吉，时维春元。","上册三殿，旷古无前。","思齐重闱，积庆有源。","是尊是崇，帝心载虔。","丕赫有宋，三圣授受。","谁其助之，繄我太母。","东朝受册，饮此春酒。","圣子神孙，密侍左右。","坤德益崇，天寿平格。","庆流万世，子孙千亿。","刻玉范金，铺张赫奕。","惟昔姜任，则莫我匹。","鞠育保护，母道备矣。","密赞亲传，德其至矣。","綵服来朝，慈容有喜。","既受鸿名，又多受祉。","仰瞻慈闱，登进宝册。","惟时御，祗率厥职。","曰寿曰名，母兮兼得。","俪我尊父，亿载无极。"],["德厚重闱，冲澹粹穆。","何以名之，惟慈惟福。","宝镂精镠，册镌华玉。","物盛礼崇，丕昭群目。","于皇帝室，休运贻孙。","重熙叠庆，祗进号荣。","爰授兹册，必躬必亲。","天子圣孝，万邦仪刑。","煌煌册宝，天子受之。","言徐其行，肃展乃仪。","其仪维何，剑佩黄麾。","鸾驾清跸，耸瞻九逵。","熙辰礼备，济济雍雍。","言奉斯册，重亲之宫。","宫帷既敞，协气感通。","皇仪亲展，寿祉无穷。","既肃琨庭，载升金戺。","乃导乃陪，威仪济济。","天步继临，孝诚备矣。","声容孔昭，中外悦喜。","雕舆彩仗，祗诣慈宫。","宝册前奉，龙挟云从。","言备兹礼，于宫之中。","惟天子孝，于昭祲容。","懿典大册，陈仪邃深。","怡怡愉愉，宝坐是临。","重綵俨侍，罙展肃心。","三宫协庆，永播徽音。","宝册既奉，祗诵乃言。","仁深庆衍，益显益尊。","和声协气，充溢乾坤。","并受伊嘏，圣子神孙。"],["天拥帝家，泽流子孙。","三宫燕胥，四海崇尊。","声谐韶濩，辉烛瑶琨。","维皇缉熙，耀德乾坤。","祖后重寿，亲闱并崇。","骈庆联休，申景铺鸿。","叠璧交辉，多仪焕丛。","亿万斯年，福禄攸同。","太任媚姜，涂山翼禹。","慈祥曼衍，鸿仪迭举。","宝章奕奕，祲宫俣俣。","帝用将之，于彼宫所。","东朝层邃，端闱靖深。","列仗节銮，镂玉绳金。","来奉来崇，载祗载钦。","曾孙之庆，世世徽音。","纯佑我宋，母仪四朝。","拥翼孙谋，如虞承尧。","仁覃函夏，喜浮庆霄。","福禄万年，金玉孔昭。","神人和怿，天日淑清。","王母来燕，必寿而名。","琨庭璈音，五云佩声。","勉勉我皇，遹昭厥成。","曾孙致养，五福骈臻。","太极所运，两仪三辰。","辉光日新，启佑后人。","永翼瑶图，亿万尧春。","徽光宣华，仁声流文。","旷仪合沓，泰和絪缊。","慈颜有喜，祚我圣君。","珠宫含饴，坐阅来云。","缛仪既登，宝册既膺。","喜洽祥流，云烝川增。","天子万年，鸣玉慈庭。","惠我无疆，诜诜绳绳。","新庭靖安，祖后燕怡。","有开圣谋，累崇天基。","典章文明，声容葳蕤。","御于邦家，曰寿曰慈。","三礼崇容，八銮警卫。","有来辰仪，阐徽妫汭。","璇宫肃雍，藻景澄霁。","文子文孙，本支百世。","尧门叠瑞，姒幄齐辉。","重坤靖夷，丽册华徽。","天子仁圣，礼文弗违。","福寿康宁，同燕层闱。","文母曼寿，载锡之光。","总集瑞命，宜君宜王。","惠以仁显，慈以德彰。","保佑子孙，受福无疆。","华鸾编玉，文螭液金。","颂德摛英，扬徽嗣音。","紫幄天开，翠华日临。","岁岁年年，如周太任。","宋有明德，天保佑之。","以寿继寿，以慈广慈。","声文宣昭，福祉茂绥。","神孙之休，燕及华夷。","大安耽耽，兴庆崇崇。","维皇之尊，与天比隆。","非心閒燕，文命延鸿。","欲报之恩，礼缛仪丰。","上帝有赫，百灵效祥。","储祉垂恩，锡年降康。","皇仪睟温，帝躬肃庄。","三宫齐欢，地久天长。","夏典稽瑞，禹玉含淳。","追琢有章，温润孔纯。","圣底于安，寿绵于仁。","太上立德，自天其申。","父尊母亲，天涵地育。","燕我翼子，景命有仆。","得名得寿，如金如玉。","子孙千亿，成其厚福。","天地清宁，日月华光。","归尊慈极，嵩呼未央。","庆函百嘉，寿跻八荒。","上皇万岁，俾炽俾昌。","晨趋慈幄，佳气郁葱。","受帝之祉，配天其崇。","璧华金精，礼敷乐充。","天子是若，欢声融融。","文物流彩，銮辂靖陈。","龟瑞荐祉，坤仪效珍。","比皇之寿，翼帝以仁。","和气致祥，与物为春。","黼黻其文，金玉其相。","永寿于万，合德无疆。","福绪祥源，厥后克昌。","天维格斯，祚我圣皇。","荣怀之庆，莫盛于斯。","三宫四册，五叶一时。","德阜而丰，福大而滋。","子子孙孙，于时保之。"],["思齐太任，嫔于周京。","至哉坤元，万物资生。","不可仪测，矧可强名。","镂玉绳金，昭哉号荣。","鼓钟喤喤，仪物载陈。","仪物陈矣，烂其瑶琨。","咨尔上公，相予文孙。","勿亟勿徐，奉我重亲。","荡荡天门，金铺玉户。","采旄翠旌，流苏葆羽。","千官影从，乃导乃辅。","都人纵观，填道呼舞。","煌煌宝书，玉篆金缕。","曷为来哉，自天子所。","自天子所，以燕文母。","婉嬗祥云，日正当午。","文物备矣，三事其承。","崇牙高张，乐充宫庭。","耽耽广殿，左墄右平。","敬尔威仪，摄齐以登。","维寿伊何，圣德日新。","维慈伊何，祐于后人。","乃范斯金，乃镂斯珉。","皇举玉趾，从于尧门。","侍中版奏，办外严中。","出自玉房，袆褕被躬。","我龙受之，祲威盛容。","皇帝圣孝，其乐融融。","麟趾袅蹄，我宝斯刻。","碝磩采致，载备斯册。","眉寿万年，诒谋燕翼。","于赫汤孙，克绵永福。"],["思齐圣母，媲于周任。","体乾履坤，博厚洪深。","七帙既启，万寿自今。","昕庭发号，式昭德音。","煌煌仪物，绎绎鼓钟。","奉兹宝册，至于阶东。","上公相仪，列辟尽恭。","拜手慈宸，福如华嵩。","帝阙肃开，天阶坦履。","霓旌羽盖，导仪护卫。","匪誇雕瑑，匪矜繁丽。","兹谓盛仪，亿载千岁。","金坚玉纯，文郁礼缛。","来从帝所，作瑞王国。","天开地辟，日熙春燠。","兹谓盛事，永燕茀禄。","皇仪有炜，綵舁次升。","沈沈邃殿，穆穆天廷。","坤德罙隆，皇图永宁。","咨尔廷臣，摄齐以登。","寿为福先，明烛物表。","仁沾动植，福齐穹昊。","曰慈与睿，并崇丕号。","演而申之，万世永保。","迩臣跪奏，严办必恭。","乃御袆褕，升于殿中。","慈颜雍穆，和气冲融。","芳流清史，传之无穷。","徽音孔昭，宝传斯刻。","金昭玉粹，有烨斯册。","载祈载祝，以燕以翼。","宝之万年，与宋无极。","皇文既举，庆礼告虔。","肇自宫闱，格于幅员。","子称母寿，母谓子贤。","陟降在兹，隆名际天。"],["既登乃依，如日之升。","有严有翼，丕显丕承。","天作之合，家邦其兴。","朱芾斯皇，子孙绳绳。","我礼嘉成，我驾言旋。","降坐而跸，奏鼓渊渊。","景命有仆，保佑自天。","永锡祚嗣，何千万年。","宣哲维公，就位肃庄。","册宝具举，丕显其光。","出于宸闱，鼓钟喤喤。","母仪天下，万寿无疆。"],["天地奠位，乾坤以分。","夫妇有别，父子相亲。","圣王之治，礼重婚姻。","端冕从事，是正大伦。","天子当阳，群工就列。","册宝既陈，钟鼓备设。","上公奉事，容庄心协。","克相盛礼，光昭玉牒。","穆穆睟容，如天之临。","赫赫明命，如玉之音。","虔恭出门，礼容兢兢。","涂山生启，夏道以兴。","朝阳已升，薰风习至。","乐奏既成，礼容亦备。","玉佩锵鸣，帝徐举趾。","壶政穆宣，以听内治。","猗欤贤后，德本性成。","承天致顺，溯日为明。","作配俪极，王化以行。","万有千岁，奉祀宗祊。","款承祗事，时惟肃雍。","跪奉册宝，陈于法宫。","以俯以仰，有仪有容。","明神介之，福禄来崇。","温惠之德，袆翟之衣。","行中采荠，礼无或违。","降于丹陛，有容有仪。","委委蛇蛇，谁其似之。","镂苍玉兮，盛德载扬。","铸南金兮，作镇椒房。","虔受赐兮，有烨有光。","宜室家兮，朱芾斯皇。","礼既行兮，厥位孔安。","母仪正兮，容止可观。","奉东朝兮，常得其欢。","求淑女兮，岂乐多般。","素月澄辉，众星显列。","炳为天文，各有攸别。","椒房既正，阴教斯设。","关雎麟趾，应如响捷。","窈窕其容，淑嫕其姿。","烂其如云，瞻我母仪。","曰天之妹，作合惟宜。","粲然舞抃，畴不肃祗。","宝字煌煌，册书粲粲。","副笄加饰，袆褕有烂。","祗若帝休，委蛇乐衎。","亿万斯年，永膺宸翰。","太任徽音，太姒是嗣。","则百斯男，周室以炽。","天子万年，受兹女士。","如姒事任，从以孙子。"],["赫赫惟皇，如日之光。","肃肃惟后，如月之常。","礼行一时，明照无疆。","天子莅止，畴敢不庄。","卜月惟良，练辰斯臧。","臣工在庭，剑佩玱玱。","来汝疑丞，明命是将。","有淑其仪，无或怠遑。","刻简以珉，铸宝以金。","持节伊谁，时惟四邻。","自我文德，达之穆清。","委蛇委蛇，往迄于成。","册行何向，于门东偏。","礼备乐成，合扇鸣鞭。","皇举玉趾，如天之旋。","燕及家邦，亿万斯年。","椒涂兰驭，河润山容。","副笄在首，袆衣被躬。","静女其姝，实翼实从。","自彼西閤，聿来殿中。","德隆位尊，礼厚文缛。","乃篆斯金，乃镂斯玉。","群公盈门，执事有肃。","愿言保之，永镇坤轴。","规殿沉沉，叶气旼旼。","明章妇顺，表正人伦。","蹑是左墄，暨于中庭。","尚宫显相，罔有弗钦。","备物典册，乐之鼓钟。","拜而受之，极其肃雍。","司言司宝，各以职从。","行地有庆，与天无穷。","容典既膺，壶仪既正。","羽卫外列，扬颜中映。","如帝如天，以庄以靓。","六宫承式，二南流咏。","葛覃节用，樛木逮下。","形为嫔则，夙已心化。","兹临长秋，遂正诸夏。","以庆以祈，百祥来迓。","硕人其颀，公侯之妻。","翟茀以朝，象服是宜。","如星之共，溯月之辉。","母仪既瞻，群心则夷。","窈窕淑女，备六服兮。","陟降多仪，耸群目兮。","内治允备，阴教肃兮。","宜君宜王，绥有福兮。","天监有周，是生太任。","亦有太姒，嗣其徽音。","孰如两宫，慈爱相承。","思齐之盛，复见于今。"],["乾位既正，坤斯顺承。","日丽于天，月斯溯明。","惟帝受命，惟帝并登。","黼扆尊临，典册是行。","乃协良辰，维春之宜。","乃诏近弼，来汝相仪。","九门洞开，文物华辉。","声诗载歌，于以侑之。","有玺范金，有册镂琼。","汝使汝介，持节以行。","礼始文德，达于穆清。","是恪是虔，依我和声。","鼓钟喤喤，磬筦锵锵。","剑佩充庭，济济洋洋。","礼典告备，皇心乐康。","于万斯年，受福无疆。","懿范柔容，如月斯辉。","驾厥翟辂，被以袆衣。","九御从之，如云祁祁。","典册是承，心焉肃祗。","华榱璧珰，有馨椒殿。","备物来陈，多仪式焕。","曰册曰宝，是刻是瑑。","并举以行，皇矣懿典。","袆褕盛服，有恪其容。","是陟是降，相以尚宫。","金殿玉阶，聿来于中。","展诗应律，载咏肃雍。","帝有显命，禀于亲慈。","后德克承，拜而受之。","人伦既正，王化是基。","亿载万年，永祚坤仪。","帝庆三宫，膺受宝册。","御于中闱，载欣载惕。","乃孚阴教，乃明内则。","翼翼鱼贯，罔不承式。","掖庭颁官，于位有四。","嘒彼小星，抚以德惠。","熙焉如春，育焉如地。","庆礼聿成，靡弗咸喜。","鱼轩鼎来，象服是宜。","班于内庭，率礼惟祗。","化以妇道，时惟母仪。","是庆是类，于胥乐兮。","正位长秋，容典备矣。","王假有家，人伦至矣。","俪极伣天，多受祉矣。","蛰蛰螽斯，宜孙子矣。","维天佑宋，盛事相仍。","崇号三宫，甫兹浃辰。","肇正中闱，缛礼载陈。","邦家之庆，旷古无伦。"],["乾健坤顺，群生首资。","日常月升，四时叶熙。","帝嗣天历，后崇母仪。","黼黻承晖，王化是基。","熛阙蟺蜎，璧门云龙。","烈文维辅，翊奉有容。","典章煇明，彝度肃雍。","蒇时缛仪，登于璿宫。","金晶丽辉，璧叶含春。","赞夏之翼，绎虞之嫔。","乐序韶亮，礼文藻新。","辟公相成，物采彬彬。","帟旒云舒，金秀充庭。","璇卫銮华，茜佩垂。","皇容熙备，柔仪顺承。","三宫齐欢，万福昭膺。","骖翟崇容，袆鞠陈衣。","戾止兰殿，夙兴椒闱。","淑正宣华，粹明腾煇。","钦若有承，嗣音之徽。","袆帟流光，沙祥增衍。","编玉镂德，螭金溢篆。","粹猷藻黻，徽文华显。","二南声诗，于时昭阐。","翚珩焕采，趋节风韶。","陟降墄陛，奉将英瑶。","辟道承薰，嫔仪扬翘。","是敬是祗，德音孔昭。","帝奉太室，后仪成之。","帝养三宫，后志承之。","德如关雎，盛如螽斯。","宜君宜王，百世本支。","肃肃壶彝，雍雍阴教。","险诐自防，警戒是效。","中闱端委，列御胥告。","其思辅顺，永翼帝孝。","天子九嫔，王宫六寝。","有烨令仪，载秩华品。","福履绥将，节用躬俭。","矢其德音，于以来谂。","象服之文，鹊巢之风。","化以妇道，觐于内宫。","采蘋涧滨，采藻涧中。","夙夜在公，赞彼累功。","光佑晏宁，惠慈燕喜。","寿仁并崇，家邦均祉。","懿文交举，壶册嗣美。","维亿万年，爱敬惟似。","天心仁佑，坤德世昭。","灼有慈范，著于累朝。","俭以赞虞，勤以承尧。","是用则效，共励夙宵。"],["茂建坤极，容典聿新。","天命所赞，慈训是遵。","肃涓谷旦，躬御紫宸。","鸿禧累福，骈赉翕臻。","端门晓辟，瑞气云凝。","有俨良辅，踵武造廷。","肃肃王命，是将是承。","登册穆清，万岁永膺。","瑶册玉宝，烂然瑞辉。","旁翼绛节，上承紫微。","璆鸣朝佩，徐出兽扉。","登进坤极，益彰典徽。","天临黼扆，云集弁缨。","金石递奏，典礼备成。","玉趾缓步，龙驾翼行。","言旋北极，永燕西清。","日薰椒屋，云霭璧门。","有华瑞节，来自帝阍。","统天惟乾，合德者坤。","我龙受之，福禄永繁。","虹辉灿烂，云篆绸缪。","绛节前导，瑞光上浮。","瑶阶玉扉，既集长秋。","钦承天宠，永荷帝休。","瑶殿清閟，玉墄坦夷。","袆衣副珈，陟降不迟。","宝册聿至，载肃载祗。","礼仪昭备，福履永绥。","日月临烛，乾坤覆持。","明并二曜，德合两仪。","光媲宸极，共恢化基。","膺受茂典，亿载永宜。","宝玺瑶册，既祗既承。","绣裀藻席，载跻载升。","柔仪肃穆，瑞命端凝。","永膺多福，如川方增。","服焕盛仪，班分华致。","九嫔妇职，六寝内治。","参差荇菜，求勤寤寐。","烝然来思，相礼赞祭。","妇荣于室，通籍禁中。","班列有次，车服有容。","佐我关雎，鹊巢之风。","被之僮僮，曷不肃雍。","金石具举，典礼茂明。","淑慎其止，遹观厥成。","琼琚微动，凤辇翼行。","仪光媲极，德迈嫔京。","宝坐既兴，凤舆戒行。","奏解严办，归燕邃清。","问安寿慈，奉赍宗祊。","弥千万年，内助圣明。"],["我祖受命，恭膺于天。","爰作玉宝，载祗载虔。","申锡无疆，神圣有传。","昭兹兴运，于万斯年。","于穆我皇，之德之纯。","涵濡群生，矧我遗民。","连齐跨晋，输贡效珍。","土宇日辟，一视同仁。","我祖我宗，德厚泽深。","于皇继序，益单厥心。","天人协扶，一统有临。","乾坤清夷，振古斯今。"],["主鬯之重，允属贤明。","承华肇启，上嗣腾英。","礼修乐举，育德开荣。","一人元良，万邦以宁。","皇储既建，圣祚无疆。","鸾旌列叙，鸡戟分行。","前星有烂，瑞日重光。","际天接圣，温文允臧。"],["宋受天命，圣绪无疆。","惟怀永图，乃登元良。","涓选休辰，册书是将。","黼坐天临，穆穆皇皇。","于维皇储，玉润金声。","体震之荐，重离之明。","册宝具举，环佩锵鸣。","守器承祧，惟邦之荣。","乐备既奏，和声冲融。","玉简金书，翔鸾戏鸿。","下拜登受，旋于青宫。","仪辰作贰，垂休无穷。","我礼备成，我驾言旋。","降坐而跸，奏鼓渊渊。","国本既定，保佑自天。","克昌厥后，何千万年。"],["建储以贤，辟宫于东。","典册既备，筮占既从。","济济卿士，锵锵鼓钟。","天子戾止，盛哉礼容。","雕珉瑳瑳，篆金煌煌。","对扬于庭，是承是将。","星重其晖，日重其光。","观瞻以怿，国有元良。","渊中象德，玉裕凝姿。","进退周旋，有肃其仪。","既定国本，益隆庆基。","燕及两宫，福禄如茨。","储副豫定，器之公兮。","册授孔时，礼之隆兮。","天步迟迟，旋九重兮。","寿祉万年，德无穷兮。"],["于皇我宋，受命于天。","升储主鬯，衍庆卜年。","典册告备，庭工载虔。","万乘莅止，端冕邃延。","太极端御，少阳肃祗。","珉简斯镂，衮服孔宜。","式奏备乐，乃陈盛仪。","下拜登受，永言保之。","明两承曜，作贰宣猷。","茂德金昭，令誉川流。","豫定厥本，永贻乃谋。","三朝致养，问寝龙楼。","震荐体象，我储明兮。","涣扬显册，我礼成兮。","大驾言旋，警跸鸣兮。","燕祉无疆，邦之荣兮。"],["于皇帝德，乃圣乃神。","本支百世，立爱惟亲。","敬共冠事，以明人伦。","承天右序，休命用申。","丰芑诒谋，建尔元子。","揆礼仪年，筮宾敬事。","八音克谐，嘉宾至止。","于以冠之，成其福履。","礼国之本，冠礼之始。","宾升自西，维宾之位。","于著于阼，维子之义。","厥惟钦哉，敬以从事。","路寝辟门，黼坐恭己。","群公在庭，所重维礼。","正心齐家，以燕翼子。","于万斯年，王心载喜。","有来振振，月重轮兮。","瑜玉在佩，綦组明兮。","左徵右羽，德结旌兮。","步中采荠，矩彟循兮。","我有嘉宾，直大以方。","亦既至止，厥德用光。","冠而字之，厥义孔彰。","表里纯备，黄耇无疆。","吉圭休成，其日南至。","天子有诏，冠尔皇嗣。","为国之本，隆邦之礼。","拜而受之，式共敬止。","兹惟阼阶，厥义有在。","历阶而升，敬谨将冠。","经训昭昭，邦仪粲粲。","正纚宾筵，寿考未艾。","秩秩宾筵，笾豆孔嘉。","帝子至止，衿缨振华。","周旋陟降，礼行三加。","成人有德，匪骄匪奢。","帝子惟贤，懋昭厥德。","跪冠于房，玄冠有特。","鼓钟喤喤，威仪抑抑。","百礼既洽，祚我王国。","有宾在筵，有尊在户。","磬管将将，醮礼时举。","跪觞祝辞，以永燕誉。","宝祚万年，磐石巩固。","复爻肇祥，震维标德。","乃共皮弁，其仪不忒。","体正色齐，维民之则。","璇霄眷佑，国寿箕翼。","冠醮之义，匪酬匪酌。","于户之西，敬共以恪。","金石相宣，冠醮相错。","帝祉之受，施及家国。","善颂善祷，三加弥尊。","爵弁峨峨，介圭温温。","阳德方长，成德允存。","燕及君亲，厥祉孔蕃。","席于宾阶，礼义以兴。","受爵执爵，多福以膺。","匪惟服加，德加愈升。","匪惟德加，寿加愈增。","命服煌煌，跬步中度。","庆辑皇闱，化行海宇。","礼具乐成，惕若戒惧。","宝璐厥躬，有秩斯祜。","皇王烝哉，令闻不已。","燕翼有谋，冠醮有礼。","百僚在庭，遹相厥事。","颂声所同，嘉受帝祉。","青社分封，前星启燄。","繁弱绥章，厥光莫掩。","容称其德，蓄学之验。","芳誉敷华，大圭无玷。","玄衮黼裳，垂徽永世。","勉勉成德，是在元子。","胙土南宾，厥旨孔懿。","充一忠字，作百无愧。","爱始于亲，圣尽伦兮。","元子冠字，邦礼成兮。","天步舒徐，皇心宁兮。","家人之吉，亿万春兮。"],["鹿鸣呦呦，命侣与俦。","宴乐嘉宾，既献且酬。","献酬有序，休祉无疆。","展矣君子，邦家之光。","鹿鸣呦呦，在彼中林。","宴乐嘉宾，式昭德音。","德音愔愔，既乐且湛。","允矣君子，实慰我心。","鹿鸣呦呦，在彼高冈。","宴乐嘉宾，吹笙鼓簧。","币帛戋戋，礼仪蹡蹡。","乐只君子，利用宾王。","鹿鸣相呼，聚泽之蒲。","我乐嘉宾，鼓瑟吹竽。","我命旨酒，以燕以娱。","何以赠之，玄纁粲如。","鹿鸣相邀，聚场之苗。","我美嘉宾，令名孔昭。","我命旨酒，以歌以谣。","何以置之，大君之朝。","鹿鸣相应，聚山之荆。","我燕嘉宾，鼓簧吹笙。","我命旨酒，以逢以迎。","何以荐之，扬于王庭。","瞻彼南陔，时物嘉良。","有泉清泚，有兰馨香。","晨饮是汲，夕膳是尝。","慈颜未悦，我心靡遑。","嬉嬉南陔，眷眷慈颜。","和气怡色，奉甘与鲜。","事亲是宜，事君是思。","虔勖忠孝，邦家之基。","洋洋嘉鱼，伫以美罛。","君子有道，嘉宾式燕以娱。","洋洋嘉鱼，伫以芳罟。","君子有德，嘉宾式歌且舞。","我有宫沼，龟龙扰之。","君子有礼，嘉宾式贵表之。","我有宫薮，麟凤来思。","君子有乐，嘉宾式慰勤思。","相彼嘉鱼，爰纵之壑。","我有旨酒，嘉宾式燕以乐。","相彼嘉鱼，在汉之梁。","我有旨酒，嘉宾式燕以康。","森森乔木，美蔓萦之。","我有旨酒，嘉宾式燕宜之。","喈喈黄鸟，载飞载止。","我有旨酒，嘉宾式燕且喜。","崇丘峨峨，动植斯属。","高既自遂，大亦自足。","和风斯扇，膏雨斯沐。","我仁如天，以亭以育。","崇丘巍巍，动植其依。","高大之性，各极尔宜。","王道坦坦，皇猷熙熙。","仁寿之域，烝民允跻。","关雎于飞，洲渚之湄。","自家刑国，乐且有仪。","郁郁芳兰，幽人撷之。","温温恭人，哲后求之。","求之无斁，寤寐所属。","罄尔一心，受天百禄。","郁郁芳兰，雨露滋之。","温温恭人，圭组縻之。","郁郁芳兰，佩服珍之。","温温恭人，福履绥之。","关雎跄跄，集水之央。","好求贤辅，同扬德光。","蘋蘩芳滋，同谁掇之。","愿言贤德，靡日不思。","偶其贤德，辅成己职。","永配玉音，服之无斁。","洁其粢盛，中心匪宁。","荐于宗庙，助君德馨。","贤淑来思，人之表仪。","风化天下，何乐如之。","彼鹊成巢，尔类攸处。","之子有归，琼瑶是祖。","彼鹊成巢，尔类攸匹。","之子有行，锦绣是饰。","彼鹊成巢，尔类攸共。","之子有从，兰荪是奉。","伊鹊成巢，珍禽戾止。","婉彼佳人，配于君子。","伊鹊营巢，珍禽攸处。","内助贤侯，弼于明主。","伊鹊营巢，珍禽辑睦。","均养嘉雏，致于蕃育。"]]