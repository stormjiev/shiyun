[["多能鄙事，圣人曲意。","惟其知之，是以不试。","宗鲁虽友，吊必以义。","尚师嘉言，祀亦罔替。"],["孔父秦父，相尚以力。","俱生贤嗣，相与以德。","是父是子，致诘畴克。","会弁儒林，令名无极。"],["勉勉子车，封邑淳于。","亲炙避席，唯诺趋隅。","发微既博，雅道是扶。","抑可尚也，不亦美乎。"],["孰封于萧，实惟子柳。","夙饫格言，克遵善诱。","明德斯馨，贤业所就。","以侑于儒，传芳逾茂。"],["雍容子皙，已望堂室。","幼则有造，成则祖述。","文采日化，儒效力弼。","永观厥成，德音秩秩。"],["东平子产，性著盛时。","奉师于塾，讲道之微。","答问其敏，婉妙以思。","升降陛廉，尚想英姿。"],["温温子里，入闻至圣。","揽道之华，秉德之柄。","深造阃域，不乖言行。","全齐之封，竹素为盛。"],["伯彼临淄，左行称贤。","睎踪十哲，秀颖三千。","心悦诚服，家至户传。","乐只君子，文声益宣。"],["彭衙高士，经籍是亲。","赞成德艺，协于彜伦。","厎绩圣道，斯肖素臣。","优哉游哉，学以致身。"],["乐氏子声，锡爵昌平。","信道之万，见善乃明。","引领高节，载惟思诚。","先贤聿集，出为时英。"],["朕念邦家历万几，幸卿相与久维持。","孜孜广道诹询处，蹇蹇封章纳诲时。","半世奇勋惟我重，一生忠节自天知。","南归奚事将为赠，金石诗篇壮羽仪。"],["天末归帆何处宿，钓船独在蓼花傍。"],["秋江烟暝泊孤舟。"],["有美三宫德，无嫌并后心。"],["趁此一轩风月好，橘香酒熟待君来。"],["气回俎豆群工泰，喜入貔貅万马秋。"],["白云断处斜阳转，几曲青山献画屏。"],["池上疎烟笼翡翠，水边迟日戏蜻蜓。"],["绕池曳杖携双鹤，架水浇花课小奴。"]]