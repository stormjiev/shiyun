[["在国南方，时维就阳。","以祈帝祉，式致民康。","豆笾鼎俎，金石丝簧。","礼行乐奏，皇祚无疆。"],["步武舒迟，升坛肃祗。","其容允若，于礼攸宜。"],["嘉玉制币，以通神明。","神不享物，享于克诚。"],["笙镛备乐，茧栗陈牲。","乃迎芳俎，以荐高明。"],["丹云之爵，金龙之杓。","挹于尊罍，是曰清酌。"],["洁兹五齐，酌彼六尊。","致诚斯至，率礼弥敦。","以介景福，永隆后昆。","重熙累洽，帝道攸尊。"],["谓天盖高，其听孔卑。","闻乐歆德，介以福禧。"],["倏兮而来，忽兮而回。","云驭杳邈，天门洞开。"],["圜丘何方，在国之阳。","礼神合祭，运启无疆。","祖考来格，笾豆成行。","其仪肃肃，降福穰穰。"],["礼备乐成，干健天行。","帝容有穆，佩玉锵鸣。"],["定位毖祀，告于神明。","嘉玉量币，享于克诚。"],["有牲斯纯，有俎斯陈。","进于上帝，昭报深仁。"],["大报于帝，盛德升闻。","醴齐良洁，粢盛苾芬。"],["祀帝圜丘，九州献力。","礼行于郊，百神受职。","灵祇格思，享我明德。","天鉴孔章，玄祉昭锡。"],["羽籥云罢，干戚载扬。","接神有恪，锡羡无疆。"],["神驾来思，风举云飞。","神驭归止，天空露晞。"],["千龄启运，三后在天。","嘉坛并侑，亿万斯年。"],["皇基缔构，帝系灵长。","躬荐鬰鬯，子孙保昌。"],["翕受骏命，震叠群方。","侑祀上帝，德厚流光。"],["诞受灵符，肇基丕业。","配享洁尊，永隆万叶。"],["无为靡远，深厚广圻。","祭神恭在，弁冕衮衣。","粢盛丰美，明德馨辉。","以祥以佑，非眇专祈。"],["神灵拥卫，景从云随。","玉色温粹，天步舒迟。","周旋陟降，皇心肃祗。","千灵是保，百福攸宜。"],["左手执籥，右手秉翟。","进旅退旅，万舞有奕。"],["陟彼郊丘，大祀是承。","其豆孔庶，其香始升。","上帝时歆，以我齐明。","卒事而彻，福禄来咸。"],["馨遗八尊，器空二簋。","至祝至虔，穹祇贶祉。"],["因山为高，爰陟其首。","玉趾躩如，在帝左右。","帝谓我王，予怀仁厚。","眷言顾之，永绥九有。"],["於穆文祖，妙道九德。","默契灵心，肇基王迹。","启佑后人，垂裕罔极。","合食昭荐，孝思维则。"],["于皇顺祖，积德累祥。","发源深厚，不耀其光。","基天明命，厥后克昌。","是孝是享，申锡无疆。"],["〔圜钟为宫三奏〕搜讲上仪，式修毖祀。","日吉辰良，礼成乐备。","风驭云旗，聿来歆止。","嘉我馨德，介兹繁祉。"],["〔黄钟为角一奏〕我将我享，涓选休成。","执事有恪，惟寅惟清。","乐既六变，肃雍和鸣。","高高在上，庶几是听。"],["〔太簇为征一奏〕礼崇禋祀，备物荐诚。","昭格穹昊，明德惟馨。","风马云车，肸蚃居歆。","申锡无疆，赉我思成。"],["〔姑洗为羽一奏〕惟天为大，物始攸资。","恭承禋祀，以报以祈。","神不可度，日监在兹。","有馨明德，庶其格思。"],["灵承上帝，厉意专精。","设洗于阼，罍水以清。","盥以致洁，感通神明。","无远弗届，其飨兹诚。"],["皇矣上帝，神格无方。","一阳肇复，典祀有常。","豆登丰洁，荐德清香。","棐诚居歆，降福穰穰。"],["治极发闻，不瑕有芬。","嘉玉陈币，神届欣欣。","诚心昭著，钦恭无文。","以妥以侑，笃祜何垠。"],["茫茫苍穹，孰知其纪。","精意潜通，虽远而迩。","量币荐诚，有实斯篚。","睠然顾之，永锡繁祉。"],["典祀有常，昭事上帝。","奉以告虔，逮迄奠币。","钟鼓既设，礼仪既备。","神之格思，恭承贶赐。"],["祀事孔明，礼文惟楙。","爰洁牺牲，载登俎豆。","或肆或将，无声无臭。","精祲潜通，永绥我后。"],["气萌黄钟，万物资始。","钦若高穹，吉蠲时祀。","神策泰元，增授无已。","群生熙熙，函蒙繁祉。"],["赫赫翼祖，受命于天。","德迈三代，威加八埏。","陟配上帝，明禋告虔。","流光垂裕，于万斯年。"],["大德曰生，阴阳寒暑。","乐舞形容，干戚籥羽。","一弛一张，退旅进旅。","神安乐之，祉锡绵宇。"],["惟圣普临，顺皇之德。","典礼有彝，享祀不忒。","笾豆静嘉，降登肸饬。","神具醉止，景贶咸集。"],["内心齐诚，外物蠲洁。","神来迪尝，俎豆既彻。","燕及群生，靡或夭阏。","降福穰穰，时万时亿。"],["于赫上帝，乘龙御天。","惟圣克事，明飨斯虔。","荐豆云彻，灵猋且旋。","载锡休祉，其惟有年。"],["灵承上帝，精意感通。","馨香旁达，粢盛既丰。","登降有仪，祀备乐终。","神之听之，福禄来崇。"],["帝出于震，巽惟齐明。","律曰姑洗，以示洁清。","我交于神，蠲意必精。","既盥而往，祈鉴斯诚。"],["阳动黄宫，日旋南极。","天门荡荡，百神受职。","爰熙紫坛，𤈶黄殊色。","神哉沛来，盖亲有德。"],["帝顾明德，监于克诚。","齐戒涤濯，式示洁清。","郊丘合祛，享意必精。","既盥而荐，熙事备成。"],["帝临崇坛，媪神其从。","稽古合祛，并侑神宗。","升阶奠玉，诚意感通。","贶施鼎来，受福无穷。"],["上穹昊天，日星垂曜。","照临下土，王国是保。","维玉与帛，寅恭昭报。","永左右之，钦若至道。"],["至哉坤厚，𬯎然止静。","柔载动植，资始成性。","玉光币色，璨若其映。","式恭禋祀，有邦之庆。"],["明明翼祖，并侑泰坛。","肇造绵宇，王业孔艰。","表正封略，上际下蟠。","躬以大报，亦止于燔。"],["赫赫巍巍，及时纯熙。","昊天成命，后则受之。","登迈邃古，光被声诗。","有币陟配，孙谋所贻。"],["躬展盛仪，天步逡巡。","乐备礼交，嘉玉既陈。","神方安坐，荐祉纷纶。","陟降有容，皇心载勤。"],["克昭王业，命成昊天。","泰畤禋燎，八陛惟圆。","肃然威仪，登降周旋。","是谓精享，神监吉蠲。"],["至大惟天，云何称德。","展诚致荐，牲用博硕。","诚以牲寓，帝由诚格。","居歆降祥，时万时亿。"],["帝出于震，巽惟洁齐。","神明其德，迺称禋柴。","惟兹吉蠲，昭事聿怀。","重盥而祀，敷锡孔皆。"],["谒款坛陛，祗祀泰禋。","丘圜自然，可格至神。","桂尊登酌，嘉荐芳新。","靡福菲眇，敷佑下民。"],["厚德光大，承元之明。","兹潜莩吹，升于昭清。","冰天桂海，咸资化成。","恭酌彝醪，报本惟精。"],["于赫皇祖，创业立极。","肃肃灵命，荡荡休德。","嘉觞精洁，雅奏金石。","丕显神谟，惟后之则。"],["丕铄帝宗，复受天命。","群阴犹黩，一戎大定。","奠鬯斯馨，功歌在咏。","佑启后人，文轨蚤正。"],["肆类上帝，怀柔百神。","槀秸既设，珪币既陈。","精诚潜交，已事而竣。","佑我亿载，基图日新。"],["恭展美报，聿修上仪。","礼乐和节，登降适宜。","德焉斯亲，神靡不娭。","海内承福，式固邦基。"],["泰元尊临，富媪繁祉。","于皇祖宗，既昭格止。","奏舞象功，灵其有喜。","永言孝思，尽善尽美。"],["阳丘其高，神祇并位。","既奠厥玉，既奉厥醴。","亦有嘉德，克相毖祀。","旨酒载爵，以成熙事。"],["爰熙紫坛，天地并贶。","来燕来宁，毕陈鬰鬯。","承神至尊，精意所乡。","告灵飨矣，祉福其畅。"],["帝临崇坛，媪神其从。","祖宗并歆，福禄攸同。","兵寝刑措，时和岁丰。","其膺受之，将施无穷。"],["八音克谐，降神出祇。","风马云车，陟降在兹。","锡我纯嘏，我应受之。","一人有庆，燕及群黎。"],["帝出于震，孝奏上仪。","燔燎膻芗，神徕燕娭。","肃若旧典，罔或不祗。","既右飨之，翕受蕃厘。"],["燎芗既升，焫膋以洁。","于豆于登，焄蒿有𫗣。","紫幄𤈶黄，神其安悦。","将以庆成，薄言盍彻。"],["九霄眇邈，神不可求。","何以降之，监德之修。","三献备成，神不可留。","何以送之，保天之休。"],["谓天盖高，阳嘘而生。","日月列宿，皆天之神。","肆求厥类，与阳俱升。","视燎于坛，以终其勤。"],["谓地盖厚，阴翕而成。","社稷群望，皆地之灵。","肆求厥类，与阴俱凝。","视瘗于坎，以终其勤。"],["舞具八佾，乐备六成。","大矣孝熙，厉意专精。","已事而竣，回轸还衡。","我应受之，以莫不增。"],["五辂鸣銮，八神警跸。","天官景从，莫不祗栗。","祲威盛容，昭哉祖述。","祚我无疆，叶气充溢。"],["合祀丘泽，登侑祖宗。","顾𬤊惟精，灵承惟恭。","有严皇仪，有庄帝容。","监于克诚，肃肃雍雍。"],["〔圜钟为宫〕天门荡荡，云车阴阴。","百神咸秩，三灵顾歆。","神哉来娭，神哉溥临。","飨时宋德，翼翼小心。"],["〔黄钟为角〕华盖既动，紫微洞开。","星枢周旋，日车徘徊。","灵兮顾佑，灵兮沛来。","载燕载娭，式时坛垓。"],["〔太簇为征〕泰尊媪厘，祖功宗德。","辰躔陪营，岳渎受职。","神哉来下，神哉来格。","飨德惟馨，留虞嘉席。"],["〔姑洗为羽〕金石宣昭，羽旄纷纶。","洁火夕照，明水夜陈。","娭哉惟灵，娭哉惟神。","风马招摇，惟德之亲。"],["皇帝俭勤，盥用陶瓦。","礼神颂祗，奠币献斝。","月鉴阴肃，醴液融冶。","挹彼注兹，礼无违者。"],["崇台穹窿，高灵下堕。","庆阴仿佛，从坐嶪峨。","宵升于丘，时通权火。","维天之命，百禄是荷。"],["帝飨于郊，一精二纯。","紫觚陟降，嘉玉妥陈。","神方留娭，瑞贶纷纶。","申锡无疆，螽斯振振。"],["肃肃礼度，𫓶𫓶宫奏。","天行徐谧，皇仪昭懋。","光连重璧，物备簋豆。","于皇以飨，无声无臭。"],["列俎孔陈，嘉笾维实。","鼎煁阳燧，玉流星液。","我牲既硕，我荐既苾。","神监下昭，安坐翔吉。"],["帝登初觞，礼严再盥。","精明显昭，齐颙洞贯。","灵娭留俞，神光炳焕。","我宋受福，永寿于万。"],["紫坛岳立，神光夜烛。","有俨旒采，有鸾佩玉。","霄垠顾佑，祖宗熙穆。","对越不忘，俾尔戬谷。"],["天容澄谧，景气晏和。","瓒斝荐醇，𫓶璆叶歌。","帝降庭止，夜其如何。","神助之休，宜尔众多。"],["甘露流英，卿云舒采。","灵俞有喜，神光晻暧。","穆穆来莅，洋洋如在。","帝用居歆，泽及四海。"],["听惟飨德，监惟棐忱。","顾𬤊思明，灵承思钦。","永言端莅，肃对下临。","上帝是皇，毋贰尔心。"],["羽籥陈容，干戚按节。","德闲而泰，功劳而决。","虞我神祇，扬我谟烈。","尽美尽善，福流有截。"],["帝临中坛，神从八陛。","华玉展瑞，明馨荐醴。","亦有嘉德，克相盛礼。","献兹重觞，降福弥弥。"],["敬事天地，升侑祖宗。","陈盥于三，介觞之重。","秉德翼翼，有来雍雍。","相予祀事，福嘏日溶。"],["孝奏展成，熙仪毕荐。","光流桂俎，祥衍椒奠。","风管晨凝，云容天转。","拜贶于郊，右序诒燕。"],["所飨惟清，所钦惟馨。","灵喜留俞，天景窈冥。","福禄来成，福禄来宁。","皇用时敛，寿我慈庭。"],["瓒斝觩䚧，觥罍氤氲。","有醴惟香，有酒惟欣。","肸蚃丰融，懿懿芬芬。","我龙受之，如川如云。"],["天锡多祉，皇受五福。","言瞻瑶坛，迄奉瑄玉。","昭星炳燿，元气回复。","帝仪载旋，有嘉穆穆。"],["璇图天深，鼎文日辉。","庆流皇家，象炳紫微。","干回冕旒，云焕衮衣。","何千万年，式于九围。"],["兰豆既升，簠簋既登。","礼备俎实，飨贵牲𦞪。","时乃告彻，器用毕兴。","祚我皇基，介福是膺。"],["神辅有德，来燕来娭。","礼荐熙成，三灵逆厘。","神飨有道，言旋言归。","福祉咸蒙，百世本支。"],["莫神乎天，阳嘘而生。","日月星辰，皆干之精。","肆求厥类，与阳俱升。","眡燎于坛，展也大成。"],["地载万物，阴翕而成。","山岳河渎，皆坤之灵。","克肖其象，与阴俱凝。","眡瘗于坎，思求厥成。"],["福方流胙，祈方钦柴。","卤簿载肃，球架允谐。","帝祉具临，皇灵允怀。","遄御于次，降福孔皆。"],["八神呵跸，千官景从。","回轸还衡，祲威盛容。","妥饰芝凤，御朝云龙。","归寿慈闱，敷时民雍。"],["天祚有开，文德来远。","祈谷日辛，侑神礼展。"],["於穆神宗，惟皇永命。","荐醴六尊，声歌千咏。"],["於穆思文，克配上帝。","涓选休成，遵扬严卫。","祗荐明诚，肃陈量币。","享兹吉蠲，申锡来裔。"],["三阳肇新，万物资始。","精诚祈天，其听斯迩。","愿均雨旸，田畴之喜。","如坻如京，以备百礼。"],["天锡勇智，允惟太宗。","功隆德盛，与帝比崇。","礼严陟配，诚达精衷。","尚其锡祉，岁以屡丰。"],["昊天盖高，祀事为大。","严配皇灵，亿福来介。"],["龙见而雩，神之来格。","牺象精良，威灵赫奕。"],["苍苍昊穹，覆临下土。","钦惟岁事，民所依怙。","爰竭精虔，礼典斯举。","甘泽以时，介我稷黍。"],["天何言哉，至清而健。","默定幽赞，降祥福善。","夙设圜坛，恭陈嘉荐。","贞驭下临，储休锡羡。","生物之祖，兴益之宗。","于国之阳，以禋昊穹。","六变降神，于论鼓钟。","亲德享道，锡羡无穷。"],["礼经之重，祭典为宗。","上公摄事，登降弥恭。","庶品丰洁，令仪肃雍。","百神萃止，惟吉之从。"],["礼崇禋祀，神鉴孔明。","牲牷博腯，以炰以烹。","馨香蠲洁，品物惟精。","锡以纯嘏，享兹至诚。"],["簠簋既陈，吉蠲登荐。","洗心防邪，肃祗祭典。","陟降惟寅，笾豆有践。","百福咸宜，淳耀丕显。"],["秩秩礼文，肃肃严祀。","仰洽神休，式协民纪。","灌献有容，叙其俎簋。","明德惟馨，以介丕祉。"],["帝临中坛，肃恭禋祀。","灵景舒光，飞龙旋轨。","送神有章，神心具醉。","辅德惟仁，永锡元祉。"],["四序伊始，三阳肇新。","气迎东郊，蛰户咸春。","功宣播殖，泽被生民。","祝史正辞，昭事惟寅。"],["条风始至，盛德在木。","平秩东作，种献穜穋。","律应青阳，气和玉烛。","惠彼兆民，以介景福。"],["备物致用，荐羞神明。","礼成乐举，克享克禋。"],["条风斯应，候历维新。","阳和启蛰，品物皆春。","篪簧协奏，簠簋毕陈。","精羞丰荐，景福攸臻。"],["长嬴戒序，候正南讹。","功资蕃育，气应清和。","鼎实嘉俎，乐备登歌。","神其来享，降福孔多。"],["象分离位，德配炎精。","景风协律，化神含生。","百嘉茂育，乃顺高明。","神无常享，享于克诚。"],["笾豆有践，黍稷惟馨。","礼终三献，神归杳冥。"],["坤舆厚载，黄裳元吉。","宅中居正，含章抱质。","分王四季，其功靡秩。","育此群生，首兹六律。"],["中央定位，厚德惟新。","五行攸正，四气爰均。","笙镛以间，簠簋斯陈。","为民祈福，肃奉明禋。"],["土德居中，方舆配位。","乐以送神，式申昭事。"]]