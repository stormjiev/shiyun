{"meta":{"id":"p348","name":"黄滔","dynasty":"tang","category":"tang","poemCount":221,"desc":"黄滔，字文江，莆田人。昭宗干宁二年，擢进士第。光化中，除四门博士，寻迁监察御史里行，充威武军节度推官。王审知据有全闽，而终其身为节将者，滔规正有力焉。集十五卷，今编诗三卷。   黄滔字文江，莆田人。补诗一首。"},"bodyChunkSize":128,"poems":[{"title":"送僧归北岩寺"},{"title":"寓言"},{"title":"长安书事"},{"title":"贾客"},{"title":"寄友人"},{"title":"落花"},{"title":"寄徐正字夤"},{"title":"秋夕贫居"},{"title":"书怀寄友人"},{"title":"闺怨"},{"title":"喜翁文尧员外病起"},{"title":"寄郑县李侍御"},{"title":"上李补阙"},{"title":"送李山人往湘中"},{"title":"书崔少府居"},{"title":"敷水卢校书"},{"title":"寄汉上友人"},{"title":"贻林铎"},{"title":"书怀"},{"title":"送陈明府归衡阳"},{"title":"秋辞江南"},{"title":"入关旅次言怀"},{"title":"贻李山人"},{"title":"寄边上从事"},{"title":"题东林寺元祐上人院"},{"title":"送陈樵下第东归"},{"title":"寄陈磻隐居"},{"title":"寄林宽"},{"title":"退居"},{"title":"送友人边游"},{"title":"下第出京"},{"title":"游东林寺"},{"title":"赠怀光上人"},{"title":"忆庐山旧游"},{"title":"别友人"},{"title":"陈侍御新居"},{"title":"寄从兄璞"},{"title":"寄李校书游简寂观"},{"title":"寄友人山居"},{"title":"上刑部卢员外"},{"title":"送友人游边"},{"title":"和友人酬寄"},{"title":"下第"},{"title":"过商山"},{"title":"旅怀"},{"title":"冬暮山舍喜标上人见访"},{"title":"关中言怀"},{"title":"题友人山居"},{"title":"寄敷水卢校书"},{"title":"赠明州霍员外"},{"title":"题友人山斋"},{"title":"书事"},{"title":"题山居逸人"},{"title":"题郑山人居"},{"title":"秋晚山居"},{"title":"游山"},{"title":"题王侍御宅内亭子"},{"title":"题道成上人院"},{"title":"贫居冬杪"},{"title":"贻张𧏖"},{"title":"晚春关中"},{"title":"河梁"},{"title":"送翁拾遗"},{"title":"逢友人"},{"title":"寄湘中郑明府"},{"title":"寄少常卢同年"},{"title":"伤翁外甥"},{"title":"东山之游未遂渐逼行期作四十字奉寄翁文尧员外"},{"title":"送林宽下第东归"},{"title":"商山赠隐者"},{"title":"送二友游湘中"},{"title":"塞下"},{"title":"下第东归留辞刑部郑郎中𫍯"},{"title":"寄怀南北故人"},{"title":"关中言怀"},{"title":"闺怨"},{"title":"旅怀"},{"title":"别友人"},{"title":"寄罗浮山道者二首 一"},{"title":"寄罗浮山道者二首 二"},{"title":"喜侯舍人蜀中新命三首 一"},{"title":"喜侯舍人蜀中新命三首 二"},{"title":"喜侯舍人蜀中新命三首 三"},{"title":"经安州感故郑郎中二首 一"},{"title":"经安州感故郑郎中二首 二"},{"title":"出京别崔学士"},{"title":"鴈"},{"title":"寄越从事林嵩侍御"},{"title":"长安书事"},{"title":"旅怀寄友人"},{"title":"寄蒋先辈"},{"title":"旅怀"},{"title":"放榜日"},{"title":"二月二日宴中贻同年封先辈渭"},{"title":"新野道中"},{"title":"酬俞钧"},{"title":"寄同年崔