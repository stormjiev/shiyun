{"meta":{"id":"p979","name":"张又新","dynasty":"tang","category":"tang","poemCount":28,"desc":"张又新，字孔昭，工部侍郎荐之子。元和中擢第，历左右补阙，坐李逢吉党，贬江州刺史，后附李训，迁刑部郎中。训死，复贬申州刺史。诗十七首。"},"bodyChunkSize":128,"poems":[{"title":"郡斋三月下旬作"},{"title":"五月水边柳"},{"title":"三月五日陪大夫泛长沙东湖"},{"title":"赠广陵妓"},{"title":"牡丹"},{"title":"游白鹤山"},{"title":"行田诗"},{"title":"罗浮山"},{"title":"青障山"},{"title":"中界山"},{"title":"帆游山"},{"title":"谢池"},{"title":"华盖山"},{"title":"吹台山"},{"title":"青㠗山"},{"title":"孤屿"},{"title":"春草池"},{"title":"谢庐山僧寄谷帘水"},{"title":"题常云峰（常云峰，去乐清县东八十里，在雁荡山西谷。以其「常」有云雾，登者心志则为澄霁。又名灵府山。）"},{"title":"太玉洞（句）"},{"title":"永嘉百咏 滴水卷"},{"title":"永嘉百咏"},{"title":"永嘉百咏 郭公山"},{"title":"永嘉百咏 大罗山"},{"title":"永嘉百咏 白鹤山"},{"title":"永嘉百咏 百里芳"},{"title":"永嘉百咏 周公庙"},{"title":"永嘉百咏"}]}