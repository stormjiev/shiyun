{"meta":{"id":"p242","name":"戴叔伦","dynasty":"tang","category":"tang","poemCount":330,"desc":"戴叔伦，字幼公，润州金坛人。刘晏管盐铁，表主运湖南。嗣曹王臯领湖南、江西，表佐幕府。臯讨李希烈，留叔伦领府事，试守抚州刺史。俄即真，迁容管经略使，绥徕蛮落，威名流闻。德宗尝赋中和节诗，遣使者宠赐，世以为荣。集十卷，今编诗二卷。  戴叔伦，字幼公，润州金坛人，刘晏管盐铁，表主运湖南，嗣曹王臯领湖南、江西，表佐幕府，臯讨李希烈，留叔伦领府事，试守抚州刺史，俄即真，迁容管经略使，绥徕蛮落，威名流闻，德宗尝赋中和节诗，遣使者宠赐，世以为荣。集十卷，今编诗二卷。"},"bodyChunkSize":128,"poems":[{"title":"横吹曲辞 关山月二首 一"},{"title":"横吹曲辞 关山月二首 二"},{"title":"相和歌辞 昭君词"},{"title":"相和歌辞 长门怨"},{"title":"杂曲歌辞 新别离"},{"title":"杂曲歌辞 独不见"},{"title":"独不见"},{"title":"去妇怨"},{"title":"古意"},{"title":"南野"},{"title":"曾游"},{"title":"江行"},{"title":"孤鸿篇"},{"title":"感怀二首 一"},{"title":"感怀二首 二"},{"title":"喜雨"},{"title":"叹葵花"},{"title":"从军行"},{"title":"九日与敬处士左学士同赋采菊上东山便为首句"},{"title":"奉天酬别郑谏议云逵卢拾遗景亮见别之作"},{"title":"梧桐"},{"title":"孤石"},{"title":"花"},{"title":"竹"},{"title":"怀素上人草书歌"},{"title":"女耕田行"},{"title":"柳花歌送客往桂阳"},{"title":"边城曲"},{"title":"屯田词"},{"title":"巫山高"},{"title":"早春曲"},{"title":"白苎词"},{"title":"行路难"},{"title":"相思曲"},{"title":"送别钱起"},{"title":"送张南史"},{"title":"春日早朝应制"},{"title":"早行寄朱山人放"},{"title":"除夜宿石头驿"},{"title":"吴明府自远而来留宿"},{"title":"客夜与故人偶集"},{"title":"送友人东归"},{"title":"江上别张欢"},{"title":"广陵送赵主簿自蜀归绛州宁觐"},{"title":"别友人"},{"title":"宿城南盛本道怀皇甫冉"},{"title":"晖上人独坐亭"},{"title":"送崔融"},{"title":"游少林寺"},{"title":"崇德道中"},{"title":"雨"},{"title":"过贾谊宅"},{"title":"冬日有怀李贺长吉"},{"title":"送郎士元"},{"title":"春江独钓"},{"title":"山居即事"},{"title":"赋得长亭柳"},{"title":"客中言怀"},{"title":"山行"},{"title":"春日访山人"},{"title":"卧病"},{"title":"赠月溪羽士"},{"title":"赠行脚僧"},{"title":"重游长真寺"},{"title":"晚望"},{"title":"寄赠翠岩奉上人"},{"title":"过龙湾五王阁访友人不遇"},{"title":"与友人过山寺"},{"title":"赋得古井送王明府"},{"title":"送耿十三𣲗复往辽海"},{"title":"寄禅师寺华上人次韵三首 一"},{"title":"寄禅师寺华上人次韵三首 二"},{"title":"寄禅师寺华上人次韵三首 三"},{"title":"独坐"},{"title":"李大夫见赠因之有呈"},{"title":"长沙送梁副端归京"},{"title":"和尉迟侍郎夏杪闻蝉"},{"title":"和李相公勉晦日蓬池游宴"},{"title":"彭婆馆逢韦判官使还"},{"title":"酬别刘九郎评事传经同泉字"},{"title":"汉南遇方评事"},{"title":"湘中怀古"},{"title":"京口怀古"},{"title":"逢友生言怀"},{"title":"长门怨"},{"title":"郊园即事寄萧侍郎"},{"title":"赠韦评事儹"},{"title":