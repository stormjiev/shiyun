{"meta":{"id":"p743","name":"于𣸣","dynasty":"tang","category":"tang","poemCount":51,"desc":"𣸣寓居尧山南六十里，里有富农，得氏琅琊，人指其貌，此多蔵者也。积粟万庾，马牛无算，血属星居于里土，生不遗，死不赠，环顾妻孥，意与天地等。故作是诗，用广知者。"},"bodyChunkSize":128,"poems":[{"title":"鼓吹曲辞 巫山高"},{"title":"横吹曲辞 陇头水"},{"title":"相和歌辞 宫怨"},{"title":"杂曲歌辞 古别离二首 一"},{"title":"杂曲歌辞 古别离二首 二"},{"title":"青楼曲"},{"title":"塞下曲"},{"title":"山村晓思"},{"title":"马嵬驿"},{"title":"苦辛吟"},{"title":"野蚕"},{"title":"秦原览古"},{"title":"古宴曲"},{"title":"南越谣"},{"title":"述己叹"},{"title":"辽阳行"},{"title":"旅馆秋思"},{"title":"长城"},{"title":"田翁叹"},{"title":"沙场夜"},{"title":"里中女"},{"title":"寒食"},{"title":"边游录戍卒言"},{"title":"古征战"},{"title":"山村叟"},{"title":"戍客南归"},{"title":"经馆娃宫"},{"title":"村居晏起"},{"title":"感怀"},{"title":"金谷感怀"},{"title":"恨从军"},{"title":"烧金曲"},{"title":"子从军"},{"title":"越溪女"},{"title":"巫山高"},{"title":"织素谣"},{"title":"拟古讽"},{"title":"赠太行开路者"},{"title":"戍卒伤春"},{"title":""},{"title":"早发"},{"title":"季夏逢朝客"},{"title":"陇头水"},{"title":"古别离 一"},{"title":"古别离 二"},{"title":"拟古意"},{"title":"陇头吟"},{"title":"思归引"},{"title":"秦富人"},{"title":"对花"},{"title":"宫怨"}]}