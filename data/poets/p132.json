{"meta":{"id":"p132","name":"姚合","dynasty":"tang","category":"tang","poemCount":558,"desc":"姚合，陕州硖石人，宰相崇曾孙。登元和进士第，授武功主簿，调富平、万年尉。宝历中监察御史、户部员外郎，出荆、杭州刺史，后为给事中、陕虢观察使。开成末，终秘书监，与马戴、与冠卿、殷尧藩、张籍游，李频师之。合诗名重于时，人称姚武功云。诗七卷。       姚合，陕州硖石人，宰相崇曾孙。登元和进士第，授武功主簿，调富平、万年尉。宝历中监察御史、户部员外郎，出荆、杭州刺史，后为给事中、陕虢观察使。开成末，终秘书监，与马戴、与冠卿、殷尧藩、张籍游，李频师之，合诗名重于时，人称姚武功云。诗七卷。"},"bodyChunkSize":128,"poems":[{"title":"送狄尚书镇太原"},{"title":"送杨尚书祭西岳"},{"title":"送李侍御过夏州"},{"title":"送李起居赴池州"},{"title":"送刘詹事赴寿州"},{"title":"送裴大夫赴亳州"},{"title":"送徐州韦仅行军"},{"title":"送刘禹锡郎中赴苏州 一"},{"title":"送刘禹锡郎中赴苏州 二"},{"title":"送贾謩赴共城营田"},{"title":"送裴宰君"},{"title":"送顾非熊下第归越"},{"title":"送雍陶游蜀"},{"title":"送崔约下第归扬州"},{"title":"送李廓侍御赴西川行营"},{"title":"送杨尚书赴东川"},{"title":"送邢郎中赴太原"},{"title":"送裴中丞赴华州"},{"title":"送徐员外赴河中从事"},{"title":"送殷尧藩侍御赴同州"},{"title":"送崔中丞赴郑州"},{"title":"送丁端公赴河阴"},{"title":"送郑尚书赴兴元"},{"title":"送田使君赴蔡州"},{"title":"送无可上人游边"},{"title":"送僧 一"},{"title":"送僧 二"},{"title":"送宋慎言"},{"title":"送家兄赴任昭义"},{"title":"送崔玄亮赴果州冬夜宴韩卿宅"},{"title":"送喻凫校书归毘陵"},{"title":"送董正字武归常州觐亲"},{"title":"送萧正字往蔡州贺裴相淮西平"},{"title":"送进士田卓入华山"},{"title":"送右司薛员外赴处州"},{"title":"送王建秘书往渭南庄"},{"title":"送殷尧藩侍御游山南"},{"title":"送李植侍御"},{"title":"送王澹"},{"title":"送崔之仁"},{"title":"送孙山人"},{"title":"送费骧"},{"title":"送河中杨少府宴崔驸马宅"},{"title":"送文著上人游越"},{"title":"送无可上人游越"},{"title":"送洛阳张员外"},{"title":"送少府田中丞入西藩"},{"title":"送王龟处士"},{"title":"送崔郎中赴常州"},{"title":"送林使君赴邵州"},{"title":"送别友人"},{"title":"送李琮归灵州觐省"},{"title":"送任畹评事赴沂海"},{"title":"送李余及第归蜀"},{"title":"送饶州张使君"},{"title":"送张宗原"},{"title":"送王求"},{"title":"送朱庆余及第后归越"},{"title":"送朱庆余越州归觐"},{"title":"送任尊师归蜀觐亲"},{"title":"送友人游蜀"},{"title":"送杜立归蜀"},{"title":"送韩湘赴江西从事"},{"title":"送潘传秀才归宣州"},{"title":"送僧默然"},{"title":"送陟遐上人游天台"},{"title":"送盛秀才赴举"},{"title":"送僧贞实归杭州天竺"},{"title":"送卢二弟茂才罢举游洛谒新相"},{"title":"送任畹及第归蜀中觐亲"},{"title":"送杜观罢举东游"},{"title":"送狄兼謩下第归故山"},{"title":"送源中丞赴新罗"},{"title":"送陈倜赴江陵从事"},{"title":"送张郎中副使赴泽潞"},{"title":"送陆畅侍御归扬州"},{"title":"送韦瑶校书赴越"},{"title":"送雍陶及第归觐"},{"title":"送李秀才赴举"},{"title":"送李传秀才归宣州"},{"title":"送元