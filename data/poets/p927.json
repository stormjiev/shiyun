{"meta":{"id":"p927","name":"冯伯规","dynasty":"song","category":"song","poemCount":36,"desc":"冯伯规，岷州（今甘肃岷县）人。光宗绍熙元年（一一九○）知巴州（《金石苑·冯伯规题字》）。今录诗三十一首。"},"bodyChunkSize":128,"poems":[{"title":"初至郡讲禊饮于江上夜归赋此"},{"title":"继而稍旱祷而复雨喜而作诗"},{"title":"次韵谢史提干见知"},{"title":"次韵酬李通江"},{"title":"次韵中秉教授喜雨之作"},{"title":"季春下澣游南龛"},{"title":"观涨"},{"title":"次韵泛舟仲秉有诗"},{"title":"次日游西龛再用韵"},{"title":"端午前三日观坡诗首夏官舍即事因次其韵"},{"title":"登云间阁"},{"title":"浄凉夜坐"},{"title":"偶得新粳□送仲秉"},{"title":"雨后观涨"},{"title":"祷晴获应喜而赋诗"},{"title":"先期登高观菊岩新榜"},{"title":"次韵忠甫初见菊开"},{"title":"击瓯楼夜饮  其一"},{"title":"击瓯楼夜饮  其二"},{"title":"次韵仲秉木犀"},{"title":"游北岩"},{"title":"约同僚游佳阴  其一"},{"title":"约同僚游佳阴  其二"},{"title":"约同僚游佳阴  其三"},{"title":"□后圃成三绝句  其一"},{"title":"□后圃成三绝句  其二"},{"title":"□后圃成三绝句  其三"},{"title":"岁晚倚栏"},{"title":"登赋诗楼"},{"title":"次韵刘阆州谢送菊岩春"},{"title":"无题"},{"title":"净凉夜坐"},{"title":"季春下浣游南龛"},{"title":"击瓯楼夜饮"},{"title":"约同僚游佳阴"},{"title":"□后圃成三绝句"}]}