{"meta":{"id":"p623","name":"刘言史","dynasty":"tang","category":"tang","poemCount":92,"desc":"刘言史，邯郸人，与李贺同时。歌诗美丽恢赡，自贺外，世莫能比，亦与孟郊友善。初客镇冀，王武俊奏为枣强令，辞疾不受，人因称为刘枣强。后客汉南，李夷简署司空掾，寻卒。歌诗六卷，今编一卷。"},"bodyChunkSize":128,"poems":[{"title":"相和歌辞 长门怨"},{"title":"杂曲歌辞 乐府二首 一"},{"title":"杂曲歌辞 乐府二首 二"},{"title":"苦妇词"},{"title":"与孟郊洛北野泉上煎茶"},{"title":"七夕歌"},{"title":"立秋日"},{"title":"题茅山仙台药院"},{"title":"送婆罗门归本国"},{"title":"潇湘游"},{"title":"放萤怨"},{"title":"观绳伎"},{"title":"买花谣"},{"title":"王中丞宅夜观舞胡腾"},{"title":"竹里梅"},{"title":"春过赵墟"},{"title":"初下东周赠孟郊"},{"title":"过春秋峡"},{"title":"长门怨"},{"title":"春游曲 一"},{"title":"春游曲 二"},{"title":"广州王园寺伏日即事寄北中亲友"},{"title":"立秋"},{"title":"别落花"},{"title":"登甘露台"},{"title":"夜泊润州江口"},{"title":"看山木瓜花二首 一"},{"title":"看山木瓜花二首 二"},{"title":"题十三弟竹园"},{"title":"乐府杂词三首 一"},{"title":"乐府杂词三首 二"},{"title":"乐府杂词三首 三"},{"title":"岁暮题杨录事江亭"},{"title":"冬日峡中旅泊"},{"title":"泊花石浦"},{"title":"闻崔倚旅葬"},{"title":"赋蕃子牧马"},{"title":"牧马泉"},{"title":"越井台望"},{"title":"扶病春亭"},{"title":"赠童尼"},{"title":"读故友于君集"},{"title":"病僧二首 一"},{"title":"病僧二首 二"},{"title":"右军墨池"},{"title":"送僧归山"},{"title":"题源分竹亭"},{"title":"山寺看樱桃花题僧壁"},{"title":"伤清江上人"},{"title":"山寺看海榴花"},{"title":"赠成炼师四首 一"},{"title":"赠成炼师四首 二"},{"title":"赠成炼师四首 三"},{"title":"赠成炼师四首 四"},{"title":"上巳日陪襄阳李尚书宴光风亭"},{"title":"奉酬"},{"title":"病中客散复言怀"},{"title":"处州月夜穆中丞席和主人"},{"title":"寻花"},{"title":"赠陈长史妓"},{"title":"题王况故居"},{"title":"偶题"},{"title":"恸柳论"},{"title":"夜入简子古城"},{"title":"桂江中题香顶台"},{"title":"僧簷前独竹咏"},{"title":"送人随姊夫任云安令"},{"title":"山中喜崔补阙见寻"},{"title":"偶题二首 一"},{"title":"偶题二首 二"},{"title":"嘉兴社日"},{"title":"席上赠李尹"},{"title":"弼公院问病"},{"title":"惜花"},{"title":"代胡僧留别"},{"title":"桂江逢王使君旅榇归"},{"title":"玉京词"},{"title":"葛巾歌"},{"title":"北原情三首 一"},{"title":"北原情三首 二"},{"title":"北原情三首 三"},{"title":"林中独醒"},{"title":"江陵客舍留别樊尚书"},{"title":"赠成鍊师四首 其一"},{"title":"赠成鍊师四首 其四"},{"title":"看山木瓜花二首"},{"title":"病僧二首"},{"title":"赠成鍊师四首"},{"title":"偶题二首"},{"title":"春游曲"},{"title":"北原情三首"},{"title":"乐府杂词三首"}]}