{"meta":{"id":"p271","name":"李端","dynasty":"tang","category":"tang","poemCount":293,"desc":"李端，字正已，赵郡人，大历五年进士。与卢纶、吉中孚、韩翃、钱起、司空曙、苗发、崔峒、耿𣲗、夏侯审唱和，号大历十才子。尝客驸马郭暧第，赋诗冠其坐客。初授校书郎，后移疾江南，官杭州司马卒。集三卷，今编诗三卷。"},"bodyChunkSize":128,"poems":[{"title":"鼓吹曲辞 巫山高"},{"title":"横吹曲辞 折杨柳"},{"title":"横吹曲辞 关山月"},{"title":"横吹曲辞 雨雪曲"},{"title":"相和歌辞 度关山"},{"title":"相和歌辞 昭君词"},{"title":"相和歌辞 乌栖曲"},{"title":"相和歌辞 襄阳曲"},{"title":"琴曲歌辞 王敬伯歌"},{"title":"杂曲歌辞 妾薄命三首 一"},{"title":"杂曲歌辞 妾薄命三首 二"},{"title":"杂曲歌辞 妾薄命三首 三"},{"title":"杂曲歌辞 千里思"},{"title":"杂曲歌辞 古别离二首 一"},{"title":"杂曲歌辞 古别离二首 二"},{"title":"杂曲歌辞 荆州泊"},{"title":"杂曲歌辞 春游乐二首 一"},{"title":"杂曲歌辞 春游乐二首 二"},{"title":"古别离二首 一"},{"title":"古别离二首 二"},{"title":"折杨柳"},{"title":"留别柳中庸"},{"title":"野亭三韵送钱员外"},{"title":"归山招王逵"},{"title":"过谷口元赞善所居"},{"title":"旅次岐山得山友书却寄凤翔张尹"},{"title":"九日赠司空文明"},{"title":"芜城"},{"title":"送吉中孚拜官归楚州"},{"title":"荆州泊"},{"title":"春游乐"},{"title":"千里思"},{"title":"白鹭咏"},{"title":"冬夜与故友聚送吉校书"},{"title":"与苗员外山行"},{"title":"早春同庾侍郎题青龙上方院"},{"title":"送从叔赴洪州"},{"title":"送路司谏侍从叔赴洪州"},{"title":"病后游青龙寺"},{"title":"夜寻司空文明逢深上人因寄晋侍御"},{"title":"长安书事寄薛戴"},{"title":"鲜于少府宅看花"},{"title":"慈恩寺怀旧"},{"title":"赠薛戴"},{"title":"东门送客"},{"title":"送韩绅卿"},{"title":"襄阳曲"},{"title":"胡腾儿"},{"title":"赠康洽"},{"title":"瘦马行"},{"title":"杂歌呈郑锡司空文明"},{"title":"杂歌"},{"title":"乌栖曲"},{"title":"送客东归"},{"title":"王敬伯歌"},{"title":"救生寺望春寄畅当"},{"title":"荆门歌送兄赴夔州"},{"title":"妾薄命"},{"title":"关山月"},{"title":"度关山"},{"title":"巫山高"},{"title":"雨雪曲"},{"title":"春游乐"},{"title":"山下泉"},{"title":"送客赴洪州"},{"title":"与郑锡游春"},{"title":"送友人"},{"title":"题从叔沆林园"},{"title":"送少微上人入蜀"},{"title":"雨后游辋川"},{"title":"同皇甫侍御题惟一上人房"},{"title":"同苗员外宿荐福寺僧舍"},{"title":"送客往湘江"},{"title":"送友人游蜀"},{"title":"送友人游江东"},{"title":"送乐平苗明府得家字"},{"title":"过宋州"},{"title":"茂陵山行陪韦金部"},{"title":"江上逢司空曙"},{"title":"逢王泌自东京至"},{"title":"山中期吉中孚"},{"title":"酬前大理寺评事张芬"},{"title":"赋得山泉送房造"},{"title":"宿兴善寺后堂池"},{"title":"忆皎然上人"},{"title":"赠衡岳隐禅师"},{"title":"云阳观寄袁稠"},{"title":"晚游东田寄司空曙"},{"title":"题崔端公园林"},{"title":"早春雪夜寄卢纶兼呈秘书元丞"},{"ti