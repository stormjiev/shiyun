{"meta":{"id":"p969","name":"储泳","dynasty":"song","category":"song","poemCount":29,"desc":"储泳，字文卿，号华谷，云间（今上海松江）人（《江湖后集》卷一一）。与陈郁（藏一）有交游。有《华谷诗藁》（《永乐大典》卷二八一三），已佚，存《华谷祛疑说》一卷。今录诗二十八首。"},"bodyChunkSize":128,"poems":[{"title":"题隠者所居"},{"title":"秋夕怀友"},{"title":"题胡琴窗方径"},{"title":"清閟轩"},{"title":"送春"},{"title":"闻采石分司芸隠讣"},{"title":"小园"},{"title":"亭下"},{"title":"思归"},{"title":"送人游边"},{"title":"送兄潮举"},{"title":"寄兄玉老"},{"title":"淀山寺"},{"title":"悼古镜果佛慧法师"},{"title":"送陈云崖"},{"title":"送卢萍斋"},{"title":"红药"},{"title":"涵虚阁"},{"title":"春日郊行"},{"title":"柬藏一"},{"title":"胡定斋惠墨求诗"},{"title":"春昼"},{"title":"送人"},{"title":"觉来"},{"title":"登涟漪阁"},{"title":"光风霁月亭"},{"title":"题梅坞画推蓬梅"},{"title":"月岩"},{"title":"齐天乐"}]}