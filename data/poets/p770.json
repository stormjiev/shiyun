{"meta":{"id":"p770","name":"郑起","dynasty":"song","category":"song","poemCount":49,"desc":"郑起，字孟隆。举进士。后周广顺初为尉氏簿，累官殿中侍御史。宋太祖干德初，掌泗州市征，出为河西令（《续资治通鉴长编》卷四）。《宋史》卷四三九有传。"},"bodyChunkSize":128,"poems":[{"title":"赠英公大师"},{"title":"烂柯山"},{"title":"卜居"},{"title":"自黄山还途中作"},{"title":"谒岳王坟"},{"title":"次照晦岩韵"},{"title":"再登南楼"},{"title":"思耕"},{"title":"登荆南城楼"},{"title":"宿虎丘"},{"title":"宿洞霄山中"},{"title":"喜静"},{"title":"余杭界早发"},{"title":"余杭道上"},{"title":"病后"},{"title":"归去好"},{"title":"送友人之淮"},{"title":"吴江三高祠堂"},{"title":"吴江太湖龙王殿"},{"title":"荆南别贾制书东归"},{"title":"送友人之鄂"},{"title":"晚春即事"},{"title":"荆江口望见君山"},{"title":"繁昌江边见两獭祭鱼人立而拜"},{"title":"虎丘尹和靖书院示开讲"},{"title":"为九华王此山赋宁石"},{"title":"关山月"},{"title":"赤壁歌"},{"title":"君乘黄"},{"title":"天高高"},{"title":"采桑曲"},{"title":"樵歌三首  其一"},{"title":"樵歌三首  其二"},{"title":"樵歌三首  其三"},{"title":"读冯道传"},{"title":"短歌行"},{"title":"饮马长城窟"},{"title":"鄂州南楼"},{"title":"洞庭君山辞"},{"title":"辞吊富沙梨山大王祠"},{"title":"招魂酹翁宾旸"},{"title":"采莲曲"},{"title":"寄题梵才大士台州安隠堂"},{"title":"寄题杭州广法善堂"},{"title":"题画兰"},{"title":"句"},{"title":"馀杭道上"},{"title":"馀杭界早发"},{"title":"樵歌三首"}]}