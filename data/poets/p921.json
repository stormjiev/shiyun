{"meta":{"id":"p921","name":"沈亚之","dynasty":"tang","category":"tang","poemCount":37,"desc":"沈亚之，字下贤，吴兴人。登元和十年进士第，历殿中丞御史、内供奉。太和初，为德州行营使柏耆判官，耆贬，亚之亦谪南康尉，终郢州掾。集九卷，今编诗一卷。"},"bodyChunkSize":128,"poems":[{"title":"虎丘山真娘墓"},{"title":"荅殷尧藩赠罢泾源记室"},{"title":"五月六日发石头城步望前船示舍弟兼寄侯郎"},{"title":"别庞子肃"},{"title":"春色满皇州"},{"title":"宿白马津寄寇立"},{"title":"汴州船行赋岸傍所见"},{"title":"送文颕上人游天台"},{"title":"宿后自华阳行次昭应寄王直方"},{"title":"题海榴树呈八叔大人"},{"title":"西蕃请谒庙"},{"title":"劝政楼下观百官献寿"},{"title":"山出云"},{"title":"曲江亭望慈恩杏花发"},{"title":"村居"},{"title":"春词酬元微之"},{"title":"题侯仙亭"},{"title":"送庞子肃"},{"title":"梦挽秦弄玉"},{"title":"梦别秦穆公"},{"title":"梦游秦宫"},{"title":"湘中怨 一"},{"title":"湘中怨 二"},{"title":"文祝延二阕 一"},{"title":"文祝延二阕 二"},{"title":"秦梦诗三首 一"},{"title":"秦梦诗三首 二"},{"title":"秦梦诗三首 三"},{"title":"传奇小说（诗句）"},{"title":"梦游仙赋附诗 一"},{"title":"梦游仙赋附诗 二"},{"title":"湘中怨解载郑生愁吟"},{"title":"书俗各两句 其一"},{"title":"文祝延二阕 其二 酬神"},{"title":"湘中怨"},{"title":"文祝延二阕 祈神"},{"title":"梦游仙赋附诗"}]}