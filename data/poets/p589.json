{"meta":{"id":"p589","name":"马之纯","dynasty":"song","category":"song","poemCount":96,"desc":"马之纯（一一四四？～？），字师文，学者称野亭先生，金华（今属浙江）人。弱冠登孝宗隆兴元年（一一六三）进士，授福州司法参军。宁宗庆元间，主管江东转运司文字。秩满，授静江府通判，未赴，卒于家。有《金陵百咏》等。《景定建康志》卷四九有传。　马之纯诗，据《景定建康志》所录，编为一卷。"},"bodyChunkSize":128,"poems":[{"title":"焚衣街"},{"title":"乌衣巷"},{"title":"宋帝驰道"},{"title":"白杨路"},{"title":"周郎桥"},{"title":"二十四航"},{"title":"四航"},{"title":"麾扇渡"},{"title":"鸡鸣埭"},{"title":"桂岭"},{"title":"栽松岘"},{"title":"秦淮"},{"title":"玄武湖"},{"title":"半阳湖"},{"title":"燕雀湖"},{"title":"青溪  其一"},{"title":"青溪  其二"},{"title":"潮沟"},{"title":"直渎"},{"title":"善泉池"},{"title":"覆杯池"},{"title":"栅塘"},{"title":"横塘"},{"title":"景阳井"},{"title":"应潮井"},{"title":"藏冰井"},{"title":"八功德水"},{"title":"汝南湾"},{"title":"长命洲"},{"title":"仪贤堂"},{"title":"蚕堂"},{"title":"白鹭亭"},{"title":"白鹭亭和人韵"},{"title":"东冶亭"},{"title":"新亭  其一"},{"title":"新亭  其二"},{"title":"新亭  其三"},{"title":"白下亭"},{"title":"劳劳亭"},{"title":"不受暑亭"},{"title":"凤凰台"},{"title":"雨花台"},{"title":"烽火台"},{"title":"独足台"},{"title":"齐云观"},{"title":"层城观"},{"title":"古华林苑"},{"title":"古芳林苑"},{"title":"古南苑"},{"title":"咏台城"},{"title":"石麒麟"},{"title":"断碑"},{"title":"钟山"},{"title":"石头城"},{"title":"幕府山"},{"title":"灵和殿前蜀柳"},{"title":"天阙山"},{"title":"清暑殿"},{"title":"梅梁殿"},{"title":"潜鹤鼓"},{"title":"促粧钟"},{"title":"铜螭署"},{"title":"金城柳"},{"title":"东山谢安"},{"title":"披香殿"},{"title":"古越城"},{"title":"西州城"},{"title":"王导宅"},{"title":"陆机宅"},{"title":"沈约宅"},{"title":"江总宅"},{"title":"三山"},{"title":"卞壸墓"},{"title":"谢安墓"},{"title":"冥漠君墓"},{"title":"蒋帝庙  其一"},{"title":"蒋帝庙  其二"},{"title":"晋谢将军庙"},{"title":"晋阴山庙"},{"title":"蒋山太平兴国禅寺"},{"title":"清凉广惠禅寺  其一"},{"title":"清凉广惠禅寺  其二"},{"title":"天禧寺阿育王塔"},{"title":"佛窟寺"},{"title":"祀马将军竹枝辞  其一"},{"title":"祀马将军竹枝辞  其二"},{"title":"祀马将军竹枝辞  其三"},{"title":"祀马将军竹枝辞  其四"},{"title":"祀马将军竹枝辞  其五"},{"title":"祀马将军竹枝辞  其六"},{"title":"祀马将军竹枝辞  其七"},{"title":"祀马将军竹枝辞  其八"},{"title":"拟岘亭诗"},{"title":"新亭"},{"title":"蒋帝庙"},{"title":"祀马将军竹枝辞"}]}