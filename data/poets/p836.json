{"meta":{"id":"p836","name":"释蕴常","dynasty":"song","category":"song","poemCount":39,"desc":"释蕴常，字不轻（《舆地纪胜》卷五）。居丹徒嘉山，与苏庠相倡酬，后苏庠弟祖可为僧，遂与之偕往庐山（《曲阿诗综》卷八）。有《荷屋集》（《天台续集别编》卷五），已佚。今录诗十首。"},"bodyChunkSize":128,"poems":[{"title":"咏石菖蒲"},{"title":"咏兰"},{"title":"送空上人"},{"title":"天竺道中"},{"title":"知止亭晚望寄清大师"},{"title":"别苏养直"},{"title":"登虎丘即事"},{"title":"春日"},{"title":"江村"},{"title":"游天台赤城山"},{"title":"句  其一"},{"title":"句  其二"},{"title":"句  其三"},{"title":"句  其四"},{"title":"句  其五"},{"title":"句  其六"},{"title":"句  其七"},{"title":"句  其八"},{"title":"句  其九"},{"title":"句  其一○"},{"title":"句  其一一"},{"title":"句  其一二"},{"title":"句  其一三"},{"title":"句  其一四"},{"title":"句  其一五"},{"title":"句  其一六"},{"title":"句  其一七"},{"title":"句  其一八"},{"title":"句  其一九"},{"title":"句  其二○"},{"title":"句  其二一"},{"title":"句  其二二"},{"title":"句  其二三"},{"title":"句  其二四"},{"title":"句  其二五"},{"title":"句  其二六"},{"title":"句  其二七"},{"title":"句  其二八"},{"title":"句  其二九"}]}