{"meta":{"id":"p959","name":"朱放","dynasty":"tang","category":"tang","poemCount":29,"desc":"朱放，字长通，襄州人。隐于越之剡溪，嗣曹王臯镇江西，辟节度参谋。贞元初，召为拾遗，不就。诗一卷。"},"bodyChunkSize":128,"poems":[{"title":"相和歌辞 铜雀妓"},{"title":"剡溪行却寄新别者"},{"title":"九日陪刘中丞宴昌乐寺送梁廷评"},{"title":"经故贺宾客镜湖道士观"},{"title":"送著公归越"},{"title":"秣陵送客入京"},{"title":"灵门寺赠灵一上人"},{"title":"江上送别"},{"title":"归桐庐旧居寄严长史"},{"title":"竹"},{"title":"铜雀妓"},{"title":"毘陵留别"},{"title":"题竹林寺"},{"title":"答陆[澧]"},{"title":"杨子津送人"},{"title":"山中谒皇甫曾"},{"title":"剡山夜月"},{"title":"九日与杨凝崔淑期登江上山会有故不得往因赠之"},{"title":"山中听子规"},{"title":"乱后经淮阴岸"},{"title":"送张山人"},{"title":"别李季兰"},{"title":"游石涧寺"},{"title":"新安所居答相访人所居萧使君为制"},{"title":"送魏校书"},{"title":"送温台"},{"title":"句"},{"title":"留别刘员外"},{"title":"和萧郎中游兰若"}]}