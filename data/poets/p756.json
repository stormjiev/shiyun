{"meta":{"id":"p756","name":"崔峒","dynasty":"tang","category":"tang","poemCount":49,"desc":"崔峒，博陵人。登进士第，为拾遗，集贤学士，终于州刺史。《艺文传》云：“终右补阙，大历十才子之一也。”诗一卷。"},"bodyChunkSize":128,"poems":[{"title":"扬州选蒙相公赏判雪后呈上"},{"title":"客舍书情寄赵中丞"},{"title":"客舍有怀因呈诸在事"},{"title":"书怀寄杨郭李王判官"},{"title":"奉和给事寓直"},{"title":"初入集贤院赠李献仁"},{"title":"酬李补阙雨中寄赠"},{"title":"初除拾遗酬丘二十二见寄"},{"title":"刘展下判官相招以诗答之"},{"title":"送侯山人赴会稽"},{"title":"宿禅智寺上方演大师院"},{"title":"题空山人石室"},{"title":"登蒋山开善寺"},{"title":"题崇福寺禅院"},{"title":"秋晚送丹徒许明府赴上国因寄江南故人"},{"title":"送薛仲方归扬州"},{"title":"送韦员外还京"},{"title":"润州送友人"},{"title":"送张芬东归"},{"title":"送苏修游上饶"},{"title":"送陆明府之盱眙"},{"title":"江南回逢赵曜因送任十一赴交城主簿"},{"title":"送薛良史往越州谒从叔"},{"title":"送丘二十二之苏州"},{"title":"登润州芙蓉楼"},{"title":"江上书怀"},{"title":"春日忆姚氏外甥"},{"title":"送真上人还兰若"},{"title":"润州送师弟自江夏往台州"},{"title":"送李道士归山"},{"title":"宿江西窦主簿厅"},{"title":"喜逢妻弟郑损因送入京"},{"title":"咏门下画小松上元王杜三相公"},{"title":"寄上礼部李侍郎"},{"title":"书情寄上苏州韦使君兼呈吴县李明府"},{"title":"题桐庐李明府官舍"},{"title":"赠窦十九"},{"title":"虔州见郑表新诗因以寄赠"},{"title":"赠元秘书"},{"title":"送韦八少府判官归东京"},{"title":"送冯八将军奏事毕归滑台幕府"},{"title":"送王侍御佐婺州"},{"title":"越中送王使君赴江华"},{"title":"送皇甫冉往白田"},{"title":"题兰若"},{"title":"送贺兰广赴选"},{"title":"清江曲内一绝"},{"title":"武康郭外望许纬先生山居"},{"title":"句"}]}