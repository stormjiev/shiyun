{"meta":{"id":"p942","name":"释圆悟","dynasty":"song","category":"song","poemCount":33,"desc":"释圆悟，号枯崖，福清（今属福建）人。能诗画，喜作竹石。理宗淳祐间住泉州光福寺，有《枯崖集》（《竹溪鬳斋十一稿续集》卷一○《泉州重修兴福寺记》），已佚。《画史会要》卷三有传。今录诗二十九首。"},"bodyChunkSize":128,"poems":[{"title":"游清源洞"},{"title":"山中四首  其一"},{"title":"山中四首  其二"},{"title":"山中四首  其三"},{"title":"山中四首  其四"},{"title":"海云阁"},{"title":"重游清源洞"},{"title":"小立"},{"title":"晚渡"},{"title":"游静真观"},{"title":"题泉州张许祠"},{"title":"和胡教授山庵见访归韵"},{"title":"大帽山"},{"title":"山中夜归"},{"title":"瑞兴寺"},{"title":"真人洞"},{"title":"和黄瑞玉山庵"},{"title":"赵山神祠"},{"title":"题秦君亭"},{"title":"承天寺寻勤上人"},{"title":"次姜秦祠和胡教授韵"},{"title":"题宝山寺二首  其一"},{"title":"题宝山寺二首  其二"},{"title":"宿友人白云庵三首  其一"},{"title":"宿友人白云庵三首  其二"},{"title":"宿友人白云庵三首  其三"},{"title":"送壁上人归承天寺"},{"title":"方海丰诗境楼分赋得春风"},{"title":"寄方俊甫"},{"title":"句"},{"title":"山中四首"},{"title":"题宝山寺二首"},{"title":"宿友人白云庵三首"}]}