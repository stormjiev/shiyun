{"meta":{"id":"p668","name":"陈必复","dynasty":"song","category":"song","poemCount":70,"desc":"陈必复，字无咎，号药房，长乐（今属福建）人。宁宗嘉定间居封禺山中，结屋为药房吟所。理宗淳祐十年（一二五○）进士（《江湖后集》卷二三）。十一年为林尚仁《端隠吟稿》作序。著作已佚，仅《南宋六十家小集》中存《山居存稿》一卷。事见《南宋六十家小集·端隠吟稿》序。　陈必复诗，据汲古阁影宋抄《南宋六十家小集》及影印文渊阁《四库全书·江湖后集》等书所录，编为一卷。"},"bodyChunkSize":128,"poems":[{"title":"山居"},{"title":"领客游闻人氏省庵园"},{"title":"搆得"},{"title":"百五节"},{"title":"赠林尚仁"},{"title":"舟中得催字"},{"title":"客枕"},{"title":"归自德清"},{"title":"游前溪西庵"},{"title":"赠张𬳶"},{"title":"东野故居"},{"title":"响应寺"},{"title":"宿龙山精舍"},{"title":"僧房"},{"title":"山中书事"},{"title":"晓步"},{"title":"吴江道中"},{"title":"和客用韵"},{"title":"舟行崇德"},{"title":"嘉禾境上"},{"title":"寄石泉云间明府叔  其一"},{"title":"寄石泉云间明府叔  其二"},{"title":"寄石泉云间明府叔  其三"},{"title":"席上和林端隠韵"},{"title":"梅花"},{"title":"防风氏庙"},{"title":"偶成"},{"title":"舟中效东坡用韵"},{"title":"春日偕游响应山观瀑泉饮漱玉亭上分复磴拥危泉赋磴韵十四"},{"title":"题东坡画像"},{"title":"村家"},{"title":"积潦简友人"},{"title":"苇迳"},{"title":"东吴逆旅"},{"title":"远游"},{"title":"雨晴小步"},{"title":"晨征"},{"title":"出郭"},{"title":"郊行"},{"title":"漏长"},{"title":"意行"},{"title":"偶出"},{"title":"书西斋几"},{"title":"迟客小轩"},{"title":"赋参政叔祖水亭"},{"title":"夜宿山庵"},{"title":"书斋戏题"},{"title":"江湖"},{"title":"过隠者居"},{"title":"奉酬陈介庵明府桐江见寄"},{"title":"戏折竹叶为舟示奚奴"},{"title":"元日酌悠然赋坐客悠字韵"},{"title":"重过东野故居"},{"title":"归来"},{"title":"幽兴"},{"title":"山中冬至"},{"title":"夜轩纳凉"},{"title":"五月十三日偶成"},{"title":"漫赋"},{"title":"读后山诗"},{"title":"夜发江城"},{"title":"远游"},{"title":"闻虏退后作"},{"title":"咏狂虏"},{"title":"松江"},{"title":"还西里所居"},{"title":"过隐者居"},{"title":"苇径"},{"title":"赠张駉"},{"title":"寄石泉云间明府叔"}]}