{"meta":{"id":"p819","name":"赵汝绩","dynasty":"song","category":"song","poemCount":45,"desc":"赵汝绩，字庶可，号山台，浚仪（今河南开封）人，寓会稽。太宗八世孙（《宋史·宗室世系》一九）。与戴复古多唱和（《石屏诗集》卷二《题赵庶可山台》）。有《山台吟稿》，已佚。《江湖后集》辑其诗为一卷。　赵汝绩诗，以影印文渊阁《四库全书·江湖后集》为底本，新辑集外诗附于卷末。"},"bodyChunkSize":128,"poems":[{"title":"别曹松山"},{"title":"无罪言"},{"title":"环碧园饯信守赵兰皋分韵得燕字"},{"title":"墨歌"},{"title":"陈老画牛"},{"title":"题黄存之春庄雨急图"},{"title":"忆昔一首"},{"title":"离越"},{"title":"游石窗"},{"title":"峡江龙祠"},{"title":"桧房"},{"title":"溪翁惠秋兰"},{"title":"渔父"},{"title":"出郊"},{"title":"和牡丹韵"},{"title":"道中登岭"},{"title":"雁山章君以江山无尽图求诗"},{"title":"送蔡廉父赴赣辟  其一"},{"title":"送蔡廉父赴赣辟  其二"},{"title":"南坡"},{"title":"将归"},{"title":"送荷渚归越"},{"title":"送荷渚兄自永嘉归越  其一"},{"title":"送荷渚兄自永嘉归越  其二"},{"title":"林壑闲步二绝  其一"},{"title":"林壑闲步二绝  其二"},{"title":"渔父"},{"title":"迎庆避暑"},{"title":"柬陈宗之"},{"title":"姚江道中"},{"title":"谢高左藏惠墨竹"},{"title":"韩仲龢墨竹"},{"title":"送竹轩归越"},{"title":"菊花"},{"title":"鸡冠花"},{"title":"瓜"},{"title":"贫居"},{"title":"剡中戴亭"},{"title":"句  其一"},{"title":"句  其二"},{"title":"林壑閒步二绝 其二"},{"title":"送蔡廉父赴赣辟"},{"title":"送荷渚兄自永嘉归越"},{"title":"林壑閒步二绝"},{"title":"句"}]}