{"meta":{"id":"p727","name":"张继","dynasty":"tang","category":"tang","poemCount":53,"desc":"张继，字懿孙，襄州人，登天宝进士第。大历末，检校祠部员外郎，分掌财赋于洪州。高仲武谓其“累代词伯，秀发当时，诗体清回，有道者风”。今编诗一卷。"},"bodyChunkSize":128,"poems":[{"title":"杂曲歌辞 长相思"},{"title":"郢城西楼吟"},{"title":"登丹阳楼"},{"title":"春夜皇甫冉宅欢宴"},{"title":"会稽秋晚奉呈于太守"},{"title":"题严陵钓台"},{"title":"清明日自西午桥至瓜岩村有怀"},{"title":"洛阳作"},{"title":"晚次淮阳"},{"title":"送窦十九判官使江南"},{"title":"江上送客游庐山"},{"title":"酬张二十员外前国子博士窦叔向"},{"title":"会稽郡楼雪霁"},{"title":"冯翊西楼"},{"title":"送邹判官往陈留"},{"title":"酬李书记校书越城秋夜见赠"},{"title":"感怀"},{"title":"长相思"},{"title":"奉寄皇甫补阙"},{"title":"枫桥夜泊"},{"title":"阊门即事"},{"title":"安公房问法"},{"title":"上清词"},{"title":"送顾况泗上觐叔父"},{"title":"留别"},{"title":"送张中丞归使幕"},{"title":"华州夜宴庾侍御宅"},{"title":"赠章八元"},{"title":"城西虎跑寺"},{"title":"禇主簿宅会毕庶子钱员外郎使君"},{"title":"奉送王相公赴幽州"},{"title":"重经巴丘"},{"title":"九日巴丘杨公台上宴集"},{"title":"游灵岩"},{"title":"河间献王墓"},{"title":"秋日道中"},{"title":"华清宫"},{"title":"春申君祠"},{"title":"人日代客子是日立春"},{"title":"寄郑员外"},{"title":"饮李十二宅"},{"title":"山家"},{"title":"归山"},{"title":"金谷园"},{"title":"邮亭"},{"title":"宿白马寺"},{"title":"明德宫"},{"title":"读峄山碑"},{"title":"句"},{"title":"望归舟"},{"title":"代书索镜"},{"title":"剡县法台寺灌顶坛诗"},{"title":"送客"}]}