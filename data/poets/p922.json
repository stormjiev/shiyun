{"meta":{"id":"p922","name":"殷文圭","dynasty":"tang","category":"tang","poemCount":32,"desc":"殷文圭，池州人。居九华，苦学，所用墨池，底为之穴。唐末，词场请托公行，文圭与游恭独步场屋。干宁中及第，为裴枢宣谕判官。后事杨行密，终左千牛卫将军。诗一卷。"},"bodyChunkSize":128,"poems":[{"title":"八月十五夜"},{"title":"省试夜投献座主"},{"title":"观贺皇太子册命"},{"title":"行朝早春侍师门宴西溪席上作"},{"title":"贺同年第三人刘先辈咸辟命"},{"title":"寄广南刘仆射"},{"title":"题吴中陆龟蒙山斋"},{"title":"经李翰林墓"},{"title":"鹦鹉"},{"title":"边将别"},{"title":"江南秋日"},{"title":"题友人庭竹"},{"title":"览陆龟蒙旧集"},{"title":"玉仙道中"},{"title":"赵侍郎看红白牡丹因寄杨状头赞图"},{"title":"题胡州太学丘光庭博士幽居"},{"title":"初秋留别越中幕客"},{"title":"送道者朝见后归山"},{"title":"赠战将"},{"title":"九华贺雨吟"},{"title":"赠池州张太守"},{"title":"中秋自宛陵寄池阳太守"},{"title":"次韵九华杜先辈重阳寄投宛陵丞相"},{"title":"寄贺杜荀鹤及第"},{"title":"春草碧色"},{"title":"和友人送衡尚书赴池阳副车"},{"title":"贻李南平"},{"title":"句"},{"title":"楼上看九华（三首） 一"},{"title":"楼上看九华（三首） 二"},{"title":"楼上看九华（三首） 三"},{"title":"送池阳徐守"}]}