{"meta":{"id":"p984","name":"宋自逊","dynasty":"song","category":"song","poemCount":34,"desc":"宋自逊，字谦父，号壶山，金华（今属浙江）人，居南昌（今属江西）。与曾原一（子实）有唱和，工词，有《渔樵笛谱》（《瀛奎律髓》卷一三），已佚。今录诗二十七首。"},"bodyChunkSize":128,"poems":[{"title":"萍"},{"title":"桂花"},{"title":"五月菊"},{"title":"种柳"},{"title":"夜雪"},{"title":"茶磨"},{"title":"蚊"},{"title":"隠逸"},{"title":"莲"},{"title":"赠隠者"},{"title":"赠戴石屏"},{"title":"答客问"},{"title":"谢深道问近况答之"},{"title":"和曾子实题画笺韵"},{"title":"照镜辞"},{"title":"闲地"},{"title":"店翁送花"},{"title":"看人取木绵"},{"title":"乌鹊引"},{"title":"啄木吟"},{"title":"买马"},{"title":"山家"},{"title":"田家谣"},{"title":"一室"},{"title":"书报先生壁"},{"title":"寿铁石翁"},{"title":"东湖看荷花呈愿父"},{"title":"西江月"},{"title":"昼锦堂 上李真州"},{"title":"贺新郎 七夕"},{"title":"贺新郎 题雪堂"},{"title":"满江红 愁感"},{"title":"蓦山溪 自述"},{"title":"沁园春 送戴石屏"}]}