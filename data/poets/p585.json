{"meta":{"id":"p585","name":"金朋说","dynasty":"song","category":"song","poemCount":98,"desc":"金朋说，字希传，号碧岩，休宁（今属安徽）人。曾从朱熹学。孝宗淳熙十四年（一一八七）进士。初为教官，后于知鄱阳时值庆元党禁，归隠于碧岩山，时人比之陶潜。有《碧岩诗集》二卷，明万历间裔孙金袍曾刊刻。事见本集卷首宋范宽、明金大绶序。　金朋说诗，以清抄《碧岩诗集》（藏北京图书馆）为底本，明显舛误酌作校正。"},"bodyChunkSize":128,"poems":[{"title":"碧岩吟"},{"title":"积学吟"},{"title":"诚意吟"},{"title":"正心吟"},{"title":"自欺吟"},{"title":"读书吟"},{"title":"闲居吟"},{"title":"芸禾吟"},{"title":"修身吟"},{"title":"齐家吟"},{"title":"省斋吟"},{"title":"夏日山居"},{"title":"种豆吟"},{"title":"种柳吟"},{"title":"赋归吟"},{"title":"冬雪吟"},{"title":"种桃吟"},{"title":"种梅吟"},{"title":"种松吟"},{"title":"种竹吟"},{"title":"种菊吟"},{"title":"晨鸡吟"},{"title":"持敬斋吟"},{"title":"止斋吟"},{"title":"戒五荒"},{"title":"春日吟"},{"title":"游山吟"},{"title":"春山吟"},{"title":"海棠吟"},{"title":"牡丹吟"},{"title":"芍药吟"},{"title":"蔷薇吟"},{"title":"茉莉吟"},{"title":"木槿花"},{"title":"木樨吟"},{"title":"菊花吟"},{"title":"梅花吟"},{"title":"山茶花"},{"title":"莲花吟"},{"title":"葵花吟"},{"title":"赏桃吟"},{"title":"赏李吟"},{"title":"赏柳吟"},{"title":"赏松吟"},{"title":"赏竹吟"},{"title":"幽居吟"},{"title":"新秋即事"},{"title":"秋日书怀"},{"title":"七夕吟"},{"title":"中秋夜偕朱表姪题月"},{"title":"秋山吟"},{"title":"冬日忆友"},{"title":"冬日幽居"},{"title":"雪山"},{"title":"咏朱默斋山茶花"},{"title":"题吴表兄雪鹤山茶图"},{"title":"乐渔吟"},{"title":"乐樵吟"},{"title":"乐耕吟"},{"title":"乐牧吟"},{"title":"夏日幽居"},{"title":"泰伯虞仲祠"},{"title":"闵子骞"},{"title":"漂母堂"},{"title":"折槛吟"},{"title":"汉党锢"},{"title":"诸葛武侯"},{"title":"荀彧饮药"},{"title":"赤壁鏖兵"},{"title":"司马昭弑魏主"},{"title":"司马温公帝魏"},{"title":"李密陈情表"},{"title":"建康怀古"},{"title":"苻坚伐晋"},{"title":"唐太宗"},{"title":"武则天"},{"title":"杨贵妃"},{"title":"张忠靖"},{"title":"李谪仙"},{"title":"韩昌黎"},{"title":"唐宪宗"},{"title":"裴垍"},{"title":"李绛裴度"},{"title":"唐穆宗"},{"title":"唐敬宗"},{"title":"唐文宗  其一"},{"title":"唐文宗  其二"},{"title":"悉怛谋降唐"},{"title":"唐宣宗饵药"},{"title":"歇后宰相"},{"title":"唐阉宦"},{"title":"五季梁主"},{"title":"五季石晋  其一"},{"title":"五季石晋  其二"},{"title":"五季相冯道"},{"title":"中秋夜偕朱表侄题月"},{"title":"五季石晋"},{"title":"唐文宗"}]}