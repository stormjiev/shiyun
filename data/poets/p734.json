{"meta":{"id":"p734","name":"刘希夷","dynasty":"tang","category":"tang","poemCount":56,"desc":"刘希夷，一名庭芝，汝州人。少有文华，落魄不拘常格，后为人所害。希夷善为从军闺情诗，词旨悲苦，未为人重。后孙昱撰《正声集》，以希夷诗为集中之最，由是大为时所称赏。集十卷，今编诗一卷。"},"bodyChunkSize":128,"poems":[{"title":"横吹曲辞 入塞"},{"title":"相和歌辞 江南曲八首 一"},{"title":"相和歌辞 江南曲八首 二"},{"title":"相和歌辞 江南曲八首 三"},{"title":"相和歌辞 江南曲八首 四"},{"title":"相和歌辞 江南曲八首 五"},{"title":"相和歌辞 江南曲八首 六"},{"title":"相和歌辞 江南曲八首 七"},{"title":"相和歌辞 江南曲八首 八"},{"title":"相和歌辞 采桑"},{"title":"相和歌辞 从军行"},{"title":"相和歌辞 白头吟"},{"title":"将军行"},{"title":"从军行"},{"title":"春女行"},{"title":"孤松篇"},{"title":"嵩岳闻笙"},{"title":"秋日题汝阳潭壁"},{"title":"采桑"},{"title":"谒汉世祖庙"},{"title":"巫山怀古"},{"title":"归山"},{"title":"代闺人春日"},{"title":"蜀城怀古"},{"title":"洛川怀古"},{"title":"春日行歌"},{"title":"江南曲八首 一"},{"title":"江南曲八首 二"},{"title":"江南曲八首 三"},{"title":"江南曲八首 四"},{"title":"江南曲八首 五"},{"title":"江南曲八首 六"},{"title":"江南曲八首 七"},{"title":"江南曲八首 八"},{"title":"捣衣篇"},{"title":"公子行"},{"title":"代悲白头吟"},{"title":"代秦女赠行人"},{"title":"洛中晴月送殷四入关"},{"title":"入塞"},{"title":"览镜"},{"title":"晚春"},{"title":"送友人之新丰"},{"title":"饯李秀才赴举"},{"title":"夜集张𬤇所居"},{"title":"故园置酒"},{"title":"晚憩南阳旅馆"},{"title":"夏弹琴（《文苑英华》二一二《音乐》、《初学记》一六「乐」部）"},{"title":"独鹤篇"},{"title":"初度岭过韶州灵鹫广果二寺其寺院相接故同诗一首"},{"title":"江上覊情"},{"title":"谒诸葛祠"},{"title":"北邙篇"},{"title":"死马赋"},{"title":"江上羁情"},{"title":"江南曲八首"}]}