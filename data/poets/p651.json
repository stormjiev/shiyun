{"meta":{"id":"p651","name":"严维","dynasty":"tang","category":"tang","poemCount":76,"desc":"严维，字正文，越州山阴人。至德二载进士，擢辞藻宏丽科。调诸暨尉，辟河南幕府，终秘书省校书郎。与刘长卿善。诗一卷。"},"bodyChunkSize":128,"poems":[{"title":"酬耿拾遗题赠"},{"title":"酬王侍御西陵渡见寄"},{"title":"酬刘员外见寄"},{"title":"同韩员外宿云门寺"},{"title":"酬诸公宿镜水宅"},{"title":"送薛尚书入蜀"},{"title":"送李秘书往儋州"},{"title":"送人入金华"},{"title":"送崔峒使往睦州兼寄薛司户"},{"title":"送房元直赴北京"},{"title":"荆溪馆呈丘义兴"},{"title":"一公新泉"},{"title":"奉试水精环"},{"title":"自云阳归晚泊陆澧宅"},{"title":"九日陪崔郎中北山䜩"},{"title":"留别邹绍刘长卿"},{"title":"书情献相公"},{"title":"赠送朱放"},{"title":"剡中赠张卿侍御"},{"title":"赠万经"},{"title":"书情上李苏州"},{"title":"余姚祗役奉简鲍参军"},{"title":"奉和独孤中丞游云门寺"},{"title":"奉和皇甫大夫夏日游花严寺"},{"title":"宿法华寺"},{"title":"题茅山李尊师所居"},{"title":"送薛居士和州读书"},{"title":"送李端"},{"title":"宿天竺寺"},{"title":"丹阳送韦参军"},{"title":"入唐溪"},{"title":"送桃岩成上人归本寺"},{"title":"酬普选二上人期相会见寄"},{"title":"相里使君宅听澄上人吹小管"},{"title":"赠别至弘上人"},{"title":"奉和刘祭酒伤白马"},{"title":"哭灵一上人"},{"title":"题鲍行军小阁"},{"title":"陪皇甫大夫谒禹庙"},{"title":"同王徴君湘中有怀"},{"title":"奉和皇甫大夫祈雨应时雨降"},{"title":"赠别刘长卿时赴河南严中丞幕府"},{"title":"晦日宴游"},{"title":"夏日纳凉"},{"title":"僧房避暑"},{"title":"九日登高"},{"title":"九月十日即事"},{"title":"送丘为下第归苏州"},{"title":"送少微上人东南游"},{"title":"赠送崔子向"},{"title":"答刘长卿七里濑重送"},{"title":"岁初喜皇甫侍御至"},{"title":"送舍弟"},{"title":"示外生"},{"title":"咏孩子"},{"title":"酬谢侍御喜王宇及第见贺不遇之作"},{"title":"秋日与诸公文会天寺"},{"title":"荅刘长卿蛇浦桥月下重送"},{"title":"发桐庐寄刘员外"},{"title":"秋夜船行"},{"title":"游灞陵山"},{"title":"重送新安刘员外"},{"title":"忆长安 五月"},{"title":"状江南 季春"},{"title":"句"},{"title":"中元日鲍端公宅遇吴天师联句"},{"title":"酒语联句各分一字"},{"title":"一字至九字诗联句"},{"title":"晚霁登王六东阁"},{"title":"经兰亭故池联句"},{"title":"游荆溪"},{"title":"剑诗"},{"title":"句"},{"title":"赠王叔雅兄弟（题拟）"},{"title":"李端公"},{"title":"赠王叔雅兄弟"}]}