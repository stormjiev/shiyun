{"meta":{"id":"p790","name":"李远","dynasty":"song","category":"song","poemCount":44,"desc":"李远，字求一作承古，蜀人。第太和进士，历忠、建、江三州刺史，终御史中丞。集一卷。"},"bodyChunkSize":128,"poems":[{"title":"仆久客钱塘有吹笛月下者同旅闻之凄然皆有归思属令赋之"},{"title":"赠写御真李长史"},{"title":"失鹤"},{"title":"咏壁鱼"},{"title":"句  其一"},{"title":"句  其二"},{"title":"句  其三"},{"title":"立春日"},{"title":"翦彩"},{"title":"题僧院"},{"title":"观廉女真葬"},{"title":"闲居"},{"title":"及第后送家兄游蜀"},{"title":"送人入蜀"},{"title":"游故王驸马池亭"},{"title":"悲铜雀台"},{"title":"陪新及第赴同年会"},{"title":"咏鴈"},{"title":"与碧溪上人别"},{"title":"赠殷山人"},{"title":"咏壁鱼"},{"title":"听话丛台"},{"title":"失鹤"},{"title":"赠写御容李长史"},{"title":"赠潼关不下山僧"},{"title":"过旧游见双鹤怆然有怀"},{"title":"赠友人"},{"title":"赠南岳僧"},{"title":"赠弘文杜校书"},{"title":"听王氏话归州昭君庙"},{"title":"过马嵬山"},{"title":"吴越怀古"},{"title":"长安即事寄友人"},{"title":"闻明上人逝寄友人"},{"title":"赠咸阳李少府"},{"title":"隣人自金仙观移竹"},{"title":"慈恩寺避暑"},{"title":"读田光传"},{"title":"友人下第因以赠之"},{"title":"咏鸳鸯"},{"title":"赠筝妓伍卿"},{"title":"黄陵庙词"},{"title":"句"},{"title":"老僧续得贵妃袜（李群玉同作）"}]}