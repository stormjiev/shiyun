{"meta":{"id":"p579","name":"薛逢","dynasty":"tang","category":"tang","poemCount":103,"desc":"薛逢，字陶臣，蒲州河东人。会昌初，擢进士第，授为万年尉，直弘文馆，历侍御史、尚书郎。出为巴州刺史，复斥蓬州，寻以太常少卿召还，历给事中，迁秘书监，卒。集十卷，今编诗一卷。"},"bodyChunkSize":128,"poems":[{"title":"杂曲歌辞 凉州词"},{"title":"杂曲歌辞 何满子"},{"title":"镊白曲"},{"title":"君不见"},{"title":"老去也"},{"title":"追昔行"},{"title":"醉春风"},{"title":"邻相反行"},{"title":"灵台家兄古镜歌"},{"title":"观竞渡"},{"title":"酬牛秀才登楼见示"},{"title":"夏夜宴明月湖"},{"title":"大水"},{"title":"席上酬东川严中丞叙旧见赠"},{"title":"禁火"},{"title":"咏柳"},{"title":"宫词"},{"title":"长安春日"},{"title":"韦寿博书斋"},{"title":"潼关河亭"},{"title":"送衢州崔员外"},{"title":"开元后乐"},{"title":"汉武宫辞"},{"title":"潼关驿亭"},{"title":"五峰隠者"},{"title":"上吏部崔相公"},{"title":"送刘郎中牧杭州"},{"title":"贫女吟"},{"title":"夜宴观妓"},{"title":"送西川杜司空赴镇"},{"title":"长安夜雨"},{"title":"猎骑"},{"title":"金城宫"},{"title":"惊秋"},{"title":"六街尘"},{"title":"悼古"},{"title":"九华观废月池"},{"title":"社日游开元观"},{"title":"九日曲池游眺"},{"title":"九日郡斋有感"},{"title":"九日嘉州发军亭即事"},{"title":"九日雨中言怀"},{"title":"题劒门先寄上西蜀杜司徒"},{"title":"八月初一驾幸延喜楼看冠带降戎"},{"title":"送司徒相公赴阙"},{"title":"送灵州田尚书"},{"title":"座中走笔送前萧使君"},{"title":"重送徐州李从事商隠"},{"title":"醉中闻甘州"},{"title":"北亭醉后叙旧赠东川陈书记"},{"title":"宣政殿前陪位观册顺宗宪宗皇帝尊号"},{"title":"元日楼前观仗 一"},{"title":"元日楼前观仗 二"},{"title":"醉中看花因思去岁之任"},{"title":"题白马驿"},{"title":"题筹笔驿"},{"title":"贺杨收作相"},{"title":"元日田家"},{"title":"送庆上人归湖州因寄道儒座主"},{"title":"早发剡山"},{"title":"题春台观"},{"title":"春晚东园晓思"},{"title":"芙蓉溪送前资州裴使君归京宁拜户部裴侍郎"},{"title":"伏闻令公疾愈对见延英因有贺诗远封投献"},{"title":"题独孤处士村居"},{"title":"题上皇观"},{"title":"奉和仆射相公送东川李支使归使府夏侯相公"},{"title":"送封尚书节制兴元"},{"title":"送西川梁常侍之新筑龙山城幷锡赉两州刺史及部落酋长等"},{"title":"河满子"},{"title":"题黄花驿"},{"title":"凉州词"},{"title":"嘉陵江"},{"title":"观猎"},{"title":"狼烟"},{"title":"侠少年"},{"title":"感塞"},{"title":"听曹刚弹琵琶"},{"title":"定山寺"},{"title":"越王楼送高梓州入朝"},{"title":"送李蕴赴郑州因献卢郎中"},{"title":"送裴评事"},{"title":"送沈单作尉江都"},{"title":"送薛耽先辈归谒汉南"},{"title":"送同年郑祥先辈归汉南"},{"title":"李先辈擢第东归有赠送"},{"title":"送韩绛归淮南寄韩绰先辈"},{"title":"送卢缄归扬州"},{"title":"送剡客"},{"title":"凉州词 一"},{"title":"凉州词 二"},{"title":"凉州词 三"},{"title":"送萧俛