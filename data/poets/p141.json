{"meta":{"id":"p141","name":"张籍","dynasty":"tang","category":"zhong_tang","poemCount":502,"desc":"张籍，字文昌，苏州吴人，或曰和州乌江人。贞元十五年登进士第，授太常寺太祝。久之，迁秘书郎。韩愈荐为国子博士，历水部员外郎、主客郎中。当时有名士皆与游，而愈贤重之。籍为诗长于乐府，多警句，仕终国子司业。诗集七卷，今编为五卷。"},"bodyChunkSize":128,"poems":[{"title":"鼓吹曲辞 朱鹭"},{"title":"横吹曲辞 陇头"},{"title":"横吹曲辞 出塞"},{"title":"横吹曲辞 望行人"},{"title":"横吹曲辞 关山月"},{"title":"相和歌辞 江南曲"},{"title":"相和歌辞 楚妃叹"},{"title":"相和歌辞 楚妃怨"},{"title":"相和歌辞 短歌行"},{"title":"相和歌辞 猛虎行"},{"title":"相和歌辞  董逃行"},{"title":"相和歌辞 白头吟"},{"title":"相和歌辞 乌栖曲"},{"title":"相和歌辞 贾客乐"},{"title":"相和歌辞 采莲曲"},{"title":"舞曲歌辞 白纻歌"},{"title":"琴曲歌辞 别鹤"},{"title":"琴曲歌辞 乌夜啼引"},{"title":"琴曲歌辞 宛转行"},{"title":"杂曲歌辞 伤歌行"},{"title":"杂曲歌辞 妾薄命"},{"title":"杂曲歌辞 春日行"},{"title":"杂曲歌辞 少年行"},{"title":"杂曲歌辞 车遥遥"},{"title":"杂曲歌辞 行路难"},{"title":"杂曲歌辞 远别离"},{"title":"杂曲歌辞 别离曲"},{"title":"杂曲歌辞 筑城曲"},{"title":"杂曲歌辞 秋夜长"},{"title":"杂曲歌辞 春江曲"},{"title":"杂曲歌辞 凉州词 一"},{"title":"杂曲歌辞 凉州词 二"},{"title":"杂曲歌辞 凉州词 三"},{"title":"杂歌谣辞 吴楚歌"},{"title":"杂歌谣辞 白鼍鸣"},{"title":"寄远曲"},{"title":"行路难"},{"title":"征妇怨"},{"title":"白纻歌"},{"title":"野老歌"},{"title":"寄衣曲"},{"title":"送远曲"},{"title":"筑城词"},{"title":"猛虎行"},{"title":"别离曲"},{"title":"牧童词"},{"title":"沙堤行呈裴相公"},{"title":"求仙行"},{"title":"古钗叹"},{"title":"各东西"},{"title":"节妇吟寄东平李司空师道"},{"title":"䜩客词"},{"title":"永嘉行"},{"title":"采莲曲"},{"title":"伤歌行"},{"title":"吴宫怨"},{"title":"北邙行"},{"title":"关山月"},{"title":"陇头行"},{"title":"楚妃叹"},{"title":"春日行"},{"title":"秋夜长"},{"title":"白鼍鸣"},{"title":"洛阳行"},{"title":"春江曲"},{"title":"送远曲"},{"title":"塞下曲"},{"title":"董逃行"},{"title":"少年行"},{"title":"白头吟"},{"title":"将军行"},{"title":"贾客乐"},{"title":"羁旅行"},{"title":"车遥遥"},{"title":"妾薄命"},{"title":"朱鹭"},{"title":"远别离"},{"title":"楚宫行"},{"title":"江南行"},{"title":"乌夜啼引"},{"title":"促促词"},{"title":"宛转行"},{"title":"短歌行"},{"title":"山头鹿"},{"title":"湘江曲"},{"title":"楚妃怨"},{"title":"离宫怨"},{"title":"成都曲"},{"title":"寒塘曲"},{"title":"春别曲"},{"title":"春堤曲"},{"title":"乌栖曲"},{"title":"雀飞多"},{"title":"泗水行"},{"title":"废居行"},{"title":"寄菖蒲"},{"title":"江村行"},{"title":"樵客吟"},