{"meta":{"id":"p799","name":"灵一","dynasty":"tang","category":"tang","poemCount":44,"desc":"灵一，姓吴氏，广陵人。居余杭宜丰寺，禅诵之暇，辄赋诗歌，与朱放、张继、皇甫曾诸人为尘外友。诗一卷。"},"bodyChunkSize":128,"poems":[{"title":"酬皇甫冉西陵见寄"},{"title":"溪行即事"},{"title":"栖霞山夜坐"},{"title":"宿天柱观"},{"title":"酬皇甫冉将赴无锡于云门寺赠别"},{"title":"宜丰新泉"},{"title":"静林精舍"},{"title":"江行寄张舍人"},{"title":"送王颖悟归左绵"},{"title":"安公"},{"title":"林公"},{"title":"远公"},{"title":"雨后欲寻天目山问元骆二公溪路"},{"title":"题僧院"},{"title":"宿静林寺"},{"title":"再还宜丰寺"},{"title":"春日山斋"},{"title":"留别忠州故人"},{"title":"送别"},{"title":"送冽寺主之京迎禅和尚"},{"title":"送王法师之西川"},{"title":"送范律师往果州"},{"title":"送明素上人归楚觐省"},{"title":"项王庙"},{"title":"酬陈明府舟中见赠"},{"title":"题东兰若"},{"title":"送朱放"},{"title":"归岑山过惟审上人别业"},{"title":"於潜道中呈元八处士"},{"title":"送殷判官归上都"},{"title":"赠别皇甫曾"},{"title":"送陈允初卜居麻园"},{"title":"秋题刘逸人林泉"},{"title":"自大林与韩明府归郭中精舍"},{"title":"同使君宿大梁驿"},{"title":"题黄公陶翰别业"},{"title":"哭卫尚书"},{"title":"赠灵澈禅师"},{"title":"将出宜丰寺留题山房"},{"title":"妙乐观"},{"title":"与元居士青山潭饮茶"},{"title":"送人得荡子归倡妇"},{"title":"句"},{"title":"于潜道中呈元八处士"}]}