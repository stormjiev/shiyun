{"meta":{"id":"p960","name":"张南史","dynasty":"tang","category":"tang","poemCount":30,"desc":"张南史，字季直，幽州人。好弈棋，其后折节读书，遂入诗境，以试参军。避乱，居扬州，再召，未赴而卒。诗一卷。"},"bodyChunkSize":128,"poems":[{"title":"富阳南楼望浙江风起"},{"title":"奉酬李舍人秋日寓直见寄"},{"title":"同韩侍郎秋朝使院"},{"title":"送朱大游塞"},{"title":"送郑录事赴太原"},{"title":"送余赞善使还赴薛尚书幕"},{"title":"送李侍御入茅山采药"},{"title":"寄中书李舍人"},{"title":"和崔中丞中秋月"},{"title":"西陵怀灵一上人兼寄朱放"},{"title":"寄静虚上人云门"},{"title":"送司空十四北游宋州"},{"title":"殷卿宅夜宴"},{"title":"宣城雪后还望郡中寄孟侍御"},{"title":"独孤常州北亭"},{"title":"早春书事奉寄中书李舍人"},{"title":"陆胜宅秋暮雨中探韵同作"},{"title":"春日道中寄孟侍御"},{"title":"江北春望赠皇甫补阙"},{"title":"酬张二仓曹杨子闲居见寄兼呈韩郎中左补阙皇甫冉"},{"title":"秋夜闻鴈寄南十五兼呈空和尚"},{"title":"雪"},{"title":"月"},{"title":"泉"},{"title":"竹"},{"title":"花"},{"title":"草"},{"title":"竹〖1〗"},{"title":"送李使君贬郴州"},{"title":"陆胜宅秋雨中探韵"}]}