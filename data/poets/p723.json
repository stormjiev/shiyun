{"meta":{"id":"p723","name":"后主煜","dynasty":"tang","category":"tang","poemCount":54,"desc":"煜，字重光，南唐元宗子。仁孝，善属文，工书画，妙于音律。置澄心堂于内苑，引文士居其间，尝著《杂说》百篇，时人以为可继《典论》。开宝中，封陇西公，赠吴王。集十卷，诗一卷，失传，今存诗十八首。"},"bodyChunkSize":128,"poems":[{"title":"九月十日偶书"},{"title":"秋莺"},{"title":"病起题山舍壁"},{"title":"送邓王二十弟从益牧宣城"},{"title":"渡中江望石城泣下"},{"title":"挽辞 一"},{"title":"挽辞 二"},{"title":"悼诗"},{"title":"感怀 一"},{"title":"感怀 二"},{"title":"梅花"},{"title":"梅花"},{"title":"书灵筵手巾"},{"title":"书琵琶背"},{"title":"病中感怀"},{"title":"病中书事"},{"title":"赐宫人庆奴"},{"title":"题金楼子后"},{"title":"句"},{"title":"渔父 一"},{"title":"渔父 二"},{"title":"忆江南 一"},{"title":"忆江南 二"},{"title":"忆江南 三"},{"title":"忆江南 四"},{"title":"捣练子 一"},{"title":"捣练子 二"},{"title":"相见欢 一"},{"title":"相见欢 二"},{"title":"长相思 一"},{"title":"长相思 二"},{"title":"浣溪沙 一"},{"title":"浣溪沙 二"},{"title":"采桑子 一"},{"title":"采桑子 二"},{"title":"菩萨蛮 一"},{"title":"菩萨蛮 二"},{"title":"菩萨蛮 三"},{"title":"菩萨蛮 四"},{"title":"清平乐"},{"title":"喜迁莺"},{"title":"阮郎归"},{"title":"锦堂春"},{"title":"应天长"},{"title":"望远行"},{"title":"浪淘沙 一"},{"title":"浪淘沙 二"},{"title":"木兰花"},{"title":"虞美人 一"},{"title":"虞美人 二"},{"title":"一斛珠"},{"title":"临江仙"},{"title":"蝶恋花"},{"title":"破陈子"}]}