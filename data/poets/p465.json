{"meta":{"id":"p465","name":"李嘉祐","dynasty":"tang","category":"tang","poemCount":145,"desc":"李嘉祐，字从一，赵州人。天宝七年擢第，授秘书正字。坐事谪鄱江令，调江阴，入为中台郎。上元中，出为台州刺史。大历中，复为袁州刺史，与严维、冷朝阳诸人友善。为诗丽婉，有齐梁风。集一卷，今编诗二卷。"},"bodyChunkSize":128,"poems":[{"title":"杂曲歌辞 江上曲"},{"title":"江上曲"},{"title":"伤吴中"},{"title":"夜闻江南人家赛神因题即事"},{"title":"古兴"},{"title":"杂兴"},{"title":"送韦邕少府归钟山"},{"title":"送卢员外往饶州"},{"title":"送裴五归京口"},{"title":"送严维归越州"},{"title":"送杜士瞻楚州觐省"},{"title":"送裴宣城上元所居"},{"title":"留别毘陵诸公"},{"title":"送独孤拾遗先辈先赴上都"},{"title":"常州韦郎中泛舟见饯"},{"title":"送崔侍御入朝"},{"title":"送岳州司马弟之任"},{"title":"裴侍御见赠斑竹杖"},{"title":"送张观归袁州"},{"title":"冬夜饶州使堂饯相公五叔赴歙州"},{"title":"蒋山开善寺"},{"title":"晚发江宁道中呈严维"},{"title":"句容县东青阳馆作"},{"title":"晚春宴无锡蔡明府西亭"},{"title":"送王端赴朝"},{"title":"送王正字山寺读书"},{"title":"送房明府罢长宁令湖州客舍"},{"title":"咏萤"},{"title":"送李中丞杨判官"},{"title":"至七里滩作"},{"title":"南浦渡口"},{"title":"暮秋迁客增思寄京华"},{"title":"送苏修往上饶"},{"title":"题王十九茆堂"},{"title":"送弘志上人归湖州"},{"title":"送陆士伦宰义兴"},{"title":"和张舍人中书宿直"},{"title":"司勋王郎中宅送韦九郎中往濠州"},{"title":"晚春送吉校书归楚州"},{"title":"送严二擢第东归"},{"title":"送冷朝阳及第东归江宁"},{"title":"送越州辛法曹之任"},{"title":"送樊兵曹潭州谒韦大夫"},{"title":"送杜御史还广陵"},{"title":"送兖州杜别驾之任"},{"title":"题裴十六少卿东亭"},{"title":"同皇甫侍御题荐福寺一公房"},{"title":"送从姪端之东都"},{"title":"送王谏议充东都留守判官"},{"title":"和都官苗员外秋夜省直对雨简诸知己"},{"title":"送从弟归河朔"},{"title":"送崔夷甫员外和蕃"},{"title":"春日长安送从弟尉吴县"},{"title":"元日无衣冠入朝寄皇甫拾遗冉从弟补阙纾"},{"title":"和韩郎中扬子津玩雪寄严维"},{"title":"送王牧往吉州谒王使君叔"},{"title":"广陵送林宰"},{"title":"赠卫南长官赴任"},{"title":"自常州还江阴途中作"},{"title":"润州杨别驾宅送蒋九侍御收兵归扬州"},{"title":"仲夏江阴官舍寄裴明府"},{"title":"送夏侯审参军游江东"},{"title":"送袁员外宣慰劝农毕赴洪州使院"},{"title":"送侍御史四叔归朝"},{"title":"登楚州城望驿路十余里山村竹林相次交映"},{"title":"奉陪韦润州游鹤林寺"},{"title":"奉酬路五郎中院长新除工部员外见简"},{"title":"送韦司直西行"},{"title":"送上官侍御赴黔中"},{"title":"送元侍御还荆南幕府"},{"title":"登湓城浦望庐山初晴直省赍敕催赴江阴"},{"title":"九日"},{"title":"九日送人"},{"title":"春日淇上作"},{"title":"送从叔阳冰祇召赴都"},{"title":"送友人入湘"},{"title":"送裴员外往江南"},{"title":"登秦岭"},{"title":"送张惟俭秀才入举"},{"title":"送韦侍御湖南幕府"},{"title":"同皇甫冉赴官留别灵一上人"},{"title":"送客游荆州"},{"title":"与郑锡游春"},{"title":"故燕国相