{"meta":{"id":"p898","name":"萧澥","dynasty":"song","category":"song","poemCount":37,"desc":"萧澥，字泛之，自号金精山民，宁都（今属江西）人。理宗绍定中，隠居金精山。著有《竹外蛩吟稿》，已佚。事见《江湖后集》卷一五。今录诗三十三首。"},"bodyChunkSize":128,"poems":[{"title":"读史  其一"},{"title":"读史  其二"},{"title":"写乐府昭君怨后"},{"title":"昭君词"},{"title":"读秦纪"},{"title":"读文君白头吟"},{"title":"戏效玉台体"},{"title":"题东篱采菊图"},{"title":"江上冬日效石湖田园杂咏体"},{"title":"睡起"},{"title":"雪晴"},{"title":"绍定庚寅纪事  其一"},{"title":"绍定庚寅纪事  其二"},{"title":"绍定庚寅纪事  其三"},{"title":"绍定庚寅纪事  其四"},{"title":"绍定庚寅纪事  其五"},{"title":"寇中逃山  其一"},{"title":"寇中逃山  其二"},{"title":"度九曲岭"},{"title":"客中月夜"},{"title":"题或林尼院壁"},{"title":"题壶"},{"title":"常山舟中"},{"title":"还安舟中"},{"title":"过东平悼曾英甫"},{"title":"韶口山家"},{"title":"避乱山家  其一"},{"title":"避乱山家  其二"},{"title":"乱后过隆教寺"},{"title":"乱定到邑"},{"title":"写林和靖梅花诗后"},{"title":"无题"},{"title":"重过邓村"},{"title":"读史"},{"title":"绍定庚寅纪事"},{"title":"寇中逃山"},{"title":"避乱山家"}]}